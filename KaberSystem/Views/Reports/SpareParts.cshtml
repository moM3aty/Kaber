<!-- مسار الملف: Views/Reports/SpareParts.cshtml -->
@model IEnumerable<dynamic>
@{
    ViewData["Title"] = "حصر قطع الغيار والأكثر استخداماً";
    Layout = "~/Views/Shared/_SystemLayout.cshtml";
}

<div class="sys-page-header d-print-none fade-in-up">
    <div>
        <h1 class="sys-page-title text-primary"><i class="fa-solid fa-boxes-packing me-2"></i> تقرير حصر القطع المستهلكة</h1>
        <p class="sys-page-desc">تحليل شامل لحركة قطع الغيار المستهلكة في الطلبات، لمعرفة الأكثر مبيعاً والأكثر تحقيقاً للأرباح</p>
    </div>
    <div class="d-flex gap-2">
        <button class="btn btn-dark fw-bold px-4 rounded-pill shadow-sm hover-elevate" onclick="window.print()">
            <i class="fa-solid fa-print me-1"></i> طباعة التقرير
        </button>
    </div>
</div>

<!-- 📌 لوحة المؤشرات العلوية -->
<div class="row g-4 mb-4 fade-in-up" style="animation-delay: 0.1s;">
    <div class="col-md-4">
        <div class="premium-card bg-primary bg-opacity-10 border-0 h-100 p-4 text-center border-top border-4 border-primary">
            <div class="icon-box bg-white text-primary mx-auto mb-3 shadow-sm"><i class="fa-solid fa-layer-group"></i></div>
            <h6 class="fw-bold text-muted mb-2">إجمالي القطع المستهلكة</h6>
            <h3 class="fw-bolder text-dark m-0">@ViewBag.TotalPartsSold <span class="fs-6 text-muted">قطعة</span></h3>
        </div>
    </div>
    <div class="col-md-4">
        <div class="premium-card bg-info bg-opacity-10 border-0 h-100 p-4 text-center border-top border-4 border-info">
            <div class="icon-box bg-white text-info mx-auto mb-3 shadow-sm"><i class="fa-solid fa-money-bill-trend-up"></i></div>
            <h6 class="fw-bold text-muted mb-2">إجمالي مبيعات القطع</h6>
            <h3 class="fw-bolder text-dark m-0">@ViewBag.TotalPartsSales.ToString("N2") <span class="fs-6 text-muted">ر.س</span></h3>
        </div>
    </div>
    <div class="col-md-4">
        <div class="premium-card bg-success bg-opacity-10 border-0 h-100 p-4 text-center border-top border-4 border-success">
            <div class="icon-box bg-white text-success mx-auto mb-3 shadow-sm"><i class="fa-solid fa-sack-dollar"></i></div>
            <h6 class="fw-bold text-muted mb-2">صافي الربح من القطع (فقط)</h6>
            <h3 class="fw-bolder text-success m-0">@ViewBag.TotalPartsProfit.ToString("N2") <span class="fs-6 text-muted">ر.س</span></h3>
        </div>
    </div>
</div>

<div class="premium-card fade-in-up" style="animation-delay: 0.2s;">
    <div class="card-header-premium bg-white pb-3 border-bottom">
        <h5 class="fw-bolder m-0 text-dark"><i class="fa-solid fa-list-ol text-primary me-2"></i> ترتيب القطع تنازلياً حسب الاستهلاك</h5>
    </div>
    <div class="table-responsive p-0">
        <table class="table premium-table align-middle text-center mb-0 w-100 sys-table">
            <thead class="bg-light">
                <tr>
                    <th class="text-start ps-4">اسم القطعة (الصنف)</th>
                    <th>الكود</th>
                    <th>الكمية المستهلكة <i class="fa-solid fa-arrow-down-wide-short ms-1 text-muted"></i></th>
                    <th>إجمالي التكلفة (شراء)</th>
                    <th>إجمالي الضريبة</th>
                    <th>إجمالي المبيعات (بيع)</th>
                    <th>صافي الربح المحقق</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr style="border-bottom: 1px solid #f1f5f9;">
                        <td class="text-start ps-4 fw-bolder text-dark fs-6">@item.PartName</td>
                        <td><span class="badge bg-light text-muted border border-secondary shadow-sm px-3 py-2 rounded-pill"><i class="fa-solid fa-barcode me-1"></i> @item.PartCode</span></td>
                        <td>
                            <!-- 📌 التحديث: تحويل الكمية لزر يفتح نافذة المواعيد -->
                            <button type="button" class="btn btn-sm btn-primary fw-bold px-3 py-1 rounded-pill shadow-sm hover-elevate" onclick="openOrdersModal('@item.PartName', '@item.OrderIds')">
                                @item.TotalQuantityUsed <i class="fa-solid fa-eye ms-1 small"></i>
                            </button>
                        </td>
                        <td class="fw-bold text-danger">@item.TotalCost.ToString("N2") ر.س</td>
                        <td class="fw-bold text-warning text-dark">@item.TotalTax.ToString("N2") ر.س</td>
                        <td class="fw-bold text-info text-dark">@item.TotalSales.ToString("N2") ر.س</td>
                        <td class="fw-bolder text-success bg-success bg-opacity-10 border-start border-end">@item.NetProfit.ToString("N2") ر.س</td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="6" class="text-center py-5">
                            <div class="bg-light rounded-circle d-inline-flex align-items-center justify-content-center mb-3 shadow-sm" style="width: 80px; height: 80px;">
                                <i class="fa-solid fa-box-open fs-2 text-muted opacity-50"></i>
                            </div>
                            <h6 class="text-muted fw-bold m-0">لا توجد قطع غيار تم استهلاكها بعد.</h6>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- 📌 التحديث: نافذة (Modal) عرض المواعيد التي ركبت فيها القطعة -->
<div class="modal fade d-print-none" id="ordersModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content premium-modal border-0 shadow-lg">
            <div class="modal-header border-bottom-0 pb-0 px-4 pt-4">
                <h5 class="modal-title fw-bolder text-dark m-0"><i class="fa-solid fa-clipboard-list text-primary me-2"></i> المواعيد المرتبطة</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4 text-start">
                <div class="alert alert-info py-2 small fw-bold mb-4 border-0 rounded-3 shadow-sm bg-info bg-opacity-10 text-dark">
                    هذه قائمة بأرقام المواعيد (الطلبات المنجزة) التي تم تركيب القطعة: <br />
                    <b id="modalPartName" class="text-primary fs-6"></b>
                </div>

                <div id="ordersLinksContainer" class="d-flex flex-wrap gap-2">
                    <!-- سيتم إضافة الأزرار هنا عبر الجافاسكريبت -->
                </div>
            </div>
            <div class="modal-footer border-top-0 pt-0 px-4 pb-4">
                <button type="button" class="btn btn-light fw-bold px-4 rounded-pill w-100" data-bs-dismiss="modal">إغلاق</button>
            </div>
        </div>
    </div>
</div>

<style>
    :root {
        --prem-surface: #ffffff;
        --prem-border: #e2e8f0;
        --prem-text: #1e293b;
        --prem-muted: #64748b;
        --prem-primary: #f1950b;
        --prem-radius: 20px;
    }

    .fade-in-up {
        animation: fadeInUp 0.6s cubic-bezier(0.16, 1, 0.3, 1) both;
    }

    @@keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(20px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .premium-card {
        background: var(--prem-surface);
        border-radius: var(--prem-radius);
        border: 1px solid var(--prem-border);
        box-shadow: 0 10px 30px rgba(0,0,0,0.02);
        overflow: hidden;
    }

    .card-header-premium {
        padding: 24px;
        border-bottom: 1px solid var(--prem-border);
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .icon-box {
        width: 45px;
        height: 45px;
        border-radius: 12px;
        display: flex;
        justify-content: center;
        align-items: center;
        font-size: 20px;
        flex-shrink: 0;
    }

    .premium-table th {
        font-weight: 800;
        color: var(--prem-muted);
        border-bottom: 2px solid var(--prem-border) !important;
        padding: 16px;
        font-size: 0.85rem;
        text-transform: uppercase;
    }

    .premium-table td {
        padding: 16px;
        vertical-align: middle;
    }

    .premium-table tr:hover td {
        background-color: #f8fafc;
    }

    .hover-elevate {
        transition: transform 0.2s cubic-bezier(0.4, 0, 0.2, 1), box-shadow 0.2s;
        cursor: pointer;
    }

        .hover-elevate:hover {
            transform: translateY(-3px);
            box-shadow: 0 10px 20px rgba(0,0,0,0.08) !important;
        }

    @@media print {
        body {
            background: white !important;
        }

        .sys-sidebar, .sys-header, .d-print-none, .dataTables_filter, .dataTables_info, .dataTables_paginate, .dataTables_length {
            display: none !important;
        }

        .sys-main {
            margin: 0 !important;
            padding: 0 !important;
            width: 100% !important;
        }

        .premium-card {
            box-shadow: none !important;
            border: 1px solid #000 !important;
            padding: 15px !important;
        }

        .premium-table th, .premium-table td {
            border: 1px solid #ddd !important;
        }

        * {
            -webkit-print-color-adjust: exact !important;
            print-color-adjust: exact !important;
        }
    }
</style>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('.sys-table').DataTable({
                "language": { "url": "//cdn.datatables.net/plug-ins/1.13.6/i18n/ar.json" },
                "pageLength": 50,
                "ordering": false // ترك الترتيب الافتراضي من السيرفر (الأكثر استخداماً في الأعلى)
            });
        });

        // 📌 التحديث: دالة الجافاسكريبت لفتح نافذة المواعيد
        function openOrdersModal(partName, orderIdsString) {
            document.getElementById('modalPartName').innerText = partName;

            var container = document.getElementById('ordersLinksContainer');
            container.innerHTML = ''; // تفريغ القديم

            if (orderIdsString && orderIdsString.trim() !== "") {
                var orderIds = orderIdsString.split(',');
                orderIds.forEach(function(id) {
                    var btn = document.createElement('a');
                    btn.href = "/Orders/Details/" + id.trim();
                    btn.target = "_blank"; // فتح في نافذة جديدة
                    btn.className = "btn btn-outline-dark fw-bold rounded-pill px-3 shadow-sm hover-elevate mb-2";
                    btn.innerHTML = '<i class="fa-solid fa-hashtag text-warning me-1"></i> ' + id.trim();
                    container.appendChild(btn);
                });
            } else {
                container.innerHTML = '<span class="text-muted fw-bold small">لا توجد بيانات متاحة.</span>';
            }

            var ordersModal = new bootstrap.Modal(document.getElementById('ordersModal'));
            ordersModal.show();
        }
    </script>
}