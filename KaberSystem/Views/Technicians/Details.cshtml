<!-- مسار الملف: Views/Technicians/Details.cshtml -->
@model KaberSystem.Models.Technician
@{
    ViewData["Title"] = "ملف المهندس: " + Model.Name;
    Layout = "~/Views/Shared/_SystemLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-5 d-print-none fade-in-up">
    <div class="d-flex align-items-center gap-3">
        <div class="bg-white text-primary rounded-circle d-flex justify-content-center align-items-center shadow-sm" style="width: 55px; height: 55px; font-size: 22px;">
            <i class="fa-solid fa-user-tie"></i>
        </div>
        <div>
            <h2 class="fw-bolder text-dark mb-1" style="letter-spacing: -0.5px;">ملف الفني: <span class="text-primary">@Model.Name</span></h2>
            <p class="text-muted fw-bold mb-0">متابعة أداء الفني، الطلبات المسندة إليه، وجرد العهدة الحالية</p>
        </div>
    </div>
    <div class="d-flex gap-2">
        <a href="/Technicians/Index" class="btn btn-light text-muted fw-bold px-4 rounded-pill hover-elevate border shadow-sm">
            <i class="fa-solid fa-arrow-right me-1"></i> عودة للقائمة
        </a>
    </div>
</div>

<div class="row g-4 mb-4">
    <!-- 📌 1. معلومات الفني الأساسية والإحصائيات -->
    <div class="col-lg-4 fade-in-up" style="animation-delay: 0.1s;">
        <div class="premium-card text-center h-100 position-relative overflow-hidden border-0 shadow-sm p-0">
            <div class="position-absolute top-0 start-0 w-100" style="height: 130px; background: linear-gradient(135deg, rgba(241, 149, 11, 0.15), rgba(241, 149, 11, 0.05)); z-index: 0;"></div>

            <div class="position-relative z-1" style="margin-top: 60px;">
                <img src="https://ui-avatars.com/api/?name=@Uri.EscapeDataString(Model.Name)&background=f1950b&color=fff&size=120&bold=true" class="rounded-circle shadow border border-4 border-white mb-3">
                <h4 class="fw-bolder text-dark mb-1">@Model.Name</h4>
                <p class="text-muted fw-bold fs-6 mb-4" dir="ltr"><i class="fa-solid fa-phone text-primary me-2"></i>@Model.Phone</p>

                <div class="mb-4">
                    @if (Model.IsAvailable)
                    {
                        <span class="badge bg-success bg-opacity-10 text-success fs-6 border border-success rounded-pill px-4 py-2 shadow-sm"><i class="fa-solid fa-check-circle me-1"></i> متاح للعمل (جاهز للاستلام)</span>
                    }
                    else
                    {
                        <span class="badge bg-danger bg-opacity-10 text-danger fs-6 border border-danger rounded-pill px-4 py-2 shadow-sm"><i class="fa-solid fa-ban me-1"></i> مشغول حالياً</span>
                    }
                </div>

                <div class="mt-4 border-top pt-4 pb-4 px-3 d-flex justify-content-around bg-light">
                    <div>
                        <h3 class="fw-bolder text-primary mb-1">@(Model.AssignedOrders?.Count ?? 0)</h3>
                        <span class="text-muted fw-bold small text-uppercase">إجمالي الطلبات</span>
                    </div>
                    <div class="border-start ps-3">
                        <h3 class="fw-bolder text-success mb-1">@(Model.AssignedOrders?.Count(o => o.Status == KaberSystem.Models.OrderStatus.Completed || o.Status == KaberSystem.Models.OrderStatus.Approved) ?? 0)</h3>
                        <span class="text-muted fw-bold small text-uppercase">طلبات منجزة</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- 📌 2. الطلبات المسندة للفني (التي تم إضافتها لتوضيح موقع العميل) -->
    <div class="col-lg-8 fade-in-up" style="animation-delay: 0.2s;">
        <div class="premium-card h-100 d-flex flex-column">
            <div class="card-header-premium bg-light d-flex justify-content-between align-items-center">
                <h5 class="fw-bolder m-0 text-dark"><i class="fa-solid fa-map-location-dot text-primary me-2"></i> الطلبات الحالية المسندة للفني</h5>
            </div>

            <div class="card-body-premium p-0 flex-grow-1">
                @if (Model.AssignedOrders != null && Model.AssignedOrders.Any(o => o.Status != KaberSystem.Models.OrderStatus.Completed && o.Status != KaberSystem.Models.OrderStatus.Approved && o.Status != KaberSystem.Models.OrderStatus.Cancelled))
                {
                    <div class="table-responsive">
                        <table class="table premium-table align-middle text-center mb-0 w-100">
                            <thead class="bg-light text-muted small fw-bold text-uppercase">
                                <tr>
                                    <th class="ps-4 text-start">رقم الطلب</th>
                                    <th>العميل والتواصل</th>
                                    <th>الجهاز</th>
                                    <th>الموقع / العنوان</th>
                                    <th>إجراءات</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var order in Model.AssignedOrders.Where(o => o.Status != KaberSystem.Models.OrderStatus.Completed && o.Status != KaberSystem.Models.OrderStatus.Approved && o.Status != KaberSystem.Models.OrderStatus.Cancelled).OrderByDescending(o => o.CreatedAt))
                                {
                                    string phoneStr = order.PhoneNumber.StartsWith("0") ? order.PhoneNumber.Substring(1) : order.PhoneNumber;
                                    string whatsappNumber = "966" + phoneStr;

                                    <tr style="border-bottom: 1px solid #f8f9fa;">
                                        <td class="text-start ps-4">
                                            <span class="fw-bolder px-2 py-1 bg-light border rounded text-dark shadow-sm">#@order.OrderId</span>
                                            <div class="small mt-2">
                                                @if (order.Status == KaberSystem.Models.OrderStatus.Returned)
                                                {
                                                    <span class="badge bg-danger">مُرجع للتعديل</span>
                                                }
                                                else if (order.Status == KaberSystem.Models.OrderStatus.InProgress)
                                                {

                                                    <span class="badge bg-info text-dark">قيد التنفيذ</span>
                                                }
                                                else
                                                {

                                                    <span class="badge bg-primary">مُعين حديثاً</span>
                                                }
                                            </div>
                                        </td>
                                        <td>
                                            <span class="fw-bold text-dark d-block">@order.CustomerName</span>
                                            <div class="d-flex align-items-center justify-content-center gap-2 mt-1">
                                                <span class="small fw-bold text-muted" dir="ltr">@order.PhoneNumber</span>
                                                <a href="https://wa.me/@whatsappNumber" target="_blank" class="text-success hover-elevate"><i class="fa-brands fa-whatsapp fs-5"></i></a>
                                            </div>
                                        </td>
                                        <td class="fw-bold text-primary">@order.DeviceName</td>
                                        <td>
                                            <!-- 📌 هنا يظهر موقع العميل ورابط الخريطة للفني -->
                                            @if (!string.IsNullOrEmpty(order.LocationMapUrl))
                                            {
                                                <a href="@order.LocationMapUrl" target="_blank" class="btn btn-sm btn-light border text-primary fw-bold rounded-pill px-3 shadow-sm hover-elevate mb-1">
                                                    <i class="fa-solid fa-map-location-dot text-danger me-1"></i> فتح الخريطة
                                                </a>
                                            }
                                            <span class="d-block small text-muted fw-bold mt-1" style="max-width: 150px; margin: auto; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;" title="@order.Address">
                                                <i class="fa-solid fa-location-dot text-danger opacity-50 me-1"></i> @order.Address
                                            </span>
                                        </td>
                                        <td>
                                            <a href="/Orders/Details/@order.OrderId" class="btn btn-sm btn-outline-primary fw-bold rounded-pill px-3 hover-elevate">
                                                متابعة الطلب
                                            </a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="text-center py-5">
                        <div class="bg-light rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width: 80px; height: 80px;">
                            <i class="fa-solid fa-mug-hot fs-2 text-muted opacity-50"></i>
                        </div>
                        <h6 class="fw-bold text-muted mb-0">لا توجد طلبات جارية مسندة لهذا الفني في الوقت الحالي.</h6>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<!-- 📌 3. سجل العهدة والمخزون في سيارة الفني -->
<div class="premium-card fade-in-up" style="animation-delay: 0.3s;">
    <div class="card-header-premium d-flex justify-content-between align-items-center flex-wrap gap-3">
        <h5 class="fw-bolder m-0 text-dark"><i class="fa-solid fa-toolbox text-primary me-2"></i> العهدة الحالية (صندوق الفني)</h5>
        @if (User.IsInRole("Admin") || User.IsInRole("Store"))
        {
            <button class="btn btn-primary fw-bold rounded-pill px-4 shadow-sm hover-elevate" data-bs-toggle="modal" data-bs-target="#assignStockModal">
                <i class="fa-solid fa-plus me-1"></i> صرف قطع جديدة للعهدة
            </button>
        }
    </div>

    <div class="card-body-premium p-0">
        @if (Model.Inventory != null && Model.Inventory.Any())
        {
            <div class="table-responsive">
                <table class="table premium-table align-middle text-center mb-0 w-100">
                    <thead class="bg-light text-muted small fw-bold text-uppercase">
                        <tr>
                            <th class="ps-4 text-start">القطعة (الكود والبيان)</th>
                            <th>الكمية المتوفرة بسيارته</th>
                            <th>سعر المبيع التقريبي</th>
                            @if (User.IsInRole("Admin") || User.IsInRole("Store"))
                            {
                                <th>إجراء الإرجاع</th>
                            }
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Inventory)
                        {
                            <tr style="border-bottom: 1px solid #f8f9fa;">
                                <td class="text-start ps-4">
                                    <span class="text-muted small fw-bold d-block mb-1">#@item.PartId</span>
                                    <span class="fw-bold text-dark fs-6">@item.SparePart?.Name</span>
                                </td>
                                <td>
                                    <span class="premium-badge @(item.Quantity > 2 ? "success" : "danger") fs-6 shadow-sm">
                                        @item.Quantity
                                    </span>
                                </td>
                                <td class="fw-bold text-success">@(item.SparePart?.SellingPrice.ToString("N2")) <span class="small fw-normal text-muted">ر.س</span></td>

                                @if (User.IsInRole("Admin") || User.IsInRole("Store"))
                                {
                                    <td>
                                        <button class="btn btn-sm btn-light border text-danger fw-bold rounded-pill px-3 hover-elevate" data-bs-toggle="modal" data-bs-target="#returnStockModal-@item.PartId">
                                            <i class="fa-solid fa-arrow-rotate-left me-1"></i> إرجاع للمخزن
                                        </button>

                                        <!-- Modal إرجاع العهدة للمخزن -->
                                        <div class="modal fade" id="returnStockModal-@item.PartId" tabindex="-1" aria-hidden="true">
                                            <div class="modal-dialog modal-dialog-centered">
                                                <div class="modal-content premium-modal border-0 shadow-lg text-start">
                                                    <div class="modal-header border-bottom-0 pb-0 px-4 pt-4">
                                                        <h5 class="modal-title fw-bolder text-danger"><i class="fa-solid fa-arrow-rotate-left me-2"></i> إرجاع قطعة للمخزن الرئيسي</h5>
                                                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                                                    </div>
                                                    <form asp-action="ReturnStock" method="post">
                                                        <div class="modal-body p-4">
                                                            <input type="hidden" name="technicianId" value="@Model.TechnicianId" />
                                                            <input type="hidden" name="partId" value="@item.PartId" />

                                                            <div class="alert alert-danger py-2 small fw-bold mb-4 border-0 border-start border-4 border-danger rounded-3 bg-danger bg-opacity-10">
                                                                سيتم سحب <span class="text-dark">@item.SparePart?.Name</span> من عهدة الفني وإعادتها للرصيد الرئيسي للمؤسسة.
                                                            </div>

                                                            <div class="mb-3">
                                                                <label class="premium-label">الكمية المراد إرجاعها للمخزن <span class="text-danger">*</span></label>
                                                                <input type="number" name="returnQuantity" class="premium-input form-control text-center fs-5" min="1" max="@item.Quantity" value="1" required />
                                                                <small class="text-muted fw-bold mt-2 d-block text-center">الحد الأقصى المتاح للإرجاع: @item.Quantity</small>
                                                            </div>
                                                        </div>
                                                        <div class="modal-footer border-top-0 pt-0 px-4 pb-4">
                                                            <button type="button" class="btn btn-light fw-bold px-4 rounded-pill" data-bs-dismiss="modal">إلغاء</button>
                                                            <button type="submit" class="btn btn-danger fw-bolder px-4 rounded-pill shadow-sm hover-elevate">تأكيد الإرجاع <i class="fa-solid fa-check ms-1"></i></button>
                                                        </div>
                                                    </form>
                                                </div>
                                            </div>
                                        </div>
                                    </td>
                                }
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="text-center py-5">
                <div class="bg-light rounded-circle d-inline-flex align-items-center justify-content-center mb-3 shadow-sm" style="width: 80px; height: 80px;">
                    <i class="fa-solid fa-box-open fs-2 text-muted opacity-50"></i>
                </div>
                <h6 class="fw-bold text-muted mb-2">لا توجد عهدة مصروفة لهذا الفني حالياً.</h6>
                <p class="text-muted small mb-0">قم بصرف قطع الغيار له ليتمكن من استخدامها في طلبات الصيانة فوراً عند العميل.</p>
            </div>
        }
    </div>
</div>

<!-- 📌 Modal صرف عهدة للفني -->
<div class="modal fade" id="assignStockModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content premium-modal border-0 shadow-lg">
            <div class="modal-header border-bottom-0 pb-0 px-4 pt-4">
                <h5 class="modal-title fw-bolder text-primary"><i class="fa-solid fa-truck-ramp-box me-2"></i> صرف قطع غيار للعهدة</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-action="AssignStock" method="post">
                <div class="modal-body p-4 text-start">
                    <input type="hidden" name="technicianId" value="@Model.TechnicianId" />

                    <div class="mb-4">
                        <label class="premium-label">اختر القطعة من المخزن العام <span class="text-danger">*</span></label>
                        <select name="partId" class="premium-input form-select fw-bold" required>
                            <option value="">-- اضغط للاختيار --</option>
                            @if (ViewData["AvailableParts"] != null)
                            {
                                foreach (var part in (IEnumerable<KaberSystem.Models.SparePart>)ViewData["AvailableParts"])
                                {
                                    <option value="@part.PartId">@part.Name (المتاح: @part.MainStockQuantity)</option>
                                }
                            }
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="premium-label">الكمية المراد صرفها <span class="text-danger">*</span></label>
                        <input type="number" name="quantity" class="premium-input form-control text-center fs-5" min="1" value="1" required />
                        <small class="text-muted fw-bold mt-2 d-block text-center"><i class="fa-solid fa-info-circle text-primary me-1"></i> سيتم خصم هذه الكمية من المخزن الرئيسي وإضافتها لسيارة الفني.</small>
                    </div>
                </div>
                <div class="modal-footer border-top-0 pt-0 px-4 pb-4">
                    <button type="button" class="btn btn-light fw-bold px-4 rounded-pill" data-bs-dismiss="modal">إلغاء</button>
                    <button type="submit" class="btn btn-primary fw-bolder px-4 rounded-pill shadow-sm hover-elevate">تأكيد الصرف <i class="fa-solid fa-check ms-1"></i></button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        @if (TempData["SuccessMessage"] != null)
        {
                var msg = System.Text.Json.JsonSerializer.Serialize(TempData["SuccessMessage"]?.ToString());
                <text>Swal.fire({ icon: 'success', title: 'عملية ناجحة', html: @Html.Raw(msg), confirmButtonColor: '#198754', customClass: { popup: 'premium-swal' } });</text>
        }
        @if (TempData["ErrorMessage"] != null)
        {
                var errMsg = System.Text.Json.JsonSerializer.Serialize(TempData["ErrorMessage"]?.ToString());
                <text>Swal.fire({ icon: 'error', title: 'خطأ', html: @Html.Raw(errMsg), confirmButtonColor: '#ee5d50', customClass: { popup: 'premium-swal' } });</text>
        }
    </script>
}

<style>
    /* Premium Dashboard UI Styles */
    :root {
        --prem-bg: #f8f9fc;
        --prem-surface: #ffffff;
        --prem-border: #e2e8f0;
        --prem-text: #1e293b;
        --prem-muted: #64748b;
        --prem-primary: #f1950b;
        --prem-radius: 20px;
    }

    .fade-in-up {
        animation: fadeInUp 0.6s cubic-bezier(0.16, 1, 0.3, 1) both;
    }

    @@keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(20px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .premium-card {
        background: var(--prem-surface);
        border-radius: var(--prem-radius);
        border: 1px solid var(--prem-border);
        box-shadow: 0 10px 30px rgba(0,0,0,0.02);
        overflow: hidden;
    }

    .card-header-premium {
        padding: 20px 24px;
        border-bottom: 1px solid var(--prem-border);
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .card-body-premium {
        padding: 24px;
    }

    /* Inputs */
    .premium-label {
        font-weight: 800;
        color: var(--prem-muted);
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        margin-bottom: 8px;
        display: block;
    }

    .premium-input {
        background-color: #f8fafc;
        border: 1px solid var(--prem-border);
        border-radius: 12px;
        padding: 14px 20px;
        font-weight: 700;
        color: var(--prem-text);
        box-shadow: none !important;
        transition: all 0.3s ease;
    }

        .premium-input:focus {
            background-color: #fff;
            border-color: var(--prem-primary);
            box-shadow: 0 0 0 4px rgba(241, 149, 11, 0.1) !important;
        }

    /* Badges */
    .premium-badge {
        padding: 6px 16px;
        border-radius: 30px;
        font-size: 0.85rem;
        font-weight: 800;
    }

        .premium-badge.default {
            background: #f1f5f9;
            color: #475569;
            border: 1px solid #e2e8f0;
        }

        .premium-badge.primary {
            background: rgba(241,149,11,0.1);
            color: var(--prem-primary);
            border: 1px solid rgba(241,149,11,0.2);
        }

        .premium-badge.success {
            background: #ecfdf5;
            color: #198754;
            border: 1px solid #d1e7dd;
        }

        .premium-badge.warning {
            background: #fff3cd;
            color: #856404;
            border: 1px solid #ffeeba;
        }

        .premium-badge.info {
            background: #cff4fc;
            color: #055160;
            border: 1px solid #b6effb;
        }

        .premium-badge.danger {
            background: #f8d7da;
            color: #842029;
            border: 1px solid #f5c2c7;
        }

        .premium-badge.dark {
            background: #e2e3e5;
            color: #41464b;
            border: 1px solid #d3d6d8;
        }

        .premium-badge.primary-light {
            background: #e0e7ff;
            color: #4f46e5;
        }

        .premium-badge.dark-light {
            background: #f1f5f9;
            color: #0f172a;
        }

    /* Table */
    .premium-table th {
        font-weight: 800;
        color: var(--prem-muted);
        border-bottom: 2px solid var(--prem-border);
        padding: 16px;
        font-size: 0.85rem;
        text-transform: uppercase;
    }

    .premium-table td {
        padding: 16px;
        vertical-align: middle;
    }

    /* Modals & Buttons */
    .premium-modal {
        border-radius: 24px;
        overflow: hidden;
    }

    .hover-elevate {
        transition: transform 0.2s cubic-bezier(0.4, 0, 0.2, 1), box-shadow 0.2s;
    }

        .hover-elevate:hover {
            transform: translateY(-3px);
            box-shadow: 0 10px 20px rgba(0,0,0,0.08) !important;
        }

    .premium-swal {
        border-radius: 20px !important;
    }
</style>