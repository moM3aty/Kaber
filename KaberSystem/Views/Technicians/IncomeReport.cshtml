@model IEnumerable<KaberSystem.Models.Technician>
@{
    ViewData["Title"] = "تقرير أرباح الفنيين";
    Layout = "~/Views/Shared/_SystemLayout.cshtml";
}

<div class="sys-page-header d-print-none">
    <div>
        <h1 class="sys-page-title">أرباح وإنتاجية الفنيين</h1>
        <p class="sys-page-desc">تقرير محاسبي يوضح إجمالي الإيرادات التي حققها كل فني وحساب العمولة المستحقة له</p>
    </div>
    <button class="sys-btn sys-btn-primary" onclick="window.print()">
        <i class="fa-solid fa-print"></i> طباعة التقرير
    </button>
</div>

<div class="sys-card printable-card">

    <!-- ترويسة الطباعة (تظهر فقط في الورق) -->
    <div class="d-none d-print-block text-center border-bottom pb-4 mb-4">
        <h2 class="fw-bold text-dark mb-1"><i class="fa-solid fa-bolt text-primary me-2"></i> شركة كابر للصيانة</h2>
        <h4 class="text-muted fw-bold mb-3">تقرير أرباح وعمولات الفنيين</h4>
        <div class="d-flex justify-content-between align-items-center mt-3 px-3">
            <p class="m-0 fw-bold fs-5">تاريخ الطباعة: @DateTime.Now.ToString("yyyy-MM-dd")</p>
            <p class="m-0 fw-bold fs-5">القسم: الإدارة المالية</p>
        </div>
    </div>

    <!-- عنوان الشاشة (يختفي في الطباعة) -->
    <div class="d-flex align-items-center border-bottom pb-3 mb-4 d-print-none">
        <div class="bg-success bg-opacity-10 text-success rounded-circle d-flex justify-content-center align-items-center me-3" style="width: 50px; height: 50px;">
            <i class="fa-solid fa-hand-holding-dollar fs-4"></i>
        </div>
        <h4 class="fw-bold m-0 text-dark">كشف حساب الفنيين</h4>
    </div>

    <div class="table-responsive overflow-visible">
        <table class="table table-hover align-middle text-center sys-table w-100 print-table">
            <thead class="table-light">
                <tr>
                    <th>اسم الفني</th>
                    <th>إجمالي الطلبات المنجزة</th>
                    <th>إجمالي إيرادات أجور اليد (الفحص)</th>
                    <th>العمولة المستحقة (30%)</th>
                    <th>الحالة</th>
                </tr>
            </thead>
            <tbody>
                @{
                    decimal totalAllIncomes = 0;
                    decimal totalAllCommissions = 0;
                }
                @foreach (var tech in Model)
                {
                    // حساب أجور اليد فقط (بدون قطع الغيار) للطلبات المكتملة
                    decimal totalLaborIncome = tech.AssignedOrders?
                    .Where(o => o.Status == KaberSystem.Models.OrderStatus.Completed)
                    .Sum(o => o.EstimatedPrice) ?? 0;

                    // حساب العمولة (مثلاً 30%)
                    decimal commission = totalLaborIncome * 0.30m;

                    // تجميع الإجماليات
                    totalAllIncomes += totalLaborIncome;
                    totalAllCommissions += commission;

                    <tr>
                        <td class="fw-bold text-dark text-start">
                            <img src="https://ui-avatars.com/api/?name=@Uri.EscapeDataString(tech.Name)&background=f1950b&color=fff" class="rounded-circle me-2 d-print-none" width="35" height="35">
                            @tech.Name
                        </td>
                        <td class="fw-bold fs-5">@(tech.AssignedOrders?.Count(o => o.Status == KaberSystem.Models.OrderStatus.Completed) ?? 0)</td>
                        <td class="text-success fw-bold fs-5 bg-light">@totalLaborIncome ر.س</td>
                        <td class="text-primary fw-bold fs-5">@commission ر.س</td>
                        <td>
                            @if (commission > 0)
                            {
                                <span class="badge bg-warning text-dark px-3 py-2 rounded-pill print-badge"><i class="fa-solid fa-clock d-print-none"></i> مستحقة الدفع</span>
                            }
                            else
                            {
                                <span class="text-muted small fw-bold">لا يوجد أرباح</span>
                            }
                        </td>
                    </tr>
                }

                <!-- صف الإجمالي يظهر في الطباعة والشاشة -->
                <tr class="table-dark text-white fw-bold fs-5">
                    <td colspan="2" class="text-end pe-4">الإجمالي العام:</td>
                    <td class="text-white">@totalAllIncomes ر.س</td>
                    <td class="text-warning">@totalAllCommissions ر.س</td>
                    <td></td>
                </tr>
            </tbody>
        </table>
    </div>

    <!-- أماكن التوقيع (تظهر فقط في الطباعة) -->
    <div class="d-none d-print-flex justify-content-between mt-5 pt-5 px-5">
        <div class="text-center">
            <h5 class="fw-bold text-dark mb-4">المحاسب المختص</h5>
            <p>.......................................</p>
        </div>
        <div class="text-center">
            <h5 class="fw-bold text-dark mb-4">اعتماد الإدارة</h5>
            <p>.......................................</p>
        </div>
    </div>
</div>

<style>
    /* تنسيقات الطباعة الاحترافية للتقرير */
    @@media print {
        body {
            background: white !important;
            margin: 0 !important;
            padding: 0 !important;
        }
        /* إخفاء العناصر غير المطلوبة */
        .sys-sidebar, .sys-header, .d-print-none, #backToTop, .whatsapp-btn, .dataTables_wrapper .row {
            display: none !important;
        }

        .sys-main {
            margin: 0 !important;
            padding: 20px !important;
            width: 100% !important;
        }

        .sys-content {
            padding: 0 !important;
        }

        .printable-card {
            box-shadow: none !important;
            border: 2px solid #000 !important;
            border-radius: 10px !important;
            padding: 30px !important;
            break-inside: avoid;
            width: 100%;
        }
        /* ضبط الجدول للطباعة */
        .print-table {
            border-collapse: collapse !important;
            width: 100% !important;
            margin-bottom: 30px !important;
        }

            .print-table th, .print-table td {
                border: 1px solid #000 !important;
                color: #000 !important;
                padding: 12px !important;
                background-color: transparent !important;
            }

            .print-table th {
                background-color: #f8f9fa !important;
                -webkit-print-color-adjust: exact !important;
                print-color-adjust: exact !important;
            }
        /* توحيد الألوان للأسود لتبدو رسمية */
        * {
            color: #000 !important;
        }

        .table-dark th, .table-dark td {
            background-color: #eee !important;
            -webkit-print-color-adjust: exact !important;
            print-color-adjust: exact !important;
        }
        /* تحويل الـ Badges لنص عادي مع إطار خفيف */
        .print-badge {
            border: 1px solid #000 !important;
            background: transparent !important;
            color: #000 !important;
            border-radius: 5px !important;
            padding: 5px 10px !important;
        }
    }
</style>