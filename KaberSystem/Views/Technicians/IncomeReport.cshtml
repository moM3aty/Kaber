@{
    ViewData["Title"] = "تقارير الأرباح والحسابات";
    Layout = "~/Views/Shared/_SystemLayout.cshtml";

    decimal totalRevenue = ViewBag.TotalRevenue ?? 0;
    decimal cogs = ViewBag.CostOfGoodsSold ?? 0;
    decimal grossProfit = ViewBag.GrossProfit ?? 0;
    decimal totalExpenses = ViewBag.TotalExpenses ?? 0;
    decimal damagesCost = ViewBag.TotalDamagesCost ?? 0;
    decimal netProfit = ViewBag.NetCompanyProfit ?? 0;

    string currentMonthYear = ViewBag.CurrentMonthYear;
    string monthName = ViewBag.MonthName;
}

<div class="sys-page-header d-flex justify-content-between align-items-center flex-wrap">
    <div>
        <h1 class="sys-page-title text-success"><i class="fa-solid fa-chart-line me-2"></i> قائمة الدخل والمركز المالي</h1>
        <p class="sys-page-desc">مراقبة الأرباح والمصروفات الخاصة بالشهر المحدد، مع ترحيل مديونيات الفنيين.</p>
    </div>
    <div class="d-flex gap-3 align-items-center mt-3 mt-md-0">
        <form method="get" asp-action="Index" class="m-0 bg-white p-1 rounded-pill shadow-sm border border-success">
            <div class="d-flex align-items-center px-2">
                <i class="fa-regular fa-calendar-days text-success me-2"></i>
                <span class="fw-bold text-dark me-2 small">شهر الحساب:</span>
                <input type="month" name="monthYear" value="@currentMonthYear" class="form-control form-control-sm fw-bold border-0 text-success" style="box-shadow: none; cursor: pointer;" onchange="this.form.submit()" />
            </div>
        </form>
        <!-- 📌 تم إضافة زر لفتح شيت الإكسل الشامل (Master Ledger) -->
        <a href="/Accounting/MasterLedger" class="sys-btn btn-success text-white fw-bold"><i class="fa-solid fa-file-excel"></i> الدفتر الشامل (Excel)</a>
    </div>
</div>

<!-- (نفس كروت الإحصائيات السابقة كما هي) -->
<div class="row g-4 mb-5">
    <div class="col-md-3">
        <div class="sys-card bg-primary bg-opacity-10 border-0 h-100 p-4 text-center">
            <i class="fa-solid fa-sack-dollar fs-1 text-primary mb-2"></i>
            <h6 class="fw-bold text-muted mb-1">المبيعات (إيرادات @monthName)</h6>
            <h3 class="fw-bold text-dark m-0">@totalRevenue.ToString("N2") <span class="fs-6">ر.س</span></h3>
        </div>
    </div>
    <div class="col-md-3">
        <div class="sys-card bg-secondary bg-opacity-10 border-0 h-100 p-4 text-center" style="border-top: 4px solid #6c757d !important;">
            <i class="fa-solid fa-boxes-packing fs-1 text-secondary mb-2"></i>
            <h6 class="fw-bold text-muted mb-1">تكلفة القطع المباعة (COGS)</h6>
            <h3 class="fw-bold text-secondary m-0">- @cogs.ToString("N2") <span class="fs-6">ر.س</span></h3>
            <small class="text-muted fw-bold d-block mt-1">أسعار شراء القطع المستهلكة بالشهر</small>
        </div>
    </div>
    <div class="col-md-3">
        <div class="sys-card bg-info bg-opacity-10 border-0 h-100 p-4 text-center">
            <i class="fa-solid fa-scale-balanced fs-1 text-info mb-2"></i>
            <h6 class="fw-bold text-muted mb-1">مجمل الربح (للشهر المحدد)</h6>
            <h3 class="fw-bold text-dark m-0">@grossProfit.ToString("N2") <span class="fs-6">ر.س</span></h3>
        </div>
    </div>
    <div class="col-md-3">
        <div class="sys-card bg-danger bg-opacity-10 border-0 h-100 p-4 text-center">
            <i class="fa-solid fa-arrow-trend-down fs-1 text-danger mb-2"></i>
            <h6 class="fw-bold text-muted mb-1">مصروفات وتوالف (للشهر المحدد)</h6>
            <h3 class="fw-bold text-danger m-0">- @((totalExpenses + damagesCost).ToString("N2")) <span class="fs-6">ر.س</span></h3>
        </div>
    </div>
</div>

<div class="row justify-content-center mb-5">
    <div class="col-md-8">
        <div class="sys-card h-100 d-flex flex-column align-items-center p-5 text-white shadow-lg position-relative overflow-hidden @(netProfit >= 0 ? "bg-success" : "bg-danger")">
            <i class="fa-solid fa-chart-pie position-absolute" style="font-size: 200px; opacity: 0.1; right: -20px; bottom: -40px;"></i>
            <div class="position-relative z-1 text-center">
                <p class="fw-bold text-white-50 mb-2 fs-4">صافي الربح الفعلي عن شهر (@monthName)</p>
                <h1 class="fw-bolder m-0 display-3" style="letter-spacing: -1px;">
                    @if (netProfit > 0)
                    {
                        <text>+</text>
                    }
 @netProfit.ToString("N2") <span class="fs-3">ريال سعودي</span>
                </h1>
                <p class="text-white-50 mt-3 mb-0 fw-bold"><i class="fa-solid fa-check-double me-1"></i> هذا الرقم هو الربح الحقيقي بعد خصم تكلفة البضاعة والمصروفات والتوالف.</p>
            </div>
        </div>
    </div>
</div>

<!-- 📌 التحديث: فصل أجور اليد عن القطع في جدول الفنيين بناءً على ملاحظة الفيديو -->
<div class="sys-card mt-4">
    <h4 class="fw-bold text-dark border-bottom pb-3 mb-4"><i class="fa-solid fa-users-gear text-primary me-2"></i> ملخص مبيعات وحسابات الفنيين</h4>

    <div class="table-responsive">
        <table class="table table-hover align-middle text-center sys-table w-100">
            <thead class="table-light">
                <tr>
                    <th>اسم الفني</th>
                    <th>إجمالي المبيعات<br><span class="text-muted small">(هذا الشهر)</span></th>
                    <th>مبيعات أجور اليد<br><span class="text-success small">(تُحسب منها العمولة)</span></th>
                    <th>مبيعات قطع الغيار<br><span class="text-info small">(لا تدخل بالعمولة)</span></th>
                    <th>إجمالي السلف / مديونية<br><span class="text-danger small">(مرحّلة)</span></th>
                    <th>العهدة (الكاش المُحصّل)<br><span class="text-primary small">(مرحّلة)</span></th>
                    <th>إجراءات</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var tech in ViewBag.TechnicianReports)
                {
                    <tr>
                        <td class="fw-bold text-start ps-3"><i class="fa-solid fa-user-tie text-muted me-2"></i> @tech.Name</td>
                        <td class="fw-bold text-dark fs-6">@tech.TotalIncome.ToString("N2")</td>
                        <!-- أجور اليد مفصولة -->
                        <td class="fw-bold text-success fs-6 bg-success bg-opacity-10 border-end border-start">@tech.LaborSales.ToString("N2")</td>
                        <!-- مبيعات القطع مفصولة -->
                        <td class="fw-bold text-info text-dark">@tech.PartsSales.ToString("N2")</td>

                        <td class="fw-bold text-danger">@tech.AllTimeDeductions.ToString("N2")</td>
                        <td class="fw-bold text-primary bg-primary bg-opacity-10 rounded-3">@tech.WalletBalance.ToString("N2")</td>
                        <td>
                            <button type="button" class="btn btn-sm btn-outline-success fw-bold px-3 rounded-pill" data-bs-toggle="modal" data-bs-target="#settleModal_@tech.Id">
                                <i class="fa-solid fa-hand-holding-dollar me-1"></i> توريد كاش
                            </button>

                            <!-- Modal تصفية الكاش (كما هو مسبقاً) -->
                            <div class="modal fade" id="settleModal_@tech.Id" tabindex="-1" aria-hidden="true">
                                <div class="modal-dialog modal-dialog-centered">
                                    <div class="modal-content border-0 rounded-4 shadow-lg">
                                        <div class="modal-header border-bottom-0 pb-0">
                                            <h5 class="modal-title fw-bold text-success"><i class="fa-solid fa-vault me-2"></i> توريد كاش من الفني: @tech.Name</h5>
                                            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                        </div>
                                        <form asp-action="SettleTechCash" method="post">
                                            <div class="modal-body py-4 text-start">
                                                <input type="hidden" name="techId" value="@tech.Id" />

                                                <div class="alert alert-info py-2 small fw-bold lh-lg">
                                                    إجمالي الكاش (التراكمي) الذي استلمه الفني من العملاء بيده ولم يورده: <b>@tech.WalletBalance.ToString("N2") ريال</b>
                                                </div>

                                                <div class="mb-3 mt-3">
                                                    <label class="form-label fw-bold">المبلغ المُورّد للخزنة الآن <span class="text-danger">*</span></label>
                                                    <div class="input-group">
                                                        <input type="number" step="0.01" name="amount" class="form-control fw-bold border-success text-success" required />
                                                        <span class="input-group-text bg-light fw-bold">ر.س</span>
                                                    </div>
                                                </div>
                                                <div class="mb-3">
                                                    <label class="form-label fw-bold">البيان / ملاحظات</label>
                                                    <input type="text" name="note" class="form-control bg-light fw-bold" placeholder="مثال: تصفية عهدة يومية" />
                                                </div>
                                            </div>
                                            <div class="modal-footer border-top-0 pt-0">
                                                <button type="submit" class="btn btn-success fw-bold w-100 py-2"><i class="fa-solid fa-check"></i> تأكيد التوريد للخزنة</button>
                                            </div>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    @if (TempData["SuccessMessage"] != null)
    {
        <script>
            var msg = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(TempData["SuccessMessage"]?.ToString()));
            Swal.fire({ icon: 'success', title: 'تم', text: msg, confirmButtonColor: '#198754' });
        </script>
    }
}