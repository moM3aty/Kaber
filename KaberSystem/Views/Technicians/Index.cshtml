@model IEnumerable<KaberSystem.Models.Technician>
@{
    ViewData["Title"] = "إدارة المهندسين والفنيين";
    Layout = "~/Views/Shared/_SystemLayout.cshtml";
}

<div class="sys-page-header">
    <div>
        <h1 class="sys-page-title">فريق المهندسين والفنيين</h1>
        <p class="sys-page-desc">إدارة فريق الصيانة، متابعة التوفر، ومراقبة الطلبات المسندة لكل فني</p>
    </div>
    @if (User.IsInRole("Admin") || User.IsInRole("CallCenter"))
    {
        <a href="/Technicians/Create" class="sys-btn sys-btn-primary">
            <i class="fa-solid fa-user-plus"></i> إضافة فني جديد
        </a>
    }
</div>

<div class="row g-4">
    @foreach (var tech in Model)
    {
        <div class="col-xl-3 col-lg-4 col-md-6">
            <div class="sys-card text-center position-relative overflow-hidden h-100 p-0" style="transition: transform 0.3s;" onmouseover="this.style.transform='translateY(-5px)'" onmouseout="this.style.transform='translateY(0)'">

                <!-- شريط الحالة العلوي -->
                @if (tech.IsAvailable)
                {
                    <div class="bg-success text-white py-2 fw-bold text-center w-100 position-absolute top-0 start-0 z-1" style="font-size: 13px; letter-spacing: 1px;">
                        <i class="fa-solid fa-check-circle me-1"></i> متاح للعمل
                    </div>
                }
                else
                {
                    <div class="bg-danger text-white py-2 fw-bold text-center w-100 position-absolute top-0 start-0 z-1" style="font-size: 13px; letter-spacing: 1px;">
                        <i class="fa-solid fa-ban me-1"></i> مشغول حالياً
                    </div>
                }

                <div class="p-4" style="margin-top: 35px;">
                    <div class="mb-3 position-relative d-inline-block">
                        <img src="https://ui-avatars.com/api/?name=@Uri.EscapeDataString(tech.Name)&background=f1950b&color=fff&size=100&bold=true&font-size=0.4" class="rounded-circle shadow-sm border border-3 border-white" alt="@tech.Name" width="90" height="90">
                    </div>

                    <h4 class="fw-bold mb-1 text-dark" style="font-size: 20px;">@tech.Name</h4>
                    <p class="text-muted fw-bold mb-4" dir="ltr" style="font-size: 15px;"><i class="fa-solid fa-phone ms-1 text-primary"></i> @tech.Phone</p>

                    <div class="d-flex justify-content-center gap-3 mb-4">
                        <div class="bg-light rounded-3 p-2 w-50" style="border: 1px solid var(--sys-border);">
                            <span class="d-block text-muted small fw-bold mb-1">نشطة</span>
                            <span class="fs-4 fw-bold text-primary">@(tech.AssignedOrders?.Count(o => o.Status == KaberSystem.Models.OrderStatus.Assigned || o.Status == KaberSystem.Models.OrderStatus.InProgress) ?? 0)</span>
                        </div>
                        <div class="bg-light rounded-3 p-2 w-50" style="border: 1px solid var(--sys-border);">
                            <span class="d-block text-muted small fw-bold mb-1">منجزة</span>
                            <span class="fs-4 fw-bold text-success">@(tech.AssignedOrders?.Count(o => o.Status == KaberSystem.Models.OrderStatus.Completed) ?? 0)</span>
                        </div>
                    </div>

                    <div class="d-flex flex-column gap-2">
                        <a href="/Technicians/Details/@tech.TechnicianId" class="btn w-100 fw-bold border border-2 py-2 text-primary border-primary rounded-3 hover-elevate">
                            <i class="fa-solid fa-boxes-stacked me-1"></i> التفاصيل والعهدة
                        </a>

                        <!-- أزرار الأدمن (التعديل والحذف) تظهر في كارت الفني -->
                        @if (User.IsInRole("Admin"))
                        {
                            <div class="d-flex gap-2">
                                <a href="/Technicians/Edit/@tech.TechnicianId" class="btn btn-outline-warning w-50 fw-bold text-dark rounded-3">
                                    <i class="fa-solid fa-pen"></i> تعديل
                                </a>
                                <button type="button" onclick="confirmAdminDelete('/Technicians/Delete/@tech.TechnicianId', 'الفني: @tech.Name')" class="btn btn-outline-danger w-50 fw-bold rounded-3">
                                    <i class="fa-solid fa-trash"></i> حذف
                                </button>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    }
</div>

<style>
    .hover-elevate:hover {
        background-color: var(--sys-primary) !important;
        color: white !important;
        border-color: var(--sys-primary) !important;
    }
</style>

@section Scripts {
    @if (TempData["SuccessMessage"] != null)
    {
        <script>Swal.fire({ icon: 'success', title: 'نجاح', text: '@Html.Raw(TempData["SuccessMessage"])', confirmButtonColor: '#f1950b' });</script>
    }
}