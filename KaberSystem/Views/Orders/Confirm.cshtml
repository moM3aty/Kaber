@model KaberSystem.Models.Order
@{
    ViewData["Title"] = "تأكيد الطلب وإصدار الفاتورة المبدئية";
    Layout = "~/Views/Shared/_SystemLayout.cshtml";
}

<div class="sys-page-header">
    <div>
        <h1 class="sys-page-title">تأكيد الطلب رقم #@Model.OrderId</h1>
        <p class="sys-page-desc">تحديد موعد الزيارة والسعر المبدئي لإصدار الفاتورة وتأكيد الطلب مع العميل</p>
    </div>
    <a href="/Orders/Index" class="btn btn-outline-secondary fw-bold px-4 rounded-3 border-2">
        <i class="fa-solid fa-arrow-right"></i> عودة للقائمة
    </a>
</div>

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="sys-card border-top border-4 border-warning shadow-lg">

            <div class="alert alert-info border-0 rounded-4 mb-4">
                <h5 class="fw-bold m-0"><i class="fa-solid fa-user me-2"></i> العميل: @Model.CustomerName | <i class="fa-solid fa-phone ms-3 me-2"></i> @Model.PhoneNumber</h5>
            </div>

            <form asp-action="Confirm" method="post">
                <input type="hidden" name="id" value="@Model.OrderId" />

                <div class="row g-4">
                    <div class="col-md-12">
                        <label class="form-label fw-bold text-dark fs-5"><i class="fa-regular fa-calendar-check text-primary me-2"></i> موعد الزيارة المتفق عليه <span class="text-danger">*</span></label>
                        <input type="datetime-local" name="scheduledDate" class="form-control form-control-lg bg-light border-secondary" required />
                    </div>

                    <div class="col-md-6">
                        <label class="form-label fw-bold text-dark fs-5"><i class="fa-solid fa-money-bill text-primary me-2"></i> تكلفة الفحص / السعر المبدئي <span class="text-danger">*</span></label>
                        <div class="input-group input-group-lg">
                            <input type="number" step="0.01" name="estimatedPrice" class="form-control bg-light border-secondary border-end-0" required />
                            <span class="input-group-text bg-white border-secondary border-start-0 fw-bold">ر.س</span>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label fw-bold text-dark fs-5"><i class="fa-solid fa-hand-holding-dollar text-primary me-2"></i> الدفعة المقدمة المطلوبة</label>
                        <div class="input-group input-group-lg">
                            <input type="number" step="0.01" name="advancePayment" class="form-control bg-light border-secondary border-end-0" value="0" />
                            <span class="input-group-text bg-white border-secondary border-start-0 fw-bold">ر.س</span>
                        </div>
                        <div class="form-text mt-1 text-muted fw-bold small">اكتب 0 إذا لم يكن هناك دفعة مقدمة</div>
                    </div>

                    <div class="col-12 mt-5 text-end">
                        <button type="submit" class="sys-btn sys-btn-primary py-3 px-5 fs-5 rounded-pill shadow-sm">
                            <i class="fa-solid fa-check-double me-2"></i> تأكيد وإصدار الفاتورة المبدئية
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>