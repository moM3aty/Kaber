@model KaberSystem.Models.Order
@{
    ViewData["Title"] = "تفاصيل الطلب #" + Model.OrderId;
    Layout = "~/Views/Shared/_SystemLayout.cshtml";

    string phone = Model.PhoneNumber.StartsWith("0") ? Model.PhoneNumber.Substring(1) : Model.PhoneNumber;
    string waNumber = "966" + phone;
    decimal partsTotal = Model.UsedSpareParts?.Sum(p => p.QuantityUsed * p.SellingPriceAtTime) ?? 0;
    decimal appliedFee = Model.IsFeeApplied ? Model.EstimatedPrice : 0;

    // جلب طلبات قطع الغيار النواقص من الـ ViewBag
    var partRequests = ViewBag.PartRequests as IEnumerable<KaberSystem.Models.OrderPartRequest>;
}

<div class="sys-page-header d-print-none">
    <div>
        <h1 class="sys-page-title">متابعة الطلب #@Model.OrderId</h1>
        <p class="sys-page-desc">إدارة تفاصيل الزيارة، الميزانية، والاعتماد النهائي</p>
    </div>
    <div class="d-flex gap-2">
        <a href="/Orders/Index" class="btn btn-outline-secondary fw-bold px-4 border-2 rounded-3">
            <i class="fa-solid fa-arrow-right"></i> عودة
        </a>
        <a href="/Orders/PrintInvoice/@Model.OrderId" target="_blank" class="sys-btn sys-btn-primary">
            <i class="fa-solid fa-file-invoice"></i> عرض الفاتورة
        </a>
    </div>
</div>

@if (Model.Status == KaberSystem.Models.OrderStatus.Completed && User.IsInRole("Admin"))
{
    <!-- 📌 تنبيه للإدارة بضرورة مراجعة الطلب -->
    <div class="alert alert-dark border-0 border-start border-4 border-warning shadow-sm mb-4 d-flex align-items-center">
        <i class="fa-solid fa-clipboard-check fs-2 text-warning me-3"></i>
        <div>
            <h5 class="fw-bold text-dark mb-1">الطلب بانتظار المراجعة والاعتماد!</h5>
            <p class="mb-0 text-muted fw-bold">قام الفني بإنهاء العمل. يرجى مراجعة قطع الغيار والرسوم، ثم تغيير الحالة إلى (معتمد نهائي) لترحيل الفاتورة، أو (إرجاع) للفني.</p>
        </div>
    </div>
}
else if (Model.Status == KaberSystem.Models.OrderStatus.Returned && User.IsInRole("Technician"))
{
    <div class="alert alert-danger border-0 border-start border-4 border-danger shadow-sm mb-4 d-flex align-items-center">
        <i class="fa-solid fa-rotate-left fs-2 text-danger me-3"></i>
        <div>
            <h5 class="fw-bold text-danger mb-1">تم إرجاع الطلب من قبل الإدارة!</h5>
            <p class="mb-0 text-dark fw-bold">الرجاء قراءة ملاحظات الإدارة بالأسفل، تعديل المطلوب، ثم إعادة تسليم الطلب (مكتمل).</p>
        </div>
    </div>
}

<div class="row g-4">
    <!-- بيانات العميل والمشكلة -->
    <div class="col-lg-8">
        <div class="sys-card h-100 printable-card">
            <div class="d-flex justify-content-between align-items-center border-bottom pb-3 mb-4 d-print-none">
                <h4 class="fw-bold text-primary m-0"><i class="fa-solid fa-user-tag me-2"></i> بيانات الطلب والعميل</h4>
                <span class="badge bg-light text-dark border fs-6">ORD-#@Model.OrderId</span>
            </div>

            <div class="row mb-3">
                <div class="col-md-4 text-muted fw-bold">اسم العميل:</div>
                <div class="col-md-8 fw-bold fs-5 text-dark">@Model.CustomerName</div>
            </div>
            <div class="row mb-3">
                <div class="col-md-4 text-muted fw-bold">رقم الهاتف:</div>
                <div class="col-md-8 fw-bold fs-5" dir="ltr" style="text-align: right;">
                    @Model.PhoneNumber
                    <a href="https://wa.me/@waNumber" target="_blank" class="text-success ms-2 d-print-none"><i class="fa-brands fa-whatsapp fs-4"></i></a>
                </div>
            </div>
            <div class="row mb-3">
                <div class="col-md-4 text-muted fw-bold">نوع الجهاز / الموديل:</div>
                <div class="col-md-8 fw-bold fs-5 text-primary">@Model.DeviceName</div>
            </div>
            <div class="row mb-3">
                <div class="col-md-4 text-muted fw-bold">العنوان:</div>
                <div class="col-md-8 fw-bold text-dark">@Model.Address</div>
            </div>

            <div class="p-4 bg-light rounded-4 border-start border-4 border-danger mb-4 mt-4">
                <h6 class="fw-bold text-danger mb-2">وصف المشكلة (الشكوى):</h6>
                <p class="mb-0 fw-bold text-dark fs-6 lh-lg">@Model.ProblemDescription</p>
            </div>

            @if (!string.IsNullOrEmpty(Model.TechnicianNotes))
            {
                <div class="p-4 bg-success bg-opacity-10 rounded-4 border-start border-4 border-success">
                    <h6 class="fw-bold text-success mb-2">التقرير الفني وملاحظات الإدارة:</h6>
                    <p class="mb-0 fw-bold text-dark fs-6 lh-lg">@Model.TechnicianNotes</p>
                </div>
            }
        </div>
    </div>

    <!-- التحكم بالحالة -->
    <div class="col-lg-4">
        <div class="sys-card h-100 d-print-none text-center">
            <h4 class="fw-bold mb-4 text-primary border-bottom pb-3"><i class="fa-solid fa-bars-progress me-2"></i> التحكم بالحالة والمراجعة</h4>

            <form asp-action="UpdateStatus" method="post" class="mb-4 bg-light p-3 rounded-3 border text-start">
                <input type="hidden" name="id" value="@Model.OrderId" />

                <div class="mb-3">
                    <label class="fw-bold mb-2 text-dark small">تحديث حالة الطلب:</label>
                    <select name="newStatus" class="form-select fw-bold border-secondary text-primary">
                        @if (User.IsInRole("Technician"))
                        {
                            <option value="InProgress" selected="@(Model.Status == KaberSystem.Models.OrderStatus.InProgress || Model.Status == KaberSystem.Models.OrderStatus.Returned)">قيد التنفيذ / تعديل الملاحظات</option>
                            <option value="Completed" selected="@(Model.Status == KaberSystem.Models.OrderStatus.Completed)">مكتمل (تسليم للإدارة)</option>
                        }
                        else
                        {
                            <!-- خيارات الإدارة والكول سنتر -->
                            <option value="InProgress" selected="@(Model.Status == KaberSystem.Models.OrderStatus.InProgress)">قيد التنفيذ</option>
                            <option value="Completed" selected="@(Model.Status == KaberSystem.Models.OrderStatus.Completed)">بانتظار المراجعة (من الفني)</option>
                            <option value="Approved" selected="@(Model.Status == KaberSystem.Models.OrderStatus.Approved)" class="text-success fw-bold">اعتماد نهائي (ترحيل الفاتورة)</option>
                            <option value="Returned" selected="@(Model.Status == KaberSystem.Models.OrderStatus.Returned)" class="text-danger fw-bold">إرجاع للفني لتصحيح الأخطاء</option>
                            <option value="Cancelled" selected="@(Model.Status == KaberSystem.Models.OrderStatus.Cancelled)">إلغاء الطلب</option>
                        }
                    </select>
                </div>

                <div class="mb-3">
                    <label class="fw-bold mb-2 text-dark small">تطبيق رسوم الفحص:</label>
                    <select name="isFeeApplied" class="form-select fw-bold border-secondary">
                        <option value="1" selected="@(Model.IsFeeApplied)">نعم (@Model.EstimatedPrice ريال)</option>
                        <option value="0" selected="@(!Model.IsFeeApplied)">لا (إعفاء ضريبي/ضمان)</option>
                    </select>
                </div>

                <div class="mb-3">
                    <label class="fw-bold mb-2 text-dark small">ملاحظات العمل / سبب الإرجاع:</label>
                    <textarea name="technicianNotes" class="form-control fw-bold border-secondary" rows="3" placeholder="اكتب الملاحظات هنا...">@Model.TechnicianNotes</textarea>
                </div>

                <button type="submit" class="btn btn-primary fw-bold w-100 py-2"><i class="fa-solid fa-save"></i> حفظ وتحديث المسار</button>
            </form>

            <h6 class="fw-bold text-muted mb-3">الفني المختص:</h6>
            @if (Model.Technician != null)
            {
                <div class="d-flex align-items-center p-3 border rounded-4 bg-white shadow-sm text-start">
                    <img src="https://ui-avatars.com/api/?name=@Uri.EscapeDataString(Model.Technician.Name)&background=f1950b&color=fff" class="rounded-circle me-3 border border-2 border-primary" width="50">
                    <div>
                        <h6 class="fw-bold mb-1 text-dark">@Model.Technician.Name</h6>
                        <span class="text-muted small fw-bold" dir="ltr">@Model.Technician.Phone</span>
                    </div>
                </div>
            }
        </div>
    </div>

    <!-- 📌 القسم الذي كان ناقصاً: طلبات توفير قطع الغيار (النواقص والدورة المستندية) -->
    <div class="col-12 d-print-none">
        <div class="sys-card bg-primary bg-opacity-10 border border-primary">
            <div class="d-flex justify-content-between align-items-center mb-4 border-bottom border-primary pb-3">
                <h4 class="fw-bold text-primary m-0"><i class="fa-solid fa-boxes-packing me-2"></i> طلبات توفير قطع الغيار (Workflow)</h4>

                @if ((Model.Status != KaberSystem.Models.OrderStatus.Completed && Model.Status != KaberSystem.Models.OrderStatus.Approved) || User.IsInRole("Admin"))
                {
                    <div class="d-flex gap-2">
                        <button class="btn btn-primary fw-bold" data-bs-toggle="modal" data-bs-target="#requestWarehouseModal">
                            <i class="fa-solid fa-warehouse"></i> طلب حجز من المخزن
                        </button>
                        <button class="btn btn-dark fw-bold" data-bs-toggle="modal" data-bs-target="#requestPurchaseModal">
                            <i class="fa-solid fa-cart-plus"></i> طلب شراء (غير متوفرة)
                        </button>
                    </div>
                }
            </div>

            @if (partRequests != null && partRequests.Any())
            {
                <div class="table-responsive bg-white rounded-3 shadow-sm">
                    <table class="table table-bordered text-center align-middle mb-0">
                        <thead class="table-light text-muted">
                            <tr>
                                <th>نوع الطلب / التصنيف</th>
                                <th>اسم القطعة والكود</th>
                                <th>الموديل المتوافق</th>
                                <th>الكمية</th>
                                <th>الحالة والمتابعة</th>
                                <th>تاريخ الطلب</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var req in partRequests)
                            {
                                <tr>
                                    <td>
                                        @if (req.RequestType == KaberSystem.Models.PartRequestType.FromWarehouse)
                                        {
                                            <span class="badge bg-primary px-2">حجز مخزن</span>
                                        }
                                        else
                                        {

                                            <span class="badge bg-dark px-2">طلب شراء</span>
                                        }
                                        <div class="small fw-bold mt-1 @(req.IsCommonRequest || (req.SparePart?.IsCommon ?? false) ? "text-info" : "text-secondary")">
                                            @(req.IsCommonRequest || (req.SparePart?.IsCommon ?? false) ? "(Common)" : "(Specific)")
                                        </div>
                                    </td>
                                    <td class="fw-bold text-dark text-start">
                                        @(req.RequestType == KaberSystem.Models.PartRequestType.FromWarehouse ? req.SparePart?.Name : req.NewPartName)
                                        <div class="text-muted small">Code: @(req.SparePart?.PartCode ?? "Pending...")</div>
                                    </td>
                                    <td class="text-primary fw-bold">@(req.SparePart?.TargetModel ?? req.DeviceModel ?? "عام لجميع الموديلات")</td>
                                    <td class="fw-bold fs-5">@req.Quantity</td>
                                    <td>
                                        @switch (req.Status)
                                        {
                                            case KaberSystem.Models.PartRequestStatus.PendingWarehouse:
                                                <span class="badge bg-warning text-dark"><i class="fa-solid fa-clock"></i> بانتظار المخزن</span>
                                                break;
                                            case KaberSystem.Models.PartRequestStatus.PendingPurchasing:

                                                <span class="badge bg-warning text-dark"><i class="fa-solid fa-clock"></i> بانتظار الشراء</span>
                                                break;
                                            case KaberSystem.Models.PartRequestStatus.ReadyForInstallation:

                                                <span class="badge bg-success fs-6"><i class="fa-solid fa-phone-volume"></i> جاهزة (تواصل مع العميل)</span>
                                                break;
                                        }
                                    </td>
                                    <td dir="ltr" class="text-muted fw-bold small">@req.RequestDate.ToString("MM/dd HH:mm")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="text-center py-4 text-muted fw-bold">لا توجد طلبات نواقص معلقة لهذا الموعد.</div>
            }
        </div>
    </div>

    <!-- الفواتير وقطع الغيار المركبة -->
    <div class="col-12">
        <div class="sys-card printable-card">
            <h4 class="fw-bold mb-4 text-primary border-bottom pb-3 d-print-none"><i class="fa-solid fa-file-invoice-dollar me-2"></i> التسعير وقطع الغيار المُرَكّبة</h4>
            <div class="row g-4 print-row-stack">
                <div class="col-md-8 print-col-full">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h6 class="fw-bold text-dark m-0">قطع الغيار المستخدمة (من عهدة الفني)</h6>

                        <!-- 📌 زر الإضافة يختفي إذا كان الطلب بانتظار المراجعة أو معتمد (إلا للإدارة) -->
                        @if ((Model.Status != KaberSystem.Models.OrderStatus.Completed && Model.Status != KaberSystem.Models.OrderStatus.Approved) || User.IsInRole("Admin"))
                        {
                            <button type="button" class="btn btn-sm btn-outline-primary fw-bold d-print-none" data-bs-toggle="modal" data-bs-target="#addPartModal">
                                <i class="fa-solid fa-plus"></i> تركيب من العهدة
                            </button>
                        }
                    </div>

                    @if (Model.UsedSpareParts != null && Model.UsedSpareParts.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-bordered text-center align-middle bg-white print-table">
                                <thead class="table-light text-muted">
                                    <tr>
                                        <th>كود الصنف</th>
                                        <th>اسم القطعة</th>
                                        <th>الكمية</th>
                                        <th>الإجمالي (+15%)</th>
                                        <th class="d-print-none">إجراء</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var part in Model.UsedSpareParts)
                                    {
                                        <tr>
                                            <td><span class="badge bg-dark">@part.SparePart.PartCode</span></td>
                                            <td class="fw-bold text-dark text-start">@part.SparePart.Name</td>
                                            <td class="fw-bold">@part.QuantityUsed</td>
                                            <td class="fw-bold text-success">@((part.QuantityUsed * part.SellingPriceAtTime).ToString("N2")) ريال</td>
                                            <td class="d-print-none">
                                                <div class="d-flex gap-1 justify-content-center">
                                                    <button type="button" class="btn btn-sm btn-light border fw-bold px-2" onclick="printPartLabel('@part.SparePart.PartCode', '@part.SparePart.Name')"><i class="fa-solid fa-barcode text-dark"></i></button>

                                                    @if ((Model.Status != KaberSystem.Models.OrderStatus.Completed && Model.Status != KaberSystem.Models.OrderStatus.Approved) || User.IsInRole("Admin"))
                                                    {
                                                        <form asp-action="RemoveUsedPart" method="post">
                                                            <input type="hidden" name="orderId" value="@Model.OrderId" /><input type="hidden" name="recordId" value="@part.Id" />
                                                            <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('تأكيد الحذف؟')"><i class="fa-solid fa-trash"></i></button>
                                                        </form>
                                                    }
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>

                <div class="col-md-4 print-col-full">
                    <h6 class="fw-bold text-dark mb-3 d-print-none">الملخص المالي النهائي</h6>
                    <div class="p-4 border rounded-4 bg-light shadow-sm print-no-bg">
                        <div class="d-flex justify-content-between mb-3 border-bottom pb-3"><span class="fw-bold text-muted">رسوم الفحص:</span><span class="fw-bold text-dark fs-5">@appliedFee.ToString("N2") ريال</span></div>
                        <div class="d-flex justify-content-between mb-3 border-bottom pb-3"><span class="fw-bold text-muted">قطع الغيار:</span><span class="fw-bold text-dark fs-5">@partsTotal.ToString("N2") ريال</span></div>
                        <div class="d-flex justify-content-between align-items-center mt-4"><span class="fw-bold text-dark fs-4">المستحق:</span><span class="fw-bold text-success fs-3 border border-success px-3 py-1 rounded-3">@Model.FinalPrice.ToString("N2") ريال</span></div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- 📌 Modal: طلب حجز من المخزن الرئيسي -->
<div class="modal fade" id="requestWarehouseModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 rounded-4 shadow-lg">
            <div class="modal-header border-bottom-0 pb-0">
                <h5 class="modal-title fw-bold text-primary"><i class="fa-solid fa-warehouse me-2"></i> طلب حجز قطعة من المخزن</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-action="RequestFromWarehouse" method="post">
                <div class="modal-body py-4 text-start">
                    <input type="hidden" name="orderId" value="@Model.OrderId" />
                    <div class="alert alert-primary py-2 small fw-bold">سيتم إخطار أمين المخزن بحجز القطعة فوراً.</div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">اختر القطعة المطلوبة <span class="text-danger">*</span></label>
                        <select name="partId" class="form-select fw-bold bg-light" required>
                            <option value="">-- اختر من مخزن المؤسسة --</option>
                            @if (ViewData["AvailableParts"] != null)
                            {
                                foreach (var p in (IEnumerable<KaberSystem.Models.SparePart>)ViewData["AvailableParts"])
                                {
                                    <option value="@p.PartId">@p.Name [@(p.IsCommon ? "عامة" : p.TargetModel)] (المتاح: @p.MainStockQuantity)</option>
                                }
                            }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">الكمية</label>
                        <input type="number" name="quantity" class="form-control fw-bold" min="1" value="1" required />
                    </div>
                </div>
                <div class="modal-footer border-top-0 pt-0">
                    <button type="button" class="btn btn-light fw-bold px-4" data-bs-dismiss="modal">إلغاء</button>
                    <button type="submit" class="btn btn-primary fw-bold px-4">إرسال الطلب</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- 📌 Modal: طلب شراء خارجي وتكويد جديد -->
<div class="modal fade" id="requestPurchaseModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 rounded-4 shadow-lg">
            <div class="modal-header border-bottom-0 pb-0">
                <h5 class="modal-title fw-bold text-dark"><i class="fa-solid fa-cart-plus text-warning me-2"></i> طلب شراء صنف وتكويده</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-action="RequestPurchase" method="post" enctype="multipart/form-data">
                <div class="modal-body py-4 text-start">
                    <input type="hidden" name="orderId" value="@Model.OrderId" />
                    <div class="mb-3">
                        <label class="form-label fw-bold">اسم القطعة المطلوبة <span class="text-danger">*</span></label>
                        <input type="text" name="partName" class="form-control fw-bold bg-light" placeholder="مثال: كومبريسور كاريير 3 حصان" required />
                    </div>
                    <div class="bg-light p-3 rounded-3 border mb-3">
                        <label class="fw-bold text-primary mb-2">تصنيف التكويد:</label>
                        <div class="form-check mb-2">
                            <input class="form-check-input" type="radio" name="isCommon" id="cmYes" value="true" checked onclick="toggleMdInput(true)">
                            <label class="form-check-label fw-bold" for="cmYes">صنف مشترك (Common)</label>
                        </div>
                        <div class="form-check">
                            <input class="form-check-input" type="radio" name="isCommon" id="cmNo" value="false" onclick="toggleMdInput(false)">
                            <label class="form-check-label fw-bold" for="cmNo">صنف لموديل محدد (Specific)</label>
                        </div>
                    </div>
                    <div id="mdGroup" class="mb-3 d-none">
                        <label class="form-label fw-bold">رقم الموديل / الجهاز</label>
                        <input type="text" name="deviceModel" class="form-control fw-bold border-primary" placeholder="رقم الموديل لربط القطعة" />
                    </div>
                    <div class="row">
                        <div class="col-6 mb-3">
                            <label class="form-label fw-bold">الكمية</label>
                            <input type="number" name="quantity" class="form-control fw-bold" min="1" value="1" required />
                        </div>
                        <div class="col-6 mb-3">
                            <label class="form-label fw-bold">صورة المرفق (اختياري)</label>
                            <input type="file" name="partImage" class="form-control" accept="image/*" />
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-top-0 pt-0">
                    <button type="button" class="btn btn-light fw-bold px-4" data-bs-dismiss="modal">إلغاء</button>
                    <button type="submit" class="btn btn-dark fw-bold px-4">إرسال للمشتريات</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Modal إضافة قطعة غيار من العهدة -->
<div class="modal fade d-print-none" id="addPartModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 rounded-4 shadow-lg">
            <div class="modal-header border-bottom-0 pb-0">
                <h5 class="modal-title fw-bold text-primary"><i class="fa-solid fa-plus-circle me-2"></i> تركيب قطعة من عهدتك</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-action="AddUsedPart" method="post">
                <div class="modal-body py-4 text-start">
                    <input type="hidden" name="orderId" value="@Model.OrderId" />
                    <div class="mb-3">
                        <label class="form-label fw-bold">اختر القطعة من عهدتك <span class="text-danger">*</span></label>
                        <select name="partId" class="form-select fw-bold bg-light" required>
                            <option value="">-- اختر صنفاً --</option>
                            @if (ViewData["AvailableParts"] != null)
                            {
                                foreach (var p in (IEnumerable<KaberSystem.Models.SparePart>)ViewData["AvailableParts"])
                                {
                                    <option value="@p.PartId">@p.Name [Code: @p.PartCode] (السعر: @p.SellingPrice)</option>
                                }
                            }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">الكمية</label>
                        <input type="number" name="quantity" class="form-control fw-bold" min="1" value="1" required />
                    </div>
                </div>
                <div class="modal-footer border-top-0 pt-0">
                    <button type="button" class="btn btn-light fw-bold px-4" data-bs-dismiss="modal">إلغاء</button>
                    <button type="submit" class="btn btn-primary fw-bold px-4">تأكيد التركيب</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/jsbarcode@3.11.5/dist/JsBarcode.all.min.js"></script>
    <script>
        function toggleMdInput(isCommon) {
            var g = document.getElementById('mdGroup');
            if(isCommon) g.classList.add('d-none'); else g.classList.remove('d-none');
        }

        function printPartLabel(code, name) {
            var printFrame = document.createElement('iframe');
            printFrame.style.display = 'none';
            document.body.appendChild(printFrame);
            var doc = printFrame.contentWindow.document;
            var styleAt = String.fromCharCode(64);
            doc.write('<html><head><style>' + styleAt + 'page { size: 50mm 25mm; margin:0; } body { font-family: Cairo; text-align:center; padding:2px; } .title { font-size:10px; font-weight:bold; margin-bottom:2px; overflow:hidden; white-space:nowrap; } svg { width:100%; height:auto; }</style></head><body>');
            doc.write('<div class="title">' + name + '</div><svg id="bc"></svg>');
            doc.write('<script src="https://cdn.jsdelivr.net/npm/jsbarcode@@3.11.5/dist/JsBarcode.all.min.js"><\/script>');
            doc.write('<script>window.onload = function() { JsBarcode("#bc", "' + code + '", { height:30, fontSize:12, margin:0 }); window.print(); setTimeout(function(){ window.close(); }, 500); }<\/script></body></html>');
            doc.close();
            setTimeout(function() { document.body.removeChild(printFrame); }, 3000);
        }

        @if (TempData["SuccessMessage"] != null)
        {
                <text>Swal.fire({ icon: 'success', title: 'تم التحديث', text: '@Html.Raw(TempData["SuccessMessage"])', confirmButtonText: 'حسناً', confirmButtonColor: '#f1950b' });</text>
        }
        @if (TempData["ErrorMessage"] != null)
        {
                <text>Swal.fire({ icon: 'error', title: 'تنبيه', text: '@Html.Raw(TempData["ErrorMessage"])', confirmButtonColor: '#ee5d50' });</text>
        }
    </script>
}

