@model KaberSystem.Models.Order
@{
    ViewData["Title"] = "تفاصيل الطلب #" + Model.OrderId;
    Layout = "~/Views/Shared/_SystemLayout.cshtml";

    // تجهيز رسالة الواتساب المنسقة
    string phone = Model.PhoneNumber.StartsWith("0") ? Model.PhoneNumber.Substring(1) : Model.PhoneNumber;
    string waNumber = "966" + phone;
    decimal partsTotal = Model.UsedSpareParts?.Sum(p => p.QuantityUsed * p.SellingPriceAtTime) ?? 0;

    string waMessage = $"مرحباً *{Model.CustomerName}*،\n\n" +
                       $"إليك تفاصيل فاتورة الصيانة الخاصة بك من *(شركة كابر)*:\n" +
                       $"▫️ *رقم الطلب:* #{Model.OrderId}\n" +
                       $"▫️ *تكلفة الفحص / أجور اليد:* {Model.EstimatedPrice} ريال\n" +
                       $"▫️ *إجمالي قطع الغيار:* {partsTotal} ريال\n";

    if (Model.AdvancePayment > 0)
    {
        waMessage += $"▫️ *الدفعة المقدمة:* -{Model.AdvancePayment} ريال\n";
    }

    waMessage += $"\n💰 *المبلغ النهائي المستحق:* {Model.FinalPrice} ريال\n\n" +
                 $"شكراً لثقتكم بخدماتنا! 🛠️";

    string encodedMessage = Uri.EscapeDataString(waMessage);
}

<div class="sys-page-header d-print-none">
    <div>
        <h1 class="sys-page-title">متابعة الطلب #@Model.OrderId</h1>
        <p class="sys-page-desc">مراجعة وتحديث بيانات العميل، الفني المختص، وإدارة الفواتير وقطع الغيار</p>
    </div>
    <div class="d-flex gap-2">
        <a href="/Orders/Index" class="btn btn-outline-secondary fw-bold px-4 border-2 rounded-3">
            <i class="fa-solid fa-arrow-right"></i> عودة
        </a>
        <a href="/Orders/PrintInvoice/@Model.OrderId" target="_blank" class="sys-btn sys-btn-primary">
            <i class="fa-solid fa-file-invoice"></i> عرض الفاتورة للعميل
        </a>
    </div>
</div>

<!-- Timeline لحالة الطلب -->
<div class="sys-card mb-4 d-print-none text-center py-4">
    <h5 class="fw-bold mb-4 text-secondary">مسار وتتبع الطلب</h5>
    <div class="d-flex justify-content-between align-items-center position-relative w-75 mx-auto">
        <!-- الخط الخلفي -->
        <div class="position-absolute w-100" style="height: 4px; background: var(--sys-border); top: 50%; transform: translateY(-50%); z-index: 1;"></div>
        <!-- الخط الملون بناءً على الحالة -->
        @{
            int progress = Model.Status switch { KaberSystem.Models.OrderStatus.New => 0, KaberSystem.Models.OrderStatus.Assigned => 25, KaberSystem.Models.OrderStatus.Confirmed => 50, KaberSystem.Models.OrderStatus.InProgress => 75, KaberSystem.Models.OrderStatus.Completed => 100, _ => 0 };
        }
        <div class="position-absolute" style="height: 4px; background: var(--sys-primary); top: 50%; transform: translateY(-50%); z-index: 2; width: @progress%; transition: 1s ease;"></div>

        <!-- النقاط -->
        <div class="position-relative z-3 bg-white rounded-circle p-1 @(progress >= 0 ? "text-primary" : "text-muted")">
            <i class="fa-solid fa-circle-dot fs-3"></i>
            <div class="position-absolute top-100 start-50 translate-middle-x mt-2 fw-bold small">جديد</div>
        </div>
        <div class="position-relative z-3 bg-white rounded-circle p-1 @(progress >= 25 ? "text-primary" : "text-muted")">
            <i class="fa-solid fa-circle-dot fs-3"></i>
            <div class="position-absolute top-100 start-50 translate-middle-x mt-2 fw-bold small">معين</div>
        </div>
        <div class="position-relative z-3 bg-white rounded-circle p-1 @(progress >= 50 ? "text-primary" : "text-muted")">
            <i class="fa-solid fa-circle-dot fs-3"></i>
            <div class="position-absolute top-100 start-50 translate-middle-x mt-2 fw-bold small">مؤكد</div>
        </div>
        <div class="position-relative z-3 bg-white rounded-circle p-1 @(progress >= 75 ? "text-primary" : "text-muted")">
            <i class="fa-solid fa-circle-dot fs-3"></i>
            <div class="position-absolute top-100 start-50 translate-middle-x mt-2 fw-bold small">قيد التنفيذ</div>
        </div>
        <div class="position-relative z-3 bg-white rounded-circle p-1 @(progress >= 100 ? "text-success" : "text-muted")">
            <i class="fa-solid fa-circle-check fs-3"></i>
            <div class="position-absolute top-100 start-50 translate-middle-x mt-2 fw-bold small">مكتمل</div>
        </div>
    </div>
</div>

<div class="row g-4">
    <!-- بيانات العميل والمشكلة -->
    <div class="col-lg-8">
        <div class="sys-card h-100 printable-card">

            <!-- ترويسة الطباعة (تظهر فقط عند الطباعة) -->
            <div class="d-none d-print-block text-center border-bottom pb-4 mb-4">
                <h2 class="fw-bold text-dark mb-1"><i class="fa-solid fa-bolt text-primary me-2"></i> شركة كابر للصيانة</h2>
                <h4 class="text-muted fw-bold mb-3">فاتورة صيانة وقطع غيار</h4>
                <div class="d-flex justify-content-between align-items-center mt-3 px-3">
                    <p class="m-0 fw-bold fs-5">تاريخ الإصدار: @DateTime.Now.ToString("yyyy-MM-dd")</p>
                    <p class="m-0 fw-bold fs-5">رقم الفاتورة: #@Model.OrderId</p>
                </div>
            </div>

            <div class="d-flex justify-content-between align-items-center border-bottom pb-3 mb-4 d-print-none">
                <h4 class="fw-bold text-primary m-0"><i class="fa-solid fa-user-tag me-2"></i> بيانات الطلب والعميل</h4>
                <span class="badge bg-light text-dark border fs-6">ORD-#@Model.OrderId</span>
            </div>

            <div class="row mb-3">
                <div class="col-md-4 text-muted fw-bold"><i class="fa-regular fa-user me-1"></i> اسم العميل:</div>
                <div class="col-md-8 fw-bold fs-5 text-dark">@Model.CustomerName</div>
            </div>
            <div class="row mb-3">
                <div class="col-md-4 text-muted fw-bold"><i class="fa-solid fa-phone me-1"></i> رقم الهاتف:</div>
                <div class="col-md-8 fw-bold fs-5" dir="ltr" style="text-align: right;">
                    @Model.PhoneNumber
                    <a href="https://wa.me/@waNumber" target="_blank" class="text-success ms-2 d-print-none"><i class="fa-brands fa-whatsapp fs-4"></i></a>
                </div>
            </div>
            <div class="row mb-3">
                <div class="col-md-4 text-muted fw-bold"><i class="fa-solid fa-location-dot me-1"></i> العنوان:</div>
                <div class="col-md-8 fw-bold text-dark">@Model.Address</div>
            </div>
            @if (!string.IsNullOrEmpty(Model.LocationMapUrl))
            {
                <div class="row mb-3 d-print-none">
                    <div class="col-md-4 text-muted fw-bold"><i class="fa-solid fa-map me-1"></i> الموقع (GPS):</div>
                    <div class="col-md-8">
                        <a href="@Model.LocationMapUrl" target="_blank" class="btn btn-sm btn-outline-primary fw-bold rounded-3"><i class="fa-solid fa-map-location-dot"></i> فتح الخريطة عبر جوجل</a>
                    </div>
                </div>
            }
            <div class="row mb-4 d-print-none">
                <div class="col-md-4 text-muted fw-bold"><i class="fa-regular fa-clock me-1"></i> تاريخ ووقت الطلب:</div>
                <div class="col-md-8 fw-bold text-dark">@Model.CreatedAt.ToString("yyyy-MM-dd hh:mm tt")</div>
            </div>

            <div class="p-4 bg-light rounded-4 border-start border-4 border-danger print-no-border">
                <h6 class="fw-bold text-danger mb-2"><i class="fa-solid fa-triangle-exclamation"></i> وصف المشكلة (الشكوى):</h6>
                <p class="mb-0 fw-bold text-dark fs-6 lh-lg">@Model.ProblemDescription</p>
            </div>
        </div>
    </div>

    <!-- حالة الطلب والفني -->
    <div class="col-lg-4">
        <div class="sys-card h-100 d-print-none">
            <h4 class="fw-bold mb-4 text-primary border-bottom pb-3"><i class="fa-solid fa-bars-progress me-2"></i> التحكم بالحالة</h4>

            <form asp-action="UpdateStatus" method="post" class="mb-4 bg-light p-3 rounded-3 border">
                <input type="hidden" name="id" value="@Model.OrderId" />
                <label class="fw-bold mb-2 text-dark small">تحديث حالة الطلب يدوياً:</label>
                <div class="d-flex gap-2">
                    <select name="newStatus" class="form-select fw-bold border-secondary">
                        <option value="New" selected="@(Model.Status == KaberSystem.Models.OrderStatus.New)">جديد</option>
                        <option value="Assigned" selected="@(Model.Status == KaberSystem.Models.OrderStatus.Assigned)">تم التعيين</option>
                        <option value="Confirmed" selected="@(Model.Status == KaberSystem.Models.OrderStatus.Confirmed)">مؤكد</option>
                        <option value="InProgress" selected="@(Model.Status == KaberSystem.Models.OrderStatus.InProgress)">قيد التنفيذ</option>
                        <option value="Completed" selected="@(Model.Status == KaberSystem.Models.OrderStatus.Completed)">مكتمل</option>
                        <option value="Cancelled" selected="@(Model.Status == KaberSystem.Models.OrderStatus.Cancelled)">ملغي</option>
                    </select>
                    <button type="submit" class="btn btn-primary fw-bold"><i class="fa-solid fa-save"></i> تحديث</button>
                </div>
            </form>

            <h6 class="fw-bold text-muted mb-3 mt-4">الفني المختص (المنفذ):</h6>
            @if (Model.Technician != null)
            {
                <div class="d-flex align-items-center p-3 border rounded-4 bg-white shadow-sm">
                    <img src="https://ui-avatars.com/api/?name=@Uri.EscapeDataString(Model.Technician.Name)&background=f1950b&color=fff" class="rounded-circle me-3 border border-2 border-primary" width="55" height="55">
                    <div>
                        <h6 class="fw-bold mb-1 text-dark fs-5">@Model.Technician.Name</h6>
                        <span class="text-muted fw-bold" dir="ltr"><i class="fa-solid fa-phone small text-primary"></i> @Model.Technician.Phone</span>
                    </div>
                </div>
            }
            else
            {
                <div class="alert alert-warning text-center fw-bold rounded-4 border-warning">
                    <i class="fa-solid fa-user-clock fs-1 mb-2 text-warning opacity-75 d-block"></i>
                    لم يتم تعيين فني للصيانة بعد!
                    <a href="/Orders/Assign/@Model.OrderId" class="btn btn-dark d-block mt-3 fw-bold rounded-pill">تعيين فني الآن <i class="fa-solid fa-arrow-left"></i></a>
                </div>
            }
        </div>
    </div>

    <!-- الفواتير وقطع الغيار -->
    <div class="col-12">
        <div class="sys-card printable-card">
            <h4 class="fw-bold mb-4 text-primary border-bottom pb-3 d-print-none"><i class="fa-solid fa-file-invoice-dollar me-2"></i> التسعير وقطع الغيار المصروفة</h4>
            <h4 class="fw-bold mb-4 text-dark border-bottom pb-3 d-none d-print-block">تفاصيل الفاتورة</h4>

            <div class="row g-4 print-row-stack">
                <div class="col-md-7 print-col-full">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h6 class="fw-bold text-dark m-0"><i class="fa-solid fa-boxes-stacked text-primary d-print-none"></i> قطع الغيار المستخدمة في هذا الطلب</h6>
                        @if (Model.Status == KaberSystem.Models.OrderStatus.InProgress || Model.Status == KaberSystem.Models.OrderStatus.Assigned)
                        {
                            <button type="button" class="btn btn-sm btn-outline-primary fw-bold d-print-none" data-bs-toggle="modal" data-bs-target="#addPartModal">
                                <i class="fa-solid fa-plus"></i> إضافة قطعة (خصم من العهدة)
                            </button>
                        }
                    </div>

                    @if (Model.UsedSpareParts != null && Model.UsedSpareParts.Any())
                    {
                        <table class="table table-bordered text-center align-middle bg-white print-table">
                            <thead class="table-light text-muted">
                                <tr>
                                    <th>اسم القطعة</th>
                                    <th>الكمية</th>
                                    <th>سعر الوحدة</th>
                                    <th>الإجمالي</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var part in Model.UsedSpareParts)
                                {
                                    <tr>
                                        <td class="fw-bold text-dark text-start">@part.SparePart.Name</td>
                                        <td class="fw-bold">@part.QuantityUsed</td>
                                        <td class="fw-bold text-muted">@part.SellingPriceAtTime ريال</td>
                                        <td class="fw-bold text-success">@(part.QuantityUsed* part.SellingPriceAtTime) ريال</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                    else
                    {
                        <div class="p-4 bg-light border rounded-3 text-center text-muted fw-bold print-no-bg">
                            لم يتم استخدام أي قطع غيار في هذه الصيانة.
                        </div>
                    }
                </div>

                <div class="col-md-5 print-col-full">
                    <h6 class="fw-bold text-dark mb-3"><i class="fa-solid fa-receipt text-primary d-print-none"></i> الملخص المالي</h6>
                    <div class="p-4 border rounded-4 bg-light shadow-sm print-no-bg">
                        <div class="d-flex justify-content-between mb-3 border-bottom pb-3">
                            <span class="fw-bold text-muted">تكلفة الفحص / أجور اليد:</span>
                            <span class="fw-bold text-dark fs-5">@Model.EstimatedPrice ريال</span>
                        </div>
                        <div class="d-flex justify-content-between mb-3 border-bottom pb-3">
                            <span class="fw-bold text-muted">إجمالي قطع الغيار:</span>
                            <span class="fw-bold text-dark fs-5">@partsTotal ريال</span>
                        </div>
                        @if (Model.AdvancePayment > 0)
                        {
                            <div class="d-flex justify-content-between mb-3 border-bottom pb-3">
                                <span class="fw-bold text-muted">الدفعة المقدمة:</span>
                                <span class="fw-bold text-danger fs-5">- @Model.AdvancePayment ريال</span>
                            </div>
                        }
                        <div class="d-flex justify-content-between align-items-center mt-4">
                            <span class="fw-bold text-dark fs-4">المبلغ المستحق:</span>
                            <span class="fw-bold text-success fs-3 border border-success px-3 py-1 rounded-3">@Model.FinalPrice ريال</span>
                        </div>

                        <!-- زر الواتساب المنسق -->
                        <div class="text-center mt-4 pt-3 d-print-none">
                            <a href="https://wa.me/@waNumber?text=@encodedMessage" target="_blank" class="btn btn-success fw-bold w-100 py-3 rounded-pill fs-5 shadow-sm hover-elevate text-white">
                                <i class="fa-brands fa-whatsapp fs-4 me-1"></i> إرسال الفاتورة للعميل
                            </a>
                        </div>
                    </div>
                </div>
            </div>

            <!-- تذييل الطباعة -->
            <div class="d-none d-print-block mt-5 pt-4 border-top text-center">
                <p class="fw-bold fs-5 text-dark mb-1">شكراً لثقتكم بخدمات شركة كابر للصيانة.</p>
                <p class="text-muted fw-bold">لأي استفسار يرجى التواصل معنا على الرقم: 0541683466</p>
            </div>

        </div>
    </div>
</div>

<!-- Modal إضافة قطعة غيار -->
<div class="modal fade d-print-none" id="addPartModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 rounded-4 shadow-lg">
            <div class="modal-header border-bottom-0 pb-0">
                <h5 class="modal-title fw-bold text-primary"><i class="fa-solid fa-plus-circle me-2"></i> استهلاك قطعة غيار من العهدة</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-action="AddUsedPart" method="post">
                <div class="modal-body py-4">
                    <input type="hidden" name="orderId" value="@Model.OrderId" />

                    <div class="mb-3">
                        <label class="form-label fw-bold text-dark">اختر القطعة <span class="text-danger">*</span></label>
                        <select name="partId" class="form-select form-select-lg fw-bold bg-light border-0" required>
                            <option value="">-- اضغط للاختيار --</option>
                            @if (ViewData["AvailableParts"] != null)
                            {
                                foreach (var part in (IEnumerable<KaberSystem.Models.SparePart>)ViewData["AvailableParts"])
                                {
                                    <option value="@part.PartId">@part.Name (السعر: @part.SellingPrice ريال)</option>
                                }
                            }
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold text-dark">الكمية المستخدمة <span class="text-danger">*</span></label>
                        <input type="number" name="quantity" class="form-control form-control-lg fw-bold bg-light border-0" min="1" value="1" required />
                        <small class="text-danger fw-bold mt-1 d-block"><i class="fa-solid fa-circle-info"></i> سيتم خصم هذه الكمية من عهدة الفني تلقائياً.</small>
                    </div>
                </div>
                <div class="modal-footer border-top-0 pt-0">
                    <button type="button" class="btn btn-light fw-bold px-4" data-bs-dismiss="modal">إلغاء</button>
                    <button type="submit" class="btn btn-primary fw-bold px-4">تأكيد الإضافة</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @if (TempData["SuccessMessage"] != null)
    {
        <script>
            Swal.fire({ icon: 'success', title: 'تم التحديث', text: '@Html.Raw(TempData["SuccessMessage"])', confirmButtonText: 'حسناً', confirmButtonColor: '#f1950b' });
        </script>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <script>
            Swal.fire({ icon: 'error', title: 'خطأ', text: '@Html.Raw(TempData["ErrorMessage"])', confirmButtonText: 'إغلاق', confirmButtonColor: '#ee5d50' });
        </script>
    }
}

<style>
    .hover-elevate {
        transition: transform 0.3s;
    }

        .hover-elevate:hover {
            transform: translateY(-3px);
        }

    /* تنسيقات الطباعة الاحترافية للفاتورة */
    @@media print {
        body

    {
        background: white !important;
        margin: 0 !important;
        padding: 0 !important;
    }

    .sys-sidebar, .sys-header, .d-print-none, #backToTop, .whatsapp-btn {
        display: none !important;
    }

    .sys-main {
        margin: 0 !important;
        padding: 15px !important;
        width: 100% !important;
    }

    .sys-content {
        padding: 0 !important;
    }

    .printable-card {
        box-shadow: none !important;
        border: 2px solid #000 !important;
        border-radius: 10px !important;
        padding: 30px !important;
        break-inside: avoid;
        width: 100%;
    }

    .print-no-border {
        border: none !important;
        border-right: 4px solid #000 !important; /* للغة العربية الاتجاه يمين */
    }

    .print-no-bg {
        background-color: transparent !important;
    }

    .print-row-stack {
        display: flex !important;
        flex-direction: column !important;
    }

    .print-col-full {
        width: 100% !important;
        flex: 0 0 100% !important;
        max-width: 100% !important;
        margin-bottom: 20px;
    }

    .print-table th, .print-table td {
        border: 1px solid #000 !important;
        color: #000 !important;
    }

    * {
        color: #000 !important;
        -webkit-print-color-adjust: exact !important;
        print-color-adjust: exact !important;
    }

    .text-success, .text-danger, .text-primary {
        color: #000 !important;
    }

    .badge {
        border: 1px solid #000 !important;
        color: #000 !important;
    }

    }
</style>