<!-- مسار الملف: Views/Orders/Details.cshtml -->
@model KaberSystem.Models.Order
@{
    ViewData["Title"] = "تفاصيل الطلب #" + Model.OrderId;
    Layout = "~/Views/Shared/_SystemLayout.cshtml";

    string phone = Model.PhoneNumber.StartsWith("0") ? Model.PhoneNumber.Substring(1) : Model.PhoneNumber;
    string waNumber = "966" + phone;

    // 📌 الحسابات المالية الدقيقة (وفقاً للقاعدة المحاسبية الجديدة)
    decimal partsTotal = Model.UsedSpareParts?.Sum(p => p.QuantityUsed * p.SellingPriceAtTime) ?? 0;
    decimal appliedLaborFee = Model.IsFeeApplied ? Model.EstimatedPrice : 0; 

    // FinalPrice من قاعدة البيانات الآن يمثل (إجمالي الفاتورة الكامل) 
    // المبلغ المتبقي لتحصيله = الإجمالي - المقدم
    decimal remainingToPay = Model.FinalPrice - Model.AdvancePayment;
    if (remainingToPay < 0) remainingToPay = 0;

    var partRequests = ViewBag.PartRequests as IEnumerable<KaberSystem.Models.OrderPartRequest>;
}

<div class="sys-page-header d-print-none">
    <div>
        <h1 class="sys-page-title">متابعة الطلب #@Model.OrderId</h1>
        <p class="sys-page-desc">إدارة تفاصيل الزيارة، الميزانية، والاعتماد النهائي للطلب</p>
    </div>
    <div class="d-flex gap-2">
        <a href="/Orders/Index" class="btn btn-outline-secondary fw-bold px-4 border-2 rounded-3 shadow-sm">
            <i class="fa-solid fa-arrow-right"></i> عودة
        </a>
        <a href="/Orders/Quotation/@Model.OrderId" target="_blank" class="btn btn-info fw-bold px-4 rounded-3 shadow-sm text-dark">
            <i class="fa-solid fa-file-signature"></i> عرض السعر
        </a>
        <a href="/Orders/PrintInvoice/@Model.OrderId" target="_blank" class="sys-btn sys-btn-primary shadow-sm">
            <i class="fa-solid fa-file-invoice"></i> عرض الفاتورة
        </a>
    </div>
</div>

@if (Model.Status == KaberSystem.Models.OrderStatus.Completed && User.IsInRole("Admin"))
{
    <div class="alert alert-dark border-0 border-start border-4 border-warning shadow-sm mb-4 d-flex align-items-center">
        <i class="fa-solid fa-clipboard-check fs-2 text-warning me-3"></i>
        <div>
            <h5 class="fw-bold text-dark mb-1">الطلب بانتظار المراجعة والاعتماد!</h5>
            <p class="mb-0 text-muted fw-bold">قام الفني بإنهاء العمل. يرجى مراجعة قطع الغيار والرسوم، ثم تغيير الحالة إلى (معتمد نهائي) أو تحصيل الفاتورة مباشرة.</p>
        </div>
    </div>
}

<div class="row g-4">
    <div class="col-lg-8">
        <div class="sys-card h-100 printable-card">
            <div class="d-flex justify-content-between align-items-center border-bottom pb-3 mb-4 d-print-none">
                <h4 class="fw-bold text-primary m-0"><i class="fa-solid fa-user-tag me-2"></i> بيانات الطلب والعميل</h4>
                <span class="badge bg-light text-dark border fs-6">ORD-#@Model.OrderId</span>
            </div>

            <div class="row mb-3">
                <div class="col-md-4 text-muted fw-bold">اسم العميل:</div>
                <div class="col-md-8 fw-bold fs-5 text-dark">@Model.CustomerName</div>
            </div>
            <div class="row mb-3">
                <div class="col-md-4 text-muted fw-bold">رقم الهاتف:</div>
                <div class="col-md-8 fw-bold fs-5" dir="ltr" style="text-align: right;">
                    @Model.PhoneNumber
                    <a href="https://wa.me/@waNumber" target="_blank" class="text-success ms-2 d-print-none"><i class="fa-brands fa-whatsapp fs-4"></i></a>
                </div>
            </div>
            <div class="row mb-3">
                <div class="col-md-4 text-muted fw-bold">نوع الجهاز / الموديل:</div>
                <div class="col-md-8 fw-bold fs-5 text-primary">@Model.DeviceName</div>
            </div>
            <div class="row mb-3">
                <div class="col-md-4 text-muted fw-bold">العنوان:</div>
                <div class="col-md-8 fw-bold text-dark">@Model.Address</div>
            </div>

            <div class="p-4 bg-light rounded-4 border-start border-4 border-danger mb-4 mt-4">
                <h6 class="fw-bold text-danger mb-2">وصف المشكلة (الشكوى):</h6>
                <p class="mb-0 fw-bold text-dark fs-6 lh-lg">@Model.ProblemDescription</p>
            </div>

            @if (!string.IsNullOrEmpty(Model.TechnicianNotes))
            {
                <div class="p-4 bg-success bg-opacity-10 rounded-4 border-start border-4 border-success">
                    <h6 class="fw-bold text-success mb-2">التقرير الفني وملاحظات الإدارة:</h6>
                    <p class="mb-0 fw-bold text-dark fs-6 lh-lg">@Model.TechnicianNotes</p>
                </div>
            }
        </div>
    </div>

    <!-- التحكم بالحالة والتسعير -->
    <div class="col-lg-4">
        <div class="sys-card h-100 d-print-none text-center">
            <h4 class="fw-bold mb-4 text-primary border-bottom pb-3"><i class="fa-solid fa-bars-progress me-2"></i> التحكم والميزانية</h4>

            <form asp-action="UpdateStatus" method="post" class="mb-4 bg-light p-3 rounded-3 border text-start">
                <input type="hidden" name="id" value="@Model.OrderId" />

                <div class="mb-3">
                    <label class="fw-bold mb-2 text-dark small">تحديث حالة الطلب:</label>
                    <select name="newStatus" class="form-select fw-bold border-secondary text-primary">
                        @if (User.IsInRole("Technician"))
                        {
                            <option value="InProgress" selected="@(Model.Status == KaberSystem.Models.OrderStatus.InProgress || Model.Status == KaberSystem.Models.OrderStatus.Returned)">قيد التنفيذ / تعديل الملاحظات</option>
                            <option value="Completed" selected="@(Model.Status == KaberSystem.Models.OrderStatus.Completed)">مكتمل (تسليم للإدارة)</option>
                        }
                        else
                        {
                            <option value="InProgress" selected="@(Model.Status == KaberSystem.Models.OrderStatus.InProgress)">قيد التنفيذ</option>
                            <option value="Completed" selected="@(Model.Status == KaberSystem.Models.OrderStatus.Completed)">بانتظار المراجعة (من الفني)</option>
                            <option value="Approved" selected="@(Model.Status == KaberSystem.Models.OrderStatus.Approved)" class="text-success fw-bold">اعتماد نهائي</option>
                            <option value="Returned" selected="@(Model.Status == KaberSystem.Models.OrderStatus.Returned)" class="text-danger fw-bold">إرجاع للفني للتصحيح</option>
                            <option value="Cancelled" selected="@(Model.Status == KaberSystem.Models.OrderStatus.Cancelled)">إلغاء الطلب</option>
                        }
                    </select>
                </div>

                <div class="mb-3">
                    <label class="fw-bold mb-1 text-dark small">إجمالي أجور اليد المطبقة (فحص + تركيب):</label>
                    <select name="isFeeApplied" class="form-select fw-bold border-secondary mb-1">
                        <option value="1" selected="@(Model.IsFeeApplied)">تطبيق الأجرة (@Model.EstimatedPrice ريال)</option>
                        <option value="0" selected="@(!Model.IsFeeApplied)">لا (إعفاء/ضمان)</option>
                    </select>
                </div>

                <div class="mb-3">
                    <label class="fw-bold mb-2 text-dark small">ملاحظات العمل:</label>
                    <textarea name="technicianNotes" class="form-control fw-bold border-secondary" rows="2">@Model.TechnicianNotes</textarea>
                </div>

                <button type="submit" class="btn btn-primary fw-bold w-100 py-2"><i class="fa-solid fa-save"></i> حفظ وتحديث</button>
            </form>

            <h6 class="fw-bold text-muted mb-3">الفني المختص:</h6>
            @if (Model.Technician != null)
            {
                <div class="d-flex align-items-center p-3 border rounded-4 bg-white shadow-sm text-start">
                    <img src="https://ui-avatars.com/api/?name=@Uri.EscapeDataString(Model.Technician.Name)&background=f1950b&color=fff" class="rounded-circle me-3 border border-2 border-primary" width="50">
                    <div>
                        <h6 class="fw-bold mb-1 text-dark">@Model.Technician.Name</h6>
                        <span class="text-muted small fw-bold" dir="ltr">@Model.Technician.Phone</span>
                    </div>
                </div>
            }
        </div>
    </div>

    <!-- قسم طلبات الغيار وتوفير النواقص -->
    <div class="col-12 d-print-none">
        <div class="sys-card bg-primary bg-opacity-10 border border-primary">
            <div class="d-flex justify-content-between align-items-center mb-4 border-bottom border-primary pb-3">
                <h4 class="fw-bold text-primary m-0"><i class="fa-solid fa-boxes-packing me-2"></i> طلبات توفير قطع الغيار (النواقص)</h4>

                @if ((Model.Status != KaberSystem.Models.OrderStatus.Completed && Model.Status != KaberSystem.Models.OrderStatus.Approved) || User.IsInRole("Admin"))
                {
                    <div class="d-flex gap-2">
                        <button class="btn btn-primary fw-bold" data-bs-toggle="modal" data-bs-target="#requestWarehouseModal">
                            <i class="fa-solid fa-warehouse"></i> طلب حجز من المخزن
                        </button>
                        <button class="btn btn-dark fw-bold" data-bs-toggle="modal" data-bs-target="#requestPurchaseModal">
                            <i class="fa-solid fa-cart-plus"></i> طلب شراء
                        </button>
                    </div>
                }
            </div>

            @if (partRequests != null && partRequests.Any())
            {
                <div class="table-responsive bg-white rounded-3 shadow-sm">
                    <table class="table table-bordered text-center align-middle mb-0">
                        <thead class="table-light text-muted">
                            <tr>
                                <th>نوع الطلب</th>
                                <th>اسم القطعة</th>
                                <th>الكمية</th>
                                <th>الحالة</th>
                                @if (User.IsInRole("Admin") || User.IsInRole("Store"))
                                {
                                    <th>الإجراءات (للمخزن والإدارة)</th>
                                }
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var req in partRequests)
                            {
                                <tr>
                                    <td>
                                        @if (req.RequestType == KaberSystem.Models.PartRequestType.FromWarehouse)
                                        {
                                            <span class="badge bg-primary px-2">حجز مخزن</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-dark px-2">طلب شراء</span>
                                        }
                                    </td>
                                    <td class="fw-bold text-dark text-start">@(req.RequestType == KaberSystem.Models.PartRequestType.FromWarehouse ? req.SparePart?.Name : req.NewPartName)</td>
                                    <td class="fw-bold fs-5">@req.Quantity</td>
                                    <td>
                                        @switch (req.Status)
                                        {
                                            case KaberSystem.Models.PartRequestStatus.PendingWarehouse:
                                                <span class="badge bg-warning text-dark"><i class="fa-solid fa-clock"></i> بانتظار المخزن</span>
                                                break;
                                            case KaberSystem.Models.PartRequestStatus.PendingPurchasing:
                                                <span class="badge bg-warning text-dark"><i class="fa-solid fa-clock"></i> بانتظار الشراء</span>
                                                break;
                                            case KaberSystem.Models.PartRequestStatus.ReadyForInstallation:
                                                <span class="badge bg-success fs-6"><i class="fa-solid fa-phone-volume"></i> متوفرة وجاهزة</span>
                                                break;
                                            case KaberSystem.Models.PartRequestStatus.Rejected:
                                                <span class="badge bg-danger fs-6"><i class="fa-solid fa-ban"></i> مرفوضة</span>
                                                break;
                                        }
                                    </td>
                                    @if (User.IsInRole("Admin") || User.IsInRole("Store"))
                                    {
                                        <td>
                                            @if (req.Status == KaberSystem.Models.PartRequestStatus.PendingWarehouse)
                                            {
                                                <div class="d-flex gap-1 justify-content-center">
                                                    <!-- 📌 زر الموافقة والصرف -->
                                                    <form asp-action="ApproveWarehouseRequest" method="post">
                                                        <input type="hidden" name="requestId" value="@req.Id" />
                                                        <button type="submit" class="btn btn-sm btn-success fw-bold" title="موافقة وصرف لعهدة الفني" onclick="return confirm('هل متأكد من صرف القطعة من المخزن وتحويلها لعهدة الفني؟')">
                                                            <i class="fa-solid fa-check"></i> صرف
                                                        </button>
                                                    </form>

                                                    <!-- 📌 زر الرفض -->
                                                    <form asp-action="RejectWarehouseRequest" method="post">
                                                        <input type="hidden" name="requestId" value="@req.Id" />
                                                        <button type="submit" class="btn btn-sm btn-danger fw-bold" title="رفض الطلب" onclick="return confirm('تأكيد رفض طلب الصرف؟')">
                                                            <i class="fa-solid fa-xmark"></i> رفض
                                                        </button>
                                                    </form>
                                                </div>
                                            }
                                        </td>
                                    }
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>

    <!-- الفواتير وقطع الغيار المركبة -->
    <div class="col-12 mt-4">
        <div class="sys-card printable-card">
            <h4 class="fw-bold mb-4 text-primary border-bottom pb-3 d-print-none"><i class="fa-solid fa-file-invoice-dollar me-2"></i> التسعير المالي والتحصيل</h4>
            <div class="row g-4">
                <div class="col-md-7">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h6 class="fw-bold text-dark m-0">قطع الغيار المستخدمة (تم تركيبها)</h6>
                        @if ((Model.Status != KaberSystem.Models.OrderStatus.Completed && Model.Status != KaberSystem.Models.OrderStatus.Approved) || User.IsInRole("Admin"))
                        {
                            <button type="button" class="btn btn-sm btn-outline-primary fw-bold d-print-none" data-bs-toggle="modal" data-bs-target="#addPartModal">
                                <i class="fa-solid fa-plus"></i> تركيب من العهدة
                            </button>
                        }
                    </div>

                    @if (Model.UsedSpareParts != null && Model.UsedSpareParts.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-bordered text-center align-middle bg-white print-table">
                                <thead class="table-light text-muted">
                                    <tr>
                                        <th>اسم القطعة</th>
                                        <th>الكمية</th>
                                        <th>الإجمالي</th>
                                        <th class="d-print-none">حذف</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var part in Model.UsedSpareParts)
                                    {
                                        <tr>
                                            <td class="fw-bold text-dark text-start">@part.SparePart?.Name</td>
                                            <td class="fw-bold">@part.QuantityUsed</td>
                                            <td class="fw-bold text-success">@((part.QuantityUsed * part.SellingPriceAtTime).ToString("N2")) ريال</td>
                                            <td class="d-print-none">
                                                @if ((Model.Status != KaberSystem.Models.OrderStatus.Completed && Model.Status != KaberSystem.Models.OrderStatus.Approved) || User.IsInRole("Admin"))
                                                {
                                                    <form asp-action="RemoveUsedPart" method="post">
                                                        <input type="hidden" name="orderId" value="@Model.OrderId" /><input type="hidden" name="recordId" value="@part.Id" />
                                                        <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('تأكيد الحذف والإرجاع للعهدة؟')"><i class="fa-solid fa-trash"></i></button>
                                                    </form>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>

                <!-- 📌 الخلاصة المالية الدقيقة -->
                <div class="col-md-5">
                    <h6 class="fw-bold text-dark mb-3 d-print-none">الخلاصة المالية للفاتورة</h6>
                    <div class="p-4 border rounded-4 bg-light shadow-sm print-no-bg">
                        
                        <div class="d-flex justify-content-between mb-2 pb-2"><span class="fw-bold text-muted">إجمالي أجور اليد:</span><span class="fw-bold text-dark fs-6">@appliedLaborFee.ToString("N2") ريال</span></div>
                        <div class="d-flex justify-content-between mb-2 pb-2"><span class="fw-bold text-muted">إجمالي قطع الغيار:</span><span class="fw-bold text-dark fs-6">@partsTotal.ToString("N2") ريال</span></div>
                        
                        <div class="d-flex justify-content-between mt-3 align-items-center border-top pt-3">
                            <span class="fw-bold text-dark fs-5">إجمالي الفاتورة:</span>
                            <span class="fw-bold text-dark fs-4">@Model.FinalPrice.ToString("N2") ريال</span>
                        </div>

                        @if (Model.AdvancePayment > 0)
                        {
                            <div class="d-flex justify-content-between mt-2 text-danger pb-3 border-bottom border-danger">
                                <span class="fw-bold">المدفوع مقدماً (عربون فحص):</span>
                                <span class="fw-bold fs-6">- @Model.AdvancePayment.ToString("N2") ريال</span>
                            </div>
                            
                            <div class="d-flex justify-content-between align-items-center mt-3">
                                <span class="fw-bold text-dark fs-5">المتبقي سداده الآن:</span>
                                <span class="fw-bold text-primary fs-3 border border-primary px-3 py-1 rounded-3 bg-white">@remainingToPay.ToString("N2") ريال</span>
                            </div>
                        }
                    </div>

                    @if (Model.Status == KaberSystem.Models.OrderStatus.Completed || Model.Status == KaberSystem.Models.OrderStatus.Approved)
                    {
                        <div class="mt-4 text-center d-print-none">
                            @if (!Model.IsPaid)
                            {
                                <button class="btn btn-success btn-lg w-100 fw-bold shadow-lg rounded-pill" data-bs-toggle="modal" data-bs-target="#paymentModal" style="animation: pulse 2s infinite;">
                                    <i class="fa-solid fa-cash-register me-2"></i> تحصيل الفاتورة (المتبقي: @remainingToPay ريال)
                                </button>
                            }
                            else
                            {
                                <div class="alert alert-success border-0 rounded-4 fw-bold shadow-sm">
                                    <i class="fa-solid fa-check-circle fs-3 d-block mb-2"></i>
                                    تم سداد الفاتورة بنجاح عبر: <span class="badge bg-white text-success fs-6 border border-success">@Model.PaymentMethod</span>
                                    @if (!string.IsNullOrEmpty(Model.PaymentReceiptPath))
                                    {
                                        <br>
                                        <a href="@Model.PaymentReceiptPath" target="_blank" class="btn btn-sm btn-light mt-3 fw-bold text-success border"><i class="fa-solid fa-image"></i> عرض الإيصال</a>
                                    }
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Modal الدفع -->
<div class="modal fade" id="paymentModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 rounded-4 shadow-lg">
            <div class="modal-header border-bottom-0 pb-0">
                <h5 class="modal-title fw-bold text-success"><i class="fa-solid fa-money-bill-wave me-2"></i> تحصيل الفاتورة</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="ProcessPayment" method="post" enctype="multipart/form-data">
                <div class="modal-body py-4 text-start">
                    <input type="hidden" name="orderId" value="@Model.OrderId" />

                    <div class="alert alert-info py-2 fw-bold text-center fs-5">
                        المطلوب سداده الآن: <span class="text-danger">@remainingToPay.ToString("N2") ريال</span>
                    </div>

                    <div class="mb-4 mt-4">
                        <label class="form-label fw-bold text-dark fs-5 mb-3">طريقة الدفع: <span class="text-danger">*</span></label>
                        <div class="d-flex flex-column gap-3">
                            <label class="btn btn-outline-success text-start fw-bold p-3 rounded-3 d-flex align-items-center">
                                <input type="radio" name="paymentMethod" value="Cash" class="form-check-input me-3 fs-5" required checked>
                                <div><i class="fa-solid fa-money-bills fs-4 me-2"></i> كاش (نقدي - سيورد للخزنة)</div>
                            </label>
                            <label class="btn btn-outline-primary text-start fw-bold p-3 rounded-3 d-flex align-items-center">
                                <input type="radio" name="paymentMethod" value="BankTransfer" class="form-check-input me-3 fs-5">
                                <div><i class="fa-solid fa-building-columns fs-4 me-2"></i> تحويل بنكي</div>
                            </label>
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-top-0 pt-0">
                    <button type="button" class="btn btn-light fw-bold px-4 rounded-3" data-bs-dismiss="modal">إلغاء</button>
                    <button type="submit" class="btn btn-success fw-bold px-4 rounded-3 fs-5"><i class="fa-solid fa-check-double me-1"></i> تأكيد الدفع</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Modal 1: طلب حجز قطعة من المخزن -->
<div class="modal fade d-print-none" id="requestWarehouseModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 rounded-4 shadow-lg">
            <div class="modal-header border-bottom-0 pb-0">
                <h5 class="modal-title fw-bold text-primary"><i class="fa-solid fa-warehouse me-2"></i> طلب حجز قطعة</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="RequestFromWarehouse" method="post">
                <div class="modal-body py-4 text-start">
                    <input type="hidden" name="orderId" value="@Model.OrderId" />
                    <div class="mb-3">
                        <label class="form-label fw-bold">اختر القطعة <span class="text-danger">*</span></label>
                        <select name="partId" class="form-select fw-bold bg-light" required>
                            <option value="">-- اختر --</option>
                            @if (ViewData["AvailableParts"] != null)
                            {
                                foreach (var p in (IEnumerable<KaberSystem.Models.SparePart>)ViewData["AvailableParts"])
                                {
                                    <option value="@p.PartId">@p.Name (المتاح: @p.MainStockQuantity)</option>
                                }
                            }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">الكمية</label>
                        <input type="number" name="quantity" class="form-control fw-bold" min="1" value="1" required />
                    </div>
                </div>
                <div class="modal-footer border-top-0 pt-0">
                    <button type="submit" class="btn btn-primary fw-bold px-4">حفظ الطلب</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Modal 2: طلب شراء خارجي -->
<div class="modal fade d-print-none" id="requestPurchaseModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 rounded-4 shadow-lg">
            <div class="modal-header border-bottom-0 pb-0">
                <h5 class="modal-title fw-bold text-dark"><i class="fa-solid fa-cart-plus text-warning me-2"></i> طلب شراء خارجي</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="RequestPurchase" method="post" enctype="multipart/form-data">
                <div class="modal-body py-4 text-start">
                    <input type="hidden" name="orderId" value="@Model.OrderId" />
                    <div class="mb-3">
                        <label class="form-label fw-bold">اسم القطعة المطلوبة</label>
                        <input type="text" name="partName" class="form-control fw-bold bg-light" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">الكمية</label>
                        <input type="number" name="quantity" class="form-control fw-bold" min="1" value="1" required />
                    </div>
                </div>
                <div class="modal-footer border-top-0 pt-0">
                    <button type="submit" class="btn btn-dark fw-bold px-4">إرسال للمشتريات</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- 📌 إضافة سعر القطعة داخل القائمة المنسدلة للتركيب -->
<div class="modal fade d-print-none" id="addPartModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 rounded-4 shadow-lg">
            <div class="modal-header border-bottom-0 pb-0">
                <h5 class="modal-title fw-bold text-primary"><i class="fa-solid fa-plus-circle me-2"></i> تركيب من العهدة</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="AddUsedPart" method="post">
                <div class="modal-body py-4 text-start">
                    <input type="hidden" name="orderId" value="@Model.OrderId" />
                    <div class="mb-3">
                        <label class="form-label fw-bold">القطعة</label>
                        <select name="partId" class="form-select fw-bold bg-light" required>
                            <option value="">-- اختر --</option>
                            @if (Model.Technician?.Inventory != null)
                            {
                                foreach (var p in Model.Technician.Inventory.Where(x => x.Quantity > 0))
                                {
                                    <option value="@p.PartId">@(p.SparePart?.Name ?? "قطعة غير مسماة") | السعر: @(p.SparePart?.SellingPrice ?? 0) ريال (العهدة: @p.Quantity)</option>
                                }
                            }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">الكمية المستهلكة</label>
                        <input type="number" name="quantity" class="form-control fw-bold" min="1" value="1" required />
                    </div>
                </div>
                <div class="modal-footer border-top-0 pt-0">
                    <button type="submit" class="btn btn-primary fw-bold px-4">تأكيد التركيب</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        @if (TempData["SuccessMessage"] != null)
        {
                var msg = System.Text.Json.JsonSerializer.Serialize(TempData["SuccessMessage"]?.ToString());
                <text>Swal.fire({ icon: 'success', title: 'تم', text: @Html.Raw(msg), confirmButtonColor: '#f1950b' });</text>
        }
        @if (TempData["ErrorMessage"] != null)
        {
                var errMsg = System.Text.Json.JsonSerializer.Serialize(TempData["ErrorMessage"]?.ToString());
                <text>Swal.fire({ icon: 'error', title: 'تنبيه', text: @Html.Raw(errMsg), confirmButtonColor: '#ee5d50' });</text>
        }
    </script>
}

<style>
    @@keyframes pulse {
        0% {
            transform: scale(1);
            box-shadow: 0 0 0 0 rgba(25, 135, 84, 0.7);
        }

        70% {
            transform: scale(1.02);
            box-shadow: 0 0 0 10px rgba(25, 135, 84, 0);
        }

        100% {
            transform: scale(1);
            box-shadow: 0 0 0 0 rgba(25, 135, 84, 0);
        }
    }

    .sys-card {
        border-radius: 15px;
        box-shadow: 0 4px 15px rgba(0,0,0,0.05);
    }

    .form-check-input {
        width: 1.5em;
        height: 1.5em;
        cursor: pointer;
    }

    .btn-outline-success:hover, .btn-outline-primary:hover, .btn-outline-info:hover {
        color: white !important;
    }

    label.btn {
        transition: all 0.2s ease-in-out;
    }

        label.btn:hover {
            transform: translateY(-2px);
        }

    @@media print {
        body {
            background: white !important;
        }

        .sys-sidebar, .sys-header, .d-print-none {
            display: none !important;
        }

        .sys-main {
            margin: 0 !important;
            padding: 15px !important;
            width: 100% !important;
        }

        .printable-card {
            box-shadow: none !important;
            border: 1px solid #000 !important;
            padding: 20px !important;
        }

        .print-table th, .print-table td {
            border: 1px solid #000 !important;
            color: #000 !important;
        }

        .print-no-bg {
            background-color: transparent !important;
        }
    }
</style>