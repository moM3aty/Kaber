<!-- مسار الملف: Views/Orders/PrintInvoice.cshtml -->
@model KaberSystem.Models.Order
@{
    Layout = null;

    // حساب المتبقي
    decimal remainingAmount = Model.FinalPrice - Model.AdvancePayment;
    if (remainingAmount < 0) remainingAmount = 0;

    // 📌 تحديد اسم الخدمة ديناميكياً بناءً على نوع الطلب
    string serviceName = "أجور اليد / تكلفة الفحص";
    switch (Model.Type)
    {
        case KaberSystem.Models.OrderType.Maintenance:
            serviceName = "أجور اليد / تكلفة الفحص والصيانة";
            break;
        case KaberSystem.Models.OrderType.NewInstallation:
            serviceName = "أجور تأسيس وتركيب الجهاز";
            break;
        case KaberSystem.Models.OrderType.ACWashing:
            serviceName = "تكلفة غسيل وتنظيف المكيفات";
            break;
        case KaberSystem.Models.OrderType.Warranty:
            serviceName = "زيارة ضمان (مشمول بالضمان)";
            break;
    }

    string qrRawData = $"مؤسسة كابر\nس.ت: 7037085128\nINV-{Model.OrderId}\nالعميل: {Model.CustomerName}\nالمبلغ المطلوب: {remainingAmount} ر.س";
    string qrUrl = $"https://api.qrserver.com/v1/create-qr-code/?size=130x130&data={Uri.EscapeDataString(qrRawData)}";

    string phone = Model.PhoneNumber.StartsWith("0") ? Model.PhoneNumber.Substring(1) : Model.PhoneNumber;
    string waNumber = "966" + phone;
    string whatsappMessage = $"أهلاً بك عميلنا العزيز {Model.CustomerName}،\n\nفاتورتك (INV-#{Model.OrderId}):\nالإجمالي: {Model.FinalPrice} ريال\nالمدفوع مقدماً: {Model.AdvancePayment} ريال\n*المتبقي سداده:* {remainingAmount} ريال\n\nشكراً لتعاملك مع مؤسسة كابر للصيانة والتكييف 🛠️.";
    string encodedMessage = Uri.EscapeDataString(whatsappMessage);
}
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <title>فاتورة صيانة - كابر</title>
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="/images/logo.png" type="image/x-icon" rel="icon" />
    <style>
        body {
            font-family: 'Cairo', sans-serif;
            background: #f4f7fe;
            padding: 40px 20px;
        }

        .invoice-box {
            max-width: 850px;
            margin: auto;
            background: #fff;
            padding: 45px;
            border-radius: 15px;
            box-shadow: 0 15px 35px rgba(0,0,0,0.1);
            border-top: 8px solid #f1950b;
        }

        .table th {
            background-color: #010217 !important;
            color: white !important;
        }

        @@media print {
            body {
                background: #fff;
                padding: 0;
            }

            .invoice-box {
                box-shadow: none;
                border: none;
                padding: 0;
            }

            .d-print-none {
                display: none !important;
            }
        }
    </style>
</head>
<body>
    <div class="text-center mb-4 d-print-none">
        <button onclick="window.print()" class="btn btn-dark rounded-pill fw-bold px-4 me-2"><i class="fa-solid fa-print"></i> طباعة الفاتورة للعميل</button>
        <a href="https://wa.me/@waNumber?text=@encodedMessage" target="_blank" class="btn btn-success rounded-pill fw-bold px-4"><i class="fa-brands fa-whatsapp fs-5 me-2"></i> إرسال للعميل (واتساب)</a>
    </div>

    <div class="invoice-box">
        <div class="row border-bottom pb-4 mb-4 align-items-center">
            <div class="col-5">
                <img src="/images/logo.png" width="160px" style="border-radius:15px;" alt="Logo" />
                <p class="text-dark mb-0 fw-bolder mt-3">كابر لصيانة جميع الأجهزة الكهربائية</p>
                <p class="text-muted fw-bold mt-1 mb-0 fs-6">سجل تجاري: 7037085128</p>
                <p class="text-muted fw-bold mb-0">المنطقة الشرقية - الدمام</p>
                <p class="text-muted fw-bold mt-1 mb-0" dir="rtl"><i class="fa-brands fa-whatsapp text-success me-1"></i> +966 55 579 4669</p>
            </div>
            <div class="col-3 text-center">
                <img src="@qrUrl" alt="QR Code" width="110" height="110" class="border p-1 rounded" />
                <p class="small text-muted fw-bold mt-1 mb-0">امسح الرمز للتحقق</p>
            </div>
            <div class="col-4 text-end">
                <h1 class="fw-bold" style="color: #f1950b; font-size: 36px;">فاتورة ضريبية</h1>
                <h4 class="fw-bold text-dark mb-3">INV-#@Model.OrderId</h4>
                <span class="badge bg-light text-dark border px-3 py-2 fw-bold fs-6">تاريخ: @DateTime.Now.ToString("yyyy-MM-dd")</span>
            </div>
        </div>

        <div class="row mb-4 g-3">
            <div class="col-md-6">
                <div class="bg-light p-3 rounded-3 border h-100">
                    <h6 class="fw-bold text-primary mb-3"><i class="fa-solid fa-user-tag me-2"></i> بيانات العميل:</h6>
                    <div class="d-flex justify-content-between mb-2"><span class="text-muted fw-bold">الاسم:</span> <span class="fw-bold text-dark">@Model.CustomerName</span></div>
                    <div class="d-flex justify-content-between mb-2"><span class="text-muted fw-bold">الجوال:</span> <span class="fw-bold text-dark" dir="ltr">@Model.PhoneNumber</span></div>
                    <div class="d-flex justify-content-between mb-0"><span class="text-muted fw-bold">العنوان:</span> <span class="fw-bold text-dark text-end" style="max-width: 65%;">@Model.Address</span></div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="bg-light p-3 rounded-3 border h-100">
                    <h6 class="fw-bold text-primary mb-3"><i class="fa-solid fa-screwdriver-wrench me-2"></i> تفاصيل الصيانة:</h6>
                    <div class="d-flex justify-content-between mb-2"><span class="text-muted fw-bold">الجهاز:</span> <span class="fw-bold text-dark text-end" style="max-width: 65%;">@Model.DeviceName</span></div>
                    <div class="d-flex justify-content-between mb-2"><span class="text-muted fw-bold">المهندس/الفني:</span> <span class="fw-bold text-dark">@(Model.Technician?.Name ?? "غير محدد")</span></div>
                    <div class="d-flex justify-content-between mb-0"><span class="text-muted fw-bold">حالة الدفع:</span> <span class="fw-bold @(Model.IsPaid ? "text-success" : "text-danger")">@(Model.IsPaid ? "مسددة بالكامل" : "آجلة / غير مسددة")</span></div>
                </div>
            </div>
        </div>

        <table class="table table-bordered text-center align-middle mb-4">
            <thead>
                <tr>
                    <th class="text-start ps-3">البيان / الخدمة / القطعة</th>
                    <th width="15%">الكمية</th>
                    <th width="20%">السعر</th>
                    <th width="20%">الإجمالي</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.IsFeeApplied)
                {
                    <tr>
                        <td class="fw-bold text-dark text-start ps-3">@serviceName</td>
                        <td class="fw-bold text-muted">1</td>
                        <td class="fw-bold text-muted">@Model.EstimatedPrice ريال</td>
                        <td class="fw-bold text-dark">@Model.EstimatedPrice ريال</td>
                    </tr>
                }
                else
                {
                    <tr>
                        <td class="fw-bold text-success text-start ps-3">@serviceName</td>
                        <td class="fw-bold text-muted">1</td>
                        <td class="fw-bold text-muted">0.00 ريال</td>
                        <td class="fw-bold text-success">مشمول بالضمان</td>
                    </tr>
                }

                @if (Model.UsedSpareParts != null)
                {
                    foreach (var part in Model.UsedSpareParts)
                    {
                        <tr>
                            <td class="fw-bold text-dark text-start ps-3">@part.SparePart?.Name</td>
                            <td class="fw-bold text-muted">@part.QuantityUsed</td>
                            <td class="fw-bold text-muted">@part.SellingPriceAtTime ريال</td>
                            <td class="fw-bold text-dark">@(part.QuantityUsed* part.SellingPriceAtTime) ريال</td>
                        </tr>
                    }
                }
            </tbody>
        </table>

        <!-- الإجماليات الدقيقة -->
        <div class="row justify-content-end mt-4">
            <div class="col-md-7">
                <div class="border p-4 rounded-3 bg-light shadow-sm">
                    <div class="d-flex justify-content-between mb-3 border-bottom pb-2">
                        <span class="fw-bold text-muted fs-5">إجمالي الفاتورة:</span>
                        <span class="fw-bold fs-5 text-dark">@Model.FinalPrice ريال</span>
                    </div>
                    @if (Model.AdvancePayment > 0)
                    {
                        <div class="d-flex justify-content-between mb-3 text-danger border-bottom pb-2 border-danger">
                            <span class="fw-bold">دفعات مقدمة (عربون):</span>
                            <span class="fw-bold fs-5">- @Model.AdvancePayment ريال</span>
                        </div>
                    }
                    <div class="d-flex justify-content-between mt-3 align-items-center">
                        <span class="fw-bold fs-4 text-primary">المبلغ الصافي المستحق:</span>
                        <span class="fw-bold fs-2 text-success bg-success bg-opacity-10 px-3 py-1 rounded-3">@remainingAmount ريال</span>
                    </div>
                </div>
            </div>
        </div>

        <div class="text-center mt-5 pt-4 border-top">
            <p class="fw-bold text-dark fs-5 mb-1">شكراً لثقتكم بخدمات مؤسسة كابر.</p>
            <p class="text-muted small fw-bold mb-0">هذه الفاتورة معتمدة إلكترونياً ولا تحتاج إلى توقيع أو ختم.</p>
        </div>
    </div>
</body>
</html>