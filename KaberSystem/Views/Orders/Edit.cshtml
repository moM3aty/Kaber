@model KaberSystem.Models.Order
@{
    ViewData["Title"] = "تعديل بيانات الطلب";
    Layout = "~/Views/Shared/_SystemLayout.cshtml";
}

<div class="sys-page-header">
    <div>
        <h1 class="sys-page-title text-primary">تعديل الطلب #@Model.OrderId</h1>
        <p class="sys-page-desc">شاشة مخصصة للإدارة لتعديل بيانات الطلبات أو تصحيح الأخطاء</p>
    </div>
    <a href="/Orders/Index" class="btn btn-outline-secondary fw-bold px-4 rounded-3">
        <i class="fa-solid fa-arrow-right"></i> إلغاء والعودة
    </a>
</div>

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="sys-card border-top border-4 border-warning shadow-sm">
            <form asp-action="Edit" method="post">
                <input type="hidden" asp-for="OrderId" />
                <input type="hidden" asp-for="CreatedAt" />

                <div class="row g-4">
                    <div class="col-md-6">
                        <label asp-for="CustomerName" class="form-label fw-bold">اسم العميل</label>
                        <input asp-for="CustomerName" class="form-control sys-input" required />
                    </div>
                    <div class="col-md-6">
                        <label asp-for="PhoneNumber" class="form-label fw-bold">رقم الهاتف</label>
                        <input asp-for="PhoneNumber" class="form-control sys-input" dir="ltr" required />
                    </div>
                    <div class="col-md-12">
                        <label asp-for="Address" class="form-label fw-bold">العنوان</label>
                        <input asp-for="Address" class="form-control sys-input" required />
                    </div>
                    <div class="col-md-12">
                        <label asp-for="ProblemDescription" class="form-label fw-bold">وصف المشكلة</label>
                        <textarea asp-for="ProblemDescription" class="form-control sys-input" rows="3" required></textarea>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="EstimatedPrice" class="form-label fw-bold text-danger">أجور اليد (الفحص)</label>
                        <input asp-for="EstimatedPrice" type="number" step="0.01" class="form-control sys-input" />
                    </div>
                    <div class="col-md-4">
                        <label asp-for="AdvancePayment" class="form-label fw-bold text-danger">الدفعة المقدمة</label>
                        <input asp-for="AdvancePayment" type="number" step="0.01" class="form-control sys-input" />
                    </div>
                    <div class="col-md-4">
                        <label asp-for="Status" class="form-label fw-bold">حالة الطلب</label>
                        <select asp-for="Status" class="form-select sys-input fw-bold" asp-items="Html.GetEnumSelectList<KaberSystem.Models.OrderStatus>()"></select>
                    </div>

                    <div class="col-12 mt-4 text-end border-top pt-4">
                        <button type="submit" class="sys-btn btn-warning text-dark px-5 py-3 fs-5 fw-bold shadow-sm">
                            <i class="fa-solid fa-save me-2"></i> حفظ التعديلات
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>