@model KaberSystem.Models.Order
@{
    ViewData["Title"] = "عرض سعر #" + Model.OrderId;
    Layout = "~/Views/Shared/_SystemLayout.cshtml";

    decimal partsTotal = Model.UsedSpareParts?.Sum(p => p.QuantityUsed * p.SellingPriceAtTime) ?? 0;
    decimal laborFee = Model.IsFeeApplied ? Model.EstimatedPrice : 0;
    decimal grandTotal = partsTotal + laborFee;
}

<div class="sys-page-header d-print-none">
    <div>
        <h1 class="sys-page-title">عرض سعر مبدئي</h1>
        <p class="sys-page-desc">يمكنك طباعة هذا العرض أو حفظه كـ PDF وإرساله للعميل</p>
    </div>
    <div class="d-flex gap-2">
        <button class="sys-btn sys-btn-primary" onclick="window.print()">
            <i class="fa-solid fa-print"></i> طباعة / حفظ PDF
        </button>
        <a href="/Orders/Details/@Model.OrderId" class="btn btn-outline-secondary fw-bold px-4 border-2 rounded-3">
            عودة للطلب
        </a>
    </div>
</div>

<div class="row justify-content-center">
    <div class="col-lg-10">
        <div class="sys-card printable-card bg-white position-relative overflow-hidden" style="min-height: 800px;">

            <div class="position-absolute top-50 start-50 translate-middle" style="opacity: 0.03; z-index: 0; pointer-events: none;">
                <i class="fa-solid fa-file-signature" style="font-size: 400px;"></i>
            </div>

            <div class="d-flex justify-content-between align-items-start border-bottom pb-4 mb-4 position-relative z-1">
                <div>
                    <h2 class="fw-bold text-dark mb-1"><i class="fa-solid fa-bolt text-primary me-2"></i> شركة كابر للصيانة</h2>
                    <p class="text-muted fw-bold mb-0">المملكة العربية السعودية</p>
                    <p class="text-muted fw-bold mb-0">جوال: 0541683466</p>
                </div>
                <div class="text-end">
                    <h2 class="fw-bold text-warning mb-2 border border-2 border-warning px-4 py-2 rounded-3 d-inline-block">عرض سعر (Quotation)</h2>
                    <p class="m-0 fw-bold fs-6 text-dark mt-2">رقم المرجع: <span class="text-primary">QT-#@Model.OrderId</span></p>
                    <p class="m-0 fw-bold fs-6 text-dark">تاريخ الإصدار: @DateTime.Now.ToString("yyyy-MM-dd")</p>
                </div>
            </div>

            <div class="row mb-5 position-relative z-1">
                <div class="col-sm-6">
                    <div class="p-3 bg-light rounded-3 border-start border-4 border-primary h-100 print-no-bg">
                        <h6 class="fw-bold text-muted mb-2">مقدم إلى العميل:</h6>
                        <h5 class="fw-bold text-dark mb-1">@Model.CustomerName</h5>
                        <p class="mb-1 fw-bold text-muted" dir="ltr" style="text-align:right;">@Model.PhoneNumber <i class="fa-solid fa-phone ms-1 small"></i></p>
                        <p class="mb-0 fw-bold text-muted">@Model.Address <i class="fa-solid fa-location-dot ms-1 small"></i></p>
                    </div>
                </div>
                <div class="col-sm-6">
                    <div class="p-3 bg-light rounded-3 border-start border-4 border-secondary h-100 print-no-bg">
                        <h6 class="fw-bold text-muted mb-2">بيانات الصيانة:</h6>
                        <p class="mb-1 fw-bold text-dark"><span class="text-muted">الجهاز:</span> @Model.DeviceName</p>
                        <p class="mb-0 fw-bold text-dark"><span class="text-muted">المشكلة:</span> @Model.ProblemDescription</p>
                    </div>
                </div>
            </div>

            <div class="position-relative z-1">
                <table class="table table-bordered text-center align-middle print-table">
                    <thead class="table-light">
                        <tr>
                            <th class="py-3">البيان / القطعة</th>
                            <th class="py-3">الكمية</th>
                            <th class="py-3">سعر الوحدة</th>
                            <th class="py-3">الإجمالي (شامل الضريبة)</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td class="fw-bold text-dark text-start">أجور اليد / الفحص الفني للطلب</td>
                            <td class="fw-bold">1</td>
                            <td class="fw-bold text-muted">@laborFee.ToString("N2") ريال</td>
                            <td class="fw-bold text-dark">@laborFee.ToString("N2") ريال</td>
                        </tr>

                        @if (Model.UsedSpareParts != null && Model.UsedSpareParts.Any())
                        {
                            @foreach (var part in Model.UsedSpareParts)
                            {
                                <tr>
                                    <td class="fw-bold text-dark text-start">@part.SparePart.Name</td>
                                    <td class="fw-bold">@part.QuantityUsed</td>
                                    <td class="fw-bold text-muted">@part.SellingPriceAtTime.ToString("N2") ريال</td>
                                    <td class="fw-bold text-dark">@((part.QuantityUsed * part.SellingPriceAtTime).ToString("N2")) ريال</td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="4" class="text-muted fw-bold py-3">لا توجد قطع غيار مقترحة حتى الآن، السعر يقتصر على رسوم الفحص فقط.</td>
                            </tr>
                        }
                    </tbody>
                    <tfoot class="table-light">
                        <tr>
                            <td colspan="3" class="text-end fw-bold fs-5 pe-4">الإجمالي النهائي المقدر:</td>
                            <td class="text-success fw-bold fs-4 bg-success bg-opacity-10">@grandTotal.ToString("N2") <span class="fs-6">ريال</span></td>
                        </tr>
                    </tfoot>
                </table>
            </div>

            <div class="mt-5 pt-3 border-top position-relative z-1 text-muted fw-bold small lh-lg">
                <p class="mb-1 text-danger"><i class="fa-solid fa-circle-info"></i> ملاحظات هامة:</p>
                <ul class="mb-0">
                    <li>هذا المستند هو عرض سعر مبدئي (تقديري) بناءً على الفحص الأولي، وقد يتغير السعر في حال اكتشاف أعطال إضافية أثناء العمل.</li>
                    <li>عرض السعر صالح لمدة (7) أيام من تاريخ إصداره.</li>
                    <li>الأسعار الموضحة أعلاه شاملة لضريبة القيمة المضافة.</li>
                </ul>
            </div>

            <div class="d-flex justify-content-between mt-5 pt-5 px-4 position-relative z-1 d-none d-print-flex">
                <div class="text-center">
                    <h6 class="fw-bold text-dark mb-4">توقيع العميل (بالموافقة)</h6>
                    <p>.......................................</p>
                </div>
                <div class="text-center">
                    <h6 class="fw-bold text-dark mb-4">توقيع الفني / الإدارة</h6>
                    <p>.......................................</p>
                </div>
            </div>

        </div>
    </div>
</div>

<style>
    @@media print {
        body { background: white !important; margin: 0 !important; padding: 0 !important; }
        .sys-sidebar, .sys-header, .d-print-none { display: none !important; }
        .sys-main { margin: 0 !important; padding: 0 !important; width: 100% !important; }
        .printable-card { box-shadow: none !important; border: none !important; padding: 20px !important; }
        .print-table th, .print-table td { border: 1px solid #000 !important; color: #000 !important; }
        * { color: #000 !important; -webkit-print-color-adjust: exact !important; print-color-adjust: exact !important; }
        .print-no-bg { background-color: transparent !important; border: 1px solid #ccc !important; }
    }
</style>