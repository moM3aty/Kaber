@model KaberSystem.Models.Order
@{
    ViewData["Title"] = "إنشاء طلب جديد";
    Layout = "~/Views/Shared/_SystemLayout.cshtml";
}

<div class="sys-page-header">
    <div>
        <h1 class="sys-page-title">إنشاء طلب صيانة جديد</h1>
        <p class="sys-page-desc">إدخال بيانات العميل، إضافة جهاز أو أكثر، إرفاق الصور، والموعد المطلوب</p>
    </div>
    <a href="/Orders/Index" class="btn btn-outline-secondary fw-bold px-4 rounded-3 border-2">
        <i class="fa-solid fa-arrow-right"></i> عودة للقائمة
    </a>
</div>

<div class="row">
    <div class="col-lg-8">
        <div class="sys-card border-top border-4 border-primary">
            <!-- 📌 تم إضافة enctype لرفع الملفات -->
            <form asp-action="Create" method="post" enctype="multipart/form-data">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3 fw-bold"></div>

                <div class="row g-4">
                    <div class="col-md-6">
                        <label asp-for="CustomerName" class="form-label fw-bold text-dark"><i class="fa-regular fa-user text-primary me-1"></i> اسم العميل <span class="text-danger">*</span></label>
                        <input asp-for="CustomerName" class="form-control sys-input" placeholder="أدخل اسم العميل ثلاثي" required />
                    </div>

                    <div class="col-md-6">
                        <label asp-for="PhoneNumber" class="form-label fw-bold text-dark"><i class="fa-solid fa-phone text-primary me-1"></i> رقم الهاتف <span class="text-danger">*</span></label>
                        <input asp-for="PhoneNumber" class="form-control sys-input" placeholder="مثال: +966555794669" required />
                    </div>

                    <!-- 📌 التحديث: إضافة قائمة أجهزة مرقمة ديناميكية -->
                    <div class="col-md-12 bg-light p-3 rounded-3 border border-dashed">
                        <label class="form-label fw-bold text-dark mb-3"><i class="fa-solid fa-tv text-primary me-1"></i> الأجهزة المراد صيانتها <span class="text-danger">*</span></label>
                        <div id="devicesContainer">
                            <div class="input-group mb-2">
                                <span class="input-group-text bg-white fw-bold border-2 border-secondary">1</span>
                                <input type="text" name="DeviceNamesList" class="form-control sys-input" placeholder="مثال: مكيف سبليت ماركة LG" required />
                                <button type="button" class="btn btn-success fw-bold px-3 border-2" onclick="addDeviceField()" title="إضافة جهاز آخر"><i class="fa-solid fa-plus"></i></button>
                            </div>
                        </div>
                        <small class="text-muted fw-bold"><i class="fa-solid fa-circle-info text-primary me-1"></i> يمكنك إضافة أكثر من جهاز في نفس الطلب عبر الضغط على علامة (+).</small>
                        <!-- حقل مخفي لتخطي الـ Validation للموديل الأصلي -->
                        <input type="hidden" name="DeviceName" value="Multiple Devices" />
                    </div>

                    <div class="col-md-6">
                        <label asp-for="ScheduledDate" class="form-label fw-bold text-dark"><i class="fa-regular fa-calendar-check text-primary me-1"></i> الموعد المطلوب للتنفيذ <span class="text-danger">*</span></label>
                        <input asp-for="ScheduledDate" type="datetime-local" class="form-control sys-input" required />
                    </div>

                    <div class="col-md-12">
                        <label asp-for="Address" class="form-label fw-bold text-dark"><i class="fa-solid fa-location-dot text-primary me-1"></i> العنوان بالتفصيل <span class="text-danger">*</span></label>
                        <input asp-for="Address" class="form-control sys-input" placeholder="المدينة، الحي، الشارع، رقم المبنى" required />
                    </div>

                    <div class="col-md-12">
                        <label asp-for="LocationMapUrl" class="form-label fw-bold text-dark"><i class="fa-solid fa-map text-primary me-1"></i> رابط الموقع (Google Maps) <span class="text-muted small">- اختياري</span></label>
                        <input asp-for="LocationMapUrl" class="form-control sys-input" placeholder="انسخ والصق رابط الموقع" dir="ltr" style="text-align: left;" />
                    </div>

                    <div class="col-12 border-top pt-3 mt-4">
                        <h5 class="fw-bold text-primary mb-3"><i class="fa-solid fa-clipboard-list me-2"></i> تفاصيل الطلب والتسعير</h5>
                    </div>

                    <div class="col-md-4">
                        <label asp-for="Type" class="form-label fw-bold text-dark">نوع الطلب <span class="text-danger">*</span></label>
                        <select asp-for="Type" class="form-select sys-input fw-bold bg-light">
                            <option value="Maintenance">صيانة وإصلاح</option>
                            <option value="ACWashing">غسيل مكيفات</option>
                            <option value="NewInstallation">تركيب جديد</option>
                            <option value="Warranty">ضمان (بدون رسوم)</option>
                        </select>
                    </div>

                    <div class="col-md-4">
                        <label asp-for="TechnicianId" class="form-label fw-bold text-dark">تحديد الفني (المنفذ)</label>
                        <select asp-for="TechnicianId" class="form-select sys-input fw-bold bg-light" asp-items="ViewBag.TechnicianId">
                            <option value="">-- يحدد لاحقاً --</option>
                        </select>
                    </div>

                    <div class="col-md-4">
                        <label asp-for="EstimatedPrice" class="form-label fw-bold text-dark">رسوم الفحص</label>
                        <div class="input-group">
                            <input asp-for="EstimatedPrice" type="number" step="0.01" class="form-control sys-input border-end-0 fw-bold" placeholder="0.00" />
                            <span class="input-group-text bg-white border-2 border-start-0 border-secondary fw-bold text-muted" style="border-radius: 12px 0 0 12px;">ر.س</span>
                        </div>
                    </div>

                    <div class="col-md-12 mt-3">
                        <label asp-for="ProblemDescription" class="form-label fw-bold text-dark"><i class="fa-solid fa-triangle-exclamation text-primary me-1"></i> وصف المشكلة (الشكوى) <span class="text-danger">*</span></label>
                        <textarea asp-for="ProblemDescription" class="form-control sys-input" rows="4" placeholder="اكتب تفاصيل العطل بدقة لتسهيل المهمة على الفني..." required></textarea>
                    </div>

                    <!-- 📌 التحديث: رفع صور متعددة -->
                    <div class="col-md-12 mt-3">
                        <label class="form-label fw-bold text-dark"><i class="fa-solid fa-images text-primary me-1"></i> إرفاق صور للأجهزة أو الأعطال <span class="text-muted small fw-normal">- (يمكنك تحديد أكثر من صورة معاً)</span></label>
                        <input type="file" name="deviceImages" class="form-control sys-input" style="padding: 12px;" accept="image/*" multiple />
                    </div>

                    <div class="col-12 mt-5 text-end border-top pt-4">
                        <button type="submit" class="sys-btn sys-btn-primary px-5 fs-5">
                            <i class="fa-solid fa-paper-plane"></i> حفظ وتسجيل الطلب
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <!-- قسم التعليمات الجانبي -->
    <div class="col-lg-4">
        <div class="sys-card bg-light border-0 h-100" style="border-right: 4px solid var(--sys-primary) !important;">
            <h5 class="fw-bold mb-4 text-primary"><i class="fa-solid fa-circle-info"></i> تعليمات الكول سنتر</h5>
            <ul class="list-unstyled lh-lg text-muted fw-bold">
                <li class="mb-3 d-flex align-items-start"><i class="fa-solid fa-check-circle text-success ms-2 mt-1 fs-5"></i> <span>تأكد من <b>(أنواع الأجهزة)</b> والماركة، ويمكنك إضافة عدة أجهزة عبر الزر الأخضر (+).</span></li>
                <li class="mb-3 d-flex align-items-start"><i class="fa-solid fa-check-circle text-success ms-2 mt-1 fs-5"></i> <span>حدد الموعد المطلوب بناءً على رغبة العميل ليتمكن الفني من جدولته.</span></li>
                <li class="mb-3 d-flex align-items-start"><i class="fa-solid fa-check-circle text-success ms-2 mt-1 fs-5"></i> <span>اطلب من العميل إرسال <b>صور للمشكلة</b>، ويمكنك تحديد أكثر من صورة لرفعها مرة واحدة لتوضيح الحالة للفني.</span></li>
            </ul>
        </div>
    </div>
</div>

<script>
    let deviceCount = 1;
    function addDeviceField() {
        deviceCount++;
        const container = document.getElementById('devicesContainer');
        const newDiv = document.createElement('div');
        newDiv.className = 'input-group mb-2';
        newDiv.innerHTML = `
            <span class="input-group-text bg-white fw-bold border-2 border-secondary">${deviceCount}</span>
            <input type="text" name="DeviceNamesList" class="form-control sys-input" placeholder="الجهاز ${deviceCount}" required />
            <button type="button" class="btn btn-danger fw-bold px-3 border-2" onclick="this.parentElement.remove(); renumberDevices();"><i class="fa-solid fa-trash"></i></button>
        `;
        container.appendChild(newDiv);
    }

    function renumberDevices() {
        const container = document.getElementById('devicesContainer');
        const spans = container.querySelectorAll('.input-group-text');
        deviceCount = spans.length;
        spans.forEach((span, index) => {
            span.innerText = index + 1;
        });
    }
</script>

<style>
    .sys-input {
        border: 2px solid var(--sys-border);
        padding: 14px 18px;
        border-radius: 12px;
        font-weight: 600;
        color: var(--sys-text-main);
        transition: var(--sys-transition);
        background-color: #fafbfc;
    }

        .sys-input:focus {
            border-color: var(--sys-primary);
            box-shadow: 0 0 0 0.25rem rgba(241, 149, 11, 0.15);
            background-color: #fff;
            outline: none;
        }

    .input-group .sys-input {
        border-radius: 0;
    }
</style>