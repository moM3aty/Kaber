<!-- مسار الملف: Views/Orders/Index.cshtml -->
@using KaberSystem.Models
@using Microsoft.EntityFrameworkCore
@inject ApplicationDbContext DbContext
@model IEnumerable<KaberSystem.Models.Order>
@{
    ViewData["Title"] = "إدارة الطلبات والمواعيد";
    Layout = "~/Views/Shared/_SystemLayout.cshtml";

    var ordersWithReadyParts = ViewBag.OrdersWithReadyParts as List<int> ?? new List<int>();
    var techsList = ViewData["TechniciansList"] as IEnumerable<KaberSystem.Models.Technician>;

    int techAlertCount = 0;
    if (User.IsInRole("Technician"))
    {
        techAlertCount = DbContext.Orders.Count(o => o.Technician.Name == User.Identity.Name && (o.Status == OrderStatus.Assigned || o.Status == OrderStatus.Returned));
    }

    var activeOrders = Model.Where(o => o.Status != OrderStatus.Approved && o.Status != OrderStatus.Cancelled).ToList();
    var pastOrders = Model.Where(o => o.Status == OrderStatus.Approved || o.Status == OrderStatus.Cancelled).ToList();

    var todayOrders = activeOrders.Where(o => o.ScheduledDate?.Date <= DateTime.Today || o.ScheduledDate == null).ToList();
    var futureOrders = activeOrders.Where(o => o.ScheduledDate?.Date > DateTime.Today).ToList();
}

<div class="d-flex justify-content-between align-items-center mb-4 fade-in-up">
    <div class="d-flex align-items-center gap-3">
        <div class="bg-white text-primary rounded-circle d-flex justify-content-center align-items-center shadow-sm" style="width: 55px; height: 55px; font-size: 22px;">
            <i class="fa-solid fa-headset"></i>
        </div>
        <div>
            <h2 class="fw-bolder text-dark mb-1" style="letter-spacing: -0.5px;">الطلبات وجدولة المواعيد</h2>
            <p class="text-muted fw-bold mb-0">إدارة جميع طلبات الصيانة، متابعة الفنيين، وتتبع حالة المواعيد</p>
        </div>
    </div>
    @if (User.IsInRole("Admin") || User.IsInRole("CallCenter"))
    {
        <a href="/Orders/Create" class="btn btn-primary fw-bolder px-4 rounded-pill shadow-sm hover-elevate py-2">
            <i class="fa-solid fa-plus me-1"></i> إنشاء طلب جديد
        </a>
    }
</div>

@if (User.IsInRole("Technician") && techAlertCount > 0)
{
    <div class="premium-alert info fade-in-up mb-4">
        <div class="icon-box"><i class="fa-solid fa-bell fa-shake"></i></div>
        <div class="content">
            <h5 class="fw-bolder mb-1">لديك مهام بانتظارك!</h5>
            <p class="mb-0 fw-bold">يوجد (<span class="text-danger fs-5">@techAlertCount</span>) طلبات جديدة أو معادة من الإدارة للتعديل بانتظار استلامك والبدء بها.</p>
        </div>
    </div>
}

<div class="premium-card mb-4 fade-in-up border-0 bg-transparent shadow-none">
    <form method="get" asp-action="Index" class="row g-3">
        <div class="col-md-9">
            <div class="position-relative">
                <i class="fa-solid fa-magnifying-glass position-absolute text-muted" style="top: 50%; right: 20px; transform: translateY(-50%);"></i>
                <input type="text" name="searchQuery" value="@ViewData["CurrentSearch"]" class="premium-input form-control w-100 pe-5 shadow-sm" placeholder="ابحث باسم العميل أو رقم الجوال السريع..." style="border: 1px solid #e2e8f0; background: #fff;" />
            </div>
        </div>
        <div class="col-md-3">
            <button type="submit" class="btn btn-dark w-100 fw-bolder py-3 rounded-pill shadow-sm hover-elevate">
                <i class="fa-solid fa-search me-1 text-warning"></i> بحث بالطلبات
            </button>
        </div>
    </form>
</div>

<div class="premium-card fade-in-up">
    <div class="card-header-premium bg-white pb-0 border-bottom-0">
        <ul class="nav nav-pills premium-tabs mb-3 gap-2" id="ordersTabs" role="tablist">
            <li class="nav-item" role="presentation">
                <button class="nav-link active fw-bold px-4 rounded-pill" id="today-tab" data-bs-toggle="tab" data-bs-target="#today" type="button" role="tab">
                    <i class="fa-solid fa-calendar-day me-1"></i> مهام اليوم والعاجلة <span class="badge bg-white text-primary ms-2 shadow-sm">@todayOrders.Count</span>
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link fw-bold px-4 rounded-pill" id="future-tab" data-bs-toggle="tab" data-bs-target="#future" type="button" role="tab">
                    <i class="fa-solid fa-calendar-days me-1"></i> مواعيد الغد والمستقبل <span class="badge bg-white text-muted ms-2 shadow-sm">@futureOrders.Count</span>
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link fw-bold px-4 rounded-pill" id="past-tab" data-bs-toggle="tab" data-bs-target="#past" type="button" role="tab">
                    <i class="fa-solid fa-check-double me-1"></i> السجل والتنفيذ <span class="badge bg-white text-muted ms-2 shadow-sm">@pastOrders.Count</span>
                </button>
            </li>
        </ul>
    </div>

    <div class="card-body-premium p-0">
        <div class="tab-content" id="ordersTabsContent">

            <!-- 📌 1. تبويب مواعيد اليوم -->
            <div class="tab-pane fade show active" id="today" role="tabpanel">
                <div class="table-responsive p-0">
                    <table class="table premium-table align-middle text-center mb-0 w-100">
                        <thead class="bg-light">
                            <tr>
                                <th class="text-start ps-4">رقم الطلب</th>
                                <th class="text-start">اسم العميل والتواصل</th>
                                <th>نوع الطلب</th>
                                <th>موعد الزيارة (الجدولة)</th>
                                @if (!User.IsInRole("Technician"))
                                {
                                    <th>الفني المختص</th>
                                }
                                <th>حالة الطلب</th>
                                <th>إجراءات الإدارة</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in todayOrders)
                            {
                                string phoneStr = item.PhoneNumber.StartsWith("0") ? item.PhoneNumber.Substring(1) : item.PhoneNumber;
                                string whatsappNumber = "966" + phoneStr;
                                bool isReadyForInstall = ordersWithReadyParts.Contains(item.OrderId);
                                string rowClass = isReadyForInstall && (User.IsInRole("Admin") || User.IsInRole("CallCenter")) ? "ready-install-row" : "";

                                <tr class="@rowClass" style="border-bottom: 1px solid #f1f5f9;">
                                    <td class="text-start ps-4"><span class="premium-badge default fs-6 shadow-sm border">#@item.OrderId</span></td>
                                    <td class="text-start">
                                        <span class="fw-bolder text-dark d-block" style="white-space: pre-wrap;">@item.CustomerName</span>
                                        <div class="d-flex align-items-center gap-2 mt-1">
                                            <a href="tel:@item.PhoneNumber" class="text-decoration-none text-muted fw-bold small hover-primary-text" dir="ltr">@item.PhoneNumber</a>
                                            <a href="https://wa.me/@whatsappNumber" target="_blank" class="text-success hover-elevate" title="محادثة واتساب"><i class="fa-brands fa-whatsapp fs-5"></i></a>
                                        </div>
                                        @if (isReadyForInstall && (User.IsInRole("Admin") || User.IsInRole("CallCenter")))
                                        {
                                            <div class="mt-2"><span class="premium-badge success payment-btn-pulse px-2 py-1" style="font-size:11px;"><i class="fa-solid fa-box-open me-1"></i> القطعة جاهزة</span></div>
                                        }
                                    </td>
                                    <td>
                                        @switch (item.Type)
                                        {
                                            case KaberSystem.Models.OrderType.Maintenance:
                                                <span class="premium-badge primary-light"><i class="fa-solid fa-wrench me-1"></i> صيانة</span>
                                                break;
                                            case KaberSystem.Models.OrderType.NewInstallation:
                                                <span class="premium-badge success"><i class="fa-solid fa-plug me-1"></i> تركيب</span>
                                                break;
                                            case KaberSystem.Models.OrderType.Warranty:
                                                <span class="premium-badge warning"><i class="fa-solid fa-shield me-1"></i> ضمان</span>
                                                break;
                                            case KaberSystem.Models.OrderType.ACWashing:
                                                <span class="premium-badge info"><i class="fa-solid fa-shower me-1"></i> غسيل</span>
                                                break;
                                        }
                                    </td>
                                    <td>
                                        <div class="d-flex align-items-center justify-content-center gap-2">
                                            <div>
                                                @if (item.ScheduledDate.HasValue)
                                                {
                                                    <div class="fw-bolder text-primary fs-6" dir="ltr">@item.ScheduledDate.Value.ToString("yyyy-MM-dd")</div>
                                                    <div class="fw-bold text-dark small mt-1" dir="ltr"><i class="fa-regular fa-clock text-warning me-1"></i> @item.ScheduledDate.Value.ToString("hh:mm tt")</div>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-light text-danger border border-danger px-2 py-1 rounded-pill"><i class="fa-solid fa-triangle-exclamation me-1"></i> لم يحدد موعد</span>
                                                }
                                                <div class="text-muted small mt-2" style="font-size: 10px;">أُنشئ: @item.CreatedAt.ToString("MM/dd")</div>
                                            </div>
                                            @if (User.IsInRole("Admin") || User.IsInRole("CallCenter"))
                                            {
                                                <button type="button" class="btn btn-sm btn-light border text-primary rounded-circle hover-elevate shadow-sm" style="width: 32px; height: 32px;" onclick="openEditScheduleModal(@item.OrderId, '@(item.ScheduledDate?.ToString("yyyy-MM-ddTHH:mm") ?? "")')" title="تعديل أو إلغاء الموعد">
                                                    <i class="fa-solid fa-pen-to-square"></i>
                                                </button>
                                            }
                                        </div>
                                    </td>
                                    @if (!User.IsInRole("Technician"))
                                    {
                                        <td>
                                            @if (item.Technician != null)
                                            {
                                                <div class="d-inline-flex align-items-center bg-light border rounded-pill px-3 py-1 shadow-sm"><i class="fa-solid fa-user-gear text-primary me-2 small"></i><span class="text-dark fw-bold small">@item.Technician.Name</span></div>
                                            }
                                            else
                                            {
                                                <span class="premium-badge warning"><i class="fa-solid fa-clock me-1"></i> بانتظار التعيين</span>
                                            }
                                        </td>
                                    }
                                    <td>
                                        @switch (item.Status)
                                        {
                                            case KaberSystem.Models.OrderStatus.New:
                                                <span class="premium-badge default shadow-sm">جديد</span>
                                                break;
                                            case KaberSystem.Models.OrderStatus.Assigned:
                                                <span class="premium-badge primary shadow-sm">تم التعيين</span>
                                                break;
                                            case KaberSystem.Models.OrderStatus.Confirmed:
                                                <span class="premium-badge warning shadow-sm">مؤكد</span>
                                                break;
                                            case KaberSystem.Models.OrderStatus.InProgress:
                                                <span class="premium-badge info shadow-sm">قيد التنفيذ</span>
                                                break;
                                            case KaberSystem.Models.OrderStatus.Completed:
                                                <span class="premium-badge dark shadow-sm"><i class="fa-solid fa-clock me-1"></i> للمراجعة / يطبع فاتورة</span>
                                                break;
                                            case KaberSystem.Models.OrderStatus.Approved:
                                                <span class="premium-badge success shadow-sm"><i class="fa-solid fa-check-double me-1"></i> معتمد نهائي</span>
                                                break;
                                            case KaberSystem.Models.OrderStatus.Returned:
                                                <span class="premium-badge danger shadow-sm"><i class="fa-solid fa-rotate-left me-1"></i> مُرجع للفني</span>
                                                break;
                                            case KaberSystem.Models.OrderStatus.Cancelled:
                                                <span class="premium-badge danger shadow-sm"><i class="fa-solid fa-ban me-1"></i> ملغي</span>
                                                break;
                                        }
                                    </td>
                                    <td>
                                        <!-- 📌 أزرار الإجراءات المباشرة (تعديل وحذف بجوار فتح) -->
                                        <div class="d-flex gap-2 justify-content-center align-items-center">
                                            <a href="/Orders/Details/@item.OrderId" class="btn btn-sm btn-light border text-primary fw-bold px-3 rounded-pill hover-elevate shadow-sm"><i class="fa-solid fa-folder-open me-1"></i> فتح</a>

                                            @if (User.IsInRole("Admin") || User.IsInRole("CallCenter"))
                                            {
                                                <a href="/Orders/Edit/@item.OrderId" class="btn btn-sm btn-warning text-dark fw-bold px-3 rounded-pill shadow-sm hover-elevate" title="تعديل الطلب">
                                                    <i class="fa-solid fa-pen me-1"></i> تعديل
                                                </a>

                                                @if (item.Status == KaberSystem.Models.OrderStatus.New)
                                                {
                                                    <a href="/Orders/Assign/@item.OrderId" class="btn btn-sm btn-primary fw-bold text-white rounded-circle hover-elevate d-flex justify-content-center align-items-center shadow-sm" style="width: 32px; height: 32px;" title="تعيين فني"><i class="fa-solid fa-user-plus"></i></a>
                                                }
                                                @if (isReadyForInstall)
                                                {
                                                    <button type="button" class="btn btn-sm btn-success fw-bold px-3 rounded-pill text-white hover-elevate shadow-sm" data-bs-toggle="modal" data-bs-target="#scheduleModal" onclick="setupScheduleModal(@item.OrderId, '@Html.Raw(item.CustomerName.Replace("'", "\\'"))', @(item.TechnicianId ?? 0))"><i class="fa-solid fa-calendar-plus me-1"></i> تركيب</button>
                                                }
                                            }

                                            @if (User.IsInRole("Admin"))
                                            {
                                                <a href="/Orders/Delete/@item.OrderId" onclick="return confirm('تأكيد الحذف النهائي للطلب وكل بياناته؟');" class="btn btn-sm btn-danger rounded-circle hover-elevate d-flex justify-content-center align-items-center shadow-sm" style="width: 32px; height: 32px;" title="حذف نهائي">
                                                    <i class="fa-solid fa-trash"></i>
                                                </a>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                            @if (!todayOrders.Any())
                            {
                                <tr><td colspan="8" class="text-center py-5"><div class="bg-light rounded-circle d-inline-flex align-items-center justify-content-center mb-3 shadow-sm" style="width: 80px; height: 80px;"><i class="fa-solid fa-box-open fs-2 text-muted opacity-50"></i></div><h6 class="text-muted fw-bold m-0">لا توجد طلبات هنا حالياً.</h6></td></tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- 📌 2. تبويب مواعيد المستقبل -->
            <div class="tab-pane fade" id="future" role="tabpanel">
                <div class="table-responsive p-0">
                    <table class="table premium-table align-middle text-center mb-0 w-100">
                        <thead class="bg-light">
                            <tr>
                                <th class="text-start ps-4">رقم الطلب</th>
                                <th class="text-start">اسم العميل والتواصل</th>
                                <th>نوع الطلب</th>
                                <th>موعد الزيارة (الجدولة)</th>
                                @if (!User.IsInRole("Technician"))
                                {
                                    <th>الفني المختص</th>
                                }
                                <th>حالة الطلب</th>
                                <th>إجراءات الإدارة</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in futureOrders)
                            {
                                string phoneStr = item.PhoneNumber.StartsWith("0") ? item.PhoneNumber.Substring(1) : item.PhoneNumber;
                                string whatsappNumber = "966" + phoneStr;
                                bool isReadyForInstall = ordersWithReadyParts.Contains(item.OrderId);
                                string rowClass = isReadyForInstall && (User.IsInRole("Admin") || User.IsInRole("CallCenter")) ? "ready-install-row" : "";

                                <tr class="@rowClass" style="border-bottom: 1px solid #f1f5f9;">
                                    <td class="text-start ps-4"><span class="premium-badge default fs-6 shadow-sm border">#@item.OrderId</span></td>
                                    <td class="text-start">
                                        <span class="fw-bolder text-dark d-block" style="white-space: pre-wrap;">@item.CustomerName</span>
                                        <div class="d-flex align-items-center gap-2 mt-1">
                                            <a href="tel:@item.PhoneNumber" class="text-decoration-none text-muted fw-bold small hover-primary-text" dir="ltr">@item.PhoneNumber</a>
                                            <a href="https://wa.me/@whatsappNumber" target="_blank" class="text-success hover-elevate" title="محادثة واتساب"><i class="fa-brands fa-whatsapp fs-5"></i></a>
                                        </div>
                                        @if (isReadyForInstall && (User.IsInRole("Admin") || User.IsInRole("CallCenter")))
                                        {
                                            <div class="mt-2"><span class="premium-badge success payment-btn-pulse px-2 py-1" style="font-size:11px;"><i class="fa-solid fa-box-open me-1"></i> القطعة جاهزة</span></div>
                                        }
                                    </td>
                                    <td>
                                        @switch (item.Type)
                                        {
                                            case KaberSystem.Models.OrderType.Maintenance:
                                                <span class="premium-badge primary-light"><i class="fa-solid fa-wrench me-1"></i> صيانة</span>
                                                break;
                                            case KaberSystem.Models.OrderType.NewInstallation:

                                                <span class="premium-badge success"><i class="fa-solid fa-plug me-1"></i> تركيب</span>
                                                break;
                                            case KaberSystem.Models.OrderType.Warranty:

                                                <span class="premium-badge warning"><i class="fa-solid fa-shield me-1"></i> ضمان</span>
                                                break;
                                            case KaberSystem.Models.OrderType.ACWashing:

                                                <span class="premium-badge info"><i class="fa-solid fa-shower me-1"></i> غسيل</span>
                                                break;
                                        }
                                    </td>
                                    <td>
                                        <div class="d-flex align-items-center justify-content-center gap-2">
                                            <div>
                                                @if (item.ScheduledDate.HasValue)
                                                {
                                                    <div class="fw-bolder text-primary fs-6" dir="ltr">@item.ScheduledDate.Value.ToString("yyyy-MM-dd")</div>
                                                    <div class="fw-bold text-dark small mt-1" dir="ltr"><i class="fa-regular fa-clock text-warning me-1"></i> @item.ScheduledDate.Value.ToString("hh:mm tt")</div>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-light text-danger border border-danger px-2 py-1 rounded-pill"><i class="fa-solid fa-triangle-exclamation me-1"></i> لم يحدد موعد</span>
                                                }
                                            </div>
                                            @if (User.IsInRole("Admin") || User.IsInRole("CallCenter"))
                                            {
                                                <button type="button" class="btn btn-sm btn-light border text-primary rounded-circle hover-elevate shadow-sm" style="width: 32px; height: 32px;" onclick="openEditScheduleModal(@item.OrderId, '@(item.ScheduledDate?.ToString("yyyy-MM-ddTHH:mm") ?? "")')" title="تعديل أو إلغاء الموعد">
                                                    <i class="fa-solid fa-pen-to-square"></i>
                                                </button>
                                            }
                                        </div>
                                    </td>
                                    @if (!User.IsInRole("Technician"))
                                    {
                                        <td>
                                            @if (item.Technician != null)
                                            {
                                                <div class="d-inline-flex align-items-center bg-light border rounded-pill px-3 py-1 shadow-sm"><i class="fa-solid fa-user-gear text-primary me-2 small"></i><span class="text-dark fw-bold small">@item.Technician.Name</span></div>
                                            }
                                            else
                                            {

                                                <span class="premium-badge warning"><i class="fa-solid fa-clock me-1"></i> بانتظار التعيين</span>
                                            }
                                        </td>
                                    }
                                    <td>
                                        @switch (item.Status)
                                        {
                                            case KaberSystem.Models.OrderStatus.New:
                                                <span class="premium-badge default shadow-sm">جديد</span>
                                                break;
                                            case KaberSystem.Models.OrderStatus.Assigned:

                                                <span class="premium-badge primary shadow-sm">تم التعيين</span>
                                                break;
                                            case KaberSystem.Models.OrderStatus.Confirmed:

                                                <span class="premium-badge warning shadow-sm">مؤكد</span>
                                                break;
                                            case KaberSystem.Models.OrderStatus.InProgress:

                                                <span class="premium-badge info shadow-sm">قيد التنفيذ</span>
                                                break;
                                            case KaberSystem.Models.OrderStatus.Completed:

                                                <span class="premium-badge dark shadow-sm"><i class="fa-solid fa-clock me-1"></i> للمراجعة / يطبع فاتورة</span>
                                                break;
                                            case KaberSystem.Models.OrderStatus.Approved:

                                                <span class="premium-badge success shadow-sm"><i class="fa-solid fa-check-double me-1"></i> معتمد نهائي</span>
                                                break;
                                            case KaberSystem.Models.OrderStatus.Returned:

                                                <span class="premium-badge danger shadow-sm"><i class="fa-solid fa-rotate-left me-1"></i> مُرجع للفني</span>
                                                break;
                                        }
                                    </td>
                                    <td>
                                        <!-- 📌 أزرار الإجراءات المباشرة -->
                                        <div class="d-flex gap-2 justify-content-center align-items-center">
                                            <a href="/Orders/Details/@item.OrderId" class="btn btn-sm btn-light border text-primary fw-bold px-3 rounded-pill hover-elevate shadow-sm"><i class="fa-solid fa-folder-open me-1"></i> فتح</a>

                                            @if (User.IsInRole("Admin") || User.IsInRole("CallCenter"))
                                            {
                                                <a href="/Orders/Edit/@item.OrderId" class="btn btn-sm btn-warning text-dark fw-bold px-3 rounded-pill shadow-sm hover-elevate" title="تعديل الطلب">
                                                    <i class="fa-solid fa-pen me-1"></i> تعديل
                                                </a>
                                            }

                                            @if (User.IsInRole("Admin"))
                                            {
                                                <a href="/Orders/Delete/@item.OrderId" onclick="return confirm('تأكيد الحذف النهائي للطلب وكل بياناته؟');" class="btn btn-sm btn-danger rounded-circle hover-elevate d-flex justify-content-center align-items-center shadow-sm" style="width: 32px; height: 32px;" title="حذف نهائي">
                                                    <i class="fa-solid fa-trash"></i>
                                                </a>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                            @if (!futureOrders.Any())
                            {
                                <tr><td colspan="8" class="text-center py-5"><div class="bg-light rounded-circle d-inline-flex align-items-center justify-content-center mb-3 shadow-sm" style="width: 80px; height: 80px;"><i class="fa-solid fa-calendar-check fs-2 text-muted opacity-50"></i></div><h6 class="text-muted fw-bold m-0">لا توجد مواعيد مستقبلية.</h6></td></tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- 📌 3. تبويب السجل الماضي (المعتمدة والملغاة) -->
            <div class="tab-pane fade" id="past" role="tabpanel">
                <div class="table-responsive p-0">
                    <table class="table premium-table align-middle text-center mb-0 w-100">
                        <thead class="bg-light">
                            <tr>
                                <th class="text-start ps-4">رقم الطلب</th>
                                <th class="text-start">اسم العميل والتواصل</th>
                                <th>نوع الطلب</th>
                                <th>موعد الزيارة</th>
                                @if (!User.IsInRole("Technician"))
                                {
                                    <th>الفني المختص</th>
                                }
                                <th>حالة الطلب</th>
                                <th>إجراءات الإدارة</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in pastOrders)
                            {
                                string phoneStr = item.PhoneNumber.StartsWith("0") ? item.PhoneNumber.Substring(1) : item.PhoneNumber;
                                string whatsappNumber = "966" + phoneStr;

                                <tr style="border-bottom: 1px solid #f1f5f9;">
                                    <td class="text-start ps-4"><span class="premium-badge default fs-6 shadow-sm border">#@item.OrderId</span></td>
                                    <td class="text-start">
                                        <span class="fw-bolder text-dark d-block" style="white-space: pre-wrap;">@item.CustomerName</span>
                                        <div class="d-flex align-items-center gap-2 mt-1">
                                            <a href="tel:@item.PhoneNumber" class="text-decoration-none text-muted fw-bold small hover-primary-text" dir="ltr">@item.PhoneNumber</a>
                                            <a href="https://wa.me/@whatsappNumber" target="_blank" class="text-success hover-elevate" title="محادثة واتساب"><i class="fa-brands fa-whatsapp fs-5"></i></a>
                                        </div>
                                    </td>
                                    <td>
                                        @switch (item.Type)
                                        {
                                            case KaberSystem.Models.OrderType.Maintenance:
                                                <span class="premium-badge primary-light"><i class="fa-solid fa-wrench me-1"></i> صيانة</span>
                                                break;
                                            case KaberSystem.Models.OrderType.NewInstallation:

                                                <span class="premium-badge success"><i class="fa-solid fa-plug me-1"></i> تركيب</span>
                                                break;
                                            case KaberSystem.Models.OrderType.Warranty:

                                                <span class="premium-badge warning"><i class="fa-solid fa-shield me-1"></i> ضمان</span>
                                                break;
                                            case KaberSystem.Models.OrderType.ACWashing:

                                                <span class="premium-badge info"><i class="fa-solid fa-shower me-1"></i> غسيل</span>
                                                break;
                                        }
                                    </td>
                                    <td>
                                        @if (item.ScheduledDate.HasValue)
                                        {
                                            <div class="fw-bolder text-primary fs-6" dir="ltr">@item.ScheduledDate.Value.ToString("yyyy-MM-dd")</div>
                                        }
                                    </td>
                                    @if (!User.IsInRole("Technician"))
                                    {
                                        <td>
                                            @if (item.Technician != null)
                                            {
                                                <div class="d-inline-flex align-items-center bg-light border rounded-pill px-3 py-1 shadow-sm"><i class="fa-solid fa-user-gear text-primary me-2 small"></i><span class="text-dark fw-bold small">@item.Technician.Name</span></div>
                                            }
                                        </td>
                                    }
                                    <td>
                                        @if (item.Status == OrderStatus.Approved)
                                        {
                                            <span class="premium-badge success shadow-sm"><i class="fa-solid fa-check-double me-1"></i> معتمد نهائي</span>
                                        }
                                        else if (item.Status == OrderStatus.Cancelled)
                                        {

                                            <span class="premium-badge danger shadow-sm"><i class="fa-solid fa-ban me-1"></i> ملغي</span>
                                        }
                                    </td>
                                    <td>
                                        <div class="d-flex gap-2 justify-content-center align-items-center">
                                            <a href="/Orders/Details/@item.OrderId" class="btn btn-sm btn-light border text-primary fw-bold px-3 rounded-pill hover-elevate shadow-sm"><i class="fa-solid fa-folder-open me-1"></i> السجل</a>

                                            @if (User.IsInRole("Admin") || User.IsInRole("CallCenter"))
                                            {
                                                <a href="/Orders/Edit/@item.OrderId" class="btn btn-sm btn-warning text-dark fw-bold px-3 rounded-pill shadow-sm hover-elevate" title="تعديل الطلب">
                                                    <i class="fa-solid fa-pen me-1"></i> تعديل
                                                </a>
                                            }

                                            @if (User.IsInRole("Admin"))
                                            {
                                                <a href="/Orders/Delete/@item.OrderId" onclick="return confirm('تأكيد الحذف النهائي للطلب وكل بياناته؟');" class="btn btn-sm btn-danger rounded-circle hover-elevate d-flex justify-content-center align-items-center shadow-sm" style="width: 32px; height: 32px;" title="حذف نهائي">
                                                    <i class="fa-solid fa-trash"></i>
                                                </a>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                            @if (!pastOrders.Any())
                            {
                                <tr><td colspan="8" class="text-center py-5"><div class="bg-light rounded-circle d-inline-flex align-items-center justify-content-center mb-3 shadow-sm" style="width: 80px; height: 80px;"><i class="fa-solid fa-box-archive fs-2 text-muted opacity-50"></i></div><h6 class="text-muted fw-bold m-0">السجل المعتمد فارغ.</h6></td></tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

        </div>
    </div>
</div>

<!-- Modal تحديد موعد تركيب للإدارة -->
@if (User.IsInRole("Admin") || User.IsInRole("CallCenter"))
{
    <div class="modal fade" id="scheduleModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content premium-modal border-0 shadow-lg">
                <div class="modal-header border-bottom-0 pb-0 px-4 pt-4">
                    <h4 class="fw-bolder text-success m-0"><i class="fa-solid fa-calendar-check me-2"></i> تحديد موعد تركيب نواقص</h4>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <form asp-action="ScheduleInstallation" method="post">
                    <div class="modal-body p-4 text-start">
                        <input type="hidden" name="orderId" id="schedOrderId" value="" />

                        <div class="premium-alert success px-4 py-3 mb-4">
                            <div class="icon-box" style="width:30px; height:30px; font-size:14px;"><i class="fa-solid fa-info"></i></div>
                            <div class="content">
                                <h6 class="fw-bolder m-0">القطعة المطلوبة متوفرة لطلب العميل:</h6>
                                <span id="schedCustomerName" class="text-dark fw-bolder fs-6 d-block mt-1"></span>
                            </div>
                        </div>

                        <div class="mb-4">
                            <label class="premium-label">الموعد الجديد لزيارة التركيب <span class="text-danger">*</span></label>
                            <input type="datetime-local" name="scheduledDate" class="premium-input form-control" required />
                        </div>

                        <div class="mb-4">
                            <label class="premium-label">تأكيد الفني <span class="text-danger">*</span></label>
                            <select name="technicianId" id="schedTechId" class="premium-input form-select fw-bold" required>
                                <option value="">-- اختر الفني --</option>
                                @if (techsList != null)
                                {
                                    foreach (var t in techsList)
                                    {
                                        <option value="@t.TechnicianId">@t.Name</option>
                                    }
                                }
                            </select>
                        </div>

                        <div class="mb-4">
                            <label class="premium-label">رسوم التركيب الإضافية (إن وجدت)</label>
                            <div class="input-group shadow-sm">
                                <input type="number" step="0.01" name="additionalInstallFee" id="schedLaborFee" class="premium-input form-control border-0 bg-light rounded-end" value="0" required />
                                <span class="input-group-text bg-white border-0 rounded-start fw-bolder text-success px-4">ر.س</span>
                            </div>
                        </div>

                        <div class="mb-2">
                            <label class="premium-label">ملاحظات <span class="text-muted fw-normal">(اختياري)</span></label>
                            <textarea name="adminNotes" class="premium-input form-control" rows="2"></textarea>
                        </div>
                    </div>
                    <div class="modal-footer border-top-0 pt-0 px-4 pb-4">
                        <button type="button" class="btn btn-light fw-bold px-4 rounded-pill" data-bs-dismiss="modal">إلغاء</button>
                        <button type="submit" class="btn btn-success fw-bolder px-4 rounded-pill shadow-sm hover-elevate">تأكيد الجدولة <i class="fa-solid fa-check-double ms-1"></i></button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- 📌 التحديث الجديد: نافذة تعديل أو إلغاء الموعد الحالي -->
    <div class="modal fade" id="editScheduleModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content premium-modal border-0 shadow-lg">
                <div class="modal-header border-bottom-0 pb-0 px-4 pt-4">
                    <h4 class="fw-bolder text-primary m-0"><i class="fa-solid fa-clock-rotate-left me-2"></i> تعديل موعد الزيارة</h4>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <form asp-action="UpdateSchedule" method="post" id="editScheduleForm">
                    <div class="modal-body p-4 text-start">
                        <input type="hidden" name="orderId" id="editSchedOrderId" value="" />

                        <div class="mb-4">
                            <label class="premium-label">الموعد الجديد للزيارة</label>
                            <input type="datetime-local" name="newScheduledDate" id="editSchedInput" class="premium-input form-control" />
                            <small class="text-muted fw-bold mt-2 d-block">اترك الحقل فارغاً أو اضغط على (إلغاء الموعد) إذا كنت تريد جعل الطلب بدون موعد مؤقتاً.</small>
                        </div>

                    </div>
                    <div class="modal-footer border-top-0 pt-0 px-4 pb-4 d-flex justify-content-between">
                        <button type="button" class="btn btn-danger fw-bolder px-4 rounded-pill shadow-sm hover-elevate" onclick="clearScheduleAndSubmit()">
                            <i class="fa-solid fa-calendar-xmark me-1"></i> إلغاء الموعد تماماً
                        </button>
                        <div>
                            <button type="button" class="btn btn-light fw-bold px-4 rounded-pill" data-bs-dismiss="modal">إغلاق</button>
                            <button type="submit" class="btn btn-primary fw-bolder px-4 rounded-pill shadow-sm hover-elevate">
                                <i class="fa-solid fa-save me-1"></i> حفظ الموعد
                            </button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
}

<style>
    :root {
        --prem-surface: #ffffff;
        --prem-border: #e2e8f0;
        --prem-text: #1e293b;
        --prem-muted: #64748b;
        --prem-primary: #f1950b;
        --prem-radius: 20px;
    }

    .fade-in-up {
        animation: fadeInUp 0.6s cubic-bezier(0.16, 1, 0.3, 1) both;
    }

    @@keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(20px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .premium-card {
        background: var(--prem-surface);
        border-radius: var(--prem-radius);
        border: 1px solid var(--prem-border);
        box-shadow: 0 10px 30px rgba(0,0,0,0.02);
        overflow: hidden;
    }

    .card-header-premium {
        padding: 20px 24px;
        border-bottom: 1px solid var(--prem-border);
    }

    .card-body-premium {
        padding: 24px;
    }

    .premium-tabs .nav-link {
        color: var(--prem-muted);
        transition: 0.3s ease;
        border: 1px solid transparent;
        background: #f8fafc;
        margin-bottom: 5px;
    }

        .premium-tabs .nav-link:hover {
            background: #f1f5f9;
            border-color: var(--prem-border);
            color: var(--prem-text);
        }

        .premium-tabs .nav-link.active {
            background: var(--prem-primary);
            color: white !important;
            box-shadow: 0 4px 15px rgba(241,149,11,0.2);
        }

            .premium-tabs .nav-link.active .badge {
                color: var(--prem-primary) !important;
            }

    .premium-label {
        font-weight: 800;
        color: var(--prem-muted);
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        margin-bottom: 8px;
        display: block;
    }

    .premium-input {
        background-color: #f8fafc;
        border: 1px solid var(--prem-border);
        border-radius: 12px;
        padding: 14px 20px;
        font-weight: 700;
        color: var(--prem-text);
        box-shadow: none !important;
        transition: all 0.3s ease;
    }

        .premium-input:focus {
            background-color: #fff;
            border-color: var(--prem-primary);
            box-shadow: 0 0 0 4px rgba(241, 149, 11, 0.1) !important;
        }

    .premium-badge {
        padding: 6px 16px;
        border-radius: 30px;
        font-size: 0.85rem;
        font-weight: 800;
    }

        .premium-badge.default {
            background: #f1f5f9;
            color: #475569;
            border: 1px solid #e2e8f0;
        }

        .premium-badge.primary {
            background: rgba(241,149,11,0.1);
            color: var(--prem-primary);
            border: 1px solid rgba(241,149,11,0.2);
        }

        .premium-badge.success {
            background: #ecfdf5;
            color: #198754;
            border: 1px solid #d1e7dd;
        }

        .premium-badge.warning {
            background: #fff3cd;
            color: #856404;
            border: 1px solid #ffeeba;
        }

        .premium-badge.info {
            background: #cff4fc;
            color: #055160;
            border: 1px solid #b6effb;
        }

        .premium-badge.danger {
            background: #f8d7da;
            color: #842029;
            border: 1px solid #f5c2c7;
        }

        .premium-badge.dark {
            background: #e2e3e5;
            color: #41464b;
            border: 1px solid #d3d6d8;
        }

        .premium-badge.primary-light {
            background: #e0e7ff;
            color: #4f46e5;
        }

        .premium-badge.dark-light {
            background: #f1f5f9;
            color: #0f172a;
        }

    .premium-alert {
        background: #fffbfa;
        border: 1px solid #fee2e2;
        border-radius: 16px;
        padding: 20px;
        display: flex;
        align-items: flex-start;
        gap: 15px;
        box-shadow: 0 4px 12px rgba(239, 68, 68, 0.05);
    }

        .premium-alert.info {
            background: #f0f9ff;
            border-color: #bae6fd;
            box-shadow: 0 4px 12px rgba(14, 165, 233, 0.05);
        }

            .premium-alert.info .icon-box {
                background: #bae6fd;
                color: #0284c7;
            }

        .premium-alert.success {
            background: #f0fdf4;
            border-color: #bbf7d0;
        }

            .premium-alert.success .icon-box {
                background: #bbf7d0;
                color: #16a34a;
            }

        .premium-alert .icon-box {
            width: 45px;
            height: 45px;
            border-radius: 12px;
            display: flex;
            justify-content: center;
            align-items: center;
            font-size: 20px;
            flex-shrink: 0;
        }

    .premium-table th {
        font-weight: 800;
        color: var(--prem-muted);
        border-bottom: 2px solid var(--prem-border);
        padding: 16px;
        font-size: 0.85rem;
        text-transform: uppercase;
    }

    .premium-table td {
        padding: 16px;
        vertical-align: middle;
    }

    .premium-table tr:hover td {
        background-color: #f8fafc;
    }

    .ready-install-row td {
        background-color: rgba(25, 135, 84, 0.02) !important;
    }

    .ready-install-row:hover td {
        background-color: rgba(25, 135, 84, 0.05) !important;
    }

    .premium-modal {
        border-radius: 24px;
        overflow: hidden;
    }

    .hover-elevate {
        transition: transform 0.2s cubic-bezier(0.4, 0, 0.2, 1), box-shadow 0.2s;
    }

        .hover-elevate:hover {
            transform: translateY(-3px);
            box-shadow: 0 10px 20px rgba(0,0,0,0.08) !important;
        }

    .btn-whatsapp-icon {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 36px;
        height: 36px;
        background: #ecfdf5;
        color: #10b981;
        border-radius: 10px;
        font-size: 18px;
        transition: 0.3s;
        text-decoration: none;
    }

        .btn-whatsapp-icon:hover {
            background: #10b981;
            color: #fff;
            transform: scale(1.1);
        }

    .hover-primary-text {
        transition: color 0.2s;
    }

        .hover-primary-text:hover {
            color: var(--prem-primary) !important;
        }

    .payment-btn-pulse {
        animation: pulseGreen 2s infinite;
    }

    @@keyframes pulseGreen {
        0% {
            box-shadow: 0 0 0 0 rgba(25, 135, 84, 0.4);
        }

        70% {
            box-shadow: 0 0 0 10px rgba(25, 135, 84, 0);
        }

        100% {
            box-shadow: 0 0 0 0 rgba(25, 135, 84, 0);
        }
    }

    .premium-swal {
        border-radius: 20px !important;
    }
</style>

@section Scripts {
    <script>
        function setupScheduleModal(orderId, customerName, currentTechId) {
            document.getElementById('schedOrderId').value = orderId;
            document.getElementById('schedCustomerName').innerText = customerName;
            document.getElementById('schedLaborFee').value = 0;
            if(currentTechId && currentTechId > 0) {
                document.getElementById('schedTechId').value = currentTechId;
            } else {
                document.getElementById('schedTechId').value = "";
            }
        }

        // 📌 التحديث الجديد: سكربت فتح مودال تعديل الموعد وإلغاؤه
        function openEditScheduleModal(orderId, currentDateStr) {
            document.getElementById('editSchedOrderId').value = orderId;
            document.getElementById('editSchedInput').value = currentDateStr;
            var myModal = new bootstrap.Modal(document.getElementById('editScheduleModal'));
            myModal.show();
        }

        function clearScheduleAndSubmit() {
            document.getElementById('editSchedInput').value = '';
            document.getElementById('editScheduleForm').submit();
        }

        @if (TempData["SuccessMessage"] != null)
        {
                    var msg = System.Text.Json.JsonSerializer.Serialize(TempData["SuccessMessage"]?.ToString());
                    <text>Swal.fire({ icon: 'success', title: 'عملية ناجحة', text: @Html.Raw(msg), confirmButtonColor: '#198754', customClass: { popup: 'premium-swal' } });</text>
        }
        @if (TempData["ErrorMessage"] != null)
        {
                    var errMsg = System.Text.Json.JsonSerializer.Serialize(TempData["ErrorMessage"]?.ToString());
                    <text>Swal.fire({ icon: 'error', title: 'تنبيه', text: @Html.Raw(errMsg), confirmButtonColor: '#ee5d50', customClass: { popup: 'premium-swal' } });</text>
        }
    </script>
}