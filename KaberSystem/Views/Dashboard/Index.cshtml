@model IEnumerable<KaberSystem.Models.Order>
@{
    ViewData["Title"] = "لوحة القيادة الإحصائية";
    Layout = "~/Views/Shared/_SystemLayout.cshtml";
}

<div class="sys-page-header">
    <div>
        <h1 class="sys-page-title">نظرة عامة على أداء النظام</h1>
        <p class="sys-page-desc">متابعة سير العمل، الإيرادات، وأداء الفنيين بشكل لحظي وتفاعلي</p>
    </div>
    <div class="d-flex gap-2">
        <button class="btn btn-light border fw-bold text-muted" onclick="location.reload();">
            <i class="fa-solid fa-rotate-right"></i> تحديث البيانات
        </button>
        <a href="/Orders/Create" class="sys-btn sys-btn-primary">
            <i class="fa-solid fa-plus"></i> طلب صيانة جديد
        </a>
    </div>
</div>

<!-- بطاقات الإحصائيات (KPIs) -->
<div class="row g-4 mb-4">
    <div class="col-xl-3 col-lg-6">
        <div class="sys-card d-flex align-items-center h-100 p-4 position-relative overflow-hidden" style="border-bottom: 4px solid var(--sys-primary);">
            <div class="flex-grow-1 position-relative z-1">
                <h6 class="text-muted fw-bold mb-2">إجمالي الطلبات</h6>
                <h2 class="fw-bold m-0 text-dark">@ViewData["TotalOrders"]</h2>
            </div>
            <div class="bg-light rounded-circle d-flex align-items-center justify-content-center position-relative z-1" style="width: 65px; height: 65px;">
                <i class="fa-solid fa-chart-line fs-3 text-primary"></i>
            </div>
            <i class="fa-solid fa-chart-line position-absolute text-light" style="font-size: 100px; right: -15px; bottom: -20px; opacity: 0.4; z-index: 0;"></i>
        </div>
    </div>

    <div class="col-xl-3 col-lg-6">
        <div class="sys-card d-flex align-items-center h-100 p-4 position-relative overflow-hidden" style="border-bottom: 4px solid var(--sys-success);">
            <div class="flex-grow-1 position-relative z-1">
                <h6 class="text-muted fw-bold mb-2">الطلبات المنجزة</h6>
                <h2 class="fw-bold m-0 text-dark">@ViewData["CompletedOrders"]</h2>
            </div>
            <div class="rounded-circle d-flex align-items-center justify-content-center position-relative z-1" style="width: 65px; height: 65px; background-color: var(--sys-success-light);">
                <i class="fa-solid fa-check-double fs-3 text-success"></i>
            </div>
            <i class="fa-solid fa-check-circle position-absolute text-light" style="font-size: 100px; right: -15px; bottom: -20px; opacity: 0.4; z-index: 0;"></i>
        </div>
    </div>

    <div class="col-xl-3 col-lg-6">
        <div class="sys-card d-flex align-items-center h-100 p-4 position-relative overflow-hidden" style="border-bottom: 4px solid var(--sys-info);">
            <div class="flex-grow-1 position-relative z-1">
                <h6 class="text-muted fw-bold mb-2">الإيرادات المحصلة</h6>
                <h2 class="fw-bold m-0 text-dark">@ViewData["TotalRevenue"] <span class="fs-6">ر.س</span></h2>
            </div>
            <div class="rounded-circle d-flex align-items-center justify-content-center position-relative z-1" style="width: 65px; height: 65px; background-color: #eef2ff;">
                <i class="fa-solid fa-wallet fs-3 text-info"></i>
            </div>
            <i class="fa-solid fa-sack-dollar position-absolute text-light" style="font-size: 100px; right: -15px; bottom: -20px; opacity: 0.4; z-index: 0;"></i>
        </div>
    </div>

    <div class="col-xl-3 col-lg-6">
        <div class="sys-card d-flex align-items-center h-100 p-4 position-relative overflow-hidden" style="border-bottom: 4px solid var(--sys-warning);">
            <div class="flex-grow-1 position-relative z-1">
                <h6 class="text-muted fw-bold mb-2">فنيين متاحين للعمل</h6>
                <h2 class="fw-bold m-0 text-dark">@ViewData["ActiveTechnicians"]</h2>
            </div>
            <div class="rounded-circle d-flex align-items-center justify-content-center position-relative z-1" style="width: 65px; height: 65px; background-color: #fff9e6;">
                <i class="fa-solid fa-users-gear fs-3 text-warning"></i>
            </div>
            <i class="fa-solid fa-users position-absolute text-light" style="font-size: 100px; right: -15px; bottom: -20px; opacity: 0.4; z-index: 0;"></i>
        </div>
    </div>
</div>

<!-- قسم الرسوم البيانية (Charts) -->
<div class="row g-4 mb-4">
    <!-- رسم بياني لحالات الطلبات -->
    <div class="col-lg-4">
        <div class="sys-card h-100">
            <h5 class="fw-bold text-secondary border-bottom pb-3 mb-4"><i class="fa-solid fa-chart-pie text-primary me-2"></i> توزيع حالات الطلبات</h5>
            <div style="height: 250px; position: relative;">
                <canvas id="orderStatusChart"></canvas>
            </div>
        </div>
    </div>

    <!-- رسم بياني للإيرادات -->
    <div class="col-lg-8">
        <div class="sys-card h-100">
            <h5 class="fw-bold text-secondary border-bottom pb-3 mb-4"><i class="fa-solid fa-chart-column text-primary me-2"></i> إحصائيات الإيرادات (آخر 6 أشهر)</h5>
            <div style="height: 250px; position: relative;">
                <canvas id="revenueChart"></canvas>
            </div>
        </div>
    </div>
</div>

<!-- أحدث الطلبات -->
<div class="row">
    <div class="col-12">
        <div class="sys-card">
            <div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-3">
                <h4 class="fw-bold text-primary m-0"><i class="fa-solid fa-clock-rotate-left me-2"></i> أحدث الطلبات الواردة</h4>
                <a href="/Orders/Index" class="btn btn-sm btn-light border fw-bold text-dark">فتح سجل الطلبات كامل <i class="fa-solid fa-arrow-left ms-1"></i></a>
            </div>

            <div class="table-responsive">
                <table class="table table-hover align-middle sys-table text-center w-100">
                    <thead class="table-light">
                        <tr>
                            <th>رقم الطلب</th>
                            <th>اسم العميل</th>
                            <th>تاريخ ووقت الطلب</th>
                            <th>الفني المعين</th>
                            <th>الحالة</th>
                            <th>الإجراء</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td><span class="fw-bold px-2 py-1 bg-light border rounded text-primary">#@item.OrderId</span></td>
                                <td class="fw-bold text-dark">@item.CustomerName</td>
                                <td class="text-muted fw-bold">@item.CreatedAt.ToString("yyyy/MM/dd - hh:mm tt")</td>
                                <td>
                                    @if (item.Technician != null)
                                    {
                                        <span class="badge bg-light text-primary border border-primary rounded-pill px-3 py-2 fs-6">
                                            <i class="fa-solid fa-user-gear me-1"></i> @item.Technician.Name
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-light text-muted border rounded-pill px-3 py-2"><i class="fa-solid fa-clock text-warning"></i> بانتظار التعيين</span>
                                    }
                                </td>
                                <td>
                                    @switch (item.Status)
                                    {
                                        case KaberSystem.Models.OrderStatus.New:
                                            <span class="badge bg-secondary rounded-pill px-3 py-2">جديد</span>
                                            break;
                                        case KaberSystem.Models.OrderStatus.Completed:
                                            <span class="badge bg-success rounded-pill px-3 py-2">مكتمل</span>
                                            break;
                                        case KaberSystem.Models.OrderStatus.Cancelled:
                                            <span class="badge bg-danger rounded-pill px-3 py-2">ملغي</span>
                                            break;
                                        default:
                                            <span class="badge bg-warning text-dark rounded-pill px-3 py-2">قيد المعالجة</span>
                                            break;
                                    }
                                </td>
                                <td>
                                    <a href="/Orders/Details/@item.OrderId" class="btn btn-sm btn-outline-primary fw-bold rounded-3">
                                        <i class="fa-solid fa-eye"></i> فتح الطلب
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<style>
    .sys-table th {
        color: var(--sys-text-muted);
        font-weight: 800;
        font-size: 14px;
        padding: 16px;
        border-bottom: 2px solid var(--sys-border) !important;
    }

    .sys-table td {
        padding: 16px;
        border-bottom: 1px solid var(--sys-border);
        vertical-align: middle;
    }
</style>

@section Scripts {
    <!-- استدعاء مكتبة Chart.js من الـ CDN مباشرة في الصفحة -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <script>
        document.addEventListener('DOMContentLoaded', function () {
                    if ($.fn.DataTable) {
            $('.sys-table').DataTable({
                "language": {
                    "url": "//cdn.datatables.net/plug-ins/1.13.6/i18n/ar.json"
                },
                "pageLength": 10,
                "ordering": true,
                "info": true,
                "responsive": true,
                "dom": '<"d-flex justify-content-between align-items-center mb-3"lf>rt<"d-flex justify-content-between align-items-center mt-3"ip>'
            });
        }
            // 1. إعداد الرسم البياني الدائري (حالات الطلبات)
            var orderCanvas = document.getElementById('orderStatusChart');
            if (orderCanvas) {
                var ctxOrder = orderCanvas.getContext('2d');
                new Chart(ctxOrder, {
                    type: 'doughnut',
                    data: {
                        labels: ['طلبات جديدة', 'قيد التنفيذ', 'طلبات مكتملة'],
                        datasets: [{
                            // قراءة الأرقام من C# مباشرة
                            data: [@(ViewData["NewOrders"] ?? 0), @(ViewData["InProgressOrders"] ?? 0), @(ViewData["CompletedOrders"] ?? 0)],
                            backgroundColor: ['#a3aed1', '#3965ff', '#05cd99'],
                            borderWidth: 0,
                            hoverOffset: 8
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: {
                            legend: {
                                position: 'bottom',
                                labels: { font: { family: 'Cairo', size: 14 } }
                            }
                        },
                        cutout: '70%'
                    }
                });
            }

            // 2. إعداد الرسم البياني للأعمدة (الإيرادات)
            var revenueCanvas = document.getElementById('revenueChart');
            if (revenueCanvas) {
                var ctxRev = revenueCanvas.getContext('2d');

                // قراءة إجمالي الإيرادات الحالي من C#
                var currentMonthRevenue = @(ViewData["TotalRevenue"] ?? 0);

                new Chart(ctxRev, {
                    type: 'bar',
                    data: {
                        labels: ['يناير', 'فبراير', 'مارس', 'أبريل', 'مايو', 'الشهر الحالي'],
                        datasets: [{
                            label: 'الإيرادات (ر.س)',
                            // أرقام تجريبية للأشهر السابقة، والرقم الحقيقي للشهر الحالي
                            data: [3500, 4200, 5800, 4900, 7100, currentMonthRevenue],
                            backgroundColor: '#f1950b',
                            borderRadius: 6,
                            barPercentage: 0.5
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        scales: {
                            y: {
                                beginAtZero: true,
                                grid: { borderDash: [5, 5], color: '#e9edf7' }
                            },
                            x: {
                                grid: { display: false }
                            }
                        },
                        plugins: {
                            legend: { display: false },
                            tooltip: {
                                titleFont: { family: 'Cairo', size: 14 },
                                bodyFont: { family: 'Cairo', size: 14 },
                                callbacks: {
                                    label: function(context) {
                                        return context.raw + ' ر.س';
                                    }
                                }
                            }
                        }
                    }
                });
            }
        });
    </script>
}