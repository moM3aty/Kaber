@model KaberSystem.Models.SparePart
@{
    ViewData["Title"] = "تعديل الصنف";
    Layout = "~/Views/Shared/_SystemLayout.cshtml";
}

<div class="sys-page-header">
    <div>
        <h1 class="sys-page-title">تعديل بيانات الصنف</h1>
        <p class="sys-page-desc">تحديث معلومات قطعة الغيار، الأسعار، أو الجرد اليدوي للكميات</p>
    </div>
    <a href="/Inventory/Index" class="btn btn-outline-secondary fw-bold px-4 rounded-3 border-2">
        <i class="fa-solid fa-arrow-right"></i> عودة للمخزون
    </a>
</div>

<div class="row justify-content-center mt-3">
    <div class="col-lg-8">
        <div class="sys-card border-top border-4 border-warning shadow-sm">
            <div class="d-flex align-items-center mb-4 pb-3 border-bottom">
                <div class="bg-warning bg-opacity-10 text-warning rounded-circle d-flex justify-content-center align-items-center me-3" style="width: 50px; height: 50px;">
                    <i class="fa-solid fa-pen-to-square fs-4"></i>
                </div>
                <h4 class="fw-bold m-0 text-dark">تعديل: @Model.Name</h4>
            </div>

            <form asp-action="Edit" method="post">
                <input type="hidden" asp-for="PartId" />
                <div class="row g-4">
                    <div class="col-md-12">
                        <!-- الحماية البصرية للكمية -->
                        <div class="col-md-12">
                            <label asp-for="MainStockQuantity" class="form-label fw-bold text-dark">الكمية الحالية بالمخزن (تعديل الجرد)</label>

                            @if (User.IsInRole("Admin"))
                            {
                                <input asp-for="MainStockQuantity" type="number" class="form-control sys-input border-primary" />
                                <small class="text-danger fw-bold mt-2 d-block"><i class="fa-solid fa-triangle-exclamation"></i> أنت تمتلك صلاحية (المدير) للتعديل اليدوي على الكميات.</small>
                            }
                            else
                            {
                                <input asp-for="MainStockQuantity" type="number" class="form-control sys-input bg-light text-muted" readonly style="pointer-events: none;" />
                                <small class="text-danger fw-bold d-block mt-2"><i class="fa-solid fa-lock me-1"></i> غير مصرح لك بتعديل الكمية يدوياً. الكمية تتحدث تلقائياً عبر فواتير المشتريات.</small>
                            }
                        </div>

                        <!-- 📌 إضافة بيانات المورد -->
                        <div class="col-12 border-top pt-3 mt-4">
                            <h5 class="fw-bold text-primary mb-3"><i class="fa-solid fa-truck-field me-2"></i> بيانات المورد (اختياري)</h5>
                        </div>

                        <div class="col-md-4">
                            <label asp-for="SupplierName" class="form-label fw-bold text-dark">اسم المورد / الشركة</label>
                            <input asp-for="SupplierName" class="form-control sys-input" placeholder="اسم مورد هذه القطعة" />
                        </div>

                        <div class="col-md-4">
                            <label asp-for="SupplierPhone" class="form-label fw-bold text-dark">رقم الجوال</label>
                            <input asp-for="SupplierPhone" class="form-control sys-input" dir="ltr" placeholder="05XXXXXXXX" style="text-align: right;" />
                        </div>

                        <div class="col-md-4">
                            <label asp-for="SupplierLocation" class="form-label fw-bold text-dark">موقع المورد (العنوان)</label>
                            <input asp-for="SupplierLocation" class="form-control sys-input" placeholder="المدينة، الشارع، أو رابط الخريطة" />
                        </div>

                        <div class="col-12 mt-5 text-end border-top pt-4">
                            <button type="submit" class="sys-btn sys-btn-warning text-dark px-5 py-3 fs-5 shadow-sm fw-bold">
                                <i class="fa-solid fa-check-double me-2"></i> حفظ التعديلات
                            </button>
                        </div>
                    </div>
            </form>
        </div>
    </div>
</div>

<style>
    .sys-input {
        border: 2px solid var(--sys-border);
        padding: 12px 18px;
        border-radius: 10px;
        font-weight: 600;
        transition: all 0.3s;
        background-color: var(--sys-bg);
        color: var(--sys-text-main);
    }

        .sys-input:focus {
            border-color: var(--sys-primary);
            box-shadow: 0 0 0 0.25rem rgba(241, 149, 11, 0.15);
            background-color: #fff;
            outline: none;
        }

    .input-group .sys-input {
        border-radius: 0 10px 10px 0;
    }

    .input-group .input-group-text {
        border: 2px solid var(--sys-border);
        border-right: none;
        border-radius: 10px 0 0 10px;
    }
</style>