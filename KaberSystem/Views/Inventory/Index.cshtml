@model IEnumerable<KaberSystem.Models.SparePart>
@{
    ViewData["Title"] = "المخزون العام";
    Layout = "~/Views/Shared/_SystemLayout.cshtml";
}

<div class="sys-page-header">
    <div>
        <h1 class="sys-page-title">إدارة المخزون العام (المستودع)</h1>
        <p class="sys-page-desc">مراقبة المخزون، التحكم بالتسعير، وطباعة ملصقات الباركود للقطع</p>
    </div>
    @if (User.IsInRole("Admin") || User.IsInRole("Store"))
    {
        <a href="/Inventory/Create" class="sys-btn sys-btn-primary">
            <i class="fa-solid fa-plus"></i> تعريف صنف جديد
        </a>
    }
</div>

<!-- 📌 شريط البحث الفخم (Premium Search Bar) -->
<div class="sys-card mb-4 bg-light border-0">
    <form method="get" asp-action="Index" class="row g-3 align-items-center">
        <div class="col-md-9">
            <div class="input-group input-group-lg shadow-sm">
                <span class="input-group-text bg-white border-end-0 text-primary"><i class="fa-solid fa-magnifying-glass"></i></span>
                <input type="text" name="searchQuery" value="@ViewData["CurrentSearch"]" class="form-control border-start-0 fw-bold" placeholder="ابحث باسم القطعة، كود الباركود، الموديل، أو المورد..." />
            </div>
        </div>
        <div class="col-md-3">
            <button type="submit" class="btn btn-primary btn-lg w-100 fw-bold shadow-sm">بحث في المخزون</button>
        </div>
    </form>
</div>

<div class="sys-card">
    <div class="table-responsive">
        <table class="table table-hover align-middle text-center sys-table w-100">
            <thead class="table-light">
                <tr>
                    <th>الكود والطباعة</th>
                    <th>البيان والتصنيف</th>
                    <th>المورد</th>
                    <th>تكلفة الشراء</th>
                    <th>سعر البيع (للعميل)</th>
                    <th>رصيد المخزن الحالي</th>
                    <th>إجراءات</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>
                            <div class="d-flex flex-column align-items-center gap-2">
                                <span class="fw-bold px-3 py-1 bg-dark text-white rounded-pill shadow-sm small" style="letter-spacing: 1px;">
                                    <i class="fa-solid fa-barcode me-1"></i> @(item.PartCode ?? $"#P-{item.PartId}")
                                </span>
                                <!-- زر فتح نافذة الباركود -->
                                <button type="button" class="btn btn-sm btn-outline-secondary py-1 fw-bold border"
                                        data-barcode="@(item.PartCode ?? $"P-{item.PartId}")"
                                        data-itemname="@item.Name"
                                        onclick="openBarcodeModal(this)"
                                        title="طباعة ملصق الباركود">
                                    <i class="fa-solid fa-print text-dark"></i> طباعة
                                </button>
                            </div>
                        </td>
                        <td class="fw-bold text-dark text-start">
                            @item.Name
                            <div class="small mt-2">
                                @if (item.IsCommon)
                                {
                                    <span class="badge bg-info text-dark px-2 border"><i class="fa-solid fa-layer-group"></i> عام (Common)</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary px-2"><i class="fa-solid fa-tag"></i> موديل: @item.TargetModel</span>
                                }
                            </div>
                        </td>
                        <td>
                            @if (!string.IsNullOrEmpty(item.SupplierName))
                            {
                                <span class="badge bg-light text-dark border border-secondary rounded-pill px-2"><i class="fa-solid fa-truck text-muted"></i> @item.SupplierName</span>
                            }
                            else
                            {
                                <span class="text-muted small">غير محدد</span>
                            }
                        </td>
                        <td class="text-danger fw-bold">@item.PurchasePrice <span class="small">ر.س</span></td>
                        <td class="text-success fw-bold fs-6">@item.SellingPrice <span class="small">ر.س</span></td>
                        <td>
                            @if (item.MainStockQuantity <= 0)
                            {
                                <span class="badge bg-danger rounded-pill px-3 py-2"><i class="fa-solid fa-xmark-circle me-1"></i> نفذت الكمية</span>
                            }
                            else if (item.MainStockQuantity <= 5)
                            {
                                <span class="badge bg-warning text-dark rounded-pill px-3 py-2 fw-bold"><i class="fa-solid fa-exclamation-triangle me-1"></i> @item.MainStockQuantity (نواقص)</span>
                            }
                            else
                            {
                                <span class="badge bg-light text-dark border border-secondary rounded-pill px-3 py-2 fw-bold fs-6">@item.MainStockQuantity</span>
                            }
                        </td>
                        <td>
                            <div class="d-flex gap-2 justify-content-center">
                                @if (User.IsInRole("Admin") || User.IsInRole("Store"))
                                {
                                    <a href="/Inventory/Edit/@item.PartId" class="btn btn-sm btn-outline-primary fw-bold rounded-3 px-2" title="تعديل بيانات الصنف">
                                        <i class="fa-solid fa-pen-to-square"></i>
                                    </a>
                                }

                                @if (User.IsInRole("Admin"))
                                {
                                    <button type="button" class="btn btn-sm btn-outline-danger fw-bold px-2 rounded-3"
                                            data-delete-url="/Inventory/Delete/@item.PartId"
                                            data-item-name="صنف: @item.Name"
                                            onclick="confirmAdminDelete(this.getAttribute('data-delete-url'), this.getAttribute('data-item-name'))"
                                            title="حذف الصنف نهائياً">
                                        <i class="fa-solid fa-trash"></i>
                                    </button>
                                }
                            </div>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr><td colspan="7" class="text-muted fw-bold py-5">لا توجد أصناف مطابقة للبحث.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Modal نافذة طباعة الباركود بأحجام مختلفة -->
<div class="modal fade" id="barcodeModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 rounded-4 shadow-lg">
            <div class="modal-header border-bottom-0 pb-0">
                <h5 class="modal-title fw-bold text-dark"><i class="fa-solid fa-barcode text-primary me-2"></i> طباعة ملصق الباركود</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body py-4 text-center">

                <!-- منطقة الباركود التي ستطبع فقط -->
                <div id="barcodePrintArea" class="bg-white d-inline-block p-2 rounded-3 border mb-4">
                    <div id="modalProductName" class="fw-bold text-dark mb-1" style="font-size: 13px; max-width: 200px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; margin: 0 auto;"></div>
                    <svg id="barcodeSvg"></svg>
                </div>

                <div class="mb-3 text-start">
                    <label class="fw-bold text-dark mb-2">اختر حجم الملصق للطابعة الحرارية:</label>
                    <select id="printSize" class="form-select fw-bold border-secondary">
                        <option value="small">ملصق صغير (38mm x 25mm) - للقطع الصغيرة</option>
                        <option value="medium" selected>ملصق متوسط (50mm x 25mm) - قياسي</option>
                        <option value="large">ملصق كبير (70mm x 40mm) - للكراتين</option>
                    </select>
                </div>
            </div>
            <div class="modal-footer border-top-0 pt-0">
                <button type="button" class="btn btn-light fw-bold px-4" data-bs-dismiss="modal">إغلاق</button>
                <button type="button" class="btn btn-dark fw-bold px-4" onclick="printBarcode()"><i class="fa-solid fa-print me-1"></i> طباعة الآن</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/jsbarcode@3.11.5/dist/JsBarcode.all.min.js"></script>

    <script>
        var currentBarcodeToPrint = '';
        var currentItemNameToPrint = '';

        // دالة فتح نافذة الباركود وتجهيز الكود بأمان
        function openBarcodeModal(btnElement) {
            currentBarcodeToPrint = btnElement.getAttribute('data-barcode');
            currentItemNameToPrint = btnElement.getAttribute('data-itemname');

            if (!currentBarcodeToPrint || currentBarcodeToPrint === '') {
                Swal.fire({ icon: 'error', title: 'خطأ', text: 'لا يوجد باركود لهذا الصنف، أو أنه لم يستلم بعد.', confirmButtonColor: '#ee5d50' });
                return;
            }

            document.getElementById('modalProductName').innerText = currentItemNameToPrint;

            // توليد الباركود للعرض المبدئي في النافذة فقط
            JsBarcode("#barcodeSvg", currentBarcodeToPrint, {
                format: "CODE128",
                width: 2,
                height: 40,
                displayValue: true,
                fontSize: 14,
                fontOptions: "bold",
                margin: 5
            });

            var barcodeModal = new bootstrap.Modal(document.getElementById('barcodeModal'));
            barcodeModal.show();
        }

        // دالة الطباعة المضبوطة بالمقاس الفعلي للملليمتر (mm)
        function printBarcode() {
            var size = document.getElementById('printSize').value;

            var width, height, fontSize, barWidth, barHeight;
            if(size === 'small') {
                width = '38mm'; height = '25mm'; fontSize = '11px'; barWidth = 1.2; barHeight = 25;
            }
            else if(size === 'medium') {
                width = '50mm'; height = '25mm'; fontSize = '13px'; barWidth = 1.8; barHeight = 35;
            }
            else {
                width = '70mm'; height = '40mm'; fontSize = '16px'; barWidth = 2.5; barHeight = 55;
            }

            JsBarcode("#barcodeSvg", currentBarcodeToPrint, {
                format: "CODE128",
                width: barWidth,
                height: barHeight,
                displayValue: true,
                fontSize: parseInt(fontSize),
                fontOptions: "bold",
                margin: 2
            });

            var printContent = document.getElementById('barcodePrintArea').innerHTML;

            var printFrame = document.createElement('iframe');
            printFrame.style.position = 'absolute';
            printFrame.style.top = '-9999px';
            printFrame.style.left = '-9999px';
            printFrame.style.width = width;
            printFrame.style.height = height;
            document.body.appendChild(printFrame);

            var doc = printFrame.contentWindow.document;
            doc.open();

            var atSign = String.fromCharCode(64);

            doc.write('<html><head><style>');
            doc.write(atSign + 'media print { ' + atSign + 'page { size: ' + width + ' ' + height + '; margin: 0; } body { margin: 0; } }');
            doc.write('body { font-family: Arial, sans-serif; text-align: center; margin: 0; padding: 2px; display: flex; flex-direction: column; align-items: center; justify-content: center; width: 100vw; height: 100vh; overflow: hidden; background: white; box-sizing: border-box; }');
            doc.write('#modalProductName { font-size: ' + fontSize + '; font-weight: bold; color: black; max-width: 95%; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; margin-bottom: 2px; }');
            doc.write('svg { width: 100% !important; height: auto !important; max-height: 80% !important; }');
            doc.write('</style></head><body>');
            doc.write(printContent);

            doc.write('</bo' + 'dy></ht' + 'ml>');
            doc.close();

            setTimeout(function() {
                printFrame.contentWindow.focus();
                printFrame.contentWindow.print();

                var bModalEl = document.getElementById('barcodeModal');
                if (bModalEl) {
                    var barcodeModal = bootstrap.Modal.getInstance(bModalEl);
                    if (barcodeModal) {
                        barcodeModal.hide();
                    }
                }

                setTimeout(function() { document.body.removeChild(printFrame); }, 1000);
            }, 500);
        }

        // التمرير الآمن لرسائل النظام
        @if (TempData["SuccessMessage"] != null)
        {
                var msg = System.Text.Json.JsonSerializer.Serialize(TempData["SuccessMessage"]?.ToString());
                <text>
                Swal.fire({ icon: 'success', title: 'نجاح', text: @Html.Raw(msg), confirmButtonColor: '#f1950b' });
                </text>
        }
    </script>
}