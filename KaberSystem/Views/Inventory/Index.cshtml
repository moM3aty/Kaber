<!-- مسار الملف: Views/Inventory/Index.cshtml -->
@model IEnumerable<KaberSystem.Models.SparePart>
@{
    ViewData["Title"] = "المخزون العام";
    Layout = "~/Views/Shared/_SystemLayout.cshtml";
}

<div class="sys-page-header fade-in-up">
    <div>
        <h1 class="sys-page-title">إدارة المخزون (المستودعات)</h1>
        <p class="sys-page-desc">مراقبة المخزون، التحكم بالتسعير، طباعة الباركود، ومعرفة النواقص</p>
    </div>
    @if (User.IsInRole("Admin") || User.IsInRole("Store"))
    {
        <div class="d-flex gap-2">
            <!-- 📌 التحديث: أزرار إدارة المستودعات والجرد -->
            <a href="/Inventory/Stocktake" class="btn btn-warning text-dark fw-bold px-4 rounded-pill shadow-sm hover-elevate">
                <i class="fa-solid fa-clipboard-list me-1"></i> عمليات الجرد
            </a>
            <a href="/Inventory/Warehouses" class="btn btn-dark fw-bold px-4 rounded-pill shadow-sm hover-elevate">
                <i class="fa-solid fa-building-flag me-1"></i> فروع المخازن
            </a>
            <a href="/Inventory/Create" class="btn btn-primary fw-bold px-4 rounded-pill shadow-sm hover-elevate">
                <i class="fa-solid fa-plus me-1"></i> تعريف صنف جديد
            </a>
        </div>
    }
</div>

<!-- 📌 شريط البحث والفلترة بالمستودع -->
<div class="sys-card mb-4 bg-light border-0 shadow-sm fade-in-up" style="animation-delay: 0.1s;">
    <form method="get" asp-action="Index" class="row g-3 align-items-center">
        <div class="col-md-3">
            <select name="warehouseId" class="form-select premium-input border-secondary fw-bold" asp-items="ViewBag.WarehousesList">
                <option value="">-- كل المستودعات --</option>
            </select>
        </div>
        <div class="col-md-6">
            <div class="position-relative">
                <i class="fa-solid fa-magnifying-glass position-absolute text-muted" style="top: 50%; right: 20px; transform: translateY(-50%);"></i>
                <input type="text" name="searchQuery" value="@ViewData["CurrentSearch"]" class="premium-input form-control w-100 pe-5 shadow-sm" placeholder="ابحث باسم القطعة، كود الباركود، أو الموديل..." style="background: #fff;" />
            </div>
        </div>
        <div class="col-md-3">
            <button type="submit" class="btn btn-dark w-100 fw-bolder py-3 rounded-pill shadow-sm hover-elevate">
                <i class="fa-solid fa-filter text-warning me-1"></i> فلترة وبحث
            </button>
        </div>
    </form>
</div>

<div class="sys-card fade-in-up" style="animation-delay: 0.2s;">
    <div class="table-responsive">
        <table class="table table-hover align-middle text-center sys-table w-100">
            <thead class="table-light text-muted small fw-bold text-uppercase">
                <tr>
                    <th class="text-start ps-4">الكود والطباعة</th>
                    <th class="text-start">البيان والتصنيف</th>
                    <th>المستودع</th>
                    <th>تكلفة الشراء</th>
                    <th>سعر البيع (للعميل)</th>
                    <th>الرصيد الفعلي</th>
                    <th>إجراءات</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    // 📌 التحديث: تظليل الصف باللون الأحمر الخفيف إذا كانت القطعة مخلصة (رصيد 0)
                    string rowClass = item.MainStockQuantity <= 0 ? "out-of-stock-row" : "";

                    <tr class="@rowClass" style="border-bottom: 1px solid #f8f9fa;">
                        <td class="text-start ps-4">
                            <div class="d-flex flex-column align-items-start gap-2">
                                <span class="fw-bold px-3 py-1 bg-dark text-white rounded-pill shadow-sm small" style="letter-spacing: 1px;">
                                    <i class="fa-solid fa-barcode me-1"></i> @(item.PartCode ?? $"#P-{item.PartId}")
                                </span>
                                <button type="button" class="btn btn-sm btn-outline-secondary py-1 fw-bold border"
                                        data-barcode="@(item.PartCode ?? $"P-{item.PartId}")"
                                        data-itemname="@item.Name"
                                        onclick="openBarcodeModal(this)"
                                        title="طباعة ملصق الباركود">
                                    <i class="fa-solid fa-print text-dark"></i> طباعة
                                </button>
                            </div>
                        </td>
                        <td class="fw-bold text-dark text-start">
                            @item.Name
                            <div class="small mt-2">
                                @if (item.IsCommon)
                                {
                                    <span class="badge bg-info bg-opacity-10 text-dark px-2 border border-info"><i class="fa-solid fa-layer-group"></i> عام (Common)</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary bg-opacity-10 text-secondary border px-2"><i class="fa-solid fa-tag"></i> موديل: @item.TargetModel</span>
                                }
                            </div>
                        </td>
                        <td>
                            <span class="badge bg-light text-primary border px-2 py-1 shadow-sm"><i class="fa-solid fa-building me-1"></i> @(item.Warehouse?.Name ?? "الرئيسي")</span>
                        </td>
                        <td class="text-danger fw-bold">@item.PurchasePrice <span class="small">ر.س</span></td>
                        <td class="text-success fw-bold fs-6">@item.SellingPrice <span class="small">ر.س</span></td>
                        <td>
                            @if (item.MainStockQuantity <= 0)
                            {
                                <span class="badge bg-danger rounded-pill px-3 py-2 shadow-sm"><i class="fa-solid fa-xmark-circle me-1"></i> نفذت (0)</span>
                            }
                            else if (item.MainStockQuantity <= 5)
                            {
                                <span class="badge bg-warning text-dark rounded-pill px-3 py-2 fw-bold shadow-sm"><i class="fa-solid fa-exclamation-triangle me-1"></i> @item.MainStockQuantity (نواقص)</span>
                            }
                            else
                            {
                                <span class="badge bg-light text-dark border border-secondary rounded-pill px-3 py-2 fw-bold fs-6 shadow-sm">@item.MainStockQuantity</span>
                            }
                        </td>
                        <td>
                            <div class="d-flex gap-2 justify-content-center">
                                @if (User.IsInRole("Admin") || User.IsInRole("Store"))
                                {
                                    <a href="/Inventory/Edit/@item.PartId" class="btn btn-sm btn-outline-primary fw-bold rounded-circle hover-elevate shadow-sm" style="width:35px; height:35px; line-height:22px;" title="تعديل بيانات الصنف">
                                        <i class="fa-solid fa-pen-to-square"></i>
                                    </a>
                                }

                                @if (User.IsInRole("Admin"))
                                {
                                    <form asp-action="Delete" method="get" class="d-inline" onsubmit="return confirm('تأكيد الحذف؟ سيتم إخفاء الصنف وتصفير رصيده بشكل آمن للحفاظ على الفواتير القديمة.');">
                                        <input type="hidden" name="id" value="@item.PartId" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger fw-bold rounded-circle hover-elevate shadow-sm" style="width:35px; height:35px; line-height:22px;" title="أرشفة وحذف">
                                            <i class="fa-solid fa-trash"></i>
                                        </button>
                                    </form>
                                }
                            </div>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr><td colspan="7" class="text-muted fw-bold py-5"><i class="fa-solid fa-box-open fs-1 opacity-25 d-block mb-3"></i> لا توجد أصناف مطابقة للبحث.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Modal نافذة طباعة الباركود -->
<div class="modal fade" id="barcodeModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content premium-modal border-0 rounded-4 shadow-lg">
            <div class="modal-header border-bottom-0 pb-0 px-4 pt-4">
                <h5 class="modal-title fw-bold text-dark"><i class="fa-solid fa-barcode text-primary me-2"></i> طباعة ملصق الباركود</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body py-4 px-4 text-center">

                <div id="barcodePrintArea" class="bg-white d-inline-block p-2 rounded-3 border mb-4 shadow-sm">
                    <div id="modalProductName" class="fw-bold text-dark mb-1" style="font-size: 13px; max-width: 200px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; margin: 0 auto;"></div>
                    <svg id="barcodeSvg"></svg>
                </div>

                <div class="mb-3 text-start">
                    <label class="fw-bold text-muted small text-uppercase mb-2">اختر حجم الملصق للطابعة الحرارية:</label>
                    <select id="printSize" class="form-select premium-input fw-bold border-secondary">
                        <option value="small">ملصق صغير (38mm x 25mm) - للقطع الصغيرة</option>
                        <option value="medium" selected>ملصق متوسط (50mm x 25mm) - قياسي</option>
                        <option value="large">ملصق كبير (70mm x 40mm) - للكراتين</option>
                    </select>
                </div>
            </div>
            <div class="modal-footer border-top-0 pt-0 px-4 pb-4">
                <button type="button" class="btn btn-light fw-bold px-4 rounded-pill" data-bs-dismiss="modal">إغلاق</button>
                <button type="button" class="btn btn-dark fw-bold px-4 rounded-pill hover-elevate shadow-sm" onclick="printBarcode()"><i class="fa-solid fa-print me-1 text-warning"></i> طباعة الآن</button>
            </div>
        </div>
    </div>
</div>

<style>
    :root {
        --prem-surface: #ffffff;
        --prem-border: #e2e8f0;
        --prem-text: #1e293b;
        --prem-muted: #64748b;
        --prem-primary: #f1950b;
        --prem-radius: 20px;
    }

    .fade-in-up {
        animation: fadeInUp 0.6s cubic-bezier(0.16, 1, 0.3, 1) both;
    }

    @@keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(20px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .sys-card {
        background: var(--prem-surface);
        border-radius: var(--prem-radius);
        border: 1px solid var(--prem-border);
        box-shadow: 0 10px 30px rgba(0,0,0,0.02);
        overflow: hidden;
        padding: 20px;
    }

    .premium-input {
        background-color: #f8fafc;
        border: 1px solid var(--prem-border);
        border-radius: 12px;
        padding: 14px 20px;
        font-weight: 700;
        color: var(--prem-text);
        box-shadow: none !important;
        transition: all 0.3s ease;
    }

        .premium-input:focus {
            background-color: #fff;
            border-color: var(--prem-primary);
            box-shadow: 0 0 0 4px rgba(241, 149, 11, 0.1) !important;
        }

    .sys-table th {
        font-weight: 800;
        color: var(--prem-muted);
        border-bottom: 2px solid var(--prem-border) !important;
        padding: 16px;
        font-size: 0.85rem;
        text-transform: uppercase;
    }

    .sys-table td {
        padding: 16px;
        vertical-align: middle;
    }

    .sys-table tr:hover td {
        background-color: #f8fafc;
    }

    .hover-elevate {
        transition: transform 0.2s cubic-bezier(0.4, 0, 0.2, 1), box-shadow 0.2s;
        cursor: pointer;
    }

        .hover-elevate:hover {
            transform: translateY(-3px);
            box-shadow: 0 10px 20px rgba(0,0,0,0.08) !important;
        }

    .premium-modal {
        border-radius: 24px;
        overflow: hidden;
    }

    /* 📌 التحديث: تظليل القطع المخلصة (Out of stock) */
    .out-of-stock-row td {
        background-color: rgba(238, 93, 80, 0.04) !important;
        opacity: 0.8;
    }

    .out-of-stock-row:hover td {
        background-color: rgba(238, 93, 80, 0.08) !important;
        opacity: 1;
    }
</style>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/jsbarcode@3.11.5/dist/JsBarcode.all.min.js"></script>

    <script>
        // إيقاف ترتيب الداتا تيبل لكي يعمل ترتيب قاعدة البيانات (الذي يضع الـ 0 تحت)
        $(document).ready(function () {
            $('.sys-table').DataTable({
                "language": { "url": "//cdn.datatables.net/plug-ins/1.13.6/i18n/ar.json" },
                "pageLength": 25,
                "ordering": false // 👈 هام جداً: ترك الترتيب الذي جلبته الكنترولر من C#
            });
        });

        var currentBarcodeToPrint = '';
        var currentItemNameToPrint = '';

        function openBarcodeModal(btnElement) {
            currentBarcodeToPrint = btnElement.getAttribute('data-barcode');
            currentItemNameToPrint = btnElement.getAttribute('data-itemname');

            if (!currentBarcodeToPrint || currentBarcodeToPrint === '') {
                Swal.fire({ icon: 'error', title: 'خطأ', text: 'لا يوجد باركود لهذا الصنف.', confirmButtonColor: '#ee5d50', customClass: { popup: 'premium-modal' } });
                return;
            }

            document.getElementById('modalProductName').innerText = currentItemNameToPrint;

            JsBarcode("#barcodeSvg", currentBarcodeToPrint, {
                format: "CODE128", width: 2, height: 40, displayValue: true, fontSize: 14, fontOptions: "bold", margin: 5
            });

            var barcodeModal = new bootstrap.Modal(document.getElementById('barcodeModal'));
            barcodeModal.show();
        }

        function printBarcode() {
            var size = document.getElementById('printSize').value;
            var width, height, fontSize, barWidth, barHeight;
            if(size === 'small') { width = '38mm'; height = '25mm'; fontSize = '11px'; barWidth = 1.2; barHeight = 25; }
            else if(size === 'medium') { width = '50mm'; height = '25mm'; fontSize = '13px'; barWidth = 1.8; barHeight = 35; }
            else { width = '70mm'; height = '40mm'; fontSize = '16px'; barWidth = 2.5; barHeight = 55; }

            JsBarcode("#barcodeSvg", currentBarcodeToPrint, {
                format: "CODE128", width: barWidth, height: barHeight, displayValue: true, fontSize: parseInt(fontSize), fontOptions: "bold", margin: 2
            });

            var printContent = document.getElementById('barcodePrintArea').innerHTML;
            var printFrame = document.createElement('iframe');
            printFrame.style.position = 'absolute'; printFrame.style.top = '-9999px'; printFrame.style.left = '-9999px';
            printFrame.style.width = width; printFrame.style.height = height;
            document.body.appendChild(printFrame);

            var doc = printFrame.contentWindow.document;
            doc.open();
            var atSign = String.fromCharCode(64);
            doc.write('<html><head><style>');
            doc.write(atSign + 'media print { ' + atSign + 'page { size: ' + width + ' ' + height + '; margin: 0; } body { margin: 0; } }');
            doc.write('body { font-family: Cairo, sans-serif; text-align: center; margin: 0; padding: 2px; display: flex; flex-direction: column; align-items: center; justify-content: center; width: 100vw; height: 100vh; overflow: hidden; background: white; box-sizing: border-box; }');
            doc.write('#modalProductName { font-size: ' + fontSize + '; font-weight: bold; color: black; max-width: 95%; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; margin-bottom: 2px; }');
            doc.write('svg { width: 100% !important; height: auto !important; max-height: 80% !important; }');
            doc.write('</style></head><body>');
            doc.write(printContent);
            doc.write('</bo' + 'dy></ht' + 'ml>');
            doc.close();

            setTimeout(function() {
                printFrame.contentWindow.focus(); printFrame.contentWindow.print();
                var bModalEl = document.getElementById('barcodeModal');
                if (bModalEl) { var barcodeModal = bootstrap.Modal.getInstance(bModalEl); if (barcodeModal) barcodeModal.hide(); }
                setTimeout(function() { document.body.removeChild(printFrame); }, 1000);
            }, 500);
        }

        @if (TempData["SuccessMessage"] != null)
        {
                var msg = System.Text.Json.JsonSerializer.Serialize(TempData["SuccessMessage"]);
                <text>Swal.fire({ icon: 'success', title: 'نجاح', text: @Html.Raw(msg), confirmButtonColor: '#198754', customClass: { popup: 'premium-modal' } });</text>
        }
    </script>
}