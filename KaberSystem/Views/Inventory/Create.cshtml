<!-- مسار الملف: Views/Inventory/Create.cshtml -->
@model KaberSystem.Models.SparePart
@{
    ViewData["Title"] = "تعريف صنف جديد بالمخزون";
    Layout = "~/Views/Shared/_SystemLayout.cshtml";
}

<div class="sys-page-header">
    <div>
        <h1 class="sys-page-title text-primary"><i class="fa-solid fa-box-open me-2"></i> إضافة صنف وتكويده</h1>
        <p class="sys-page-desc">إدخال قطع الغيار الجديدة لطباعة باركود لها ومتابعتها في المستودعات.</p>
    </div>
    <a href="/Inventory/Index" class="btn btn-outline-secondary fw-bold px-4 rounded-3 border-2 hover-elevate">
        <i class="fa-solid fa-arrow-right"></i> عودة للمخزون
    </a>
</div>

<div class="row justify-content-center">
    <div class="col-lg-10">
        <div class="sys-card border-top border-4 border-primary p-4 rounded-4 shadow-sm bg-white">
            <form asp-action="Create" method="post">
                <div class="row g-4">
                    <div class="col-12 border-bottom pb-3 mb-2">
                        <h5 class="fw-bolder text-dark m-0"><i class="fa-solid fa-circle-info text-info me-2"></i> البيانات الأساسية للصنف</h5>
                    </div>

                    <!-- 📌 التحديث: إضافة قائمة اختيار المستودع -->
                    <div class="col-md-6">
                        <label asp-for="WarehouseId" class="form-label fw-bolder text-dark">المستودع / الفرع التابع له <span class="text-danger">*</span></label>
                        <select asp-for="WarehouseId" class="form-select sys-input" asp-items="ViewBag.WarehouseId" required>
                            <option value="">-- اختر المستودع --</option>
                        </select>
                        <span asp-validation-for="WarehouseId" class="text-danger small fw-bold mt-1"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="Name" class="form-label fw-bolder text-dark">اسم القطعة (البيان) <span class="text-danger">*</span></label>
                        <input asp-for="Name" class="form-control sys-input" placeholder="مثال: كمبروسر LG، مروحة تبريد..." required />
                        <span asp-validation-for="Name" class="text-danger small fw-bold mt-1"></span>
                    </div>

                    <div class="col-md-4">
                        <label asp-for="PartCode" class="form-label fw-bolder text-dark">كود الباركود (اختياري)</label>
                        <input asp-for="PartCode" class="form-control sys-input bg-light" placeholder="يولد آلياً إذا تركته فارغاً" />
                    </div>

                    <div class="col-md-4">
                        <label asp-for="MainStockQuantity" class="form-label fw-bolder text-dark">الرصيد الافتتاحي (الكمية)</label>
                        <input asp-for="MainStockQuantity" type="number" class="form-control sys-input text-primary fw-bolder fs-5" value="0" min="0" />
                    </div>

                    <div class="col-12 mt-4 pt-3 border-top">
                        <label class="form-label fw-bolder text-dark mb-3">هل القطعة عامة تركب على أي جهاز أم مخصصة لموديل معين؟</label>
                        <div class="row g-3">
                            <div class="col-md-6">
                                <input type="radio" class="btn-check" name="IsCommon" id="isCommonTrue" value="true" checked onchange="toggleModelInput()">
                                <label class="btn btn-outline-info w-100 text-start fw-bold p-3 rounded-3 d-flex align-items-center" for="isCommonTrue" style="border-width: 2px;">
                                    <i class="fa-solid fa-layer-group fs-4 me-3"></i>
                                    <div>
                                        <span class="d-block text-dark">قطعة عامة (تركب لأكثر من موديل)</span>
                                        <small class="text-muted fw-normal">مثل: مسامير، أسلاك، حساس عام.</small>
                                    </div>
                                </label>
                            </div>
                            <div class="col-md-6">
                                <input type="radio" class="btn-check" name="IsCommon" id="isCommonFalse" value="false" onchange="toggleModelInput()">
                                <label class="btn btn-outline-secondary w-100 text-start fw-bold p-3 rounded-3 d-flex align-items-center" for="isCommonFalse" style="border-width: 2px;">
                                    <i class="fa-solid fa-tag fs-4 me-3"></i>
                                    <div>
                                        <span class="d-block text-dark">مخصصة لموديل معين</span>
                                        <small class="text-muted fw-normal">مثل: بوردة غسالة سامسونج موديل X.</small>
                                    </div>
                                </label>
                            </div>
                        </div>
                    </div>

                    <div class="col-md-12 mt-3" id="modelInputContainer" style="display: none;">
                        <label asp-for="TargetModel" class="form-label fw-bolder text-dark">رقم الموديل (أو الماركة) المخصصة له <span class="text-danger">*</span></label>
                        <input asp-for="TargetModel" class="form-control sys-input bg-warning bg-opacity-10 border-warning" placeholder="اكتب الموديل هنا..." />
                    </div>

                    <div class="col-12 mt-4 pt-4 border-top border-bottom pb-3 mb-2">
                        <h5 class="fw-bolder text-dark m-0"><i class="fa-solid fa-money-bill-transfer text-success me-2"></i> بيانات التكلفة والتسعير</h5>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="PurchasePrice" class="form-label fw-bolder text-dark">تكلفة الشراء الأساسية (للقطعة الواحدة) <span class="text-danger">*</span></label>
                        <div class="input-group">
                            <input asp-for="PurchasePrice" type="number" step="0.01" class="form-control sys-input border-end-0 text-danger fw-bolder fs-5" required />
                            <span class="input-group-text bg-light fw-bold text-muted border-start-0" style="border-radius: 12px 0 0 12px; border: 2px solid #e9edf7;">ر.س</span>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="SellingPrice" class="form-label fw-bolder text-dark">سعر البيع للعميل (للواحدة) <span class="text-danger">*</span></label>
                        <div class="input-group">
                            <input asp-for="SellingPrice" type="number" step="0.01" class="form-control sys-input border-end-0 text-success fw-bolder fs-5" required />
                            <span class="input-group-text bg-light fw-bold text-muted border-start-0" style="border-radius: 12px 0 0 12px; border: 2px solid #e9edf7;">ر.س</span>
                        </div>
                    </div>

                    <div class="col-12 mt-4 pt-4 border-top border-bottom pb-3 mb-2">
                        <h5 class="fw-bolder text-dark m-0"><i class="fa-solid fa-truck-field text-secondary me-2"></i> بيانات المورد (اختياري للرجوع إليه)</h5>
                    </div>

                    <div class="col-md-4">
                        <label asp-for="SupplierName" class="form-label fw-bolder text-dark">اسم المورد / المحل</label>
                        <input asp-for="SupplierName" class="form-control sys-input" />
                    </div>
                    <div class="col-md-4">
                        <label asp-for="SupplierPhone" class="form-label fw-bolder text-dark">رقم الجوال</label>
                        <input asp-for="SupplierPhone" class="form-control sys-input" dir="ltr" />
                    </div>
                    <div class="col-md-4">
                        <label asp-for="SupplierLocation" class="form-label fw-bolder text-dark">العنوان</label>
                        <input asp-for="SupplierLocation" class="form-control sys-input" />
                    </div>

                    <div class="col-12 mt-5 text-end border-top pt-4">
                        <button type="submit" class="btn btn-primary px-5 py-3 fs-5 rounded-pill shadow-sm hover-elevate fw-bolder">
                            <i class="fa-solid fa-save me-2"></i> حفظ القطعة في المخزون
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

<style>
    .sys-input {
        border: 2px solid #e9edf7;
        padding: 14px 18px;
        border-radius: 12px;
        font-weight: 600;
        color: #1e293b;
        background-color: #f8fafc;
        transition: 0.3s;
    }

        .sys-input:focus {
            background-color: #fff;
            border-color: #f1950b;
            box-shadow: 0 0 0 4px rgba(241, 149, 11, 0.1);
            outline: none;
        }

    .btn-check:checked + .btn-outline-info {
        background-color: #f0f9ff;
        color: #0ea5e9;
        border-color: #0ea5e9;
    }

    .btn-check:checked + .btn-outline-secondary {
        background-color: #f8f9fa;
        color: #495057;
        border-color: #495057;
    }

    .hover-elevate {
        transition: transform 0.2s ease, box-shadow 0.2s ease;
        cursor: pointer;
    }

        .hover-elevate:hover {
            transform: translateY(-3px);
            box-shadow: 0 10px 20px rgba(0,0,0,0.08) !important;
        }
</style>

@section Scripts {
    <script>
        function toggleModelInput() {
            var isCommon = document.getElementById('isCommonTrue').checked;
            var container = document.getElementById('modelInputContainer');
            var input = document.getElementById('TargetModel');

            if (isCommon) {
                container.style.display = 'none';
                input.required = false;
                input.value = '';
            } else {
                container.style.display = 'block';
                input.required = true;
            }
        }

        // تشغيل الدالة عند تحميل الصفحة للتأكد من الحالة المبدئية
        document.addEventListener("DOMContentLoaded", function () {
            toggleModelInput();
        });
    </script>
}