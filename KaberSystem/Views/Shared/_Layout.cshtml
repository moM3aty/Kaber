<!DOCTYPE html>
<html lang="ar" dir="rtl">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <link rel="icon" href="~/images/logo.png" type="image/png" />
    <link rel="apple-touch-icon" href="~/images/logo.png" />
    <link href="~/images/logo.png" type="image/x-icon" rel="icon" />

    <title>@ViewData["Title"] - شركة كابر</title>

    <link rel="stylesheet" href="~/css/all.min.css">
    <link rel="stylesheet" href="~/css/bootstrap.min.css">
    <link href="https://cdn.jsdelivr.net/npm/aos@2.3.4/dist/aos.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />
    <link rel="stylesheet" href="~/css/main.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@200..1000&display=swap" rel="stylesheet">
</head>

<body data-bs-spy="scroll" data-bs-target="#navbarSupportedContent" data-bs-offset="100" tabindex="0">

    @{
        // تحديد خلفية الناف بار بناءً على الصفحة
        string navDarkClass = (ViewData["IsHome"] != null && (bool)ViewData["IsHome"]) ? "" : "bg-dark";
    }

    <div class="top-bar @navDarkClass">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-md-8 top-info">
                    <span>
                        <i class="fa-solid fa-location-dot"></i>
                        المنطقة الشرقية - الدمام
                    </span>

                    <span>
                        <i class="fa-solid fa-envelope"></i>
                        info@company.com
                    </span>

                    <span>
                        <i class="fa-solid fa-phone"></i>
                        0541683466
                    </span>
                </div>
                <div class="col-md-4 text-md-start text-center social-icons">
                    <a href="#"><i class="fa-brands fa-facebook-f"></i></a>
                    <a href="#"><i class="fa-brands fa-x-twitter"></i></a>
                    <a href="#"><i class="fa-brands fa-instagram"></i></a>
                    <a href="#"><i class="fa-brands fa-pinterest"></i></a>
                </div>
            </div>
        </div>
    </div>

    <nav class="navbar navbar-expand-lg position-fixed fixed-top py-2 pt-3 pb-3 @navDarkClass" aria-label="Main Navigation">
        <div class="container-lg navbar-container d-flex justify-content-between align-items-center">
            <a class="navbar-brand fw-bold d-flex justify-content-center align-items-center" href="/" title="العودة للصفحة الرئيسية">
                <img src="~/images/logo-removebgpng.png" alt="logo image">
            </a>

            <a href="tel:0541683466" class="primary-btn d-block d-lg-none" aria-label="احجز الآن">
                <i class="fa-solid fa-phone"></i>
                احجز الآن
            </a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse"
                    data-bs-target="#navbarSupportedContent" aria-controls="navbarSupportedContent" aria-expanded="false"
                    aria-label="Toggle navigation">
                <i class="fa-solid fa-bars text-white"></i>
            </button>

            <div class="collapse navbar-collapse" id="navbarSupportedContent">
                <ul class="navbar-nav mx-auto mt-5 mt-lg-0 mb-2 mb-lg-0 d-flex justify-content-center align-items-center gap-4">
                    <li class="nav-item"><a class="nav-link active" href="/">الرئيسية</a></li>
                    <li class="nav-item"><a class="nav-link" href="/Home/About">من نحن</a></li>
                    <li class="nav-item dropdown services-dropdown">
                        <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">خدماتنا</a>
                        <ul class="dropdown-menu">
                            <li class="dropdown-submenu">
                                <a class="dropdown-item dropdown-toggle" href="#">صيانة الأجهزة المنزلية</a>
                                <ul class="dropdown-menu">
                                    <li><a class="dropdown-item" href="/Home/ServiceDetails">ثلاجات</a></li>
                                    <li><a class="dropdown-item" href="/Home/ServiceDetails">غسالات</a></li>
                                    <li><a class="dropdown-item" href="/Home/ServiceDetails">افران كهرباء</a></li>
                                    <li><a class="dropdown-item" href="/Home/ServiceDetails">فريزرات</a></li>
                                    <li><a class="dropdown-item" href="/Home/ServiceDetails">غسالات صحون</a></li>
                                    <li><a class="dropdown-item" href="/Home/ServiceDetails">مجففات</a></li>
                                    <li><a class="dropdown-item" href="/Home/ServiceDetails">مكيفات</a></li>
                                </ul>
                            </li>
                            <li><a class="dropdown-item" href="/Home/ServiceDetails">صيانة غرف التبريد</a></li>
                            <li><a class="dropdown-item" href="/Home/ServiceDetails">صيانة معدات المطاعم</a></li>
                        </ul>
                    </li>
                    <li class="nav-item"><a class="nav-link" href="/Home/Blog">المدونة</a></li>
                    <li class="nav-item"><a class="nav-link" href="/Home/Contact">اتصل بنا</a></li>
                    <li class="nav-item d-none d-lg-block"><a class="nav-link text-warning" href="/Account/Login" title="دخول الموظفين"><i class="fa-solid fa-lock"></i></a></li>
                </ul>

                <div class="d-flex align-items-center justify-content-center gap-3 mt-4 mt-lg-0">
                    <a href="tel:0541683466" class="primary-btn d-none d-lg-block" aria-label="تواصل معنا">
                        <i class="fa-solid fa-phone ms-1"></i>
                        احجز الآن
                    </a>
                </div>
            </div>
        </div>
    </nav>

    <!-- محتوى الصفحة المتغير -->
    @RenderBody()

    <!-- الفوتر الأصلي كامل بدون أي نقص -->
    <footer class="footer-section text-white">
        <div class="container">
            <div class="row g-4">
                <div class="col-lg-4 col-md-6 mb-4">
                    <a class="navbar-brand fw-bold d-flex mb-3 align-items-center" href="/" title="العودة للصفحة الرئيسية">
                        <img src="~/images/logo-removebgpng.png" alt="logo image">
                    </a>
                    <p class="footer-text">
                        نقدم خدمات صيانة كهربائية احترافية للمنازل والشركات مع ضمان الجودة
                        والالتزام بأعلى معايير الأمان.
                    </p>
                    <a href="tel:0541683466" class="solution-btn">اطلب خدمة</a>
                </div>
                <div class="col-lg-3 col-md-6 mb-4">
                    <h4 class="footer-heading">خدماتنا</h4>
                    <ul class="footer-links">
                        <li><a href="/Home/ServiceDetails">صيانة الأجهزة المنزلية</a></li>
                        <li><a href="/Home/ServiceDetails">صيانة وتنظيف المكيفات</a></li>
                        <li><a href="/Home/ServiceDetails">صيانة غرف التبريد</a></li>
                        <li><a href="/Home/ServiceDetails">صيانة معدات المطاعم</a></li>
                        <li><a href="/Home/ServiceDetails">خدمات السباكة</a></li>
                        <li><a href="/Home/ServiceDetails">غسيل السيارات</a></li>
                    </ul>
                </div>
                <div class="col-lg-2 col-md-6 mb-4">
                    <h4 class="footer-heading">صفحات هامة</h4>
                    <ul class="footer-links">
                        <li><a href="/">الرئيسية</a></li>
                        <li><a href="/Home/About">من نحن ؟</a></li>
                        <li><a href="/Home/Blog">المدونة</a></li>
                        <li><a href="/Home/Contact">اتصل بنا</a></li>
                        <li><a href="/Account/Login" class="text-warning">دخول الموظفين</a></li>
                    </ul>
                </div>
                <div class="col-lg-3 col-md-6 mb-4">
                    <h4 class="footer-heading">النشرة البريدية</h4>
                    <p class="footer-text">
                        اشترك ليصلك أحدث الأخبار والمقالات والعروض الخاصة.
                    </p>
                    <form class="newsletter">
                        <input type="email" placeholder="البريد الإلكتروني">
                        <button type="submit">اشتراك</button>
                    </form>
                </div>
            </div>
        </div>
        <div class="footer-bottom text-center">
            © 2026 جميع الحقوق محفوظة
        </div>
    </footer>

    <a href="https://wa.me/966541683466" class="whatsapp-btn" target="_blank" aria-label="WhatsApp">
        <i class="fab fa-whatsapp"></i>
    </a>

    <button id="backToTop">
        <i class="fas fa-arrow-up"></i>
    </button>

    <script src="~/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://cdn.jsdelivr.net/npm/aos@2.3.4/dist/aos.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>
    <script src="~/js/main.js"></script>

    <!-- SVG الخاص بأيقونة جوجل للتقييم التي كانت مفقودة -->
    <svg xmlns="http://www.w3.org/2000/svg" style="display:none;">
        <symbol id="grw-google" viewBox="0 0 48 48">
            <path fill="#FFC107" d="M43.6 20.5H42V20H24v8h11.3C33.7 32.1 29.2 35 24 35c-6.1 0-11-4.9-11-11S17.9 13 24 13c2.8 0 5.3 1 7.3 2.7l5.7-5.7C33.6 6.7 29.1 5 24 5 12.4 5 3 14.4 3 26s9.4 21 21 21 21-9.4 21-21c0-1.8-.2-3.6-.6-5.5z" />
            <path fill="#FF3D00" d="M6.3 14.7l6.6 4.8C14.7 16 19 13 24 13c2.8 0 5.3 1 7.3 2.7l5.7-5.7C33.6 6.7 29.1 5 24 5 16.3 5 9.7 9.2 6.3 14.7z" />
            <path fill="#4CAF50" d="M24 47c5.1 0 9.7-1.7 13.3-4.7l-6.2-5.1C29.2 39 26.7 40 24 40c-5.2 0-9.6-3.5-11.2-8.3l-6.5 5C9.6 42.3 16.3 47 24 47z" />
            <path fill="#1976D2" d="M43.6 20.5H42V20H24v8h11.3c-1.1 3-3.3 5.5-6.2 7.2l6.2 5.1C38.7 37.1 45 31 45 24c0-1.2-.1-2.4-.4-3.5z" />
        </symbol>
    </svg>
</body>
</html>