            <div class="col-md-4">
                <div class="guarantee-card p-4 h-100 rounded-4" style="border: 1px solid var(--primary-color);">
                    <i class="fa-solid fa-headset mb-4" style="font-size: 3.5rem; color: #0d6efd;"></i>
                    <h3 class="fw-bold h4 mb-3 text-white">متابعة ما بعد الخدمة</h3>
