<!-- Coverage Section -->
<section class="coverage py-5 bg-white">
    <div class="container text-center my-4" data-aos="fade-up">
        <h2 class="fw-bold display-6 text-dark mb-5">نغطي كافة أحياء ومدن المنطقة الشرقية</h2>
