            @foreach (var city in new[] { "الدمام", "الخبر", "الظهران", "رأس تنورة", "القطيف", "صفوى", "الجبيل", "سيهات" })
            {
                <div class="col-6 col-md-3">
                    <div class="p-3 border rounded-pill shadow-sm hover-elevate text-dark fw-bold">
                        <i class="fa-solid fa-map-marker-alt text-primary me-2"></i> @city
                    </div>
                </div>
            }
        </div>
        <p class="fw-bold text-muted mt-5 fs-5">ونسعى للوصول لكل مدينة في المملكة قريباً بإذن الله.</p>
    </div>
</section>

<style>
    .hover-elevate {
        transition: transform 0.3s ease-in-out, box-shadow 0.3s ease-in-out;
    }

        .hover-elevate:hover {
            transform: translateY(-8px);
            box-shadow: 0 15px 30px rgba(0,0,0,0.1) !important;
        }

    .benefit-card i {
        transition: transform 0.3s;
    }

    .benefit-card:hover i {
        transform: scale(1.2);
    }

    .guarantee-card {
        transition: transform 0.3s;
    }

        .guarantee-card:hover {
            transform: translateY(-5px);
        }
</style>