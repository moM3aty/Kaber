            detailsSubtitle = "خبرة في كافة أنظمة المجففات (أمريكي، أوروبي، حراري، مكثف)";
            details = new() {
                ("fa-fire-burner", "تغيير هيتر التسخين", "استبدال السخان التالف عند دوران الحلة دون وجود حرارة."),
                ("fa-rotate", "تغيير سير المجفف", "إصلاح مشكلة سماع صوت الموتور دون دوران الحلة الداخلية."),
                ("fa-gear", "تغيير البكرات والرولمان بلي", "القضاء على صوت الاحتكاك أو الخبط العالي أثناء التشغيل."),
                ("fa-thermometer", "إصلاح حساسات الحرارة (الثرموستات)", "معالجة توقف المجفف فجأة قبل جفاف الملابس بالكامل."),
                ("fa-microchip", "صيانة الكارتة والتايمر", "إصلاح أزرار التشغيل، وتغيير التايمر الميكانيكي أو اللوحة الرقمية."),
                ("fa-wind", "تنظيف دورة الهواء والمكثف", "إزالة الوبر المتراكم الذي يعيق خروج الهواء ويسبب ضعف التجفيف.")
            };
            break;

        case "ColdRoom":
            pageTitle = "صيانة وتجهيز غرف التبريد والتجميد";
            heroSubtitle = "حماية مثالية لمخزونك التجاري من التلف!";
            heroDesc = "نقدم حلولاً هندسية متكاملة للشركات والمطاعم والمصانع لصيانة وإنشاء غرف التبريد والتجميد المركزية بأعلى معايير الجودة المعتمدة.";
            benefitsTitle = "لماذا تعتمد علينا في صيانة غرف التبريد؟";
            icon = "fa-boxes-packing";
            colorClass = "info";
            benefits = new() {
                ("fa-boxes-packing", "حماية البضائع", "نضمن استقرار درجة الحرارة لمنع تلف اللحوم والأدوية والمواد الغذائية."),
                ("fa-bolt", "كفاءة الطاقة", "ضبط الوحدات يقلل من الفواتير التجارية الباهظة للكهرباء."),
                ("fa-stopwatch", "استجابة سريعة للطوارئ", "ندرك أن الوقت يعني المال، لذا نوفر فرق طوارئ للتدخل السريع."),
                ("fa-clipboard-check", "تقارير فنية دقيقة", "نزود الإدارة بتقارير حالة المعدات للامتثال لمتطلبات الصحة والسلامة."),
                ("fa-handshake", "عقود صيانة دورية", "برامج صيانة وقائية تمنع حدوث الأعطال الكارثية المفاجئة.")
            };
            detailsTitle = "خدماتنا لغرف التبريد والتجميد التجارية";
            detailsSubtitle = "فريق هندسي متخصص في التبريد التجاري والصناعي";
            details = new() {
                ("fa-snowflake", "صيانة وتغيير الضواغط (الكمبروسرات)", "استبدال وتعمير ضواغط التبريد الكبيرة (نصف مفتوح ومغلق)."),
                ("fa-wind", "صيانة المبخرات (Evaporators)", "غسيل كويلات المبخرات، وتغيير المراوح التالفة لضمان توزيع البرودة."),
                ("fa-gas-pump", "شحن الفريون ومعالجة التسريبات", "اختبار ضغط المواسير، لحام التسريبات، وشحن الغازات الصناعية المعتمدة."),
                ("fa-microchip", "إصلاح لوحات التحكم الكنترول", "صيانة لوحات الكهرباء (الكونتاكتور، الأوفرلود، والريلاي) وحساسات الحرارة."),
                ("fa-door-closed", "تغيير أبواب ومفصلات الغرف", "إصلاح أبواب السحب والمفصلات، وتغيير الكاوتش لمنع تسرب البرودة."),
                ("fa-icicles", "معالجة تراكم الجليد", "صيانة سخانات الإذابة (الديفروست) ومواسير الصرف لمنع تجمد المبخر.")
            };
            break;

        case "RestaurantEquipment":
            pageTitle = "صيانة معدات المطاعم والمقاهي";
            heroSubtitle = "شريكك الاستراتيجي لضمان استمرارية عمل مطعمك!";
            heroDesc = "صيانة احترافية وفورية لجميع الأجهزة التجارية (ثلاجات العرض، الأفران الصناعية، صانعات الثلج، وقلايات البطاطس) لضمان عدم توقف عملياتك.";
            benefitsTitle = "فوائد عقود الصيانة لمعدات المطاعم";
            icon = "fa-utensils";
            colorClass = "danger";
            benefits = new() {
                ("fa-clock", "عدم تعطل العمل", "الصيانة الفورية تمنع توقف المطبخ وتأخير طلبات الزبائن."),
                ("fa-shield", "الامتثال لمعايير البلدية", "أجهزة نظيفة وتعمل بكفاءة تحميك من المخالفات الصحية."),
                ("fa-money-bill-trend-up", "إطالة عمر المعدات", "المعدات التجارية باهظة الثمن، وصيانتها تحمي استثمارك."),
                ("fa-fire-extinguisher", "السلامة المهنية", "منع تسربات الغاز أو الالتماسات الكهربائية في بيئة المطبخ المزدحمة."),
                ("fa-hand-holding-dollar", "توفير تكاليف التشغيل", "الأجهزة المصانة تستهلك طاقة أقل وتعمل بكفاءة إنتاجية أعلى.")
            };
            detailsTitle = "المعدات التجارية التي نقوم بصيانتها";
            detailsSubtitle = "تغطية شاملة لخطوط الطهي الساخنة ومعدات التبريد والمشروبات";
            details = new() {
                ("fa-temperature-low", "ثلاجات وفريزرات العرض والتخزين", "صيانة ثلاجات الأندر كونتر (Under-counter) وثلاجات المشروبات الرأسية."),
                ("fa-fire-burner", "الأفران والقلايات الصناعية", "صيانة قلايات الديب فراير، أفران البيتزا، والجريلات (كهرباء وغاز)."),
                ("fa-cubes", "صانعات الثلج (Ice Makers)", "غسيل وصيانة ماكينات الثلج، تغيير الفلاتر، وإصلاح مضخات الماء."),
                ("fa-mug-hot", "ماكينات القهوة والإسبريسو", "تنظيف دورة البخار، معالجة مشاكل الضغط، وتغيير السخانات."),
                ("fa-wind", "شفاطات وأنظمة التهوية", "تنظيف وصيانة مواتير الشفط المركزية لمطابخ المطاعم الكبرى."),
                ("fa-sink", "غسالات الأطباق التجارية", "صيانة غسالات الهود تايب، ومضخات الصابون والحرارة لضمان التعقيم السريع.")
            };
            break;
    }

    ViewData["Title"] = pageTitle;
}

<!-- Hero Section (القسم العلوي المتغير ديناميكياً) -->
<div class="header pt-5 hero min-vh-100" style="background-image: linear-gradient(rgba(17, 22, 30, .8), rgba(17, 22, 30, .9)), url('/images/header.jpg'); background-position: center; background-size: cover;">
    <div class="container pt-5 mt-5 text-center" data-aos="fade-in">
        <h1 class="display-3 fw-bold text-white mb-4"><i class="fa-solid @(icon) text-@(colorClass) me-3"></i>@pageTitle</h1>
        <p class="fs-4 fw-bold text-@(colorClass) mb-3">@heroSubtitle</p>
        <p class="text-white-50 fs-5 mb-4 mx-auto" style="max-width: 800px; line-height: 1.8;">@heroDesc</p>

        <div class="d-flex gap-3 flex-wrap justify-content-center mt-4">
            <a href="tel:+966555794669" class="primary-btn fs-5 shadow-lg">
                <i class="fa-solid fa-phone me-2"></i> احجز صيانة الآن +966555794669
            </a>
            <a href="#details-section" class="secondary-btn fs-5">
                اكتشف التفاصيل
            </a>
        </div>
    </div>
</div>

<!-- Benefits Section (قسم الفوائد الخمسة) -->
<section class="benefits-section py-5 bg-light">
    <div class="container" data-aos="fade-up" data-aos-delay="100">
        <div class="text-center mb-5 mt-4">
            <h2 class="fw-bold display-6 text-dark">@benefitsTitle</h2>
            <div class="divider bg-@(colorClass) mx-auto mt-3" style="width: 80px; height: 4px; border-radius: 2px;"></div>
        </div>

        <div class="row justify-content-center g-4">
            @foreach (var benefit in benefits)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="benefit-card bg-white p-4 rounded-4 shadow-sm h-100 text-center border-bottom border-4 border-@(colorClass) hover-elevate">
                        <div class="icon-wrapper bg-@(colorClass) bg-opacity-10 text-@(colorClass) rounded-circle d-inline-flex align-items-center justify-content-center mb-4" style="width: 80px; height: 80px;">
                            <i class="fa-solid @(benefit.Icon) fs-1"></i>
                        </div>
                        <h4 class="fw-bold mb-3 text-dark">@benefit.Title</h4>
                        <p class="text-muted mb-0">@benefit.Desc</p>
                    </div>
                </div>
            }
        </div>
    </div>
</section>

<!-- Service Details Section (تفاصيل الصيانة) -->
<section id="details-section" class="services-details-section py-5">
    <div class="container mt-4" data-aos="fade-up" data-aos-delay="100">
        <div class="text-center mb-5">
            <h2 class="fw-bold display-6 text-dark mb-3">@detailsTitle</h2>
            <p class="text-muted fs-5">@detailsSubtitle</p>
        </div>

        <div class="row g-4">
            @foreach (var item in details)
            {
                <div class="col-lg-4 col-md-6">
                    <div class="service-details-card bg-white p-4 rounded-4 shadow-sm h-100 position-relative overflow-hidden hover-elevate" style="border: 1px solid var(--gray-200);">
                        <div class="position-absolute top-0 end-0 bg-@(colorClass) text-white px-3 py-2" style="border-bottom-left-radius: 15px;">
                            <i class="fa-solid @(item.Icon) fs-4"></i>
                        </div>
                        <h4 class="fw-bold text-dark mt-3 mb-3 pe-4">@item.Title</h4>
                        <p class="text-muted mb-0 lh-lg">@item.Desc</p>
                    </div>
                </div>
            }
        </div>

        <div class="d-flex flex-column gap-3 mt-5 pt-3 justify-content-center align-items-center">
            <p class="text-muted fw-bold fs-5">خدمة متكاملة تغنيك عن البحث بين عشرات الشركات بضمان معتمد</p>
            <a href="tel:+966555794669" class="btn btn-@(colorClass) text-white fs-5 px-5 py-3 rounded-pill fw-bold shadow-sm"><i class="fa-solid fa-headset me-2"></i> تواصل مع خدمة العملاء</a>
        </div>
    </div>
</section>

<!-- 📌 تم حل مشكلة الأيقونات بزيادة الـ Font Size بشكل سليم بدلاً من display-4 -->
