            </div>
            <div class="col-lg-2 col-md-4 col-sm-6">
                <div class="process-card p-4 bg-white rounded-4 shadow-sm h-100 position-relative hover-elevate">
                    <div class="step-number position-absolute top-0 start-50 translate-middle badge rounded-pill bg-primary fs-6">04</div>
                    <i class="fa-solid fa-file-signature text-primary fs-1 mb-3 mt-3"></i>
                    <h5 class="fw-bold mb-2">عرض السعر</h5>
                    <p class="text-muted small mb-0">اعتماد التكلفة قبل البدء</p>
                </div>
            </div>
            <div class="col-lg-2 col-md-4 col-sm-6">
                <div class="process-card p-4 bg-white rounded-4 shadow-sm h-100 position-relative hover-elevate">
                    <div class="step-number position-absolute top-0 start-50 translate-middle badge rounded-pill bg-primary fs-6">05</div>
                    <i class="fa-solid fa-wrench text-primary fs-1 mb-3 mt-3"></i>
                    <h5 class="fw-bold mb-2">الإصلاح</h5>
                    <p class="text-muted small mb-0">تنفيذ الصيانة بقطع أصلية</p>
                </div>
            </div>
            <div class="col-lg-2 col-md-4 col-sm-6">
                <div class="process-card p-4 bg-white rounded-4 shadow-sm h-100 position-relative hover-elevate">
                    <div class="step-number position-absolute top-0 start-50 translate-middle badge rounded-pill bg-primary fs-6">06</div>
                    <i class="fa-solid fa-file-invoice-dollar text-primary fs-1 mb-3 mt-3"></i>
