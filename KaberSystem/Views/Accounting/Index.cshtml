<!-- مسار الملف: Views/Accounting/Index.cshtml -->
@{
    ViewData["Title"] = "اللوحة المالية وصافي الربح";
    Layout = "~/Views/Shared/_SystemLayout.cshtml";

    var techReports = ViewBag.TechnicianReports as IEnumerable<dynamic>;
    decimal netProfit = ViewBag.NetCompanyProfit;
}

<div class="d-flex justify-content-between align-items-end mb-4 d-print-none">
    <div>
        <h2 class="fw-bolder text-dark mb-1" style="letter-spacing: -1px;"><i class="fa-solid fa-chart-pie text-primary me-2"></i> القوائم المالية وصافي الربح (P&L)</h2>
        <p class="text-muted fw-bold mb-0">مراقبة الإيرادات، المصروفات، وأداء الفنيين المالي بدقة</p>
    </div>
    <div class="d-flex gap-2">
        <button onclick="window.print()" class="btn btn-white border-0 shadow-sm rounded-pill px-4 fw-bold text-dark hover-elevate">
            <i class="fa-solid fa-print me-2 text-primary"></i> طباعة التقرير العام
        </button>
    </div>
</div>

<!-- 📌 لوحة صافي أرباح الشركة (الرئيسية) -->
<div class="card border-0 rounded-4 shadow-lg mb-4 overflow-hidden position-relative" style="background: linear-gradient(135deg, #1e3c72, #2a5298);">
    <i class="fa-solid fa-scale-balanced position-absolute text-white" style="font-size: 200px; opacity: 0.05; right: -20px; top: -30px;"></i>
    <div class="card-body p-4 p-xl-5 text-white position-relative z-1 text-center d-flex flex-column align-items-center justify-content-center">
        <h5 class="fw-bold opacity-75 mb-2 text-uppercase tracking-wide">صافي أرباح الشركة النهائي (Net Profit)</h5>
        <h1 class="display-3 fw-bolder mb-0 @(netProfit >= 0 ? "text-success" : "text-danger")" style="text-shadow: 0 4px 15px rgba(0,0,0,0.2);">
            @netProfit.ToString("N0") <span class="fs-4 text-white">ر.س</span>
        </h1>
        <p class="mt-3 mb-0 fw-bold opacity-75 small">المعادلة: (إجمالي الإيرادات المحصلة) - (المصروفات + الرواتب + خسائر التوالف)</p>
    </div>
</div>

<!-- 📌 البطاقات المالية التفصيلية -->
<div class="row g-4 mb-5">
    <div class="col-lg-3 col-sm-6">
        <div class="card border-0 rounded-4 shadow-sm h-100 p-4 stat-card border-bottom border-4 border-primary">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h6 class="fw-bold text-muted mb-0">إجمالي الإيرادات</h6>
                <div class="icon-box bg-primary bg-opacity-10 text-primary rounded-circle"><i class="fa-solid fa-vault"></i></div>
            </div>
            <h3 class="fw-bolder text-dark mb-0">@Convert.ToDecimal(ViewBag.TotalRevenue).ToString("N0") <span class="fs-6 text-muted">ر.س</span></h3>
        </div>
    </div>

    <div class="col-lg-3 col-sm-6">
        <div class="card border-0 rounded-4 shadow-sm h-100 p-4 stat-card border-bottom border-4 border-success">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h6 class="fw-bold text-muted mb-0">الدخل اليومي</h6>
                <div class="icon-box bg-success bg-opacity-10 text-success rounded-circle"><i class="fa-solid fa-money-bill-trend-up"></i></div>
            </div>
            <h3 class="fw-bolder text-success mb-0">+@Convert.ToDecimal(ViewBag.DailyIncome).ToString("N0") <span class="fs-6 text-muted">ر.س</span></h3>
        </div>
    </div>

    <div class="col-lg-3 col-sm-6">
        <div class="card border-0 rounded-4 shadow-sm h-100 p-4 stat-card border-bottom border-4 border-warning">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h6 class="fw-bold text-muted mb-0">المصروفات والرواتب</h6>
                <div class="icon-box bg-warning bg-opacity-10 text-warning-dark rounded-circle"><i class="fa-solid fa-file-invoice-dollar"></i></div>
            </div>
            <h3 class="fw-bolder text-warning-dark mb-0">-@Convert.ToDecimal(ViewBag.TotalExpenses).ToString("N0") <span class="fs-6 text-muted">ر.س</span></h3>
        </div>
    </div>

    <div class="col-lg-3 col-sm-6">
        <div class="card border-0 rounded-4 shadow-sm h-100 p-4 stat-card border-bottom border-4 border-danger">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h6 class="fw-bold text-muted mb-0">قيمة التوالف (خسائر)</h6>
                <div class="icon-box bg-danger bg-opacity-10 text-danger rounded-circle"><i class="fa-solid fa-dumpster-fire"></i></div>
            </div>
            <h3 class="fw-bolder text-danger mb-0">-@Convert.ToDecimal(ViewBag.TotalDamagesCost).ToString("N0") <span class="fs-6 text-muted">ر.س</span></h3>
        </div>
    </div>
</div>

<!-- 📌 جدول أرباح الفنيين وكشف الذمة المالي -->
<div class="card border-0 rounded-4 shadow-sm mb-4">
    <div class="card-header bg-white border-0 pt-4 pb-0 px-4">
        <h4 class="fw-bolder text-dark mb-0"><i class="fa-solid fa-briefcase text-warning me-2"></i> كشف إنتاجية وذمة الفنيين المالي</h4>
        <p class="text-muted small fw-bold mt-1">يتم الآن خصم المصروفات والسلف تلقائياً من دخل الفني لإظهار صافي الربح (Net Profit) لكل موظف.</p>
    </div>
    <div class="card-body p-0 mt-3">
        <div class="table-responsive">
            <table class="table table-borderless table-hover align-middle text-center mb-0 w-100 custom-table">
                <thead class="bg-light text-muted small fw-bold text-uppercase">
                    <tr>
                        <th class="py-3 ps-4 text-start">الفني المختص</th>
                        <th class="py-3">دخل الفني (Gross)</th>
                        <th class="py-3">المصروفات/الخصم</th>
                        <th class="py-3">صافي الربح (Net)</th>
                        <th class="py-3">كاش مع الفني</th>
                        <th class="py-3 pe-4">إجراءات</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var tech in techReports)
                    {
                        <tr style="border-bottom: 1px solid #f8f9fa;">
                            <td class="text-start ps-4 py-4">
                                <div class="d-flex align-items-center">
                                    <div class="avatar-sm bg-primary bg-opacity-10 text-primary rounded-circle me-3 d-flex justify-content-center align-items-center fw-bold shadow-sm">
                                        @tech.Name.Substring(0, 1)
                                    </div>
                                    <span class="fw-bolder text-dark">@tech.Name</span>
                                </div>
                            </td>
                            <td class="fw-bold text-dark">@tech.GrossIncome.ToString("N2")</td>
                            <td class="fw-bold text-danger">-@tech.TotalDeductions.ToString("N2")</td>
                            <td class="fw-bolder text-success bg-success bg-opacity-10">
                                @tech.NetProfit.ToString("N2") <small class="text-muted">ر.س</small>
                            </td>
                            <td>
                                @if(tech.WalletBalance > 0) {
                                    <span class="badge bg-warning text-dark px-3 py-2 rounded-pill fw-bold shadow-sm">
                                        <i class="fa-solid fa-wallet me-1"></i> @tech.WalletBalance.ToString("N2")
                                    </span>
                                } else {
                                    <span class="text-muted small fw-bold">0.00</span>
                                }
                            </td>
                            <td class="pe-4">
                                <button type="button" class="btn btn-sm btn-dark rounded-pill px-3 fw-bold shadow-sm" data-bs-toggle="modal" data-bs-target="#settleModal_@tech.Id">
                                    <i class="fa-solid fa-hand-holding-dollar me-1"></i> تصفية الكاش
                                </button>
                            </td>
                        </tr>

                        <!-- Modal: توريد الكاش من الفني -->
                        <div class="modal fade" id="settleModal_@tech.Id" tabindex="-1" aria-hidden="true">
                            <div class="modal-dialog modal-dialog-centered">
                                <div class="modal-content border-0 rounded-4 shadow-lg">
                                    <div class="modal-header border-0 pb-0">
                                        <h5 class="modal-title fw-bold"><i class="fa-solid fa-receipt text-success me-2"></i> توريد نقدية من @tech.Name</h5>
                                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                    </div>
                                    <form asp-action="SettleTechCash" method="post">
                                        <input type="hidden" name="techId" value="@tech.Id" />
                                        <div class="modal-body py-4">
                                            <div class="mb-3">
                                                <label class="form-label fw-bold small text-muted text-uppercase">المبلغ المستلم فعلياً <span class="text-danger">*</span></label>
                                                <div class="input-group input-group-lg">
                                                    <input type="number" step="0.01" name="amount" class="form-control fw-bold border-2 border-success text-success" max="@tech.WalletBalance" value="@tech.WalletBalance" required />
                                                    <span class="input-group-text bg-light fw-bold">ر.س</span>
                                                </div>
                                                <small class="text-muted fw-bold d-block mt-2">إجمالي الكاش المسجل في ذمة الفني: @tech.WalletBalance ريال</small>
                                            </div>
                                            <div class="mb-3 text-start">
                                                <label class="form-label fw-bold small text-muted text-uppercase">بيان الحركة</label>
                                                <input type="text" name="note" class="form-control fw-bold bg-light border-0" placeholder="مثال: توريد كاش عهدة الأسبوع" />
                                            </div>
                                        </div>
                                        <div class="modal-footer border-0 pt-0">
                                            <button type="submit" class="btn btn-success fw-bold w-100 py-3 rounded-pill shadow-sm">تأكيد التوريد لخزنة الشركة</button>
                                        </div>
                                    </form>
                                </div>
                            </div>
                        </div>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<style>
    .icon-box { width: 45px; height: 45px; display: flex; align-items: center; justify-content: center; font-size: 1.2rem; }
    .stat-card { transition: transform 0.3s ease, box-shadow 0.3s ease; }
    .stat-card:hover { transform: translateY(-5px); box-shadow: 0 10px 20px rgba(0,0,0,0.05) !important; }
    .avatar-sm { width: 45px; height: 45px; font-size: 1.2rem; }
    .custom-table th { font-size: 0.85rem; letter-spacing: 0.5px; }
    .custom-table tbody tr { transition: background-color 0.2s ease; border-bottom: 1px solid #f8f9fa; }
    .custom-table tbody tr:hover { background-color: #fcfcfd !important; }
    .text-warning-dark { color: #d39e00 !important; }
    .hover-elevate { transition: transform 0.2s ease; }
    .hover-elevate:hover { transform: translateY(-3px); }

    @@media print {
        body { background: white !important; }
        .sys-sidebar, .sys-header, .d-print-none, .modal { display: none !important; }
        .sys-main { margin: 0 !important; padding: 0 !important; width: 100% !important; }
        .card { border: 1px solid #000 !important; box-shadow: none !important; break-inside: avoid; }
        .text-white { color: #000 !important; }
        .bg-primary, .bg-success, .bg-warning { background-color: transparent !important; color: #000 !important; border: 1px solid #000 !important; }
    }
</style>

@section Scripts {
    @if (TempData["SuccessMessage"] != null)
    {
        <script>Swal.fire({ icon: 'success', title: 'عملية ناجحة', text: '@Html.Raw(TempData["SuccessMessage"])', confirmButtonColor: '#198754' });</script>
    }
}