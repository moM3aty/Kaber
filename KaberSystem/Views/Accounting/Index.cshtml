<!-- مسار الملف: Views/Accounting/Index.cshtml -->
@{
    ViewData["Title"] = "التقرير المالي العام";
    Layout = "~/Views/Shared/_SystemLayout.cshtml";

    decimal totalRevenue = ViewBag.TotalRevenue ?? 0m;
    decimal cogs = ViewBag.COGS ?? 0m;
    decimal grossProfit = ViewBag.GrossProfit ?? 0m;
    decimal allExpenses = ViewBag.AllExpenses ?? 0m;
    decimal netProfit = ViewBag.NetProfit ?? 0m;

    decimal cashExpenses = ViewBag.CashExpenses ?? 0m;
    decimal bankExpenses = ViewBag.BankExpenses ?? 0m;

    decimal totalPurchasesOutflow = ViewBag.TotalPurchasesOutflow ?? 0m;
    decimal totalCashOutflow = ViewBag.TotalCashOutflow ?? 0m;

    decimal inventoryValue = ViewBag.InventoryValue ?? 0m;
    decimal purchasingSafe = ViewBag.PurchasingSafeBalance ?? 0m;
    decimal generalSafe = ViewBag.GeneralSafeBalance ?? 0m;
    decimal bankBalance = ViewBag.BankBalance ?? 0m;
    decimal totalCashWithTechs = ViewBag.TotalCashWithTechs ?? 0m;

    string currentMonthYear = ViewBag.CurrentMonthYear;
    string monthName = ViewBag.MonthName;

    decimal totalPartnersShare = ViewBag.TotalPartnersShare ?? 0m;
    decimal remainingShare = 100m - totalPartnersShare;
}

<div class="d-flex justify-content-between align-items-center mb-4 fade-in-up">
    <div class="d-flex align-items-center gap-3">
        <div class="bg-white text-success rounded-circle d-flex justify-content-center align-items-center shadow-sm" style="width: 55px; height: 55px; font-size: 22px;">
            <i class="fa-solid fa-chart-pie"></i>
        </div>
        <div>
            <h2 class="fw-bolder text-dark mb-1" style="letter-spacing: -0.5px;">المركز المالي الشامل (ERP)</h2>
            <p class="text-muted fw-bold mb-0">نظرة شاملة على الأرباح، حركة السيولة، والأصول لتقييم أداء المؤسسة</p>
        </div>
    </div>
    <div class="d-flex gap-2">
        <form method="get" asp-action="Index" class="m-0 bg-white p-1 rounded-pill shadow-sm border hover-elevate">
            <div class="d-flex align-items-center px-3">
                <i class="fa-regular fa-calendar-days text-success me-2"></i>
                <span class="fw-bold text-dark me-2 small">شهر التقرير:</span>
                <input type="month" name="monthYear" value="@currentMonthYear" class="form-control form-control-sm fw-bold border-0 text-success p-0" style="box-shadow: none; cursor: pointer; width:auto;" onchange="this.form.submit()" />
            </div>
        </form>
    </div>
</div>

<!-- ========================================================= -->
<!-- 📌 1. قسم الأرباح والخسائر (هل نحن نربح أم نخسر؟) -->
<!-- ========================================================= -->
<h5 class="fw-bolder text-dark mb-3 fade-in-up"><i class="fa-solid fa-scale-balanced text-primary me-2"></i> 1. قائمة الدخل والأرباح (لشهر @monthName)</h5>
<div class="row g-4 mb-5 fade-in-up" style="animation-delay: 0.1s;">
    <div class="col-md-3">
        <div class="premium-card h-100 p-4 border-top border-4 border-info">
            <div class="d-flex justify-content-between align-items-start mb-3">
                <h6 class="fw-bold text-muted m-0">إجمالي المبيعات (الإيراد)</h6>
                <div class="icon-box bg-info bg-opacity-10 text-info"><i class="fa-solid fa-money-bill-trend-up"></i></div>
            </div>
            <h3 class="fw-bolder text-dark m-0">@totalRevenue.ToString("N2") <span class="fs-6 text-muted">ر.س</span></h3>
            <p class="small text-muted fw-bold mt-2 mb-0">جميع الفواتير المدفوعة (أجور + قطع).</p>
        </div>
    </div>

    <div class="col-md-3">
        <div class="premium-card h-100 p-4 border-top border-4 border-warning">
            <div class="d-flex justify-content-between align-items-start mb-3">
                <h6 class="fw-bold text-muted m-0">تكلفة القطع المباعة (COGS)</h6>
                <div class="icon-box bg-warning bg-opacity-10 text-warning"><i class="fa-solid fa-boxes-stacked"></i></div>
            </div>
            <h3 class="fw-bolder text-warning m-0">- @cogs.ToString("N2") <span class="fs-6 text-muted">ر.س</span></h3>
            <p class="small text-muted fw-bold mt-2 mb-0">سعر الشراء للقطع التي تم استهلاكها بالطلبات.</p>
        </div>
    </div>

    <div class="col-md-3">
        <div class="premium-card h-100 p-4 border-top border-4 border-danger d-flex flex-column">
            <div class="d-flex justify-content-between align-items-start mb-3">
                <h6 class="fw-bold text-muted m-0">المصاريف، الرواتب والسلف</h6>
                <div class="icon-box bg-danger bg-opacity-10 text-danger"><i class="fa-solid fa-arrow-trend-down"></i></div>
            </div>
            <h3 class="fw-bolder text-danger m-0">- @allExpenses.ToString("N2") <span class="fs-6 text-muted">ر.س</span></h3>
            <p class="small text-muted fw-bold mt-2 mb-0 lh-sm">مصروفات تشغيلية، رواتب، سلف للموظفين، وعمولات.</p>

            <div class="mt-auto pt-3 border-top border-danger border-opacity-25 d-flex justify-content-between">
                <span class="small fw-bold text-muted"><i class="fa-solid fa-money-bills text-success me-1"></i> كاش: <span class="text-dark">@cashExpenses.ToString("N2")</span></span>
                <span class="small fw-bold text-muted"><i class="fa-solid fa-credit-card text-primary me-1"></i> بنك: <span class="text-dark">@bankExpenses.ToString("N2")</span></span>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="premium-card h-100 p-4 bg-success bg-opacity-10 border-success position-relative overflow-hidden hover-elevate border-top border-4">
            <i class="fa-solid fa-sack-dollar position-absolute text-success" style="font-size: 100px; opacity: 0.1; left: -10px; bottom: -10px;"></i>
            <div class="position-relative z-1 text-end">
                <h6 class="fw-bolder text-success mb-3">صافي الربح الفعلي (Net Profit)</h6>
                <h2 class="fw-bolder text-success m-0 display-6">@netProfit.ToString("N2") <span class="fs-5">ر.س</span></h2>
                <p class="small text-success fw-bold mt-3 mb-0"><i class="fa-solid fa-check-double me-1"></i> الربح الجاهز للتوزيع على الشركاء.</p>
            </div>
        </div>
    </div>
</div>

<!-- ========================================================= -->
<!-- 📌 2. قسم حركة السيولة والمشتريات (أين ذهبت الأموال؟) -->
<!-- ========================================================= -->
<h5 class="fw-bolder text-dark mb-3 fade-in-up" style="animation-delay: 0.2s;"><i class="fa-solid fa-money-bill-transfer text-primary me-2"></i> 2. ملخص المدفوعات والمشتريات (لشهر @monthName)</h5>
<div class="row g-4 mb-5 fade-in-up" style="animation-delay: 0.2s;">
    <div class="col-md-6">
        <div class="premium-card p-4 d-flex justify-content-between align-items-center bg-light border">
            <div>
                <h6 class="fw-bold text-muted mb-1">المدفوعات لشراء بضاعة ونواقص (Purchases)</h6>
                <p class="small text-muted fw-bold m-0">السيولة التي تحولت لبضاعة (مخزن/فواتير).</p>
            </div>
            <h3 class="fw-bolder text-dark m-0">@totalPurchasesOutflow.ToString("N2") <span class="fs-6 text-muted">ر.س</span></h3>
        </div>
    </div>
    <div class="col-md-6">
        <div class="premium-card p-4 d-flex justify-content-between align-items-center bg-danger bg-opacity-10 border border-danger border-opacity-25">
            <div>
                <h6 class="fw-bold text-danger mb-1"><i class="fa-solid fa-arrow-right-from-bracket me-1"></i> إجمالي التدفقات الخارجة (Total Outflow)</h6>
                <p class="small text-danger fw-bold m-0 opacity-75">مجموع (كل المصروفات والرواتب والسلف + المشتريات).</p>
            </div>
            <h3 class="fw-bolder text-danger m-0">- @totalCashOutflow.ToString("N2") <span class="fs-6">ر.س</span></h3>
        </div>
    </div>
</div>

<!-- ========================================================= -->
<!-- 📌 3. الأصول والصناديق (كم نمتلك الآن؟) -->
<!-- ========================================================= -->
<h5 class="fw-bolder text-dark mb-3 fade-in-up" style="animation-delay: 0.3s;"><i class="fa-solid fa-vault text-warning me-2"></i> 3. الأصول، الخزنات، وحسابات البنوك (تراكمي دائم)</h5>
<div class="row g-4 mb-5 fade-in-up" style="animation-delay: 0.3s;">
    <div class="col-lg-7">
        <div class="premium-card h-100">
            <div class="card-body-premium p-4">

                <!-- خزنة المشتريات -->
                <div class="d-flex align-items-center justify-content-between p-3 rounded-4 mb-3 border hover-elevate position-relative group-hover @(purchasingSafe < 0 ? "bg-danger bg-opacity-10 border-danger" : "bg-light")">
                    <div class="d-flex align-items-center gap-3">
                        <div class="bg-primary text-white rounded-3 d-flex justify-content-center align-items-center shadow-sm" style="width: 45px; height: 45px; font-size: 18px;"><i class="fa-solid fa-rotate"></i></div>
                        <div>
                            <h6 class="fw-bolder text-dark mb-1">خزنة المشتريات النقدية</h6>
                            @if (purchasingSafe < 0)
                            {
                                <small class="text-danger fw-bold m-0"><i class="fa-solid fa-triangle-exclamation me-1"></i> الخزنة مدانة (تم السحب من العام لشراء بضاعة).</small>
                            }
                        </div>
                    </div>
                    <div class="text-end">
                        <h4 class="fw-bolder @(purchasingSafe < 0 ? "text-danger" : "text-primary") m-0" dir="ltr">@purchasingSafe.ToString("N2")</h4>
                        <button type="button" class="btn btn-sm btn-outline-primary bg-white rounded-pill fw-bold mt-2 edit-btn" onclick="openAdjustModal('Purchasing', @purchasingSafe, 'خزنة المشتريات النقدية')"><i class="fa-solid fa-pen"></i></button>
                    </div>
                </div>

                <!-- الخزنة العامة -->
                <div class="d-flex align-items-center justify-content-between p-3 bg-success bg-opacity-10 border border-success rounded-4 mb-3 hover-elevate position-relative group-hover">
                    <div class="d-flex align-items-center gap-3">
                        <div class="bg-success text-white rounded-3 d-flex justify-content-center align-items-center shadow-sm" style="width: 45px; height: 45px; font-size: 18px;"><i class="fa-solid fa-money-bill-wave"></i></div>
                        <div><h6 class="fw-bolder text-success mb-1">الخزنة العامة (الكاش الفعلي)</h6></div>
                    </div>
                    <div class="text-end">
                        <h4 class="fw-bolder text-success m-0" dir="ltr">@generalSafe.ToString("N2")</h4>
                        <button type="button" class="btn btn-sm btn-outline-success bg-white rounded-pill fw-bold mt-2 edit-btn" onclick="openAdjustModal('General', @generalSafe, 'الخزنة العامة (الكاش)')"><i class="fa-solid fa-pen"></i></button>
                    </div>
                </div>

                <!-- البنك -->
                <div class="d-flex align-items-center justify-content-between p-3 bg-info bg-opacity-10 border border-info rounded-4 mb-3 hover-elevate">
                    <div class="d-flex align-items-center gap-3">
                        <div class="bg-info text-white rounded-3 d-flex justify-content-center align-items-center shadow-sm" style="width: 45px; height: 45px; font-size: 18px;"><i class="fa-solid fa-building-columns"></i></div>
                        <div><h6 class="fw-bolder text-dark mb-1">حساب البنك (فيزا/تحويلات)</h6></div>
                    </div>
                    <h4 class="fw-bolder text-dark m-0" dir="ltr">@bankBalance.ToString("N2")</h4>
                </div>

                <div class="row g-3 mt-2 border-top pt-3">
                    <!-- المخزن -->
                    <div class="col-md-6">
                        <div class="d-flex align-items-center p-3 bg-light rounded-4 border hover-elevate h-100">
                            <div class="bg-secondary text-white rounded-3 d-flex justify-content-center align-items-center me-3 shadow-sm" style="width: 40px; height: 40px;"><i class="fa-solid fa-boxes-stacked"></i></div>
                            <div>
                                <small class="text-muted fw-bold d-block">أصول بضاعة بالمخزن</small>
                                <h5 class="fw-bolder text-secondary m-0 mt-1">@inventoryValue.ToString("N2") ر.س</h5>
                            </div>
                        </div>
                    </div>
                    <!-- ديون الفنيين -->
                    <div class="col-md-6">
                        <div class="d-flex align-items-center p-3 bg-danger bg-opacity-10 border border-danger border-opacity-25 rounded-4 hover-elevate h-100">
                            <div class="bg-danger text-white rounded-3 d-flex justify-content-center align-items-center me-3 shadow-sm" style="width: 40px; height: 40px;"><i class="fa-solid fa-users-gear"></i></div>
                            <div>
                                <small class="text-danger fw-bold d-block">كاش محصل بجيوب الفنيين</small>
                                <h5 class="fw-bolder text-danger m-0 mt-1">@totalCashWithTechs.ToString("N2") ر.س</h5>
                            </div>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </div>

    <!-- 📌 إدارة الشركاء -->
    <div class="col-lg-5">
        <div class="premium-card h-100">
            <div class="card-header-premium bg-dark text-white d-flex justify-content-between align-items-center">
                <h6 class="fw-bolder text-white m-0"><i class="fa-solid fa-users-viewfinder text-warning me-2"></i> توزيع أرباح شهر (@monthName)</h6>
                @if (remainingShare > 0)
                {
                    <button type="button" class="btn btn-sm btn-outline-light rounded-pill fw-bold" data-bs-toggle="modal" data-bs-target="#addPartnerModal"><i class="fa-solid fa-plus me-1"></i> شريك</button>
                }
            </div>
            <div class="card-body-premium p-3">
                @if (netProfit > 0 && ViewBag.Partners != null)
                {
                    <div class="d-flex flex-column gap-2">
                        @foreach (var partner in ViewBag.Partners)
                        {
                            <div class="p-3 border rounded-3 bg-light hover-elevate">
                                <div class="d-flex justify-content-between align-items-center mb-2">
                                    <div class="d-flex align-items-center gap-2">
                                        <div class="avatar-sm bg-dark text-white fw-bold shadow-sm" style="width: 30px; height:30px; font-size:12px;">@partner.Name.Substring(0, 1)</div>
                                        <h6 class="fw-bolder text-dark m-0 fs-6">@partner.Name</h6>
                                    </div>
                                    <span class="badge bg-warning text-dark">@partner.Share %</span>
                                </div>
                                <div class="d-flex justify-content-between align-items-end mt-2">
                                    <h5 class="fw-bolder text-success m-0">@partner.Amount.ToString("N2")</h5>
                                    <div class="d-flex gap-2">
                                        <button type="button" class="btn btn-sm btn-dark rounded-pill fw-bold px-3 shadow-sm" onclick="openSettlePartnerModal(@partner.Id, '@partner.Name', @partner.Amount, '@monthName')">صرف</button>
                                        <form asp-action="DeletePartner" method="post" onsubmit="return confirm('حذف الشريك؟');"><input type="hidden" name="id" value="@partner.Id" /><button type="submit" class="btn btn-sm btn-outline-danger rounded-circle" style="width:30px; height:30px;"><i class="fa-solid fa-trash-can"></i></button></form>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="alert alert-danger fw-bold text-center p-4 rounded-4 border-0">عفواً، لا يوجد صافي ربح للتوزيع.</div>
                }
            </div>
        </div>
    </div>
</div>

<div class="premium-card fade-in-up" style="animation-delay: 0.3s;">
    <div class="card-header-premium d-flex justify-content-between align-items-center">
        <h5 class="fw-bolder text-dark m-0"><i class="fa-solid fa-users-gear text-primary me-2"></i> ملخص مبيعات وحسابات الفنيين</h5>
        <a href="/Accounting/TechnicianCommissions" class="btn btn-sm btn-dark rounded-pill px-4 fw-bold shadow-sm hover-elevate">الذهاب لحاسبة التصفية الذكية <i class="fa-solid fa-arrow-left ms-1 text-warning"></i></a>
    </div>

    <div class="card-body-premium p-0">
        <div class="table-responsive">
            <table class="table premium-table table-hover align-middle text-center mb-0 w-100">
                <thead class="bg-light">
                    <tr>
                        <th class="text-start ps-4">اسم الفني</th>
                        <th>إجمالي المبيعات<br><span class="text-muted small fw-normal">(هذا الشهر)</span></th>
                        <th>مبيعات أجور اليد<br><span class="text-success small fw-normal">(تُحسب منها العمولة)</span></th>
                        <th>مبيعات قطع الغيار<br><span class="text-info small fw-normal">(ترجع لخزنة المشتريات)</span></th>
                        <th>إجمالي السلف / مديونية<br><span class="text-danger small fw-normal">(مرحّلة)</span></th>
                        <th>العهدة (الكاش المُحصّل)<br><span class="text-primary small fw-normal">(مرحّلة)</span></th>
                    </tr>
                </thead>
                <tbody>
                    @if (ViewBag.TechnicianReports != null)
                    {
                        foreach (var tech in ViewBag.TechnicianReports)
                        {
                            <tr style="border-bottom: 1px solid #f1f5f9;">
                                <td class="fw-bold text-start ps-4">
                                    <div class="d-flex align-items-center gap-2">
                                        <div class="avatar-sm bg-primary bg-opacity-10 text-primary fw-bolder">@tech.Name.Substring(0, 1)</div>
                                        @tech.Name
                                    </div>
                                </td>
                                <td class="fw-bolder text-dark fs-6">@tech.TotalSales.ToString("N2")</td>
                                <td class="fw-bolder text-success bg-success bg-opacity-10 border-end border-start">@((tech.TotalSales - tech.PartsCost).ToString("N2"))</td>
                                <td class="fw-bold text-info text-dark">@tech.PartsCost.ToString("N2")</td>
                                <td class="fw-bold text-danger">@tech.AllTimeDeductions.ToString("N2")</td>
                                <td><span class="badge bg-primary bg-opacity-10 text-primary fs-6 px-3 py-2 rounded-pill">@tech.WalletBalance.ToString("N2") ر.س</span></td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Modal إضافة شريك جديد -->
<div class="modal fade" id="addPartnerModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content premium-modal border-0 shadow-lg">
            <div class="modal-header border-bottom-0 pb-0 px-4 pt-4">
                <h5 class="modal-title fw-bolder text-dark m-0"><i class="fa-solid fa-user-plus text-primary me-2"></i> إضافة شريك جديد للمؤسسة</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="AddPartner" method="post">
                <div class="modal-body p-4 text-start">
                    <div class="mb-4">
                        <label class="premium-label">اسم الشريك / المستثمر <span class="text-danger">*</span></label>
                        <input type="text" name="name" class="premium-input form-control" required />
                    </div>
                    <div class="mb-2">
                        <label class="premium-label">نسبة الشراكة المئوية (%) <span class="text-danger">*</span></label>
                        <div class="input-group input-group-lg rounded-4 overflow-hidden shadow-sm">
                            <input type="number" step="0.01" name="sharePercentage" class="form-control fw-bolder border-0 bg-light text-primary" max="@remainingShare" required />
                            <span class="input-group-text bg-white border-0 fw-bolder px-4 text-primary">%</span>
                        </div>
                        <small class="text-muted d-block mt-2 fw-bold">الحد الأقصى المتاح للنسبة هو: @remainingShare%</small>
                    </div>
                </div>
                <div class="modal-footer border-top-0 pt-0 px-4 pb-4">
                    <button type="button" class="btn btn-light fw-bold px-4 rounded-pill" data-bs-dismiss="modal">إلغاء</button>
                    <button type="submit" class="btn btn-primary fw-bolder w-100 mt-2 py-3 rounded-pill shadow-sm hover-elevate">حفظ الشريك وإدراجه بالحسابات <i class="fa-solid fa-check ms-1"></i></button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Modal اعتماد وصرف أرباح الشريك -->
<div class="modal fade" id="settlePartnerModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content premium-modal border-0 shadow-lg">
            <div class="modal-header border-bottom-0 pb-0 px-4 pt-4">
                <h5 class="modal-title fw-bolder text-success m-0"><i class="fa-solid fa-money-bill-transfer text-success me-2"></i> اعتماد وصرف أرباح شريك</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="SettlePartnerShare" method="post">
                <div class="modal-body p-4 text-start">
                    <input type="hidden" name="partnerId" id="modalSettlePartnerId" />
                    <input type="hidden" name="partnerName" id="modalSettlePartnerNameInput" />
                    <input type="hidden" name="monthYearName" value="@monthName" />

                    <div class="alert alert-success py-3 small fw-bold mb-4 border-0 rounded-3 shadow-sm bg-success bg-opacity-10 text-dark">
                        <i class="fa-solid fa-circle-info text-success me-1"></i>
                        أنت تقوم بتسجيل واعتماد صرف أرباح الشريك <b id="modalSettlePartnerName" class="text-dark fs-6"></b> عن شهر (@monthName).
                    </div>

                    <div class="mb-4">
                        <label class="premium-label">مبلغ الأرباح المُراد صرفه وتسويته <span class="text-danger">*</span></label>
                        <div class="input-group input-group-lg rounded-4 overflow-hidden shadow-sm">
                            <input type="number" step="0.01" name="amount" id="modalSettleAmount" class="form-control fw-bolder border-0 bg-light text-success" required />
                            <span class="input-group-text bg-white border-0 fw-bolder px-4 text-success">ر.س</span>
                        </div>
                    </div>

                    <div class="mb-2 p-3 bg-light rounded-4 border">
                        <label class="form-label fw-bolder text-primary mb-3">من أين سيتم صرف المبلغ للشريك؟ <span class="text-danger">*</span></label>
                        <div class="d-flex flex-column gap-2">
                            <label class="btn btn-outline-success text-start fw-bold p-3 rounded-3 d-flex align-items-center">
                                <input type="radio" name="paymentMethod" value="Cash" class="form-check-input me-3 fs-5" required checked>
                                <div><i class="fa-solid fa-money-bills me-2"></i> كاش (تُخصم من الخزنة العامة / الدرج)</div>
                            </label>
                            <label class="btn btn-outline-primary text-start fw-bold p-3 rounded-3 d-flex align-items-center">
                                <input type="radio" name="paymentMethod" value="BankTransfer" class="form-check-input me-3 fs-5">
                                <div><i class="fa-solid fa-building-columns me-2"></i> تحويل بنكي (تُخصم من حساب البنك)</div>
                            </label>
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-top-0 pt-0 px-4 pb-4">
                    <button type="button" class="btn btn-light fw-bold px-4 rounded-pill" data-bs-dismiss="modal">إلغاء</button>
                    <button type="submit" class="btn btn-dark fw-bolder w-100 mt-2 py-3 rounded-pill shadow-sm hover-elevate">تأكيد الصرف وتسوية الدفاتر <i class="fa-solid fa-file-signature ms-1 text-warning"></i></button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Modal التسوية الجردية (المحاسب) -->
<div class="modal fade" id="adjustSafeModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content premium-modal border-0 shadow-lg">
            <div class="modal-header border-bottom-0 pb-0 px-4 pt-4">
                <h5 class="modal-title fw-bolder text-dark m-0"><i class="fa-solid fa-scale-balanced text-primary me-2"></i> تسوية جردية (تعديل الدرج)</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="AdjustSafeBalance" method="post">
                <div class="modal-body p-4 text-start">
                    <input type="hidden" name="targetSafe" id="modalTargetSafe" value="" />

                    <div class="alert alert-info py-2 small fw-bold mb-4 border-0 rounded-3 shadow-sm bg-info bg-opacity-10 text-dark">
                        <i class="fa-solid fa-circle-info text-info me-1"></i>
                        أنت تقوم بتعديل الرصيد النقدي لـ <b id="modalSafeNameName" class="text-primary"></b>.<br>
                        الرصيد المُسجل بالنظام حالياً هو: <b class="text-danger" id="modalCurrentBalance"></b> ريال.
                    </div>

                    <div class="mb-4">
                        <label class="premium-label">الرصيد النقدي الفعلي (في الدرج الآن) <span class="text-danger">*</span></label>
                        <div class="input-group input-group-lg rounded-4 overflow-hidden shadow-sm">
                            <input type="number" step="0.01" name="actualBalance" id="modalActualBalance" class="form-control fw-bolder border-0 bg-light text-primary" required />
                            <span class="input-group-text bg-white border-0 fw-bolder px-4 text-primary">ر.س</span>
                        </div>
                    </div>

                    <div class="mb-2">
                        <label class="premium-label">سبب التعديل / ملاحظات المحاسب <span class="text-danger">*</span></label>
                        <input type="text" name="notes" class="premium-input form-control" placeholder="مثال: إضافة رأس مال، عجز، مسحوبات..." required />
                    </div>
                </div>
                <div class="modal-footer border-top-0 pt-0 px-4 pb-4">
                    <button type="button" class="btn btn-light fw-bold px-4 rounded-pill" data-bs-dismiss="modal">إلغاء</button>
                    <button type="submit" class="btn btn-primary fw-bolder px-4 rounded-pill shadow-sm hover-elevate">تأكيد التسوية الجردية <i class="fa-solid fa-check-double ms-1"></i></button>
                </div>
            </form>
        </div>
    </div>
</div>

<style>
    /* Premium Dashboard UI Styles */
    :root {
        --prem-surface: #ffffff;
        --prem-border: #e2e8f0;
        --prem-text: #1e293b;
        --prem-muted: #64748b;
        --prem-radius: 20px;
        --prem-primary: #f1950b;
    }

    .fade-in-up {
        animation: fadeInUp 0.6s cubic-bezier(0.16, 1, 0.3, 1) both;
    }

    @@keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(20px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .premium-card {
        background: var(--prem-surface);
        border-radius: var(--prem-radius);
        border: 1px solid var(--prem-border);
        box-shadow: 0 10px 30px rgba(0,0,0,0.02);
        overflow: hidden;
    }

    .card-header-premium {
        padding: 24px;
        border-bottom: 1px solid var(--prem-border);
    }

    .card-body-premium {
        padding: 24px;
    }

    .icon-box {
        width: 45px;
        height: 45px;
        border-radius: 12px;
        display: flex;
        justify-content: center;
        align-items: center;
        font-size: 20px;
    }

    .avatar-sm {
        width: 35px;
        height: 35px;
        border-radius: 50%;
        display: flex;
        justify-content: center;
        align-items: center;
    }

    .hover-elevate {
        transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1), box-shadow 0.3s;
        cursor: pointer;
    }

        .hover-elevate:hover {
            transform: translateY(-5px);
            box-shadow: 0 15px 30px rgba(0,0,0,0.05) !important;
            border-color: #cbd5e1 !important;
        }

    .edit-btn {
        opacity: 0;
        transition: opacity 0.3s;
        position: absolute;
        left: 20px;
        top: 50%;
        transform: translateY(-50%);
    }

    .group-hover:hover .edit-btn {
        opacity: 1;
    }

    .premium-label {
        font-weight: 800;
        color: var(--prem-muted);
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        margin-bottom: 8px;
        display: block;
    }

    .premium-input {
        background-color: #f8fafc;
        border: 1px solid var(--prem-border);
        border-radius: 12px;
        padding: 14px 20px;
        font-weight: 700;
        color: var(--prem-text);
        box-shadow: none !important;
        transition: all 0.3s ease;
    }

        .premium-input:focus {
            background-color: #fff;
            border-color: var(--prem-primary);
            box-shadow: 0 0 0 4px rgba(241, 149, 11, 0.1) !important;
        }

    .premium-table th {
        font-weight: 800;
        color: var(--prem-muted);
        border-bottom: 2px solid var(--prem-border);
        padding: 16px;
        font-size: 0.85rem;
        text-transform: uppercase;
    }

    .premium-table td {
        padding: 16px;
        vertical-align: middle;
    }

    .premium-modal {
        border-radius: 24px;
        overflow: hidden;
    }

    .btn-check:checked + .btn-outline-success {
        background-color: #ecfdf5;
        color: #10b981;
        border-color: #10b981;
    }

    .btn-check:checked + .btn-outline-primary {
        background-color: #eff6ff;
        color: #3b82f6;
        border-color: #3b82f6;
    }
</style>

@section Scripts {
    <script>
        function openAdjustModal(safeEnum, currentVal, safeNameAr) {
            document.getElementById('modalTargetSafe').value = safeEnum;
            document.getElementById('modalSafeNameName').innerText = safeNameAr;
            document.getElementById('modalCurrentBalance').innerText = currentVal.toFixed(2);
            document.getElementById('modalActualBalance').value = currentVal.toFixed(2);
            var myModal = new bootstrap.Modal(document.getElementById('adjustSafeModal'));
            myModal.show();
        }

        function openSettlePartnerModal(id, name, amount, month) {
            document.getElementById('modalSettlePartnerId').value = id;
            document.getElementById('modalSettlePartnerNameInput').value = name;
            document.getElementById('modalSettlePartnerName').innerText = name;
            document.getElementById('modalSettleAmount').value = amount.toFixed(2);

            var myModal = new bootstrap.Modal(document.getElementById('settlePartnerModal'));
            myModal.show();
        }

        @if (TempData["SuccessMessage"] != null)
        {
                var msg = System.Text.Json.JsonSerializer.Serialize(TempData["SuccessMessage"]?.ToString());
                <text>Swal.fire({ icon: 'success', title: 'تم بنجاح', text: @Html.Raw(msg), confirmButtonColor: '#198754', customClass: { popup: 'rounded-4' } });</text>
        }
        @if (TempData["ErrorMessage"] != null)
        {
                var errMsg = System.Text.Json.JsonSerializer.Serialize(TempData["ErrorMessage"]?.ToString());
                <text>Swal.fire({ icon: 'error', title: 'خطأ', text: @Html.Raw(errMsg), confirmButtonColor: '#dc3545', customClass: { popup: 'rounded-4' } });</text>
        }
    </script>
}