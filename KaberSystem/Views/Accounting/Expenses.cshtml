<!-- مسار الملف: Views/Accounting/Expenses.cshtml -->
@model IEnumerable<KaberSystem.Models.Expense>
@{
    ViewData["Title"] = "المرتبات والمصروفات";
    Layout = "~/Views/Shared/_SystemLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-end mb-4">
    <div>
        <h2 class="fw-bolder text-dark mb-1" style="letter-spacing: -0.5px;">
            <i class="fa-solid fa-money-check-dollar text-danger me-2"></i> إدارة المرتبات والمصروفات
        </h2>
        <p class="text-muted fw-bold mb-0">تسجيل الرواتب، السلف، والمصروفات مع تحديد جهة تحمل التكلفة مالياً</p>
    </div>
</div>

<div class="row g-4">
    <!-- 📌 نموذج إضافة مصروف (Premium Design) -->
    <div class="col-lg-4">
        <div class="card border-0 rounded-4 shadow-sm h-100 position-sticky" style="top: 20px;">
            <div class="card-header bg-white border-bottom-0 pt-4 pb-0 px-4">
                <h5 class="fw-bolder text-dark mb-0"><i class="fa-solid fa-plus-circle text-primary me-2"></i> قيد مالي جديد</h5>
            </div>
            <div class="card-body p-4">
                <form asp-action="AddExpense" method="post">
                    <div class="mb-3">
                        <label class="form-label fw-bold text-muted small text-uppercase">البيان (راتب / سلفة / مصروف) <span class="text-danger">*</span></label>
                        <input type="text" name="Description" class="form-control sys-input fw-bold" placeholder="مثال: راتب شهر مارس" required />
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold text-muted small text-uppercase">المبلغ المستحق <span class="text-danger">*</span></label>
                        <div class="input-group">
                            <input type="number" step="0.01" name="Amount" class="form-control sys-input fw-bold text-danger" placeholder="0.00" required />
                            <span class="input-group-text bg-light fw-bold border-2">ر.س</span>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold text-muted small text-uppercase">مرتبط بالمستفيد (اختياري)</label>
                        <select name="TechnicianId" class="form-select sys-input fw-bold bg-light" asp-items="ViewBag.TechnicianId">
                            <option value="">-- مصروف إداري عام --</option>
                        </select>
                    </div>

                    <!-- 📌 منطق جهة الخصم الجديد -->
                    <div class="p-3 bg-light rounded-4 mb-4 border">
                        <label class="fw-bold text-primary mb-3 d-block small text-uppercase tracking-wider">
                            <i class="fa-solid fa-scale-balanced me-1"></i> جهة الخصم المحاسبية:
                        </label>

                        <div class="form-check mb-3">
                            <input class="form-check-input" type="radio" name="DeductionFrom" id="dedCompany" value="Company" checked>
                            <label class="form-check-label fw-bold text-dark" for="dedCompany">
                                <span class="d-block">دخل الشركة العام</span>
                                <small class="text-muted fw-normal">تُحسب كمصروف تشغيلي (رواتب، إيجار، بنزين)</small>
                            </label>
                        </div>

                        <div class="form-check">
                            <input class="form-check-input" type="radio" name="DeductionFrom" id="dedTech" value="Technician">
                            <label class="form-check-label fw-bold text-danger" for="dedTech">
                                <span class="d-block">دخل الفني الخاص</span>
                                <small class="text-muted fw-normal">تُخصم من صافي أرباح الفني (سلفة، مديونية، جزاء)</small>
                            </label>
                        </div>
                    </div>

                    <button type="submit" class="btn btn-primary fw-bold w-100 py-3 rounded-pill shadow-sm hover-elevate">
                        <i class="fa-solid fa-save me-2"></i> حفظ واعتماد القيد
                    </button>
                </form>
            </div>
        </div>
    </div>

    <!-- 📌 جدول السجلات المسجلة -->
    <div class="col-lg-8">
        <div class="card border-0 rounded-4 shadow-sm h-100">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-borderless table-hover align-middle text-center custom-table mb-0 w-100">
                        <thead class="bg-light text-muted small fw-bold text-uppercase">
                            <tr>
                                <th class="py-3 text-start ps-4">البيان / الوصف</th>
                                <th class="py-3">المبلغ</th>
                                <th class="py-3">جهة الخصم</th>
                                <th class="py-3">المستفيد</th>
                                <th class="py-3">التاريخ</th>
                                @if (User.IsInRole("Admin"))
                                {
                                    <th class="py-3 pe-4">إلغاء</th>
                                }
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr style="border-bottom: 1px solid #f8f9fa;">
                                    <td class="text-start ps-4 py-3">
                                        <div class="fw-bold text-dark">@item.Description</div>
                                        <div class="small text-muted">بواسطة: @item.RecordedBy</div>
                                    </td>
                                    <td class="fw-bolder text-danger fs-6">
                                        @item.Amount.ToString("N2") <span class="small fw-normal">ر.س</span>
                                    </td>
                                    <td>
                                        @if (item.DeductionFrom == KaberSystem.Models.DeductionSource.Company)
                                        {
                                            <span class="badge bg-primary bg-opacity-10 text-primary px-3 py-1 rounded-pill fw-bold">
                                                <i class="fa-solid fa-building-columns me-1 small"></i> أرباح الشركة
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger bg-opacity-10 text-danger px-3 py-1 rounded-pill fw-bold">
                                                <i class="fa-solid fa-user-minus me-1 small"></i> مديونية فني
                                            </span>
                                        }
                                    </td>
                                    <td>
                                        @if (item.Technician != null)
                                        {
                                            <div class="d-inline-flex align-items-center bg-light rounded-pill px-3 py-1 border">
                                                <i class="fa-solid fa-user-gear text-muted me-2 small"></i>
                                                <span class="text-dark fw-bold small">@item.Technician.Name</span>
                                            </div>
                                        }
                                        else
                                        {
                                            <span class="text-muted small fw-bold">مصرف إداري</span>
                                        }
                                    </td>
                                    <td dir="ltr" class="text-muted fw-bold small">
                                        @item.Date.ToString("yyyy-MM-dd")
                                    </td>
                                    @if (User.IsInRole("Admin"))
                                    {
                                        <td class="pe-4">
                                            <form asp-action="DeleteExpense" method="post" onsubmit="return confirm('هل أنت متأكد من حذف هذا القيد المالي؟ سيؤثر ذلك على التقارير فوراً.');">
                                                <input type="hidden" name="id" value="@item.Id" />
                                                <button type="submit" class="btn btn-sm btn-light text-danger rounded-circle hover-danger" style="width:38px; height:38px;">
                                                    <i class="fa-solid fa-trash-can"></i>
                                                </button>
                                            </form>
                                        </td>
                                    }
                                </tr>
                            }
                            @if (!Model.Any())
                            {
                                <tr>
                                    <td colspan="6" class="py-5 text-center text-muted">
                                        <div class="bg-light rounded-circle d-inline-flex justify-content-center align-items-center mb-3" style="width: 70px; height: 70px;">
                                            <i class="fa-solid fa-file-invoice-dollar fs-3 opacity-50"></i>
                                        </div>
                                        <h6 class="fw-bold">لا توجد سجلات مصروفات حالياً.</h6>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @if (TempData["SuccessMessage"] != null)
    {
        <script>
            Swal.fire({
                icon: 'success',
                title: 'تم بنجاح',
                text: '@Html.Raw(TempData["SuccessMessage"])',
                confirmButtonColor: '#05cd99',
                customClass: { popup: 'rounded-4' }
            });
        </script>
    }
}

<style>
    .sys-input {
        border: 2px solid #e9edf7;
        padding: 12px 18px;
        border-radius: 12px;
        font-weight: 600;
        transition: all 0.3s ease;
        background-color: #f8f9fa;
        color: #2b3674;
    }

        .sys-input:focus {
            border-color: var(--sys-primary);
            box-shadow: 0 0 0 0.25rem rgba(241, 149, 11, 0.1);
            background-color: #fff;
            outline: none;
        }

    .custom-table th {
        font-size: 0.8rem;
        letter-spacing: 0.5px;
    }

    .custom-table tbody tr {
        transition: all 0.2s ease;
    }

        .custom-table tbody tr:hover {
            background-color: #fcfcfd !important;
            transform: scale(1.002);
        }

    .hover-elevate {
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

        .hover-elevate:hover {
            transform: translateY(-3px);
            box-shadow: 0 10px 20px rgba(0,0,0,0.1) !important;
        }

    .hover-danger:hover {
        background-color: #ee5d50 !important;
        color: white !important;
        border-color: #ee5d50 !important;
        box-shadow: 0 4px 12px rgba(238, 93, 80, 0.2);
    }

    .form-check-input:checked {
        background-color: var(--sys-primary);
        border-color: var(--sys-primary);
    }

    .form-check-label {
        cursor: pointer;
        padding-right: 5px;
    }
</style>