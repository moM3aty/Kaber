@model IEnumerable<KaberSystem.Models.Order>
@{
    ViewData["Title"] = "الدفتر المالي الشامل (شيت العمليات)";
    Layout = "~/Views/Shared/_SystemLayout.cshtml";
    string currentMonthYear = ViewBag.CurrentMonthYear;

    // إجماليات الشيت
    decimal sumTotalRevenues = 0;
    decimal sumTotalPartsCost = 0;
    decimal sumTotalLabor = 0;
    decimal sumNetProfits = 0;
}

<div class="sys-page-header d-flex justify-content-between align-items-center flex-wrap print-header-container">
    <div class="text-center text-md-start w-100-print">
        <h1 class="sys-page-title text-success print-title" style="font-family: monospace;"><i class="fa-solid fa-table-cells text-success me-2"></i> الدفتر المالي الشامل لشهر (@ViewBag.MonthName)</h1>
        <p class="sys-page-desc d-print-none">عرض تفصيلي لجميع الطلبات المنجزة والمدفوعة، مطابق لتنسيق شيت الإكسل لسهولة المراجعة.</p>
    </div>
    <div class="d-flex gap-2 mt-3 mt-md-0 d-print-none">
        <form method="get" asp-action="MasterLedger" class="m-0 bg-white p-1 rounded-pill shadow-sm border border-success">
            <div class="d-flex align-items-center px-2">
                <i class="fa-regular fa-calendar-days text-success me-2"></i>
                <input type="month" name="monthYear" value="@currentMonthYear" class="form-control form-control-sm fw-bold border-0 text-success" style="box-shadow: none; cursor: pointer;" onchange="this.form.submit()" />
            </div>
        </form>
        <button onclick="window.print()" class="sys-btn btn-dark fw-bold"><i class="fa-solid fa-print"></i> طباعة الشيت</button>
    </div>
</div>

<div class="card border-0 rounded-0 shadow-sm mt-3 print-card" style="border-top: 5px solid #198754 !important;">
    <div class="card-body p-0 table-responsive print-table-wrapper">
        <!-- 📌 تصميم الجدول شبيه بالإكسل (Compact and Dense) -->
        <table class="table table-bordered table-sm table-hover align-middle text-center mb-0 excel-table">
            <thead class="bg-light align-middle text-dark" style="font-size: 13px;">
                <tr>
                    <th rowspan="2" class="bg-secondary text-white print-th">التاريخ</th>
                    <th rowspan="2" class="bg-secondary text-white print-th">رقم الفاتورة</th>
                    <th rowspan="2" class="bg-secondary text-white print-th">العميل</th>
                    <th rowspan="2" class="bg-secondary text-white print-th">طريقة الدفع</th>
                    <th rowspan="2" class="bg-secondary text-white print-th">الفني</th>
                    <th rowspan="2" class="bg-secondary text-white print-th">نوع الزيارة</th>
                    <th colspan="4" class="bg-success text-white border-bottom-0 print-th-main">التحليل المالي للعملية (بالريال)</th>
                </tr>
                <tr>
                    <th class="bg-light text-dark print-th-sub">إجمالي الفاتورة</th>
                    <th class="bg-light text-danger print-th-sub">تكلفة القطع (COGS)</th>
                    <th class="bg-light text-primary print-th-sub">أجور اليد والفحص</th>
                    <th class="bg-light text-success fw-bolder print-th-sub">صافي ربح العملية</th>
                </tr>
            </thead>
            <tbody style="font-size: 13px; font-weight: 600;">
                @foreach (var order in Model)
                {
                    // الحسابات لكل صف
                    decimal orderTotal = order.FinalPrice + order.AdvancePayment;
                    decimal orderPartsCost = order.UsedSpareParts?.Sum(p => p.QuantityUsed * (p.SparePart?.PurchasePrice ?? 0)) ?? 0;
                    decimal orderPartsSales = order.UsedSpareParts?.Sum(p => p.QuantityUsed * p.SellingPriceAtTime) ?? 0;
                    decimal orderLabor = orderTotal - orderPartsSales; // أجور اليد
                    decimal orderNetProfit = orderTotal - orderPartsCost; // صافي الربح من العملية (قبل خصم المصروفات العامة)

                    // تراكم الإجماليات
                    sumTotalRevenues += orderTotal;
                    sumTotalPartsCost += orderPartsCost;
                    sumTotalLabor += orderLabor;
                    sumNetProfits += orderNetProfit;

                    <tr>
                        <td dir="ltr" class="text-muted">@order.CreatedAt.ToString("yyyy-MM-dd")</td>
                        <td><a href="/Orders/Details/@order.OrderId" target="_blank" class="text-decoration-none print-link">INV-#@order.OrderId</a></td>
                        <td class="text-start">@order.CustomerName</td>
                        <td>
                            @if (order.PaymentMethod == KaberSystem.Models.PaymentMethod.Cash)
                            {
                                <span class="text-success print-text-normal"><i class="fa-solid fa-money-bills d-print-none"></i> كاش</span>
                            }
                            else if (order.PaymentMethod == KaberSystem.Models.PaymentMethod.BankTransfer)
                            {
                                <span class="text-primary print-text-normal"><i class="fa-solid fa-building-columns d-print-none"></i> تحويل</span>
                            }
                            else if (order.PaymentMethod == KaberSystem.Models.PaymentMethod.POS)
                            {
                                <span class="text-info text-dark print-text-normal"><i class="fa-solid fa-credit-card d-print-none"></i> شبكة</span>
                            }
                        </td>
                        <td>@order.Technician?.Name</td>
                        <td>
                            @(order.Type == KaberSystem.Models.OrderType.Maintenance ? "صيانة" : order.Type == KaberSystem.Models.OrderType.NewInstallation ? "تركيب" : "أخرى")
                        </td>

                        <!-- التحليل المالي -->
                        <td class="bg-light">@orderTotal.ToString("N2")</td>
                        <td class="text-danger">@orderPartsCost.ToString("N2")</td>
                        <td class="text-primary">@orderLabor.ToString("N2")</td>
                        <td class="text-success fw-bold bg-success bg-opacity-10 print-success-cell">@orderNetProfit.ToString("N2")</td>
                    </tr>
                }

                @if (!Model.Any())
                {
                    <tr><td colspan="10" class="py-5 text-muted fw-bold">لا توجد فواتير مدفوعة في هذا الشهر لترحيلها للدفتر.</td></tr>
                }
            </tbody>
            <tfoot class="bg-dark text-white fw-bold print-footer" style="font-size: 14px;">
                <tr>
                    <td colspan="6" class="text-end pe-3">الإجماليات لشهر (@ViewBag.MonthName):</td>
                    <td class="text-white print-footer-val">@sumTotalRevenues.ToString("N2")</td>
                    <td class="text-warning print-footer-val">@sumTotalPartsCost.ToString("N2")</td>
                    <td class="text-info print-footer-val">@sumTotalLabor.ToString("N2")</td>
                    <td class="bg-success text-white fs-6 print-footer-net">@sumNetProfits.ToString("N2")</td>
                </tr>
            </tfoot>
        </table>
    </div>
</div>

<style>
    /* تنسيق خاص ليجعل الجدول يبدو مثل Excel تماماً على الشاشة */
    .excel-table th, .excel-table td {
        border: 1px solid #dee2e6;
        vertical-align: middle;
        white-space: nowrap;
    }

    .excel-table tbody tr:hover {
        background-color: #f1f3f5 !important;
    }

    /* 📌 إعدادات الطباعة الاحترافية (Professional Print Media Query) */
    @@media print {
        /* إجبار الطابعة على قلب الورقة بالعرض لاستيعاب الأعمدة (Landscape) */
        @@page {
            size: A4 landscape;
            margin: 1cm;
        }

        body {
            background: white !important;
            margin: 0;
            padding: 0;
            font-family: 'Cairo', sans-serif !important;
        }
        /* إخفاء القوائم الجانبية والعلوية والأزرار */
        .sys-sidebar, .sys-header, .d-print-none {
            display: none !important;
        }
        /* تفريغ الهوامش لكي يأخذ الجدول كامل مساحة الورقة */
        .sys-main, .sys-wrapper, .sys-content {
            margin: 0 !important;
            width: 100% !important;
            max-width: 100% !important;
            padding: 0 !important;
        }
        /* تظبيط عنوان الصفحة ليظهر في الطباعة بشكل رسمي */
        .print-header-container {
            display: block !important;
            text-align: center !important;
            border-bottom: 2px solid #000 !important;
            padding-bottom: 15px !important;
            margin-bottom: 20px !important;
        }

        .w-100-print {
            width: 100% !important;
            text-align: center !important;
        }

        .print-title {
            color: #000 !important;
            font-size: 22px !important;
            margin: 0 !important;
        }

            .print-title i {
                display: none !important;
            }
        /* إخفاء الأيقونة في العنوان عند الطباعة */

        .print-card {
            border: none !important;
            box-shadow: none !important;
            margin-top: 0 !important;
        }
        /* إجبار المتصفح على طباعة الألوان الدقيقة للترويسة */
        * {
            -webkit-print-color-adjust: exact !important;
            color-adjust: exact !important;
            print-color-adjust: exact !important;
        }
        /* 📌 إعدادات جدول الإكسل للطباعة */
        .excel-table {
            width: 100% !important;
            border-collapse: collapse !important;
            font-size: 11pt !important;
        }

            .excel-table th, .excel-table td {
                border: 1px solid #000 !important; /* خطوط سوداء واضحة */
                padding: 6px 8px !important;
                color: #000 !important; /* النص أسود ليكون مقروءاً */
                white-space: normal !important; /* السماح بالتفاف النص إذا لزم الأمر */
            }
        /* تلوين خفيف لترويسة الجدول لسهولة القراءة */
        .print-th, .print-th-main {
            background-color: #e9ecef !important;
            color: #000 !important;
            font-weight: bold !important;
            text-align: center !important;
        }

        .print-th-sub {
            background-color: #f8f9fa !important;
            font-weight: bold !important;
            text-align: center !important;
        }
        /* تلوين خفيف لخلية صافي الربح */
        .print-success-cell {
            background-color: rgba(25, 135, 84, 0.1) !important;
            font-weight: bold !important;
        }
        /* إزالة خطوط الروابط */
        .print-link {
            text-decoration: none !important;
            color: #000 !important;
        }
        /* تظبيط ذيل الجدول (الإجماليات) */
        .print-footer td {
            background-color: #d6d8db !important;
            color: #000 !important;
            font-weight: bold !important;
            border-top: 2px solid #000 !important;
        }

        .print-footer-net {
            background-color: #d1e7dd !important;
            color: #000 !important;
        }
        /* منع انقسام الصف الواحد بين صفحتين */
        .excel-table tbody tr {
            page-break-inside: avoid !important;
        }
    }
</style>