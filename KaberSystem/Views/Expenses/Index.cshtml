@model IEnumerable<KaberSystem.Models.Expense>
@{
    ViewData["Title"] = "إدارة المصروفات";
    Layout = "~/Views/Shared/_SystemLayout.cshtml";
}

<div class="sys-page-header">
    <div>
        <h1 class="sys-page-title">المصروفات اليومية</h1>
        <p class="sys-page-desc">تسجيل ومتابعة مصروفات الشركة والتوالف لخصمها من الأرباح الصافية</p>
    </div>
</div>

<div class="row g-4">
    <!-- نموذج تسجيل مصروف جديد -->
    <div class="col-lg-4">
        <div class="sys-card border-top border-4 border-danger h-100">
            <h5 class="fw-bold mb-4 text-danger"><i class="fa-solid fa-minus-circle me-2"></i> تسجيل مصروف جديد</h5>
            <form asp-action="Create" method="post">
                <div class="mb-3">
                    <label class="form-label fw-bold text-dark">البيان (وصف المصروف) <span class="text-danger">*</span></label>
                    <input type="text" name="description" class="form-control sys-input" required />
                </div>
                <div class="mb-4">
                    <label class="form-label fw-bold text-dark">المبلغ <span class="text-danger">*</span></label>
                    <div class="input-group">
                        <input type="number" step="0.01" name="amount" class="form-control sys-input border-end-0" required />
                        <span class="input-group-text bg-light border-secondary border-start-0 fw-bold">ر.س</span>
                    </div>
                </div>
                <button type="submit" class="sys-btn sys-btn-primary w-100 justify-content-center py-3 fs-5">
                    <i class="fa-solid fa-save"></i> تسجيل
                </button>
            </form>

            <div class="mt-5 p-3 bg-danger bg-opacity-10 rounded-3 text-center border border-danger">
                <h6 class="fw-bold text-danger mb-2">إجمالي المصروفات</h6>
                <h3 class="fw-bold text-danger m-0">@ViewData["TotalExpenses"] ر.س</h3>
            </div>
        </div>
    </div>

    <!-- سجل المصروفات -->
    <div class="col-lg-8">
        <div class="sys-card h-100">
            <h5 class="fw-bold mb-4 text-dark"><i class="fa-solid fa-list-ul text-primary me-2"></i> سجل حركات المصروفات</h5>
            <div class="table-responsive">
                <table class="table table-hover align-middle text-center sys-table w-100">
                    <thead class="table-light">
                        <tr>
                            <th>رقم القيد</th>
                            <th>البيان</th>
                            <th>المبلغ</th>
                            <th>تاريخ الصرف</th>
                            <th>بواسطة</th>
                            @if (User.IsInRole("Admin"))
                            {
                                <th>إجراء</th>
                            }
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td><span class="text-muted fw-bold">#@item.Id</span></td>
                                <td class="fw-bold text-dark text-start">@item.Description</td>
                                <td class="text-danger fw-bold fs-6">@item.Amount ر.س</td>
                                <td dir="ltr" class="text-muted fw-bold">@item.Date.ToString("yyyy/MM/dd hh:mm tt")</td>
                                <td><span class="badge bg-secondary">@item.RecordedBy</span></td>

                                <!-- زر الحذف للإدارة فقط لمعالجة الإدخال الخاطئ -->
                                @if (User.IsInRole("Admin"))
                                {
                                    <td>
                                        <button type="button" onclick="confirmAdminDelete('/Expenses/Delete/@item.Id', 'المصروف: @item.Description')" class="btn btn-sm btn-outline-danger fw-bold rounded-3 px-2">
                                            <i class="fa-solid fa-trash"></i>
                                        </button>
                                    </td>
                                }
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<style>
    .sys-input {
        border: 2px solid var(--sys-border);
        padding: 12px 18px;
        border-radius: 10px;
        font-weight: 600;
        background-color: var(--sys-bg);
    }

        .sys-input:focus {
            border-color: var(--sys-primary);
            box-shadow: 0 0 0 0.25rem rgba(241, 149, 11, 0.15);
            background-color: #fff;
            outline: none;
        }
</style>

@section Scripts {
    @if (TempData["SuccessMessage"] != null)
    {
        <script>Swal.fire({ icon: 'success', title: 'عملية ناجحة', text: '@Html.Raw(TempData["SuccessMessage"])', confirmButtonColor: '#f1950b' });</script>
    }
}