<!-- مسار الملف: Views/HR/Payroll.cshtml -->
@model IEnumerable<KaberSystem.Models.PayrollRecord>
@{
    ViewData["Title"] = "توليد وصرف الرواتب";
    Layout = "~/Views/Shared/_SystemLayout.cshtml";
    string currentMonthYear = ViewBag.CurrentMonthYear;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="fw-bolder text-dark mb-1"><i class="fa-solid fa-money-check-dollar text-success me-2"></i> توليد وصرف الرواتب</h2>
        <p class="text-muted fw-bold mb-0">حساب الرواتب آلياً بناءً على الحضور والغياب، وترحيلها للحسابات العامة</p>
    </div>
    <div>
        <form method="get" asp-action="Payroll" class="d-flex gap-2">
            <input type="month" name="monthYear" class="form-control fw-bold shadow-sm" value="@currentMonthYear" onchange="this.form.submit()" />
        </form>
    </div>
</div>

<div class="row g-4">
    @foreach (var p in Model)
    {
        <div class="col-md-6">
            <div class="card border-0 rounded-4 shadow-sm @(p.IsPaid ? "bg-success bg-opacity-10 border border-success" : "bg-white")">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-center mb-3 border-bottom pb-3">
                        <h5 class="fw-bolder m-0 text-dark">@p.User?.Username</h5>
                        @if (p.IsPaid)
                        {
                            <span class="badge bg-success px-3 py-2 rounded-pill"><i class="fa-solid fa-check-double me-1"></i> تم الصرف والترحيل للحسابات</span>
                        }
                        else
                        {

                            <span class="badge bg-warning text-dark px-3 py-2 rounded-pill"><i class="fa-solid fa-clock me-1"></i> بانتظار الاعتماد</span>
                        }
                    </div>

                    <div class="row text-center mb-3">
                        <div class="col-4">
                            <small class="text-muted fw-bold d-block">الراتب الأساسي</small>
                            <span class="fw-bolder text-dark fs-5">@p.BaseSalary.ToString("N0")</span>
                        </div>
                        <div class="col-4 border-start border-end">
                            <small class="text-success fw-bold d-block">حضور</small>
                            <span class="fw-bolder text-success fs-5">@p.PresentDays <small>يوم</small></span>
                        </div>
                        <div class="col-4">
                            <small class="text-danger fw-bold d-block">غياب وخصم</small>
                            <span class="fw-bolder text-danger fs-5">@p.AbsentDays <small>يوم</small></span>
                            <div class="text-danger small fw-bold mt-1">- @p.Deductions.ToString("N0") ر.س</div>
                        </div>
                    </div>

                    <form asp-action="ApproveAndPaySalary" method="post" class="mt-3 bg-light p-3 rounded-3 border">
                        <input type="hidden" name="userId" value="@p.UserId" />
                        <input type="hidden" name="month" value="@p.Month" />
                        <input type="hidden" name="year" value="@p.Year" />

                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <span class="fw-bolder text-dark">الصافي النهائي للاستحقاق:</span>
                            <input type="number" step="0.01" name="finalNet" class="form-control text-center fw-bolder fs-4 w-50 bg-white text-success border-success" value="@p.NetSalary.ToString("0.00")" @(p.IsPaid ? "readonly" : "") />
                        </div>

                        @if (!p.IsPaid)
                        {
                            <div class="mb-3">
                                <label class="form-label fw-bold text-muted small">طريقة الصرف (من الحسابات)</label>
                                <select name="paymentMethod" class="form-select fw-bold">
                                    <option value="Cash">كاش (من الخزنة العامة)</option>
                                    <option value="BankTransfer">تحويل بنكي (من حساب البنك)</option>
                                </select>
                            </div>
                            <button type="submit" class="btn btn-success fw-bold w-100 rounded-pill py-2 shadow-sm" onclick="return confirm('تأكيد صرف الراتب وإرساله كخصم في حسابات الشركة؟');">
                                <i class="fa-solid fa-money-bill-transfer me-1"></i> اعتماد الصرف وترحيل للحسابات
                            </button>
                        }
                    </form>
                </div>
            </div>
        </div>
    }
</div>