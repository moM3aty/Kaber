<!-- مسار الملف: Views/HR/Payroll.cshtml -->
@model IEnumerable<KaberSystem.Models.PayrollSchedule>
@{
    ViewData["Title"] = "جدولة الرواتب";
    Layout = "~/Views/Shared/_SystemLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-end mb-4">
    <div>
        <h2 class="fw-bolder text-dark mb-1"><i class="fa-solid fa-calendar-check text-success me-2"></i> جدولة مواعيد الرواتب</h2>
        <p class="text-muted fw-bold mb-0">تحديد المواعيد الشهرية لصرف مستحقات الموظفين</p>
    </div>
    <button class="btn btn-success fw-bold rounded-pill px-4" data-bs-toggle="modal" data-bs-target="#setPayrollModal">
        <i class="fa-solid fa-plus me-1"></i> تحديد موعد جديد
    </button>
</div>

<div class="row g-4">
    @foreach (var s in Model)
    {
        <div class="col-md-4">
            <div class="card border-0 rounded-4 shadow-sm @(s.IsProcessed ? "bg-light opacity-75" : "bg-white border-top border-4 border-success")">
                <div class="card-body p-4 text-center">
                    <h5 class="fw-bold text-dark mb-1">رواتب شهر @s.Month / @s.Year</h5>
                    <div class="display-6 fw-bolder text-success my-3">
                        <i class="fa-solid fa-money-bill-wave fs-4 opacity-50"></i> @s.ScheduledDate.ToString("dd MMM")
                    </div>
                    <p class="text-muted fw-bold small mb-3">@s.Note</p>
                    @if (s.IsProcessed)
                    {
                        <span class="badge bg-secondary rounded-pill px-3 py-2"><i class="fa-solid fa-lock me-1"></i> تم الصرف مسبقاً</span>
                    }
                    else
                    {
                        <span class="badge bg-success rounded-pill px-3 py-2 fw-bold shadow-sm"><i class="fa-solid fa-clock me-1"></i> موعد مجدول</span>
                    }
                </div>
            </div>
        </div>
    }
</div>

<!-- Modal: تحديد موعد رواتب -->
<div class="modal fade" id="setPayrollModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 rounded-4 shadow-lg">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold">تحديد موعد صرف الرواتب</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="SetPayrollDate" method="post">
                <div class="modal-body py-4">
                    <div class="row">
                        <div class="col-6 mb-3">
                            <label class="form-label fw-bold small text-muted">الشهر</label>
                            <input type="number" name="month" class="form-control fw-bold" value="@DateTime.Now.Month" min="1" max="12" required />
                        </div>
                        <div class="col-6 mb-3">
                            <label class="form-label fw-bold small">السنة</label>
                            <input type="number" name="year" class="form-control fw-bold" value="@DateTime.Now.Year" required />
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold small">تاريخ الصرف المحدد</label>
                        <input type="date" name="date" class="form-control fw-bold" required />
                    </div>
                    <div class="mb-0">
                        <label class="form-label fw-bold small">ملاحظة إدارية</label>
                        <input type="text" name="note" class="form-control fw-bold" placeholder="مثال: صرف رواتب شهر رمضان مبكراً" />
                    </div>
                </div>
                <div class="modal-footer border-0 pt-0">
                    <button type="submit" class="btn btn-success fw-bold w-100 py-3 rounded-pill shadow-sm">اعتماد الموعد في التقويم المالي</button>
                </div>
            </form>
        </div>
    </div>
</div>