@model IEnumerable<KaberSystem.Models.SystemUser>
@{
    ViewData["Title"] = "إدارة الموارد البشرية";
    Layout = "~/Views/Shared/_SystemLayout.cshtml";
}

<div class="sys-page-header">
    <div>
        <h1 class="sys-page-title text-primary"><i class="fa-solid fa-users me-2"></i> إدارة الموظفين والموارد البشرية</h1>
        <p class="sys-page-desc">مراقبة طاقم العمل، الإجازات، وتفاصيل الموظفين في النظام</p>
    </div>
    <div class="d-flex gap-2">
        <a href="/HR/Leaves" class="sys-btn btn-warning text-dark fw-bold shadow-sm">
            <i class="fa-solid fa-umbrella-beach me-1"></i> إدارة الإجازات
        </a>
        @if (User.IsInRole("Admin"))
        {
            <a href="/Users/Create" class="sys-btn sys-btn-primary shadow-sm">
                <i class="fa-solid fa-user-plus me-1"></i> إضافة موظف جديد
            </a>
        }
    </div>
</div>

<!-- 📌 كروت الإحصائيات -->
<div class="row g-4 mb-4">
    <div class="col-md-4">
        <div class="sys-card bg-primary bg-opacity-10 border-0 p-4 d-flex align-items-center h-100 shadow-sm">
            <div class="bg-primary text-white rounded-circle d-flex justify-content-center align-items-center me-3 shadow-sm" style="width: 60px; height: 60px;">
                <i class="fa-solid fa-users fs-3"></i>
            </div>
            <div>
                <h6 class="text-muted fw-bold mb-1">إجمالي الموظفين بالنظام</h6>
                <h3 class="fw-bold text-dark m-0">@ViewBag.TotalEmployees <span class="fs-6 text-muted">موظف</span></h3>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="sys-card bg-warning bg-opacity-10 border-0 p-4 d-flex align-items-center h-100 shadow-sm">
            <div class="bg-warning text-dark rounded-circle d-flex justify-content-center align-items-center me-3 shadow-sm" style="width: 60px; height: 60px;">
                <i class="fa-solid fa-clock-rotate-left fs-3"></i>
            </div>
            <div>
                <h6 class="text-muted fw-bold mb-1">طلبات إجازة بانتظار الاعتماد</h6>
                <h3 class="fw-bold text-dark m-0">@ViewBag.PendingLeaves <span class="fs-6 text-muted">طلب</span></h3>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="sys-card bg-danger bg-opacity-10 border-0 p-4 d-flex align-items-center h-100 shadow-sm">
            <div class="bg-danger text-white rounded-circle d-flex justify-content-center align-items-center me-3 shadow-sm" style="width: 60px; height: 60px;">
                <i class="fa-solid fa-plane-departure fs-3"></i>
            </div>
            <div>
                <h6 class="text-muted fw-bold mb-1">موظفين في إجازة حالياً</h6>
                <h3 class="fw-bold text-danger m-0">@ViewBag.ActiveLeaves <span class="fs-6 text-muted">موظف مجاز</span></h3>
            </div>
        </div>
    </div>
</div>

<!-- 📌 سجل طاقم العمل -->
<div class="sys-card mt-4 shadow-sm border-0">
    <h5 class="fw-bold text-dark border-bottom pb-3 mb-4"><i class="fa-solid fa-address-book text-primary me-2"></i> سجل طاقم العمل الحالي</h5>
    <div class="table-responsive">
        <table class="table table-hover align-middle text-center sys-table w-100">
            <thead class="table-light">
                <tr>
                    <th class="py-3 text-start ps-4">الموظف (اسم الدخول)</th>
                    <th class="py-3">تاريخ الانضمام</th>
                    <th class="py-3">المنصب (Role)</th>
                    <th class="py-3 pe-4">إجراءات الإدارة</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in Model)
                {
                    <tr>
                        <td class="text-start ps-4 fw-bold text-dark">
                            <div class="d-flex align-items-center">
                                <img src="https://ui-avatars.com/api/?name=@Uri.EscapeDataString(user.Username)&background=e9edf7&color=2b3674&bold=true" class="rounded-circle me-3 border border-2 border-white shadow-sm" width="45">
                                @user.Username
                            </div>
                        </td>
                        <td dir="ltr" class="text-muted fw-bold small">
                            <i class="fa-regular fa-calendar me-1"></i> @user.CreatedAt.ToString("yyyy-MM-dd")
                        </td>
                        <td>
                            @switch (user.Role)
                            {
                                case "Admin":
                                    <span class="badge bg-danger px-3 py-2 rounded-pill">مدير نظام</span>
                                    break;
                                case "Technician":

                                    <span class="badge bg-primary px-3 py-2 rounded-pill">فني صيانة</span>
                                    break;
                                case "CallCenter":

                                    <span class="badge bg-info text-dark px-3 py-2 rounded-pill">خدمة عملاء</span>
                                    break;
                                case "Store":

                                    <span class="badge bg-secondary px-3 py-2 rounded-pill">أمين مخزن</span>
                                    break;
                                case "Accounting":

                                    <span class="badge bg-success px-3 py-2 rounded-pill">محاسب</span>
                                    break;
                                case "HR":

                                    <span class="badge bg-warning text-dark px-3 py-2 rounded-pill">موارد بشرية</span>
                                    break;
                                case "PurchasingManager":

                                    <span class="badge bg-dark px-3 py-2 rounded-pill">مدير مشتريات</span>
                                    break;
                                case "PurchasingRep":

                                    <span class="badge bg-dark px-3 py-2 rounded-pill">مندوب مشتريات</span>
                                    break;
                                default:

                                    <span class="badge bg-light text-dark border px-3 py-2 rounded-pill">@user.Role</span>
                                    break;
                            }
                        </td>
                        <td class="pe-4">
                            @if (User.IsInRole("Admin"))
                            {
                                <a href="/Users/Edit/@user.UserId" class="btn btn-sm btn-outline-primary fw-bold px-3 rounded-pill">
                                    <i class="fa-solid fa-pen me-1"></i> تعديل الصلاحيات
                                </a>
                            }
                            else
                            {
                                <span class="badge bg-light text-muted border px-3 py-2 rounded-pill shadow-sm">
                                    <i class="fa-solid fa-lock me-1 text-secondary"></i> للإدارة فقط
                                </span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>