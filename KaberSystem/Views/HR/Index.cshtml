@model IEnumerable<KaberSystem.Models.LeaveRequest>
@{
    ViewData["Title"] = "إدارة الإجازات ومباشرة العمل";
    Layout = "~/Views/Shared/_SystemLayout.cshtml";
}

<div class="sys-page-header">
    <div>
        <h1 class="sys-page-title text-warning"><i class="fa-solid fa-umbrella-beach me-2"></i> سجل الإجازات ومباشرة العمل</h1>
        <p class="sys-page-desc">اعتماد الإجازات، تطبيق الخصومات تلقائياً على الحسابات، وتسجيل العودة للعمل</p>
    </div>
    <button class="sys-btn btn-warning text-dark fw-bold" data-bs-toggle="modal" data-bs-target="#requestLeaveModal">
        <i class="fa-solid fa-plus me-1"></i> تقديم طلب إجازة
    </button>
</div>

<div class="sys-card">
    <div class="table-responsive">
        <table class="table table-hover align-middle text-center sys-table w-100">
            <thead class="table-light">
                <tr>
                    <th>الموظف</th>
                    <th>نوع الإجازة</th>
                    <th>الفترة (من - إلى)</th>
                    <th>السبب</th>
                    <th>مباشرة العمل</th>
                    <th>حالة الطلب</th>
                    <th>الإجراءات (للموارد البشرية)</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var l in Model)
                {
                    <tr>
                        <td class="text-start ps-4 fw-bold text-dark">
                            <i class="fa-solid fa-user-tie text-muted me-1"></i> @l.User?.Username
                        </td>
                        <td>
                            @switch (l.Type)
                            {
                                case KaberSystem.Models.LeaveType.Annual:
                                    <span class="badge bg-primary px-3">سنوية</span>
                                    break;
                                case KaberSystem.Models.LeaveType.Sick:

                                    <span class="badge bg-info text-dark px-3">مرضية</span>
                                    break;
                                case KaberSystem.Models.LeaveType.Emergency:

                                    <span class="badge bg-warning text-dark px-3">اضطرارية</span>
                                    break;
                                case KaberSystem.Models.LeaveType.Unpaid:

                                    <span class="badge bg-danger px-3">بدون راتب</span>
                                    break;
                            }
                        </td>
                        <td dir="ltr" class="small fw-bold text-muted">
                            @l.StartDate.ToString("yyyy/MM/dd") - @l.EndDate.ToString("MM/dd")
                        </td>
                        <td class="text-muted small fw-bold">@l.Reason</td>
                        <td>
                            @if (l.Status == KaberSystem.Models.LeaveStatus.Approved)
                            {
                                if (l.IsReturned)
                                {
                                    <span class="badge bg-success bg-opacity-10 text-success border border-success rounded-pill px-3 py-2">
                                        <i class="fa-solid fa-check-double"></i> باشر العمل (@l.ActualReturnDate?.ToString("MM/dd"))
                                    </span>
                                }
                                else
                                {
                                    <form asp-action="ReturnToWork" method="post" class="d-inline">
                                        <input type="hidden" name="leaveId" value="@l.Id" />
                                        <button type="submit" class="btn btn-sm btn-primary fw-bold rounded-pill px-3 shadow-sm pulse-badge" onclick="return confirm('تأكيد تسجيل مباشرة العمل وعودة الفني لاستلام الطلبات؟')">
                                            <i class="fa-solid fa-briefcase"></i> تسجيل مباشرة
                                        </button>
                                    </form>
                                }
                            }
                            else
                            {
                                <span class="text-muted small">-</span>
                            }
                        </td>
                        <td>
                            @if (l.Status == KaberSystem.Models.LeaveStatus.Approved)
                            {
                                <span class="badge bg-success px-3 py-2 rounded-pill"><i class="fa-solid fa-check"></i> معتمدة</span>
                            }
                            else if (l.Status == KaberSystem.Models.LeaveStatus.Rejected)
                            {
                                <span class="badge bg-danger px-3 py-2 rounded-pill"><i class="fa-solid fa-xmark"></i> مرفوضة</span>
                            }
                            else
                            {
                                <span class="badge bg-warning text-dark px-3 py-2 rounded-pill fw-bold"><i class="fa-solid fa-clock"></i> معلقة</span>
                            }
                        </td>
                        <td>
                            @if (l.Status == KaberSystem.Models.LeaveStatus.Pending && (User.IsInRole("Admin") || User.IsInRole("HR")))
                            {
                                <button type="button" class="btn btn-sm btn-success fw-bold px-3 rounded-3" data-bs-toggle="modal" data-bs-target="#approveLeaveModal_@l.Id">
                                    <i class="fa-solid fa-gavel"></i> اعتماد وخصم
                                </button>

                                <!-- Modal اعتماد الإجازة وتطبيق الخصم المالي -->
                                <div class="modal fade" id="approveLeaveModal_@l.Id" tabindex="-1" aria-hidden="true">
                                    <div class="modal-dialog modal-dialog-centered">
                                        <div class="modal-content border-0 rounded-4 shadow-lg text-start">
                                            <div class="modal-header border-bottom-0 pb-0">
                                                <h5 class="modal-title fw-bold text-success"><i class="fa-solid fa-clipboard-check me-2"></i> اعتماد الإجازة والتسميع بالحسابات</h5>
                                                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                            </div>
                                            <form asp-action="UpdateLeaveStatus" method="post">
                                                <div class="modal-body py-4">
                                                    <input type="hidden" name="id" value="@l.Id" />
                                                    <input type="hidden" name="status" value="Approved" />

                                                    <div class="alert alert-warning small fw-bold py-2">
                                                        <i class="fa-solid fa-circle-info"></i> الإجازات غير المدفوعة أو التي يترتب عليها جزاء يجب إدخال قيمتها ليتم خصمها من حساب الفني لدى المحاسبة.
                                                    </div>

                                                    <div class="mb-3">
                                                        <label class="form-label fw-bold text-danger">مبلغ الخصم (إن وجد) <span class="text-muted fw-normal">(أدخل 0 إذا كانت مدفوعة الراتب)</span></label>
                                                        <div class="input-group">
                                                            <input type="number" step="0.01" name="deductionAmount" class="form-control fw-bold border-danger" value="@(l.Type == KaberSystem.Models.LeaveType.Unpaid ? "100" : "0")" required />
                                                            <span class="input-group-text bg-light fw-bold">ر.س</span>
                                                        </div>
                                                    </div>

                                                    <div class="mb-3">
                                                        <label class="form-label fw-bold text-dark">ملاحظات الموارد البشرية (اختياري)</label>
                                                        <input type="text" name="note" class="form-control bg-light fw-bold" placeholder="مثال: خصم يومين لعدم وجود رصيد إجازات" />
                                                    </div>
                                                </div>
                                                <div class="modal-footer border-top-0 pt-0">
                                                    <button type="submit" class="btn btn-success fw-bold w-100 py-2"><i class="fa-solid fa-check-double"></i> اعتماد وترحيل للحسابات</button>
                                                </div>
                                            </form>
                                        </div>
                                    </div>
                                </div>
                            }
                            else if (l.Status == KaberSystem.Models.LeaveStatus.Pending)
                            {
                                <span class="text-muted small">بانتظار الإدارة</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Modal: تقديم طلب إجازة -->
<div class="modal fade" id="requestLeaveModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 rounded-4 shadow-lg">
            <div class="modal-header border-bottom-0 pb-0">
                <h5 class="modal-title fw-bold text-primary"><i class="fa-solid fa-paper-plane me-2"></i> طلب إجازة جديد</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="RequestLeave" method="post">
                <div class="modal-body py-4">
                    <div class="mb-3">
                        <label class="form-label fw-bold text-dark">الموظف <span class="text-danger">*</span></label>
                        <select name="UserId" class="form-select fw-bold bg-light" asp-items="ViewBag.UserId" required></select>
                    </div>
                    <div class="row">
                        <div class="col-6 mb-3">
                            <label class="form-label fw-bold text-dark">تاريخ البدء</label>
                            <input type="date" name="StartDate" class="form-control fw-bold" required />
                        </div>
                        <div class="col-6 mb-3">
                            <label class="form-label fw-bold text-dark">تاريخ الانتهاء</label>
                            <input type="date" name="EndDate" class="form-control fw-bold" required />
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold text-dark">نوع الإجازة</label>
                        <select name="Type" class="form-select fw-bold border-primary">
                            <option value="Annual">سنوية (مدفوعة)</option>
                            <option value="Sick">مرضية (بتقرير طبي)</option>
                            <option value="Emergency">اضطرارية</option>
                            <option value="Unpaid">بدون راتب (يتم خصمها)</option>
                        </select>
                    </div>
                    <div class="mb-0">
                        <label class="form-label fw-bold text-dark">السبب والتفاصيل</label>
                        <textarea name="Reason" class="form-control fw-bold bg-light" rows="2" placeholder="اكتب تفاصيل إضافية..."></textarea>
                    </div>
                </div>
                <div class="modal-footer border-top-0 pt-0">
                    <button type="submit" class="btn btn-primary fw-bold w-100 py-3 rounded-pill shadow-sm">تقديم الطلب للمراجعة</button>
                </div>
            </form>
        </div>
    </div>
</div>

<style>
    @@keyframes subtlePulse {
        0%

    {
        transform: scale(1);
        box-shadow: 0 0 0 0 rgba(13, 110, 253, 0.4);
    }

    70% {
        transform: scale(1.05);
        box-shadow: 0 0 0 6px rgba(13, 110, 253, 0);
    }

    100% {
        transform: scale(1);
        box-shadow: 0 0 0 0 rgba(13, 110, 253, 0);
    }

    }

    .pulse-badge {
        animation: subtlePulse 2s infinite;
    }
</style>

@section Scripts {
    <script>
        @if (TempData["SuccessMessage"] != null)
        {
                var msg = System.Text.Json.JsonSerializer.Serialize(TempData["SuccessMessage"]?.ToString());
                <text>Swal.fire({ icon: 'success', title: 'عملية ناجحة', text: @Html.Raw(msg), confirmButtonColor: '#f1950b' });</text>
        }
    </script>
}