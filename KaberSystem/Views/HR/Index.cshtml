<!-- مسار الملف: Views/HR/Index.cshtml -->
@model IEnumerable<KaberSystem.Models.SystemUser>
@{
    ViewData["Title"] = "إدارة الموارد البشرية";
    Layout = "~/Views/Shared/_SystemLayout.cshtml";
}

<div class="sys-page-header mb-4 d-flex justify-content-between align-items-center">
    <div>
        <h2 class="fw-bolder text-primary mb-1"><i class="fa-solid fa-users me-2"></i> إدارة الموظفين والموارد البشرية</h2>
        <p class="text-muted fw-bold mb-0">مراقبة طاقم العمل، الحضور والغياب، وتوليد الرواتب</p>
    </div>
    <div class="d-flex gap-2">
        <a href="/HR/Attendance" class="btn btn-dark fw-bold rounded-pill shadow-sm px-4">
            <i class="fa-solid fa-calendar-check me-1"></i> الحضور والغياب
        </a>
        <a href="/HR/Payroll" class="btn btn-success fw-bold rounded-pill shadow-sm px-4">
            <i class="fa-solid fa-money-check-dollar me-1"></i> الرواتب والأجور
        </a>
        <a href="/HR/Leaves" class="btn btn-warning text-dark fw-bold rounded-pill shadow-sm px-4">
            <i class="fa-solid fa-umbrella-beach me-1"></i> الإجازات
        </a>
    </div>
</div>

<div class="row g-4 mb-4">
    <div class="col-md-4">
        <div class="premium-card bg-primary bg-opacity-10 border-0 p-4 d-flex align-items-center h-100 shadow-sm rounded-4">
            <div class="bg-primary text-white rounded-circle d-flex justify-content-center align-items-center me-3 shadow-sm" style="width: 60px; height: 60px;">
                <i class="fa-solid fa-users fs-3"></i>
            </div>
            <div>
                <h6 class="text-muted fw-bold mb-1">إجمالي الموظفين بالنظام</h6>
                <h3 class="fw-bold text-dark m-0">@ViewBag.TotalEmployees <span class="fs-6 text-muted">موظف</span></h3>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="premium-card bg-warning bg-opacity-10 border-0 p-4 d-flex align-items-center h-100 shadow-sm rounded-4">
            <div class="bg-warning text-dark rounded-circle d-flex justify-content-center align-items-center me-3 shadow-sm" style="width: 60px; height: 60px;">
                <i class="fa-solid fa-clock-rotate-left fs-3"></i>
            </div>
            <div>
                <h6 class="text-muted fw-bold mb-1">طلبات إجازة بانتظار الاعتماد</h6>
                <h3 class="fw-bold text-dark m-0">@ViewBag.PendingLeaves <span class="fs-6 text-muted">طلب</span></h3>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="premium-card bg-danger bg-opacity-10 border-0 p-4 d-flex align-items-center h-100 shadow-sm rounded-4">
            <div class="bg-danger text-white rounded-circle d-flex justify-content-center align-items-center me-3 shadow-sm" style="width: 60px; height: 60px;">
                <i class="fa-solid fa-plane-departure fs-3"></i>
            </div>
            <div>
                <h6 class="text-muted fw-bold mb-1">موظفين في إجازة حالياً</h6>
                <h3 class="fw-bold text-danger m-0">@ViewBag.ActiveLeaves <span class="fs-6 text-muted">موظف مجاز</span></h3>
            </div>
        </div>
    </div>
</div>

<div class="premium-card mt-4 shadow-sm border-0 rounded-4 bg-white p-4">
    <div class="d-flex justify-content-between align-items-center border-bottom pb-3 mb-4">
        <h5 class="fw-bold text-dark m-0"><i class="fa-solid fa-address-book text-primary me-2"></i> سجل طاقم العمل الحالي</h5>
        @if (User.IsInRole("Admin"))
        {
            <a href="/Users/Create" class="btn btn-sm btn-outline-primary fw-bold rounded-pill px-3">إضافة موظف جديد</a>
        }
    </div>

    <div class="table-responsive">
        <table class="table table-hover align-middle text-center w-100">
            <thead class="bg-light">
                <tr>
                    <th class="py-3 text-start ps-4">الموظف (اسم الدخول)</th>
                    <th class="py-3">المنصب (Role)</th>
                    <th class="py-3">الراتب الأساسي</th>
                    <th class="py-3 pe-4">إجراءات</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in Model)
                {
                    <tr style="border-bottom: 1px solid #f8fafc;">
                        <td class="text-start ps-4 fw-bold text-dark py-3">
                            <div class="d-flex align-items-center">
                                <div class="bg-dark text-white rounded-circle d-flex justify-content-center align-items-center me-3 fw-bolder" style="width: 40px; height: 40px;">@user.Username.Substring(0, 1)</div>
                                @user.Username
                            </div>
                        </td>
                        <td><span class="badge bg-light text-dark border px-3 py-2 rounded-pill">@user.Role</span></td>
                        <td class="fw-bolder text-success">@user.BaseSalary.ToString("N2") ر.س</td>
                        <td class="pe-4">
                            @if (User.IsInRole("Admin"))
                            {
                                <a href="/Users/Edit/@user.UserId" class="btn btn-sm btn-light border text-primary fw-bold px-3 rounded-pill"><i class="fa-solid fa-pen me-1"></i> تعديل الموظف والراتب</a>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>