@model IEnumerable<KaberSystem.Models.SafeTransaction>
@{
    ViewData["Title"] = "إدارة الخزنة";
    Layout = "~/Views/Shared/_SystemLayout.cshtml";
}

<div class="sys-page-header">
    <div>
        <h1 class="sys-page-title text-success"><i class="fa-solid fa-vault me-2"></i> الخزنة النقدية (الكاش)</h1>
        <p class="sys-page-desc">مراقبة السيولة النقدية الواردة من الفواتير وتصفية الفنيين، وتوريد الأموال للبنك</p>
    </div>
    <button class="sys-btn btn-success fw-bold" data-bs-toggle="modal" data-bs-target="#depositModal">
        <i class="fa-solid fa-money-bill-transfer"></i> توريد أموال (سحب من الخزنة)
    </button>
</div>

<!-- لوحة المؤشرات المالية -->
<div class="row g-4 mb-4">
    <div class="col-md-4">
        <div class="sys-card bg-primary bg-opacity-10 border-0 h-100 d-flex align-items-center p-4">
            <div class="bg-primary text-white rounded-circle d-flex justify-content-center align-items-center me-3 shadow-sm" style="width: 60px; height: 60px;">
                <i class="fa-solid fa-arrow-down-short-wide fs-3"></i>
            </div>
            <div>
                <p class="text-muted fw-bold mb-1">إجمالي الوارد (كاش)</p>
                <h3 class="fw-bold text-dark m-0">@ViewBag.TotalIncome.ToString("N2") <span class="fs-6">ريال</span></h3>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="sys-card bg-danger bg-opacity-10 border-0 h-100 d-flex align-items-center p-4">
            <div class="bg-danger text-white rounded-circle d-flex justify-content-center align-items-center me-3 shadow-sm" style="width: 60px; height: 60px;">
                <i class="fa-solid fa-arrow-up-right-dots fs-3"></i>
            </div>
            <div>
                <p class="text-muted fw-bold mb-1">إجمالي المورد (خارج)</p>
                <h3 class="fw-bold text-dark m-0">@ViewBag.TotalDeposits.ToString("N2") <span class="fs-6">ريال</span></h3>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="sys-card bg-success h-100 d-flex align-items-center p-4 text-white shadow-lg position-relative overflow-hidden">
            <i class="fa-solid fa-vault position-absolute" style="font-size: 150px; opacity: 0.1; right: -20px; bottom: -20px;"></i>
            <div class="position-relative z-1">
                <p class="fw-bold text-white-50 mb-1 fs-5">رصيد الخزنة الحالي (السيولة)</p>
                <h2 class="fw-bold m-0 display-5">@ViewBag.CurrentBalance.ToString("N2") <span class="fs-4">ريال</span></h2>
            </div>
        </div>
    </div>
</div>

<div class="sys-card">
    <h5 class="fw-bold text-dark border-bottom pb-3 mb-4"><i class="fa-solid fa-list-check text-primary me-2"></i> سجل حركات الخزنة</h5>
    <div class="table-responsive">
        <table class="table table-hover align-middle text-center sys-table w-100">
            <thead class="table-light">
                <tr>
                    <th>رقم الحركة</th>
                    <th>نوع الحركة</th>
                    <th>المبلغ</th>
                    <th>البيان (الوصف)</th>
                    <th>بواسطة</th>
                    <th>التاريخ</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="fw-bold text-muted">#@item.Id</td>
                        <td>
                            @if (item.Type == KaberSystem.Models.SafeTransactionType.Income)
                            {
                                <span class="badge bg-success bg-opacity-10 text-success border border-success rounded-pill px-3 py-2"><i class="fa-solid fa-arrow-down me-1"></i> إيداع (تحصيل)</span>
                            }
                            else
                            {
                                <span class="badge bg-danger bg-opacity-10 text-danger border border-danger rounded-pill px-3 py-2"><i class="fa-solid fa-arrow-up me-1"></i> سحب (توريد)</span>
                            }
                        </td>
                        <td class="fw-bold fs-5 @(item.Type == KaberSystem.Models.SafeTransactionType.Income ? "text-success" : "text-danger")">
                            @(item.Type == KaberSystem.Models.SafeTransactionType.Income ? "+" : "-") @item.Amount.ToString("N2")
                        </td>
                        <td class="text-start fw-bold text-dark">
                            @item.Description
                            @if (item.OrderId.HasValue)
                            {
                                <a href="/Orders/Details/@item.OrderId" class="ms-2 badge bg-primary text-white text-decoration-none shadow-sm"><i class="fa-solid fa-link"></i> الفاتورة #@item.OrderId</a>
                            }
                        </td>
                        <td class="text-muted fw-bold small"><i class="fa-solid fa-user-tie me-1"></i> @item.RecordedBy</td>
                        <td dir="ltr" class="text-muted fw-bold small">@item.Date.ToString("yyyy-MM-dd hh:mm tt")</td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr><td colspan="6" class="text-center py-5 text-muted fw-bold">لا توجد أي حركات في الخزنة حالياً.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Modal: توريد أموال -->
<div class="modal fade" id="depositModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 rounded-4 shadow-lg">
            <div class="modal-header border-bottom-0 pb-0">
                <h5 class="modal-title fw-bold text-success"><i class="fa-solid fa-money-bill-transfer me-2"></i> توريد أموال من الخزنة</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-action="DepositMoney" method="post">
                <div class="modal-body py-4 text-start">
                    <div class="alert alert-warning py-2 small fw-bold"><i class="fa-solid fa-triangle-exclamation"></i> سيتم خصم هذا المبلغ من رصيد الخزنة الحالي واعتباره مورد للبنك أو المالك.</div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">المبلغ المراد توريده <span class="text-danger">*</span></label>
                        <div class="input-group input-group-lg">
                            <input type="number" step="0.01" name="amount" class="form-control fw-bold border-success text-success" max="@ViewBag.CurrentBalance" required />
                            <span class="input-group-text bg-light fw-bold">ر.س</span>
                        </div>
                        <small class="text-muted fw-bold mt-1 d-block">أقصى مبلغ متاح للسحب: @ViewBag.CurrentBalance ريال</small>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">البيان (إلى أين تم التوريد؟) <span class="text-danger">*</span></label>
                        <input type="text" name="description" class="form-control fw-bold bg-light" placeholder="مثال: إيداع في حساب الشركة البنكي (الراجحي)" required />
                    </div>
                </div>
                <div class="modal-footer border-top-0 pt-0">
                    <button type="button" class="btn btn-light fw-bold px-4" data-bs-dismiss="modal">إلغاء</button>
                    <button type="submit" class="btn btn-success fw-bold px-4"><i class="fa-solid fa-check"></i> تأكيد التوريد</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @if (TempData["SuccessMessage"] != null)
    {
        <script>
            var msg = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(TempData["SuccessMessage"]?.ToString()));
            Swal.fire({ icon: 'success', title: 'عملية ناجحة', text: msg, confirmButtonColor: '#198754' });
        </script>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <script>
            var errMsg = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(TempData["ErrorMessage"]?.ToString()));
            Swal.fire({ icon: 'error', title: 'تنبيه', text: errMsg, confirmButtonColor: '#dc3545' });
        </script>
    }
}