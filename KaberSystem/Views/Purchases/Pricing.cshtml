@model IEnumerable<KaberSystem.Models.PurchaseOrder>
@{
    ViewData["Title"] = "تسعير المنتجات وطباعة الباركود";
    Layout = "~/Views/Shared/_SystemLayout.cshtml";
}

<div class="sys-page-header">
    <div>
        <h1 class="sys-page-title">تسعير المنتجات وطباعة الباركود</h1>
        <p class="sys-page-desc">تحديد سعر البيع النهائي للعملاء، وطباعة ملصقات الباركود للصقها على المنتجات المستلمة</p>
    </div>
</div>

<div class="sys-card">
    <div class="d-flex align-items-center border-bottom pb-3 mb-4">
        <div class="bg-primary bg-opacity-10 text-primary rounded-circle d-flex justify-content-center align-items-center me-3" style="width: 50px; height: 50px;">
            <i class="fa-solid fa-tags fs-4"></i>
        </div>
        <h4 class="fw-bold m-0 text-dark">المنتجات بانتظار التسعير</h4>
    </div>

    <div class="table-responsive">
        <table class="table table-hover align-middle text-center w-100">
            <thead class="table-light">
                <tr>
                    <th>رقم العملية / الباركود</th>
                    <th>اسم المنتج</th>
                    <th>الكمية المستلمة</th>
                    <th>تكلفة الشراء</th>
                    <th>تحديد سعر البيع (ر.س)</th>
                    <th>إجراءات</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    string displayBarcode = !string.IsNullOrEmpty(item.Barcode) ? item.Barcode : $"KBR-PO-{item.PurchaseId}";

                    <tr>
                        <td>
                            <span class="fw-bold px-2 py-1 bg-light border rounded text-muted d-block mb-1">PO-#@item.PurchaseId</span>
                            <span class="badge bg-dark rounded-pill"><i class="fa-solid fa-barcode me-1"></i> @displayBarcode</span>
                        </td>
                        <td class="fw-bold text-dark text-start">@item.ItemName</td>
                        <td class="fw-bold">@item.Quantity</td>
                        <td class="text-danger fw-bold">@item.PurchasePrice ر.س</td>
                        <td style="width: 250px;">
                            <form asp-action="UpdatePrice" method="post" class="d-flex gap-2">
                                <input type="hidden" name="purchaseId" value="@item.PurchaseId" />
                                <input type="number" step="0.01" name="sellingPrice" class="form-control border-primary fw-bold" placeholder="أدخل السعر..." required />
                                <button type="submit" class="btn btn-primary fw-bold px-3 shadow-sm"><i class="fa-solid fa-check"></i> اعتماد</button>
                            </form>
                        </td>
                        <td>
                            <div class="d-flex gap-2 justify-content-center">
                                <button type="button" class="btn btn-sm btn-outline-dark fw-bold rounded-3 px-3"
                                        onclick="printBarcodeDirect('@displayBarcode', '@item.ItemName')">
                                    <i class="fa-solid fa-print"></i> باركود مباشر
                                </button>
                            </div>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="6" class="py-5 text-center text-muted">
                            <i class="fa-solid fa-clipboard-check fs-1 mb-3 opacity-50"></i>
                            <h5 class="fw-bold">لا توجد منتجات بانتظار التسعير</h5>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/jsbarcode@3.11.5/dist/JsBarcode.all.min.js"></script>

    <script>
        @if (TempData["SuccessMessage"] != null)
        {
                    var msg = System.Text.Json.JsonSerializer.Serialize(TempData["SuccessMessage"]);
                    @:Swal.fire({ icon: 'success', title: 'عملية ناجحة', text: @Html.Raw(msg), confirmButtonColor: '#f1950b' });
        }

        // 📌 حل المشكلة 3: دالة الطباعة المباشرة الجديدة (تتجاوز الـ iframe المعطل في بعض المتصفحات)
        function printBarcodeDirect(code, name) {
            var printWindow = window.open('', '', 'width=400,height=300');
            if(!printWindow) {
                Swal.fire({ icon: 'error', title: 'تنبيه', text: 'يرجى السماح بالنوافذ المنبثقة للطباعة.'});
                return;
            }

            var doc = printWindow.document;
            var styleAt = String.fromCharCode(64);

            doc.write('<html><head><style>' + styleAt + 'page { size: 50mm 25mm; margin:0; } body { font-family: Cairo, sans-serif; text-align:center; padding:2px; background: white; margin: 0; } .title { font-size:10px; font-weight:bold; margin-bottom:2px; overflow:hidden; white-space:nowrap; text-overflow: ellipsis; color: black; } svg { width:100%; height:auto; max-height: 20mm; }</style></head><body>');
            doc.write('<div class="title">' + name + '</div><svg id="bc"></svg>');
            doc.write('<script src="https://cdn.jsdelivr.net/npm/jsbarcode@3.11.5/dist/JsBarcode.all.min.js"><\/script>');
            doc.write('<script>window.onload = function() { JsBarcode("#bc", "' + code + '", { height:35, fontSize:12, fontOptions: "bold", margin:0, displayValue: true }); setTimeout(function(){ window.print(); window.close(); }, 500); }<\/script></body></html>');
            doc.close();
        }
    </script>
}