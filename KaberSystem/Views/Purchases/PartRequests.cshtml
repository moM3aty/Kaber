<!-- مسار الملف: Views/Purchases/PartRequests.cshtml -->
@model IEnumerable<KaberSystem.Models.OrderPartRequest>
@{
    ViewData["Title"] = "طلبات نواقص الفنيين";
    Layout = "~/Views/Shared/_SystemLayout.cshtml";
}

<div class="sys-page-header d-flex justify-content-between align-items-center mb-4 fade-in-up">
    <div>
        <h1 class="sys-page-title text-dark"><i class="fa-solid fa-screwdriver-wrench text-warning me-2"></i> طلبات النواقص من الفنيين</h1>
        <p class="sys-page-desc mb-0">متابعة قطع الغيار غير المتوفرة المطلوبة من الفنيين لإتمام أوامر الصيانة</p>
    </div>
    <a href="/Purchases/Index" class="btn btn-outline-secondary fw-bolder px-4 py-2 rounded-pill shadow-sm hover-elevate border-2">
        <i class="fa-solid fa-arrow-right me-1"></i> عودة للمشتريات العامة
    </a>
</div>

<!-- لوحة المؤشرات العلوية -->
<div class="row g-4 mb-4 fade-in-up" style="animation-delay: 0.1s;">
    <div class="col-md-6">
        <div class="sys-card bg-warning bg-opacity-10 border border-warning border-opacity-25 h-100 d-flex align-items-center p-4 rounded-4 shadow-sm hover-elevate">
            <div class="bg-warning text-dark rounded-3 d-flex justify-content-center align-items-center me-4 shadow-sm" style="width: 60px; height: 60px;">
                <i class="fa-solid fa-clock-rotate-left fs-3"></i>
            </div>
            <div>
                <p class="text-dark fw-bold mb-1 opacity-75 text-uppercase small tracking-wider">بانتظار الشراء والتوفير</p>
                <h3 class="fw-bolder text-dark m-0">@ViewBag.PendingCount <span class="fs-6 fw-normal text-muted">طلب معلق</span></h3>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="sys-card bg-success bg-opacity-10 border border-success border-opacity-25 h-100 d-flex align-items-center p-4 rounded-4 shadow-sm hover-elevate">
            <div class="bg-success text-white rounded-3 d-flex justify-content-center align-items-center me-4 shadow-sm" style="width: 60px; height: 60px;">
                <i class="fa-solid fa-check-double fs-3"></i>
            </div>
            <div>
                <p class="text-dark fw-bold mb-1 opacity-75 text-uppercase small tracking-wider">تم التوفير (جاهزة للتركيب)</p>
                <h3 class="fw-bolder text-dark m-0">@ViewBag.CompletedCount <span class="fs-6 fw-normal text-muted">طلب منجز</span></h3>
            </div>
        </div>
    </div>
</div>

<div class="card border-0 rounded-4 shadow-sm overflow-hidden fade-in-up" style="animation-delay: 0.2s;">
    <div class="card-header bg-white border-bottom-0 pt-4 pb-0 px-4">
        <h5 class="fw-bolder text-dark mb-3"><i class="fa-solid fa-list-check text-primary me-2"></i> قائمة النواقص المطلوبة</h5>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle text-center mb-0 w-100 custom-table">
                <thead class="bg-light text-muted small fw-bold text-uppercase">
                    <tr>
                        <th class="ps-4 text-start py-3">رقم الطلب الأصلي</th>
                        <th class="py-3">القطعة المطلوبة / الموديل</th>
                        <th class="py-3">صورة التالف</th>
                        <th class="py-3">الكمية</th>
                        <th class="py-3">الفني الطالب</th>
                        <th class="py-3">حالة الشراء</th>
                        <th class="pe-4 py-3">إجراءات المشتريات</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr style="border-bottom: 1px solid #f1f5f9;">
                            <td class="text-start ps-4 py-3">
                                <a href="/Orders/Details/@item.OrderId" target="_blank" class="badge bg-dark bg-opacity-10 text-dark text-decoration-none px-3 py-2 fs-6 shadow-sm border border-secondary border-opacity-25 hover-elevate">
                                    <i class="fa-solid fa-arrow-up-right-from-square me-1 small"></i> ORD-#@item.OrderId
                                </a>
                                <div class="text-muted small mt-2 fw-bold" dir="ltr"><i class="fa-regular fa-clock me-1 opacity-50"></i> @item.RequestDate.ToString("MM/dd HH:mm")</div>
                            </td>
                            <td class="fw-bolder text-dark text-start">
                                @item.NewPartName
                                <div class="small mt-1">
                                    @if(item.IsCommonRequest) { <span class="badge bg-info bg-opacity-10 text-info border border-info px-2 py-1 rounded-pill">قطعة عامة</span> }
                                    else { <span class="badge bg-secondary bg-opacity-10 text-secondary border border-secondary px-2 py-1 rounded-pill">موديل: @item.DeviceModel</span> }
                                </div>
                            </td>
                            <td>
                                @if (!string.IsNullOrEmpty(item.ImagePath))
                                {
                                    <a href="@item.ImagePath" target="_blank" class="btn btn-sm btn-light border text-primary fw-bold px-3 rounded-pill shadow-sm hover-elevate">
                                        <i class="fa-solid fa-image me-1"></i> عرض الصورة
                                    </a>
                                }
                                else
                                {
                                    <span class="text-muted small fw-bold"><i class="fa-solid fa-minus opacity-50"></i></span>
                                }
                            </td>
                            <td>
                                <span class="badge bg-primary fs-6 px-3 py-2 rounded-pill shadow-sm">@item.Quantity</span>
                            </td>
                            <td>
                                <div class="d-inline-flex align-items-center bg-light border rounded-pill px-3 py-1">
                                    <i class="fa-solid fa-user-gear text-muted me-2 small"></i>
                                    <span class="fw-bold text-dark small">@(item.Order?.Technician?.Name ?? "غير محدد")</span>
                                </div>
                            </td>
                            <td>
                                @switch (item.Status)
                                {
                                    case KaberSystem.Models.PartRequestStatus.PendingPurchasing: <span class="badge bg-warning text-dark px-3 py-2 rounded-pill shadow-sm"><i class="fa-solid fa-hourglass-half me-1"></i> جاري الشراء</span> break;
                                    case KaberSystem.Models.PartRequestStatus.ReadyForInstallation: <span class="badge bg-success px-3 py-2 rounded-pill shadow-sm"><i class="fa-solid fa-box-check me-1"></i> متوفرة / جاهزة</span> break;
                                    case KaberSystem.Models.PartRequestStatus.Rejected: <span class="badge bg-danger px-3 py-2 rounded-pill shadow-sm"><i class="fa-solid fa-ban me-1"></i> مرفوضة</span> break;
                                    default: <span class="badge bg-secondary px-3 py-2 rounded-pill shadow-sm"><i class="fa-solid fa-wrench me-1"></i> تم التركيب</span> break;
                                }
                            </td>
                            <td class="pe-4">
                                @if (item.Status == KaberSystem.Models.PartRequestStatus.PendingPurchasing)
                                {
                                    <div class="d-flex gap-2 justify-content-center">
                                        <!-- زر يفتح المودال (المودال نفسه موجود أسفل الجدول لتجنب مشكلة الـ Style) -->
                                        <button type="button" class="btn btn-sm btn-success fw-bolder px-3 rounded-pill shadow-sm hover-elevate" data-bs-toggle="modal" data-bs-target="#buyModal_@item.Id">
                                            <i class="fa-solid fa-cart-shopping me-1"></i> شراء وتكويد
                                        </button>
                                        
                                        <form asp-action="RejectPurchase" method="post" onsubmit="return confirm('هل أنت متأكد من الرفض لعدم التوفر في السوق؟');">
                                            <input type="hidden" name="requestId" value="@item.Id" />
                                            <input type="hidden" name="reason" value="غير متوفرة بالسوق المحلي" />
                                            <button type="submit" class="btn btn-sm btn-light border border-danger text-danger fw-bold rounded-circle shadow-sm hover-danger" style="width:34px; height:34px;" title="القطعة غير متوفرة (رفض)">
                                                <i class="fa-solid fa-xmark"></i>
                                            </button>
                                        </form>
                                    </div>
                                }
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="7" class="py-5 text-center text-muted">
                                <div class="bg-light rounded-circle d-inline-flex justify-content-center align-items-center mb-3" style="width: 70px; height: 70px;">
                                    <i class="fa-solid fa-box-open fs-3 opacity-50"></i>
                                </div>
                                <h6 class="fw-bold m-0">لا توجد أي طلبات نواقص معلقة حالياً من الفنيين.</h6>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- 📌 منطقة الـ Modals يتم وضعها خارج أي كارت وخارج الـ Table لتعمل بشكل صحيح في Bootstrap -->
@foreach (var item in Model.Where(i => i.Status == KaberSystem.Models.PartRequestStatus.PendingPurchasing))
{
    <div class="modal fade" id="buyModal_@item.Id" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 rounded-4 shadow-lg">
                <div class="modal-header border-bottom-0 pb-0 px-4 pt-4">
                    <h5 class="modal-title fw-bolder text-success"><i class="fa-solid fa-money-check-dollar me-2"></i> تأكيد الشراء والتكويد</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <form asp-action="ConfirmPurchase" method="post">
                    <div class="modal-body py-4 px-4 text-start">
                        <input type="hidden" name="requestId" value="@item.Id" />
                        
                        <div class="alert alert-success py-3 small fw-bold border-0 bg-success bg-opacity-10 text-dark rounded-3 shadow-sm mb-4">
                            <i class="fa-solid fa-circle-info text-success me-1"></i> 
                            شراء: <b class="text-success fs-6">@item.NewPartName</b> (الكمية: @item.Quantity)<br />
                            سيتم تكويد القطعة وإضافتها لفاتورة العميل فوراً.
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold text-muted small text-uppercase">سعر الشراء (التكلفة الفعلية) <span class="text-danger">*</span></label>
                            <div class="input-group shadow-sm rounded-3 overflow-hidden">
                                <input type="number" step="0.01" name="purchasePrice" class="form-control fw-bolder text-danger bg-light border-0" required />
                                <span class="input-group-text bg-white fw-bolder border-0 text-danger px-4">ر.س</span>
                            </div>
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-bold text-muted small text-uppercase">سعر البيع (للعميل) <span class="text-danger">*</span></label>
                            <div class="input-group shadow-sm rounded-3 overflow-hidden">
                                <input type="number" step="0.01" name="sellingPrice" class="form-control fw-bolder text-success bg-light border-0" required />
                                <span class="input-group-text bg-white fw-bolder border-0 text-success px-4">ر.س</span>
                            </div>
                        </div>

                        <div class="mb-4 p-3 bg-light rounded-4 border">
                            <label class="form-label fw-bolder text-primary mb-3">كيف تم سداد التكلفة للمورد؟ <span class="text-danger">*</span></label>
                            <div class="d-flex flex-column gap-2">
                                <label class="btn btn-outline-success text-start fw-bold p-3 rounded-3 d-flex align-items-center">
                                    <input type="radio" name="paymentMethod" value="Cash" class="form-check-input me-3 fs-5" required checked>
                                    <div><i class="fa-solid fa-money-bills me-2"></i> كاش (يُخصم من درج المشتريات)</div>
                                </label>
                                <label class="btn btn-outline-info text-dark text-start fw-bold p-3 rounded-3 d-flex align-items-center">
                                    <input type="radio" name="paymentMethod" value="POS" class="form-check-input me-3 fs-5">
                                    <div><i class="fa-solid fa-credit-card me-2"></i> شبكة / فيزا (يُخصم من البنك)</div>
                                </label>
                                <label class="btn btn-outline-primary text-start fw-bold p-3 rounded-3 d-flex align-items-center">
                                    <input type="radio" name="paymentMethod" value="BankTransfer" class="form-check-input me-3 fs-5">
                                    <div><i class="fa-solid fa-building-columns me-2"></i> تحويل بنكي (يُخصم من البنك)</div>
                                </label>
                            </div>
                        </div>

                        <div class="mb-2">
                            <label class="form-label fw-bold text-muted small text-uppercase">اسم المورد / المحل (اختياري)</label>
                            <input type="text" name="supplierName" class="form-control fw-bold bg-light border-secondary border-opacity-25" placeholder="من أين تم الشراء؟" />
                        </div>
                    </div>
                    <div class="modal-footer border-top-0 pt-0 px-4 pb-4">
                        <button type="button" class="btn btn-light fw-bold px-4 rounded-pill" data-bs-dismiss="modal">إلغاء</button>
                        <button type="submit" class="btn btn-success fw-bolder px-4 rounded-pill shadow-sm hover-elevate"><i class="fa-solid fa-check-double me-1"></i> حفظ وتكويد الصنف</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
}

<style>
    .fade-in-up { animation: fadeInUp 0.6s cubic-bezier(0.16, 1, 0.3, 1) both; }
    @@keyframes fadeInUp { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }

    .hover-elevate { transition: transform 0.2s ease, box-shadow 0.2s ease; cursor: pointer;}
    .hover-elevate:hover { transform: translateY(-3px); box-shadow: 0 10px 20px rgba(0,0,0,0.08) !important; }

    .hover-danger:hover { background-color: #ee5d50 !important; color: white !important; border-color: #ee5d50 !important; }

    .custom-table th { font-size: 0.85rem; letter-spacing: 0.5px; border-bottom: 2px solid #e2e8f0; }
    .custom-table td { vertical-align: middle; }

    .btn-check:checked + .btn-outline-success { background-color: #ecfdf5; color: #10b981; border-color: #10b981; }
    .btn-check:checked + .btn-outline-info { background-color: #f0f9ff; color: #0ea5e9; border-color: #0ea5e9; }
    .btn-check:checked + .btn-outline-primary { background-color: #eff6ff; color: #3b82f6; border-color: #3b82f6; }
    label.btn { transition: all 0.2s ease; }
</style>

@section Scripts {
    <script>
        @if (TempData["SuccessMessage"] != null)
        {
            var msg = System.Text.Json.JsonSerializer.Serialize(TempData["SuccessMessage"]?.ToString());
            <text>Swal.fire({ icon: 'success', title: 'عملية ناجحة', text: @Html.Raw(msg), confirmButtonColor: '#198754', customClass: { popup: 'rounded-4' } });</text>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            var errMsg = System.Text.Json.JsonSerializer.Serialize(TempData["ErrorMessage"]?.ToString());
            <text>Swal.fire({ icon: 'error', title: 'تنبيه', text: @Html.Raw(errMsg), confirmButtonColor: '#dc3545', customClass: { popup: 'rounded-4' } });</text>
        }
    </script>
}