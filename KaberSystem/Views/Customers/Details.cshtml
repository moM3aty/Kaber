@model IEnumerable<KaberSystem.Models.Order>
@{
    ViewData["Title"] = "ملف العميل: " + ViewBag.CustomerName;
    Layout = "~/Views/Shared/_SystemLayout.cshtml";
}

<!-- 📌 زر العودة -->
<div class="mb-4">
    <a href="/Customers/Index" class="text-decoration-none text-muted fw-bold hover-primary-text">
        <i class="fa-solid fa-arrow-right me-2"></i> العودة لقائمة العملاء
    </a>
</div>

<div class="row g-4 mb-4">
    <!-- 📌 بطاقة بيانات العميل (Premium Gradient Card) -->
    <div class="col-lg-5">
        <div class="card h-100 border-0 rounded-4 shadow-lg overflow-hidden position-relative profile-hero-card">
            <!-- الدوائر التجميلية في الخلفية -->
            <div class="shape-circle shape-1"></div>
            <div class="shape-circle shape-2"></div>

            <div class="card-body p-4 p-xl-5 position-relative z-1 text-white d-flex flex-column justify-content-center">
                <div class="d-flex align-items-center mb-4">
                    <div class="avatar-lg bg-white text-primary rounded-circle d-flex justify-content-center align-items-center shadow fw-bolder me-3">
                        @ViewBag.CustomerName.Substring(0, 1)
                    </div>
                    <div>
                        <h3 class="fw-bolder mb-1 text-white">@ViewBag.CustomerName</h3>
                        @if (ViewBag.TotalOrders >= 3)
                        {
                            <span class="badge bg-white text-warning fw-bolder px-3 py-1 rounded-pill mt-1 shadow-sm"><i class="fa-solid fa-crown me-1"></i> عميل مميز (VIP)</span>
                        }
                    </div>
                </div>

                <div class="mt-auto bg-white bg-opacity-10 p-3 rounded-4 backdrop-blur">
                    <div class="d-flex align-items-center mb-2">
                        <div class="icon-box-sm bg-white bg-opacity-25 rounded-circle d-flex justify-content-center align-items-center me-3">
                            <i class="fa-solid fa-phone"></i>
                        </div>
                        <span dir="ltr" class="fw-bold fs-5 tracking-wide">@ViewBag.CustomerPhone</span>
                    </div>
                    <div class="d-flex align-items-center mt-3">
                        <div class="icon-box-sm bg-white bg-opacity-25 rounded-circle d-flex justify-content-center align-items-center me-3">
                            <i class="fa-solid fa-location-dot"></i>
                        </div>
                        <span class="fw-bold opacity-75">@ViewBag.CustomerAddress</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- 📌 بطاقات الإحصائيات (Soft UI Stats) -->
    <div class="col-lg-7">
        <div class="row g-4 h-100">
            <div class="col-sm-6">
                <div class="card border-0 rounded-4 shadow-sm h-100 stat-card">
                    <div class="card-body p-4 p-xl-5 text-center d-flex flex-column justify-content-center">
                        <div class="bg-primary bg-opacity-10 text-primary rounded-circle d-inline-flex justify-content-center align-items-center mx-auto mb-3" style="width: 70px; height: 70px;">
                            <i class="fa-solid fa-toolbox fs-2"></i>
                        </div>
                        <h2 class="fw-bolder text-dark mb-1 display-5">@ViewBag.TotalOrders</h2>
                        <p class="text-muted fw-bold text-uppercase small tracking-wide mb-0">إجمالي الطلبات</p>
                    </div>
                </div>
            </div>
            <div class="col-sm-6">
                <div class="card border-0 rounded-4 shadow-sm h-100 stat-card">
                    <div class="card-body p-4 p-xl-5 text-center d-flex flex-column justify-content-center">
                        <div class="bg-success bg-opacity-10 text-success rounded-circle d-inline-flex justify-content-center align-items-center mx-auto mb-3" style="width: 70px; height: 70px;">
                            <i class="fa-solid fa-wallet fs-2"></i>
                        </div>
                        <h2 class="fw-bolder text-dark mb-1 display-6">@Convert.ToDecimal(ViewBag.TotalSpent).ToString("N0") <span class="fs-5 text-muted">ر.س</span></h2>
                        <p class="text-muted fw-bold text-uppercase small tracking-wide mb-0">القيمة الإجمالية للعميل (LTV)</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- 📌 سجل الطلبات (Clean History Table) -->
<div class="card border-0 rounded-4 shadow-sm mt-2">
    <div class="card-header bg-white border-0 pt-4 pb-0 px-4">
        <h5 class="fw-bolder text-dark mb-0"><i class="fa-solid fa-clock-rotate-left text-primary me-2"></i> السجل التاريخي للصيانات</h5>
    </div>
    <div class="card-body p-0 mt-3">
        <div class="table-responsive">
            <table class="table table-borderless table-hover align-middle text-center custom-table w-100 mb-0">
                <thead class="bg-light text-muted small fw-bold text-uppercase">
                    <tr>
                        <th class="py-3 ps-4 text-start">الطلب والتاريخ</th>
                        <th class="py-3">الجهاز</th>
                        <th class="py-3">نوع الخدمة</th>
                        <th class="py-3">الفني المنفذ</th>
                        <th class="py-3">القيمة</th>
                        <th class="py-3">الحالة</th>
                        <th class="py-3 pe-4 text-end">التفاصيل</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var order in Model)
                    {
                        <tr style="border-bottom: 1px solid #f8f9fa;">
                            <td class="text-start ps-4 py-3">
                                <span class="fw-bold text-dark d-block">ORD-#@order.OrderId</span>
                                <span dir="ltr" class="text-muted small fw-bold">@order.CreatedAt.ToString("dd MMM, yyyy")</span>
                            </td>
                            <td class="fw-bolder text-dark">@order.DeviceName</td>
                            <td>
                                @switch (order.Type)
                                {
                                    case KaberSystem.Models.OrderType.Maintenance:
                                        <span class="badge bg-primary bg-opacity-10 text-primary px-3 py-2 rounded-pill fw-bold">صيانة</span>
                                        break;
                                    case KaberSystem.Models.OrderType.NewInstallation:

                                        <span class="badge bg-success bg-opacity-10 text-success px-3 py-2 rounded-pill fw-bold">تركيب</span>
                                        break;
                                    case KaberSystem.Models.OrderType.Warranty:

                                        <span class="badge bg-warning bg-opacity-25 text-warning-dark px-3 py-2 rounded-pill fw-bold">ضمان</span>
                                        break;
                                    case KaberSystem.Models.OrderType.ACWashing:

                                        <span class="badge bg-info bg-opacity-10 text-info-dark px-3 py-2 rounded-pill fw-bold">غسيل مكيفات</span>
                                        break;
                                }
                            </td>
                            <td>
                                <div class="d-inline-flex align-items-center bg-light rounded-pill px-3 py-1">
                                    <i class="fa-solid fa-user-gear text-muted me-2 small"></i>
                                    <span class="text-muted fw-bold small">@(order.Technician?.Name ?? "غير محدد")</span>
                                </div>
                            </td>
                            <td class="text-dark fw-bolder">@order.FinalPrice <span class="text-muted small">ر.س</span></td>
                            <td>
                                @if (order.Status == KaberSystem.Models.OrderStatus.Completed || order.Status == KaberSystem.Models.OrderStatus.Approved)
                                {
                                    <span class="text-success fw-bold small"><i class="fa-solid fa-circle-check me-1"></i> مكتمل</span>
                                }
                                else if (order.Status == KaberSystem.Models.OrderStatus.Cancelled)
                                {
                                    <span class="text-danger fw-bold small"><i class="fa-solid fa-circle-xmark me-1"></i> ملغي</span>
                                }
                                else
                                {
                                    <span class="text-warning-dark fw-bold small"><i class="fa-solid fa-spinner fa-spin me-1"></i> جاري العمل</span>
                                }
                            </td>
                            <td class="text-end pe-4">
                                <a href="/Orders/Details/@order.OrderId" class="btn btn-sm btn-light rounded-circle text-primary hover-primary" style="width: 35px; height: 35px; line-height: 22px;">
                                    <i class="fa-solid fa-arrow-left"></i>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<style>
    /* CSS مخصص للتصميم الفخم (Premium UI) */
    .profile-hero-card {
        background: linear-gradient(135deg, #0f2027 0%, #203a43 50%, #2c5364 100%);
    }

    .shape-circle {
        position: absolute;
        border-radius: 50%;
        background: rgba(255, 255, 255, 0.05);
    }

    .shape-1 {
        width: 300px;
        height: 300px;
        top: -100px;
        right: -50px;
    }

    .shape-2 {
        width: 200px;
        height: 200px;
        bottom: -50px;
        left: -50px;
    }

    .avatar-lg {
        width: 65px;
        height: 65px;
        font-size: 1.8rem;
    }

    .icon-box-sm {
        width: 35px;
        height: 35px;
    }

    .backdrop-blur {
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
    }

    .tracking-wide {
        letter-spacing: 0.5px;
    }

    .stat-card {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

        .stat-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 15px 35px rgba(0,0,0,0.05) !important;
        }

    .custom-table th {
        font-size: 0.85rem;
    }

    .custom-table tbody tr {
        transition: background-color 0.2s ease;
    }

        .custom-table tbody tr:hover {
            background-color: #fcfcfd !important;
        }

    .text-warning-dark {
        color: #d39e00 !important;
    }

    .text-info-dark {
        color: #055160 !important;
    }

    .hover-primary-text {
        transition: color 0.2s;
    }

        .hover-primary-text:hover {
            color: var(--sys-primary) !important;
        }

    .hover-primary {
        transition: all 0.2s ease;
    }

        .hover-primary:hover {
            background-color: var(--sys-primary) !important;
            color: white !important;
        }
</style>