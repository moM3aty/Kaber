@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>تسجيل الدخول - نظام كابر</title>

    <!-- خطوط وجافاسكريبت -->
    <link href="~/images/logo.png" type="image/x-icon" rel="icon" />

    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="~/css/dashboard-premium.css">

    <style>
        body {
            font-family: 'Cairo', sans-serif;
            background: linear-gradient(135deg, var(--sys-secondary), #0c1170);
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
            margin: 0;
        }

        .login-card {
            background: var(--sys-surface);
            border-radius: var(--sys-radius-lg);
            box-shadow: 0 25px 50px rgba(0,0,0,0.5);
            overflow: hidden;
            width: 100%;
            max-width: 1000px;
            display: flex;
            min-height: 550px;
            animation: fadeInUp 0.6s ease-out;
        }

        .login-form-container {
            width: 50%;
            padding: 60px 50px;
            display: flex;
            flex-direction: column;
            justify-content: center;
        }

        .login-image {
            background-image: url('/images/header.jpg'); /* تأكد من مسار الصورة */
            background-size: cover;
            background-position: center;
            width: 50%;
            position: relative;
        }

            .login-image::after {
                content: '';
                position: absolute;
                inset: 0;
                background: linear-gradient(to bottom, rgba(241, 149, 11, 0.8), rgba(1, 2, 23, 0.9));
            }

        .login-image-content {
            position: relative;
            z-index: 1;
            padding: 40px;
            color: white;
            height: 100%;
            display: flex;
            flex-direction: column;
            justify-content: center;
            text-align: center;
        }

        .sys-input {
            border: 2px solid var(--sys-border);
            padding: 14px 45px 14px 20px; /* مساحة للأيقونة */
            border-radius: 12px;
            font-weight: 600;
            transition: all 0.3s;
            background-color: var(--sys-bg);
            width: 100%;
        }

            .sys-input:focus {
                border-color: var(--sys-primary);
                box-shadow: 0 0 0 4px var(--sys-primary-light);
                background-color: #fff;
                outline: none;
            }

        .input-icon {
            position: absolute;
            top: 50%;
            right: 18px;
            transform: translateY(-50%);
            color: var(--sys-text-muted);
            font-size: 18px;
        }
        @@media (max-width: 768px) {
            .login-image

        {
            display: none;
        }

        .login-form-container {
            width: 100%;
            padding: 40px 30px;
        }

        }
        @@keyframes fadeInUp {
            from

        {
            opacity: 0;
            transform: translateY(30px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }

        }
    </style>
</head>
<body>

    <div class="container">
        <div class="login-card mx-auto">
            <!-- الجانب الأيمن (النموذج) -->
            <div class="login-form-container">
                <div class="text-center mb-5">
                    <div class="d-inline-flex align-items-center justify-content-center bg-primary bg-opacity-10 rounded-circle mb-3" style="width: 80px; height: 80px;">
                        <i class="fa-solid fa-bolt text-primary fs-1"></i>
                    </div>
                    <h3 class="fw-bold" style="color: var(--sys-secondary);">مرحباً بعودتك!</h3>
                    <p class="text-muted fw-bold">الرجاء تسجيل الدخول للوصول إلى لوحة التحكم</p>
                </div>

                @if (ViewBag.Error != null)
                {
                    <div class="alert alert-danger text-center fw-bold rounded-3 shadow-sm border-0 border-start border-danger border-4">
                        <i class="fa-solid fa-circle-exclamation me-2"></i> @ViewBag.Error
                    </div>
                }

                <form asp-controller="Account" asp-action="Login" method="post">
                    <div class="mb-4 position-relative">
                        <label class="form-label fw-bold text-dark">اسم المستخدم</label>
                        <div class="position-relative">
                            <i class="fa-solid fa-user input-icon"></i>
                            <input type="text" name="username" class="sys-input" placeholder="أدخل اسم المستخدم " required>
                        </div>
                    </div>

                    <div class="mb-5 position-relative">
                        <div class="d-flex justify-content-between align-items-center">
                            <label class="form-label fw-bold text-dark m-0">كلمة المرور</label>
                        </div>
                        <div class="position-relative mt-2">
                            <i class="fa-solid fa-lock input-icon"></i>
                            <input type="password" name="password" class="sys-input" placeholder="أدخل كلمة المرور " required>
                        </div>
                    </div>

                    <button type="submit" class="sys-btn sys-btn-primary w-100 justify-content-center py-3 fs-5 shadow-sm">
                        دخول للنظام <i class="fa-solid fa-arrow-left-long ms-2"></i>
                    </button>

                    <div class="text-center mt-4">
                        <a href="/" class="text-decoration-none fw-bold text-muted hover-primary">
                            <i class="fa-solid fa-house me-1"></i> العودة للموقع الرئيسي
                        </a>
                    </div>
                </form>
            </div>

            <!-- الجانب الأيسر (الصورة والترحيب) -->
            <div class="login-image">
                <div class="login-image-content">
                    <h1 class="fw-bold mb-3 text-white">نظام كابر المتكامل <i class="fa-solid fa-check-circle text-success fs-4"></i></h1>
                    <p class="fs-5 fw-bold opacity-75 lh-lg">
                        إدارة الطلبات، المخازن، الحسابات، وتوجيه المهندسين من مكان واحد بكل سهولة واحترافية.
                    </p>
                    <div class="mt-5 pt-5 border-top border-light border-opacity-25">
                        <div class="d-flex align-items-center justify-content-center gap-4">
                            <div class="text-center">
                                <h3 class="fw-bold m-0 text-white">ERP</h3>
                                <span class="small opacity-75">نظام متكامل</span>
                            </div>
                            <div style="width: 2px; height: 40px; background: white; opacity: 0.2;"></div>
                            <div class="text-center">
                                <h3 class="fw-bold m-0 text-white"><i class="fa-solid fa-shield-halved"></i></h3>
                                <span class="small opacity-75">آمن ومحمي</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="~/js/bootstrap.bundle.min.js"></script>
</body>
</html>