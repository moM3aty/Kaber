@model KaberSystem.Models.SystemUser
@{
    ViewData["Title"] = "تعديل صلاحيات المستخدم";
    Layout = "~/Views/Shared/_SystemLayout.cshtml";

    var currentPermissions = Model.Permissions?.Split(',').ToList() ?? new List<string>();
}

<div class="sys-page-header">
    <div>
        <h1 class="sys-page-title text-primary">تعديل بيانات وصلاحيات المستخدم</h1>
        <p class="sys-page-desc">تعديل معلومات حساب الدخول أو تغيير مستوى الصلاحية الدقيقة للنظام</p>
    </div>
    <a href="/Users/Index" class="btn btn-outline-secondary fw-bold px-4 rounded-3 border-2">
        <i class="fa-solid fa-arrow-right"></i> عودة للقائمة
    </a>
</div>

<div class="row justify-content-center mt-3">
    <div class="col-lg-8">
        <div class="sys-card border-top border-4 border-warning shadow-sm h-100">

            <div class="d-flex align-items-center mb-4 pb-3 border-bottom">
                <div class="bg-warning bg-opacity-10 text-warning rounded-circle d-flex justify-content-center align-items-center me-3" style="width: 50px; height: 50px;">
                    <i class="fa-solid fa-user-pen fs-4"></i>
                </div>
                <h4 class="fw-bold m-0 text-dark">بيانات الحساب: @Model.Username</h4>
            </div>

            @if (ViewBag.Error != null)
            {
                <div class="alert alert-danger fw-bold"><i class="fa-solid fa-triangle-exclamation me-2"></i> @ViewBag.Error</div>
            }

            <form asp-action="Edit" method="post">
                <input type="hidden" asp-for="UserId" />
                <input type="hidden" asp-for="CreatedAt" />

                <div class="row g-4">
                    <div class="col-md-6">
                        <label class="form-label fw-bold">اسم المستخدم <span class="text-danger">*</span></label>
                        <input asp-for="Username" class="form-control sys-input" required />
                    </div>

                    <div class="col-md-6">
                        <label class="form-label fw-bold">كلمة المرور <span class="text-danger">*</span></label>
                        <input asp-for="Password" type="text" class="form-control sys-input" required />
                    </div>

                    <div class="col-md-12">
                        <label class="form-label fw-bold">المنصب الأساسي (Role) <span class="text-danger">*</span></label>
                        <select asp-for="Role" class="form-select sys-input fw-bold bg-light" required>
                            <option value="">-- اختر الصلاحية --</option>
                            <option value="Admin">مدير النظام (Admin)</option>
                            <option value="CallCenter">خدمة العملاء (Call Center)</option>
                            <option value="Technician">فني صيانة (Technician)</option>
                            <option value="Accounting">محاسب (Accounting)</option>
                            <option value="Store">أمين مخزن (Store)</option>
                            <option value="HR">موارد بشرية (HR)</option>
                            <option value="PurchasingManager">مدير مشتريات</option>
                            <option value="PurchasingRep">مندوب مشتريات</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">الراتب الأساسي</label>
                        <div class="input-group">
                            <input type="number" step="0.01" name="BaseSalary" value="@Model?.BaseSalary" class="form-control fw-bold" placeholder="مثال: 3000" />
                            <span class="input-group-text bg-light fw-bold">ر.س</span>
                        </div>
                    </div>
                    <!-- 📌 نظام الصلاحيات المرنة المحددة مسبقاً (تمت إضافة الـ HR) -->
                    <div class="col-12 mt-4">
                        <h5 class="fw-bold border-bottom pb-2 text-dark"><i class="fa-solid fa-user-shield text-warning me-2"></i> الصلاحيات المخصصة (المرنة)</h5>
                        <div class="row g-3 bg-light p-3 rounded-4 border mt-2">
                            <div class="col-md-4">
                                <div class="form-check form-switch">
                                    <input class="form-check-input" type="checkbox" name="SelectedPermissions" value="ManageOrders" id="pe1" @(currentPermissions.Contains("ManageOrders") ? "checked" : "")>
                                    <label class="form-check-label fw-bold" for="pe1">إدارة طلبات الصيانة</label>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="form-check form-switch">
                                    <input class="form-check-input" type="checkbox" name="SelectedPermissions" value="ManageInventory" id="pe2" @(currentPermissions.Contains("ManageInventory") ? "checked" : "")>
                                    <label class="form-check-label fw-bold" for="pe2">إدارة المخزون والعهد</label>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="form-check form-switch">
                                    <input class="form-check-input" type="checkbox" name="SelectedPermissions" value="ManagePurchases" id="pe3" @(currentPermissions.Contains("ManagePurchases") ? "checked" : "")>
                                    <label class="form-check-label fw-bold" for="pe3">دورة المشتريات والتسعير</label>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="form-check form-switch">
                                    <input class="form-check-input" type="checkbox" name="SelectedPermissions" value="ManageInvoices" id="pe4" @(currentPermissions.Contains("ManageInvoices") ? "checked" : "")>
                                    <label class="form-check-label fw-bold" for="pe4">الفواتير والحسابات</label>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="form-check form-switch">
                                    <input class="form-check-input" type="checkbox" name="SelectedPermissions" value="ManageTechnicians" id="pe5" @(currentPermissions.Contains("ManageTechnicians") ? "checked" : "")>
                                    <label class="form-check-label fw-bold" for="pe5">إدارة الفنيين</label>
                                </div>
                            </div>
                            <!-- 📌 الصلاحية المرنة للـ HR -->
                            <div class="col-md-4">
                                <div class="form-check form-switch">
                                    <input class="form-check-input" type="checkbox" name="SelectedPermissions" value="ManageHR" id="pe7" @(currentPermissions.Contains("ManageHR") ? "checked" : "")>
                                    <label class="form-check-label fw-bold text-success" for="pe7">إدارة الموارد البشرية والرواتب</label>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="form-check form-switch">
                                    <input class="form-check-input" type="checkbox" name="SelectedPermissions" value="ViewReports" id="pe6" @(currentPermissions.Contains("ViewReports") ? "checked" : "")>
                                    <label class="form-check-label fw-bold text-primary" for="pe6">رؤية التقارير</label>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="col-12 mt-4 text-end border-top pt-4">
                        <button type="submit" class="sys-btn btn-warning text-dark w-100 justify-content-center py-3 fs-5 shadow-sm fw-bold">
                            <i class="fa-solid fa-save me-2"></i> حفظ التعديلات
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

<style>
    .sys-input {
        border: 2px solid var(--sys-border);
        padding: 12px 18px;
        border-radius: 10px;
        font-weight: 600;
        background-color: var(--sys-bg);
        color: var(--sys-text-main);
    }

        .sys-input:focus {
            border-color: var(--sys-primary);
            box-shadow: 0 0 0 0.25rem rgba(241, 149, 11, 0.15);
            background-color: #fff;
            outline: none;
        }

    .form-switch .form-check-input {
        width: 2.5em;
        height: 1.25em;
        cursor: pointer;
    }

    .form-switch .form-check-label {
        margin-right: 3em;
        margin-top: 2px;
        cursor: pointer;
    }
</style>