@model KaberSystem.Models.SystemUser
@{
    ViewData["Title"] = "إضافة مستخدم";
    Layout = "~/Views/Shared/_SystemLayout.cshtml";
}

<div class="sys-page-header">
    <div>
        <h1 class="sys-page-title">إضافة موظف جديد</h1>
        <p class="sys-page-desc">إنشاء حساب وتحديد الصلاحيات المرنة الدقيقة للموظف</p>
    </div>
    <a href="/Users/Index" class="btn btn-outline-secondary fw-bold px-4 rounded-3 border-2">
        <i class="fa-solid fa-arrow-right"></i> عودة للقائمة
    </a>
</div>

<div class="row justify-content-center mt-3">
    <div class="col-lg-8">
        <div class="sys-card border-top border-4 border-primary shadow-sm">
            @if (ViewBag.Error != null)
            {
                <div class="alert alert-danger fw-bold"><i class="fa-solid fa-triangle-exclamation me-2"></i> @ViewBag.Error</div>
            }

            <form asp-action="Create" method="post">
                <div class="row g-4">
                    <div class="col-md-6">
                        <label class="form-label fw-bold">اسم المستخدم (Login Name) <span class="text-danger">*</span></label>
                        <input asp-for="Username" class="form-control sys-input" placeholder="مثال: ahmed_2024" required />
                    </div>

                    <div class="col-md-6">
                        <label class="form-label fw-bold">كلمة المرور <span class="text-danger">*</span></label>
                        <input asp-for="Password" type="text" class="form-control sys-input" placeholder="كلمة مرور الدخول" required />
                    </div>

                    <div class="col-md-12">
                        <label class="form-label fw-bold">المنصب الأساسي (Role) <span class="text-danger">*</span></label>
                        <select asp-for="Role" class="form-select sys-input fw-bold border-primary text-primary" required>
                            <option value="">-- اختر المنصب --</option>
                            <option value="Admin">مدير النظام (Admin)</option>
                            <option value="CallCenter">خدمة العملاء (Call Center)</option>
                            <option value="Technician">فني صيانة (Technician)</option>
                            <option value="Accounting">محاسب (Accounting)</option>
                            <option value="Store">أمين مخزن (Store)</option>
                            <option value="HR">موارد بشرية (HR)</option>
                            <option value="PurchasingManager">مدير مشتريات</option>
                            <option value="PurchasingRep">مندوب مشتريات</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">الراتب الأساسي</label>
                        <div class="input-group">
                            <input type="number" step="0.01" name="BaseSalary" value="@Model?.BaseSalary" class="form-control fw-bold" placeholder="مثال: 3000" />
                            <span class="input-group-text bg-light fw-bold">ر.س</span>
                        </div>
                    </div>
                    <!-- 📌 نظام الصلاحيات المرنة (تم تعديل الـ value لتطابق الـ Controllers) -->
                    <div class="col-12 mt-4">
                        <h5 class="fw-bold border-bottom pb-2 text-dark"><i class="fa-solid fa-user-shield text-warning me-2"></i> الصلاحيات المخصصة (المرنة)</h5>
                        <p class="text-muted small fw-bold">اختر الشاشات والعمليات التي يُسمح لهذا المستخدم برؤيتها والتعديل عليها:</p>

                        <div class="row g-3 bg-light p-3 rounded-4 border mt-2">
                            <div class="col-md-4">
                                <div class="form-check form-switch">
                                    <input class="form-check-input" type="checkbox" name="SelectedPermissions" value="Orders" id="perm1">
                                    <label class="form-check-label fw-bold" for="perm1">إدارة طلبات الصيانة</label>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="form-check form-switch">
                                    <input class="form-check-input" type="checkbox" name="SelectedPermissions" value="Inventory" id="perm2">
                                    <label class="form-check-label fw-bold" for="perm2">إدارة المخزون والعهد</label>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="form-check form-switch">
                                    <input class="form-check-input" type="checkbox" name="SelectedPermissions" value="Purchasing" id="perm3">
                                    <label class="form-check-label fw-bold" for="perm3">دورة المشتريات والتسعير</label>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="form-check form-switch">
                                    <input class="form-check-input" type="checkbox" name="SelectedPermissions" value="Accounting" id="perm4">
                                    <label class="form-check-label fw-bold" for="perm4">الفواتير والحسابات</label>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="form-check form-switch">
                                    <input class="form-check-input" type="checkbox" name="SelectedPermissions" value="Technicians" id="perm5">
                                    <label class="form-check-label fw-bold" for="perm5">إدارة الفنيين</label>
                                </div>
                            </div>
                            <!-- 📌 الصلاحية المرنة للـ HR -->
                            <div class="col-md-4">
                                <div class="form-check form-switch">
                                    <input class="form-check-input" type="checkbox" name="SelectedPermissions" value="HR" id="perm7">
                                    <label class="form-check-label fw-bold text-success" for="perm7">إدارة الموارد البشرية والرواتب</label>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="form-check form-switch">
                                    <input class="form-check-input" type="checkbox" name="SelectedPermissions" value="Reports" id="perm6">
                                    <label class="form-check-label fw-bold text-primary" for="perm6">رؤية التقارير والإحصائيات</label>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="col-12 mt-4 text-end border-top pt-4">
                        <button type="submit" class="sys-btn sys-btn-primary w-100 justify-content-center py-3 fs-5 shadow-sm">
                            <i class="fa-solid fa-save me-2"></i> إنشاء الحساب وتفعيل الصلاحيات
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

<style>
    .sys-input {
        border: 2px solid var(--sys-border);
        padding: 12px 18px;
        border-radius: 10px;
        font-weight: 600;
        background-color: var(--sys-bg);
    }

        .sys-input:focus {
            border-color: var(--sys-primary);
            box-shadow: 0 0 0 4px var(--sys-primary-light);
            background-color: #fff;
            outline: none;
        }

    .form-switch .form-check-input {
        width: 2.5em;
        height: 1.25em;
        cursor: pointer;
    }

    .form-switch .form-check-label {
        margin-right: 3em;
        margin-top: 2px;
        cursor: pointer;
    }
</style>